@page "/ppp-fulfillment-settings/{OwnerId:int}"
@using Dashboard
@using Dashboard.Services
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav

<div class="min-h-screen bg-[#050505] text-slate-200 p-8 font-sans antialiased pb-40">
    <PPPAdminNav CurrentPage="Logistics" />

    @if (owner != null)
    {
        <div class="max-w-5xl mx-auto mb-12">
            <h1 class="text-4xl font-black text-white italic uppercase tracking-tighter">Fulfillment Settings</h1>
            <p class="text-slate-500 text-xs uppercase tracking-[0.3em] mt-1">@owner.BusinessName Logistics & Fees</p>
        </div>

        <div class="max-w-5xl mx-auto grid grid-cols-12 gap-8">
            @* Sidebar: Master Switches *@
            <div class="col-span-12 lg:col-span-4 space-y-6">
                <div class="bg-[#111] border border-slate-800 rounded-3xl p-8 shadow-xl">
                    <h2 class="text-xs font-black uppercase tracking-[0.2em] text-emerald-500 mb-6">Service Offerings</h2>
                    
                    <div class="space-y-6">
                        <label class="flex items-center justify-between p-4 bg-black/40 rounded-2xl border @(owner.OffersPickup ? "border-emerald-500/50" : "border-slate-800") cursor-pointer transition-all">
                            <div>
                                <span class="text-sm font-black uppercase block">Offer Pickup</span>
                                <span class="text-[9px] text-slate-500 uppercase">Customers meet you</span>
                            </div>
                            <input type="checkbox" @bind="owner.OffersPickup" @oninput="ValidateToggles" class="w-6 h-6 accent-emerald-500" />
                        </label>

                        <label class="flex items-center justify-between p-4 bg-black/40 rounded-2xl border @(owner.OffersDelivery ? "border-blue-500/50" : "border-slate-800") cursor-pointer transition-all">
                            <div>
                                <span class="text-sm font-black uppercase block">Offer Delivery</span>
                                <span class="text-[9px] text-slate-500 uppercase">You go to them</span>
                            </div>
                            <input type="checkbox" @bind="owner.OffersDelivery" @oninput="ValidateToggles" class="w-6 h-6 accent-blue-500" />
                        </label>
                    </div>
                </div>
                <button @onclick="SaveGlobalSettings" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white py-4 rounded-2xl font-black text-xs uppercase tracking-widest transition-all shadow-lg">
                    Save Global Rules
                </button>
            </div>

            @* Main: Specific Configs *@
            <div class="col-span-12 lg:col-span-8 space-y-8">
                @if (owner.OffersPickup)
                {
                    <div class="bg-[#111] border border-slate-800 rounded-[2.5rem] p-8 shadow-xl animate-in fade-in slide-in-from-bottom-4">
                        <div class="flex justify-between items-center mb-6">
                            <h3 class="text-xs font-black uppercase tracking-[0.2em] text-emerald-500">Pickup Locations</h3>
                            <button @onclick="AddPickupLocation" class="text-[9px] bg-emerald-600 text-white px-4 py-2 rounded-full font-black uppercase tracking-widest">＋ Add Location</button>
                        </div>
                        <div class="space-y-4">
                            @foreach (var loc in pickupLocations)
                            {
                                <div class="bg-black/40 p-6 rounded-2xl border border-slate-800 flex gap-4">
                                    <div class="flex-1 grid grid-cols-2 gap-4">
                                        <input @bind="loc.Name" placeholder="Location Name (e.g. Town Square)" class="col-span-2 bg-transparent border-b border-slate-800 p-2 text-sm text-white font-bold" />
                                        <input @bind="loc.Address" placeholder="Address" class="bg-transparent border-b border-slate-800 p-2 text-xs text-slate-400" />
                                        <input @bind="loc.Details" placeholder="Instructions" class="bg-transparent border-b border-slate-800 p-2 text-xs text-slate-400" />
                                    </div>
                                    <button @onclick="() => pickupLocations.Remove(loc)" class="text-slate-700 hover:text-red-500 text-xl">✕</button>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (owner.OffersDelivery)
                {
                    <div class="bg-[#111] border border-slate-800 rounded-[2.5rem] p-8 shadow-xl animate-in fade-in slide-in-from-bottom-4">
                        <div class="flex justify-between items-center mb-6">
                            <h3 class="text-xs font-black uppercase tracking-[0.2em] text-blue-500">Delivery Zip Codes</h3>
                            <button @onclick="AddZipCode" class="text-[9px] bg-blue-600 text-white px-4 py-2 rounded-full font-black uppercase tracking-widest">＋ Add Zip</button>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            @foreach (var zip in zipCodes)
                            {
                                <div class="bg-black/40 p-4 rounded-2xl border border-slate-800 flex items-center gap-3">
                                    <input @bind="zip.ZipCode" placeholder="Zip" class="w-20 bg-transparent border-b border-slate-800 p-2 text-sm font-mono text-white" />
                                    <div class="flex-1 flex items-center gap-2">
                                        <span class="text-[10px] text-slate-600">$</span>
                                        <input type="number" @bind="zip.Fee" class="w-full bg-transparent border-b border-slate-800 p-2 text-sm text-blue-400" />
                                    </div>
                                    <button @onclick="() => zipCodes.Remove(zip)" class="text-slate-800 hover:text-red-500">✕</button>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int OwnerId { get; set; }
    private PPP_Owner? owner;
    private List<PPP_PickupLocation> pickupLocations = new();
    private List<PPP_DeliveryZipCode> zipCodes = new();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        owner = await db.PPP_Owners.FirstOrDefaultAsync(o => o.Id == OwnerId);
        if (owner != null)
        {
            pickupLocations = await db.Set<PPP_PickupLocation>().Where(l => l.OwnerId == OwnerId).ToListAsync();
            zipCodes = await db.Set<PPP_DeliveryZipCode>().Where(z => z.OwnerId == OwnerId).ToListAsync();
        }
    }

    private void ValidateToggles()
    {
        // Enforce that at least one must be true
        if (!owner.OffersPickup && !owner.OffersDelivery)
        {
            owner.OffersPickup = true; // Default back to pickup
        }
    }

    private void AddPickupLocation() => pickupLocations.Add(new PPP_PickupLocation { OwnerId = OwnerId });
    private void AddZipCode() => zipCodes.Add(new PPP_DeliveryZipCode { OwnerId = OwnerId });

    private async Task SaveGlobalSettings()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        
        // Update master toggles
        db.Update(owner);

        // Wipe and re-insert child collections for simplicity
        var oldLocs = db.Set<PPP_PickupLocation>().Where(l => l.OwnerId == OwnerId);
        db.RemoveRange(oldLocs);
        var oldZips = db.Set<PPP_DeliveryZipCode>().Where(z => z.OwnerId == OwnerId);
        db.RemoveRange(oldZips);
        
        await db.SaveChangesAsync();

        db.AddRange(pickupLocations);
        db.AddRange(zipCodes);
        await db.SaveChangesAsync();
        
        Nav.NavigateTo($"/ppp-owner-admin");
    }
}