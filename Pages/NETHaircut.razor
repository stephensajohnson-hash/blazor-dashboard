@page "/nethaircut"
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.EntityFrameworkCore
@using Dashboard
@inject Dashboard.AppDbContext Db
@inject NavigationManager NavManager

<div class="app-container">
    <header class="stylist-header">
        <h1>@FormattedName</h1>
        <p class="tagline">North East Texas Style & Booking</p>
    </header>

    <main class="booking-card">
        @if (isLoading)
        {
            <p>Loading Registry...</p>
        }
        else if (currentShop == null)
        {
            <div class="seed-box">
                <p class="mb-4">No data found for "@CurrentStylist".</p>
                <button class="btn-seed" @onclick="SeedInitialData">
                    🔧 Seed "Leather & Blades" Data
                </button>
            </div>
        }
        else
        {
            <section class="welcome-text">
                <h2>Welcome to @currentShop.BusinessName</h2>
                <p>Status: <strong>Active</strong></p>
            </section>

            <div class="services-list">
                @foreach (var stylist in currentShop.Stylists)
                {
                    <div class="stylist-section">
                        <h3>Stylist: @stylist.Name</h3>
                        @foreach (var service in stylist.Services)
                        {
                            <div class="service-item">
                                <span>@service.Name</span>
                                <span>$@service.Price</span>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </main>
</div>

@code {
    private string CurrentStylist { get; set; } = "GENERAL";
    private string FormattedName => CurrentStylist.Replace("%20", " ").ToUpper();
    private bool isLoading = true;
    private NETH_Shop? currentShop;

    protected override async Task OnInitializedAsync()
    {
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("stylist", out var name))
        {
            CurrentStylist = name.ToString();
        }

        await LoadShopData();
        isLoading = false;
    }

    private async Task LoadShopData()
    {
        // Look for the shop by its URL Key (e.g. leatherandblades)
        currentShop = await Db.NETH_Shops
            .Include(s => s.Stylists)
                .ThenInclude(st => st.Services)
            .FirstOrDefaultAsync(s => s.UrlKey.ToLower() == CurrentStylist.ToLower());
    }

    private async Task SeedInitialData()
    {
        isLoading = true;

        // 1. Create a Phone Entry
        var shopPhone = new NETH_Phone { Number = "9035551111", Type = "Work" };
        var brandonPhone = new NETH_Phone { Number = "9035552222", Type = "Mobile" };
        var clientPhone = new NETH_Phone { Number = "9035553333", Type = "Mobile" };
        Db.NETH_Phones.AddRange(shopPhone, brandonPhone, clientPhone);
        await Db.SaveChangesAsync();

        // 2. Create the Shop (Leather & Blades)
        var shop = new NETH_Shop
        {
            UrlKey = "leatherandblades",
            BusinessName = "Leather & Blades",
            BrandColor = "#D2B48C",
            PhoneId = shopPhone.Id
        };
        Db.NETH_Shops.Add(shop);
        await Db.SaveChangesAsync();

        // 3. Create Brandon as the Stylist
        var brandon = new NETH_Stylist
        {
            ShopId = shop.Id,
            Name = "Brandon",
            Bio = "Master Barber specializing in straight-razor fades.",
            IsIndependent = true,
            PhoneId = brandonPhone.Id
        };
        Db.NETH_Stylists.Add(brandon);
        await Db.SaveChangesAsync();

        // 4. Create Services
        Db.NETH_Services.AddRange(
            new NETH_Service { StylistId = brandon.Id, Name = "Standard Fade", Price = 30.00m, DurationMinutes = 30 },
            new NETH_Service { StylistId = brandon.Id, Name = "Beard Trim", Price = 15.00m, DurationMinutes = 15 },
            new NETH_Service { StylistId = brandon.Id, Name = "The Works", Price = 50.00m, DurationMinutes = 60 }
        );

        // 5. Create a Client & Note (The "Grand Canyon" Note)
        var client = new NETH_Client { FirstName = "Jayce", LastName = "Test", PhoneId = clientPhone.Id };
        Db.NETH_Clients.Add(client);
        await Db.SaveChangesAsync();

        var note = new NETH_ClientNote
        {
            ClientId = client.Id,
            StylistId = brandon.Id,
            ShortDescription = "Grand Canyon Trip",
            LongDescription = "Planning a big trip in 2027.",
            EventYear = 2027,
            EventMonth = 1
        };
        Db.NETH_ClientNotes.Add(note);

        await Db.SaveChangesAsync();
        await LoadShopData();
        isLoading = false;
    }
}

<style>
    /* Reuse your previous styles, plus these for the Seed button */
    .btn-seed {
        background-color: #e67e22;
        color: white;
        padding: 15px;
        border-radius: 8px;
        border: none;
        font-weight: bold;
        cursor: pointer;
        width: 100%;
        text-transform: uppercase;
        font-size: 0.8rem;
    }
    .service-item {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #444;
    }
    .stylist-section h3 {
        color: #D2B48C;
        margin-top: 20px;
        border-bottom: 2px solid #D2B48C;
    }
</style>