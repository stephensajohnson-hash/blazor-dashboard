@page "/nethaircut"
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager NavManager

<div class="app-container" style="--brand-color: @(CurrentStylist == "LEATHERANDBLADES" ? "#D2B48C" : "#E0B0FF")">
    <header class="stylist-header">
        <div class="logo-circle">
            <i class="fas fa-cut"></i>
        </div>
        <h1>@FormattedName</h1>
        <p class="tagline">North East Texas Style & Booking</p>
    </header>

    <main class="booking-card">
        <section class="welcome-text">
            <h2>Welcome to the Chair</h2>
            <p>You are viewing the specialized booking page for <strong>@FormattedName</strong>.</p>
        </section>

        <div class="status-box">
            <span class="status-dot"></span>
            <span>Mode: QueryString Simulation</span>
        </div>

        <button class="btn-primary" @onclick="SimulateBooking">
            View @FormattedName's Schedule
        </button>
    </main>

    <footer class="install-banner">
        <p>Install <strong>@FormattedName</strong> to your home screen.</p>
    </footer>
</div>

@code {
    private string CurrentStylist { get; set; } = "GENERAL";
    private string FormattedName => CurrentStylist.Replace("%20", " ").ToUpper();

    protected override void OnInitialized()
    {
        // Parse the Current URL
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        
        // Extract the "stylist" parameter
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("stylist", out var name))
        {
            CurrentStylist = name.ToString();
        }
    }

    private void SimulateBooking()
    {
        Console.WriteLine($"Opening schedule for: {CurrentStylist}");
    }
}

<style>
    :root {
        --primary-gold: var(--brand-color, #D2B48C); 
        --dark-bg: #1a1a1a;
        --card-bg: #2d2d2d;
        --text-light: #f4f4f4;
    }

    .app-container {
        background-color: var(--dark-bg);
        color: var(--text-light);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 20px;
        font-family: sans-serif;
    }

    .stylist-header { text-align: center; margin-bottom: 30px; }

    .logo-circle {
        width: 70px; height: 70px;
        background-color: var(--primary-gold);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 15px; font-size: 1.5rem; color: #1a1a1a;
    }

    .booking-card {
        background-color: var(--card-bg);
        border-radius: 12px; padding: 25px;
        width: 100%; max-width: 350px;
        border: 1px solid #444; text-align: center;
    }

    .btn-primary {
        background-color: var(--primary-gold);
        color: #1a1a1a; border: none;
        padding: 12px; width: 100%;
        border-radius: 6px; font-weight: bold; cursor: pointer;
    }

    .status-box { margin-top: 15px; font-size: 0.75rem; color: #888; }
    .status-dot { height: 6px; width: 6px; background-color: #4CAF50; border-radius: 50%; display: inline-block; margin-right: 5px; }
    .install-banner { margin-top: auto; font-size: 0.8rem; color: #aaa; }
</style>