@page "/nethaircut"
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.EntityFrameworkCore
@using Dashboard
@inject Dashboard.AppDbContext Db
@inject NavigationManager NavManager
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))

<div class="app-container" style="--brand-color: @(currentShop?.BrandColor ?? "#D2B48C")">
    <header class="stylist-header">
        <div class="logo-circle"><i class="fas fa-cut"></i></div>
        <h1>@FormattedName</h1>
        <p class="tagline">North East Texas Style & Booking</p>
    </header>

    <main class="booking-card">
        <div style="background: #000; color: #0f0; padding: 5px; font-family: monospace; font-size: 10px; margin-bottom: 10px; border: 1px solid #333;">
            KEY: @CurrentStylist | SHOPS: @shops.Count | CLIENTS: @clients.Count | PHONES: @phones.Count
        </div>

        @if (isLoading)
        {
            <div class="spinner-box">
                <div class="spinner"></div>
                <p>Processing...</p>
            </div>
        }
        else
        {
            <div class="seed-box" style="margin-bottom: 20px; padding: 15px; background: rgba(255,255,255,0.05); border-radius: 8px;">
                <h4 style="color: #fff; margin-bottom: 10px;">Maintenance Tools</h4>
                <button class="btn-seed" @onclick="HardResetAndSeed" style="background-color: #e74c3c;">
                    🔥 Wipe & Re-Seed All Data
                </button>
                @if (!string.IsNullOrEmpty(dbError))
                {
                    <p style="color: #ff4444; font-size: 0.7rem; margin-top: 10px; word-break: break-all;">@dbError</p>
                }
            </div>

            @if (currentShop != null)
            {
                <section class="welcome-text">
                    <h2>Welcome to @currentShop.BusinessName</h2>
                    <div class="status-badge"><span class="status-dot"></span> Online</div>
                </section>

                <div class="stylist-grid">
                    @foreach (var stylist in currentShop.Stylists)
                    {
                        <div class="stylist-card">
                            <h3>@stylist.Name</h3>
                            <p class="bio">@stylist.Bio</p>
                            <div class="services-list">
                                @foreach (var service in stylist.Services)
                                {
                                    <div class="service-row">
                                        <span>@service.Name</span>
                                        <span>$@service.Price.ToString("N2")</span>
                                    </div>
                                }
                            </div>
                            <button class="btn-book">Book with @stylist.Name</button>
                        </div>
                    }
                </div>
            }
        }

        <div style="margin-top: 3rem; background: #111; padding: 1rem; border-radius: 8px; font-family: monospace; font-size: 0.65rem; color: #aaa; overflow-x: auto; line-height: 1.4;">
            <h4 style="color: #fff; border-bottom: 1px solid #333; padding-bottom: 5px;">LIVE DATA DUMP</h4>
            <p style="color: #e67e22; margin-top: 10px; font-weight: bold;">[NETH_Shops]</p>
            @foreach(var s in shops) { <div>ID:@s.Id | Key:@s.UrlKey | Name:@s.BusinessName</div> }
            <p style="color: #e67e22; margin-top: 10px; font-weight: bold;">[NETH_Clients]</p>
            @foreach(var c in clients) { <div>ID:@c.Id | Name:@c.FirstName @c.LastName</div> }
            <p style="color: #e67e22; margin-top: 10px; font-weight: bold;">[NETH_Appointments]</p>
            @foreach(var a in appointments) { <div>ID:@a.Id | Client:@a.ClientId | Status:@a.Status</div> }
        </div>
    </main>
</div>

@code {
    private string CurrentStylist { get; set; } = "GENERAL";
    private string FormattedName => CurrentStylist.Replace("%20", " ").ToUpper();
    private bool isLoading = true;
    private string dbError = "";

    private List<NETH_Shop> shops = new();
    private List<NETH_Client> clients = new();
    private List<NETH_Appointment> appointments = new();
    private List<NETH_Phone> phones = new();
    private NETH_Shop? currentShop;

    protected override async Task OnInitializedAsync()
    {
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("stylist", out var name)) CurrentStylist = name.ToString();

        await LoadAllData();
        isLoading = false;
    }

    private async Task LoadAllData()
    {
        try {
            try { shops = await Db.NETH_Shops.AsNoTracking().ToListAsync(); } catch { }
            try { clients = await Db.NETH_Clients.AsNoTracking().ToListAsync(); } catch { }
            try { appointments = await Db.NETH_Appointments.AsNoTracking().ToListAsync(); } catch { }
            try { phones = await Db.NETH_Phones.AsNoTracking().ToListAsync(); } catch { }

            string key = CurrentStylist.ToLower().Trim();
            currentShop = await Db.NETH_Shops.AsNoTracking()
                .Include(s => s.Stylists).ThenInclude(st => st.Services)
                .FirstOrDefaultAsync(s => s.UrlKey.ToLower() == key);
        }
        catch (Exception ex) { dbError = $"Load Error: {ex.Message}"; }
    }

    private async Task HardResetAndSeed()
    {
        isLoading = true;
        dbError = "";
        try 
        {
            await Db.Database.ExecuteSqlRawAsync(@"
                DROP TABLE IF EXISTS ""NETH_AppointmentServices"";
                DROP TABLE IF EXISTS ""NETH_Appointments"";
                DROP TABLE IF EXISTS ""NETH_ClientNotes"";
                DROP TABLE IF EXISTS ""NETH_NoteTags"";
                DROP TABLE IF EXISTS ""NETH_Clients"";
                DROP TABLE IF EXISTS ""NETH_Media"";
                DROP TABLE IF EXISTS ""NETH_Services"";

                CREATE TABLE ""NETH_Media"" (""Id"" SERIAL PRIMARY KEY, ""FileUrl"" TEXT NOT NULL, ""Category"" TEXT NOT NULL, ""Description"" TEXT NOT NULL, ""UploadedDate"" TIMESTAMP NOT NULL);
                CREATE TABLE ""NETH_Clients"" (""Id"" SERIAL PRIMARY KEY, ""FirstName"" TEXT NOT NULL, ""LastName"" TEXT NOT NULL, ""Email"" TEXT NOT NULL, ""PhoneId"" INTEGER NOT NULL);
                CREATE TABLE ""NETH_Appointments"" (""Id"" SERIAL PRIMARY KEY, ""ShopId"" INTEGER NOT NULL, ""StylistId"" INTEGER NOT NULL, ""ClientId"" INTEGER NOT NULL, ""StartTime"" TIMESTAMP NOT NULL, ""EndTime"" TIMESTAMP NOT NULL, ""Status"" TEXT NOT NULL, ""TotalPrice"" DECIMAL NOT NULL, ""Notes"" TEXT NOT NULL, ""IsPaid"" BOOLEAN NOT NULL);
                CREATE TABLE ""NETH_Services"" (""Id"" SERIAL PRIMARY KEY, ""StylistId"" INTEGER NOT NULL, ""Name"" TEXT NOT NULL, ""Price"" DECIMAL NOT NULL, ""DurationMinutes"" INTEGER NOT NULL);
            ");

            await Db.Database.ExecuteSqlRawAsync(@"TRUNCATE TABLE ""NETH_Shops"" RESTART IDENTITY CASCADE; TRUNCATE TABLE ""NETH_Phones"" RESTART IDENTITY CASCADE;");

            var p1 = new NETH_Phone { Number = "9035551111", Type = "Work" };
            var p2 = new NETH_Phone { Number = "9035552222", Type = "Mobile" };
            Db.NETH_Phones.AddRange(p1, p2);
            await Db.SaveChangesAsync();

            var shop = new NETH_Shop { UrlKey = "leatherandblades", BusinessName = "Leather & Blades", PhoneId = p1.Id };
            Db.NETH_Shops.Add(shop);
            await Db.SaveChangesAsync();

            var brandon = new NETH_Stylist { ShopId = shop.Id, Name = "Brandon", Bio = "Master Barber", PhoneId = p2.Id };
            Db.NETH_Stylists.Add(brandon);
            await Db.SaveChangesAsync();

            var service = new NETH_Service { StylistId = brandon.Id, Name = "Signature Fade", Price = 35.00m, DurationMinutes = 30 };
            Db.NETH_Services.Add(service);
            await Db.SaveChangesAsync();

            var client = new NETH_Client { FirstName = "John", LastName = "Doe", Email = "john@test.com", PhoneId = p2.Id };
            Db.NETH_Clients.Add(client);
            await Db.SaveChangesAsync();

            var app = new NETH_Appointment { 
                ShopId = shop.Id, StylistId = brandon.Id, ClientId = client.Id, 
                StartTime = DateTime.UtcNow, EndTime = DateTime.UtcNow.AddMinutes(30), 
                Status = "Booked", IsPaid = false, TotalPrice = 35.00m, Notes = "Fresh Seed" 
            };
            Db.NETH_Appointments.Add(app);
            await Db.SaveChangesAsync();

            NavManager.NavigateTo(NavManager.Uri, forceLoad: true);
        }
        catch (Exception ex) { dbError = $"Hard Reset Fail: {ex.Message}"; isLoading = false; }
    }
}

<style>
    :root { --dark-bg: #1a1b1e; --card-bg: #25262b; --text-main: #c1c2c5; }
    .app-container { background-color: var(--dark-bg); color: var(--text-main); min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 2rem; font-family: sans-serif; }
    .booking-card { background-color: var(--card-bg); border-radius: 12px; padding: 2rem; width: 100%; max-width: 450px; border: 1px solid #373a40; }
    .stylist-card { background: rgba(0,0,0,0.2); padding: 1rem; border-radius: 8px; margin-top: 1rem; }
    .service-row { display: flex; justify-content: space-between; font-size: 0.9rem; padding: 4px 0; border-bottom: 1px solid #444; }
    .btn-book { width: 100%; margin-top: 1rem; padding: 10px; border-radius: 6px; background: #D2B48C; color: #1a1b1e; border: none; font-weight: bold; cursor: pointer; }
    .btn-seed { width: 100%; padding: 12px; border-radius: 6px; border: none; color: white; font-weight: bold; cursor: pointer; }
    .spinner { border: 4px solid rgba(255,255,255,0.1); border-top: 4px solid #D2B48C; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin: 0 auto 1rem; }
    @@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>