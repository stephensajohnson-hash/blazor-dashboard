@page "/nethaircut"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.EntityFrameworkCore
@using Dashboard
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#1a1b1e] text-gray-300 p-6 font-sans">
    
    <div class="max-w-4xl mx-auto mb-8">
        <div class="bg-[#25262b] rounded-xl border border-gray-700 p-6 shadow-2xl flex justify-between items-center">
            <div>
                <h1 class="text-2xl font-black text-[#D2B48C] uppercase tracking-widest">NETH Terminal</h1>
                <p class="text-xs text-gray-500 font-mono mt-1">Mode: @(currentShop == null ? "SYSTEM_INIT" : "ADMIN_DASHBOARD")</p>
            </div>
            @if (isAuthenticated)
            {
                <button @onclick="Logout" class="text-[10px] font-black text-red-400 border border-red-400/30 px-3 py-1 rounded hover:bg-red-400 hover:text-white transition">LOGOUT_SESSION</button>
            }
        </div>
    </div>

    @if (!isAuthenticated)
    {
        @* SIMPLE LOGIN UI *@
        <div class="max-w-md mx-auto bg-[#25262b] rounded-xl border border-gray-700 p-8 shadow-2xl">
            <h2 class="text-center font-black uppercase tracking-widest text-gray-400 mb-6">Security Access</h2>
            <div class="space-y-4">
                <div>
                    <label class="text-[10px] font-black uppercase text-gray-500 ml-1">Username</label>
                    <input @bind="loginUsername" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-3 text-white focus:border-[#D2B48C] outline-none" />
                </div>
                <div>
                    <label class="text-[10px] font-black uppercase text-gray-500 ml-1">Password</label>
                    <input type="password" @bind="loginPassword" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-3 text-white focus:border-[#D2B48C] outline-none" />
                </div>
                <button @onclick="AttemptLogin" class="w-full bg-[#D2B48C] text-[#1a1b1e] py-3 rounded font-black uppercase tracking-widest hover:bg-[#c4a47c] transition shadow-lg">Authenticate</button>
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <p class="text-red-400 text-[10px] font-mono text-center mt-4">!! @errorMessage !!</p>
                }
            </div>
            
            <div class="mt-8 pt-6 border-t border-gray-700 text-center">
                <p class="text-[9px] text-gray-500 uppercase mb-3 font-bold">First Time Setup?</p>
                <button @onclick="HandleManualReset" class="text-[10px] text-blue-400 hover:underline">Re-initialize DB & Create Admin Account</button>
            </div>
        </div>
    }
    else
    {
        @* ADMIN PANEL *@
        <div class="max-w-4xl mx-auto grid md:grid-cols-[1fr_300px] gap-6">
            <div class="space-y-6">
                <div class="bg-white rounded-xl shadow-2xl p-8 border border-gray-300 text-gray-800">
                    <h2 class="text-xl font-black uppercase mb-4">Admin Management</h2>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="p-4 bg-gray-50 rounded-lg border border-gray-200 text-center">
                            <div class="text-[10px] font-black text-gray-400 uppercase">System Users</div>
                            <div class="text-3xl font-black">@userCount</div>
                        </div>
                        <div class="p-4 bg-gray-50 rounded-lg border border-gray-200 text-center">
                            <div class="text-[10px] font-black text-gray-400 uppercase">Registry Matches</div>
                            <div class="text-3xl font-black">@shops.Count</div>
                        </div>
                    </div>
                    
                    <button @onclick="HandleManualSeed" class="mt-6 w-full py-3 bg-[#1a1b1e] text-white rounded font-black uppercase tracking-widest text-xs hover:bg-black transition shadow-xl">
                        🚀 Sync & Seed Test Records
                    </button>
                </div>
            </div>

            <div class="bg-[#282b30] rounded-xl border border-gray-700 shadow-2xl p-5">
                <h4 class="text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] mb-4">Audit Logs</h4>
                <div class="space-y-2 text-[10px] font-mono">
                    @foreach(var log in sessionLogs) {
                        <div class="text-gray-400">> @log</div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    // UI State
    private bool isAuthenticated = false;
    private bool isLoading = true;
    private string loginUsername = "";
    private string loginPassword = "";
    private string errorMessage = "";
    private List<string> sessionLogs = new();

    // Data State
    private List<NETH_Shop> shops = new();
    private int userCount = 0;
    private NETH_Shop? currentShop;
    private string CurrentStylist = "leatherandblades";

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("stylist", out var name)) CurrentStylist = name.ToString();

        await LoadAllData();
        isLoading = false;
    }

    private async Task LoadAllData()
    {
        try {
            shops = await Db.NETH_Shops.AsNoTracking().ToListAsync();
            userCount = await Db.Database.SqlQueryRaw<int>(@"SELECT COUNT(*)::int as ""Value"" FROM ""NETH_Users""").FirstOrDefaultAsync();
            currentShop = shops.FirstOrDefault(s => s.UrlKey.ToLower() == CurrentStylist.ToLower());
        } catch { }
    }

    private async Task AttemptLogin()
    {
        try {
            // Find user in Raw SQL to ensure table exists
            var user = await Db.Database.SqlQueryRaw<int>(
                @"SELECT ""Id"" as ""Value"" FROM ""NETH_Users"" WHERE ""Username"" = {0} AND ""Password"" = {1} LIMIT 1", 
                loginUsername, loginPassword
            ).FirstOrDefaultAsync();

            if (user > 0) {
                isAuthenticated = true;
                sessionLogs.Add($"LOGIN_SUCCESS: {loginUsername}");
                await LoadAllData();
            } else {
                errorMessage = "INVALID_CREDENTIALS";
            }
        } catch (Exception ex) {
            errorMessage = "AUTH_SYSTEM_OFFLINE. Please run Factory Reset.";
        }
    }

    private void Logout() => isAuthenticated = false;

    private async Task HandleManualReset()
    {
        errorMessage = "RUNNING_RESET...";
        StateHasChanged();

        try {
            await Db.Database.ExecuteSqlRawAsync(@"
                DROP TABLE IF EXISTS ""NETH_AppointmentServices""; DROP TABLE IF EXISTS ""NETH_Appointments"";
                DROP TABLE IF EXISTS ""NETH_ClientNotes""; DROP TABLE IF EXISTS ""NETH_NoteTags"";
                DROP TABLE IF EXISTS ""NETH_Clients""; DROP TABLE IF EXISTS ""NETH_Media"";
                DROP TABLE IF EXISTS ""NETH_Services""; DROP TABLE IF EXISTS ""NETH_Stylists"";
                DROP TABLE IF EXISTS ""NETH_Shops""; DROP TABLE IF EXISTS ""NETH_Phones"";
                DROP TABLE IF EXISTS ""NETH_Users"";

                CREATE TABLE ""NETH_Users"" (""Id"" SERIAL PRIMARY KEY, ""Username"" TEXT NOT NULL, ""Password"" TEXT NOT NULL, ""Role"" TEXT NOT NULL, ""CreatedDate"" TIMESTAMP NOT NULL);
                
                CREATE TABLE ""NETH_Phones"" (""Id"" SERIAL PRIMARY KEY, ""Number"" TEXT NOT NULL, ""Type"" TEXT NOT NULL, ""IsBadNumber"" BOOLEAN NOT NULL DEFAULT FALSE);
                
                CREATE TABLE ""NETH_Shops"" (""Id"" SERIAL PRIMARY KEY, ""UrlKey"" TEXT NOT NULL, ""BusinessName"" TEXT NOT NULL, ""BrandColor"" TEXT NOT NULL, ""LogoId"" INTEGER NULL, ""LogoMediaId"" INTEGER NULL, ""StripeAccountId"" TEXT NOT NULL, ""PhoneId"" INTEGER NOT NULL);
                
                CREATE TABLE ""NETH_Stylists"" (""Id"" SERIAL PRIMARY KEY, ""ShopId"" INTEGER NOT NULL, ""Name"" TEXT NOT NULL, ""Bio"" TEXT NOT NULL, ""IsIndependent"" BOOLEAN NOT NULL, ""StripeAccountId"" TEXT NOT NULL, ""PhoneId"" INTEGER NOT NULL, ""UserId"" INTEGER NULL);
                
                CREATE TABLE ""NETH_Clients"" (""Id"" SERIAL PRIMARY KEY, ""FirstName"" TEXT NOT NULL, ""LastName"" TEXT NOT NULL, ""Email"" TEXT NOT NULL, ""PhoneId"" INTEGER NOT NULL, ""UserId"" INTEGER NULL);
                
                CREATE TABLE ""NETH_Appointments"" (""Id"" SERIAL PRIMARY KEY, ""ShopId"" INTEGER NOT NULL, ""StylistId"" INTEGER NOT NULL, ""ClientId"" INTEGER NOT NULL, ""StartTime"" TIMESTAMP NOT NULL, ""EndTime"" TIMESTAMP NOT NULL, ""Status"" TEXT NOT NULL, ""TotalPrice"" DECIMAL NOT NULL, ""Notes"" TEXT NOT NULL, ""IsPaid"" BOOLEAN NOT NULL);

                -- Seed ADMIN Account
                INSERT INTO ""NETH_Users"" (""Username"", ""Password"", ""Role"", ""CreatedDate"") VALUES ('admin', 'password123', 'Admin', NOW());
            ");
            
            errorMessage = "RESET_COMPLETE. Try login: admin / password123";
            await LoadAllData();
        } catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task HandleManualSeed()
    {
        sessionLogs.Add("EXEC_SEED_CMD...");
        try {
            await Db.Database.ExecuteSqlRawAsync(@"
                INSERT INTO ""NETH_Phones"" (""Number"", ""Type"") VALUES ('9035551111', 'Work');
                INSERT INTO ""NETH_Shops"" (""UrlKey"", ""BusinessName"", ""BrandColor"", ""StripeAccountId"", ""PhoneId"") VALUES ('leatherandblades', 'Leather & Blades', '#D2B48C', '', 1);
            ");
            await LoadAllData();
            sessionLogs.Add("SEED_SUCCESS");
        } catch (Exception ex) { errorMessage = ex.Message; }
    }
}