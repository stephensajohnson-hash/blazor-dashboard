@page "/nethaircut"
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.EntityFrameworkCore
@using Dashboard
@inject Dashboard.AppDbContext Db
@inject NavigationManager NavManager
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))

<div class="app-container" style="--brand-color: @(currentShop?.BrandColor ?? "#D2B48C")">
    <header class="stylist-header">
        <div class="logo-circle"><i class="fas fa-cut"></i></div>
        <h1>@FormattedName</h1>
        <p class="tagline">North East Texas Style & Booking</p>
    </header>

    <main class="booking-card">
        @* DIAGNOSTIC BOX *@
        <div style="background: #000; color: #0f0; padding: 5px; font-family: monospace; font-size: 10px; margin-bottom: 10px; border: 1px solid #333;">
            KEY: @CurrentStylist | SHOPS: @shops.Count | CLIENTS: @clients.Count | APPS: @appointments.Count
        </div>

        @if (isLoading)
        {
            <div class="spinner-box">
                <div class="spinner"></div>
                <p>Loading Registry...</p>
            </div>
        }
        else
        {
            @if (currentShop != null)
            {
                <section class="welcome-text">
                    <h2>Welcome to @currentShop.BusinessName</h2>
                    <div class="status-badge"><span class="status-dot"></span> Online</div>
                </section>

                <div class="stylist-grid">
                    @foreach (var stylist in currentShop.Stylists)
                    {
                        <div class="stylist-card">
                            <h3>@stylist.Name</h3>
                            <p class="bio">@stylist.Bio</p>
                            <div class="services-list">
                                @foreach (var service in stylist.Services)
                                {
                                    <div class="service-row">
                                        <span>@service.Name</span>
                                        <span>$@service.Price.ToString("N2")</span>
                                    </div>
                                }
                            </div>
                            <button class="btn-book">Book with @stylist.Name</button>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="seed-box">
                    <i class="fas fa-search mb-3" style="font-size: 2rem; color: #e67e22;"></i>
                    <p>No shop found for "@CurrentStylist".</p>
                </div>
            }

            <div class="seed-box" style="margin-top: 20px; border-top: 1px solid #333; padding-top: 20px;">
                <button class="btn-seed" @onclick="SeedFullData">🔧 Populate Clients, Apps & Media</button>
                @if (!string.IsNullOrEmpty(dbError))
                {
                    <p style="color: #ff4444; font-size: 0.7rem; margin-top: 10px;">@dbError</p>
                }
            </div>
        }

        @* FULL DATA DUMP *@
        <div style="margin-top: 3rem; background: #111; padding: 1rem; border-radius: 8px; font-family: monospace; font-size: 0.65rem; color: #aaa; overflow-x: auto; line-height: 1.4;">
            <h4 style="color: #fff; border-bottom: 1px solid #333; padding-bottom: 5px;">FULL NETH DATA DUMP</h4>
            
            <p style="color: #e67e22; margin-top: 10px; font-weight: bold;">[NETH_Shops]</p>
            @foreach(var s in shops) { <div>ID:@s.Id | Key:@s.UrlKey | Name:@s.BusinessName</div> }

            <p style="color: #e67e22; margin-top: 10px; font-weight: bold;">[NETH_Clients]</p>
            @foreach(var c in clients) { <div>ID:@c.Id | Name:@c.FirstName @c.LastName | Email:@c.Email</div> }

            <p style="color: #e67e22; margin-top: 10px; font-weight: bold;">[NETH_Appointments]</p>
            @foreach(var a in appointments) { <div>ID:@a.Id | ClientID:@a.ClientId | Status:@a.Status</div> }

            <p style="color: #e67e22; margin-top: 10px; font-weight: bold;">[NETH_Media]</p>
            @foreach(var m in medias) { <div>ID:@m.Id | Cat:@m.Category | Desc:@m.Description</div> }

            <p style="color: #e67e22; margin-top: 10px; font-weight: bold;">[NETH_Phones]</p>
            @foreach(var p in phones) { <div>ID:@p.Id | Num:@p.Number | Type:@p.Type</div> }
        </div>
    </main>
</div>

@code {
    private string CurrentStylist { get; set; } = "GENERAL";
    private string FormattedName => CurrentStylist.Replace("%20", " ").ToUpper();
    private bool isLoading = true;
    private string dbError = "";

    private List<NETH_Shop> shops = new();
    private List<NETH_Stylist> stylists = new();
    private List<NETH_Client> clients = new();
    private List<NETH_ClientNote> clientNotes = new();
    private List<NETH_Appointment> appointments = new();
    private List<NETH_AppointmentService> appServices = new();
    private List<NETH_Media> medias = new();
    private List<NETH_Phone> phones = new();
    private NETH_Shop? currentShop;

    protected override async Task OnInitializedAsync()
    {
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("stylist", out var name)) CurrentStylist = name.ToString();

        await LoadAllData();
        isLoading = false;
    }

    private async Task LoadAllData()
    {
        try {
            shops = await Db.NETH_Shops.AsNoTracking().ToListAsync();
            stylists = await Db.NETH_Stylists.AsNoTracking().ToListAsync();
            phones = await Db.NETH_Phones.AsNoTracking().ToListAsync();
            clients = await Db.NETH_Clients.AsNoTracking().ToListAsync();
            clientNotes = await Db.NETH_ClientNotes.AsNoTracking().ToListAsync();
            appointments = await Db.NETH_Appointments.AsNoTracking().ToListAsync();
            medias = await Db.NETH_Media.AsNoTracking().ToListAsync();
            appServices = await Db.NETH_AppointmentsService.AsNoTracking().ToListAsync();

            string key = CurrentStylist.ToLower().Trim();
            currentShop = await Db.NETH_Shops.AsNoTracking()
                .Include(s => s.Stylists).ThenInclude(st => st.Services)
                .FirstOrDefaultAsync(s => s.UrlKey.ToLower() == key);
        }
        catch (Exception ex) { dbError = $"Audit Error: {ex.Message}"; }
    }

    private async Task SeedFullData()
    {
        isLoading = true;
        try 
        {
            var shop = await Db.NETH_Shops.FirstOrDefaultAsync(s => s.UrlKey == "leatherandblades");
            var stylist = await Db.NETH_Stylists.FirstOrDefaultAsync(s => s.Name == "Brandon");
            var service = await Db.NETH_Services.FirstOrDefaultAsync(s => s.Name == "Fade");

            if (shop == null || stylist == null) {
                dbError = "Base data (Shop/Stylist) missing.";
                isLoading = false;
                return;
            }

            // 1. Media
            var media = new NETH_Media { FileUrl = "/img/logo.png", Category = "Logo", Description = "Shop Logo" };
            Db.NETH_Media.Add(media);
            await Db.SaveChangesAsync();

            // 2. Client Phone
            var cp = new NETH_Phone { Number = "9035558888", Type = "Mobile" };
            Db.NETH_Phones.Add(cp);
            await Db.SaveChangesAsync();

            // 3. Client
            var client = new NETH_Client { FirstName = "John", LastName = "Doe", Email = "john@doe.com", PhoneId = cp.Id };
            Db.NETH_Clients.Add(client);
            await Db.SaveChangesAsync();

            // 4. Appointment
            var app = new NETH_Appointment { 
                ShopId = shop.Id, StylistId = stylist.Id, ClientId = client.Id, 
                StartTime = DateTime.UtcNow.AddDays(2), EndTime = DateTime.UtcNow.AddDays(2).AddMinutes(30),
                Status = "Booked", IsPaid = false, TotalPrice = 30.00m
            };
            Db.NETH_Appointments.Add(app);
            await Db.SaveChangesAsync();

            // 5. Link Service
            if (service != null) {
                Db.NETH_AppointmentsService.Add(new NETH_AppointmentService { 
                    AppointmentId = app.Id, ServiceId = service.Id, 
                    PriceAtBooking = service.Price, DurationAtBooking = service.DurationMinutes 
                });
                await Db.SaveChangesAsync();
            }

            NavManager.NavigateTo(NavManager.Uri, forceLoad: true);
        }
        catch (Exception ex) { dbError = $"Seed Error: {ex.Message}"; isLoading = false; }
    }
}

<style>
    :root { --dark-bg: #1a1b1e; --card-bg: #25262b; --text-main: #c1c2c5; }
    .app-container { background-color: var(--dark-bg); color: var(--text-main); min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 2rem; font-family: 'Inter', sans-serif; }
    .stylist-header { text-align: center; margin-bottom: 2rem; }
    .logo-circle { width: 60px; height: 60px; background-color: var(--brand-color); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; font-size: 1.5rem; color: #1a1b1e; }
    .booking-card { background-color: var(--card-bg); border-radius: 12px; padding: 2rem; width: 100%; max-width: 450px; border: 1px solid #373a40; box-shadow: 0 10px 25px rgba(0,0,0,0.3); }
    .status-badge { font-size: 0.75rem; color: #40c057; display: flex; align-items: center; gap: 5px; margin-top: 5px; font-weight: bold; }
    .status-dot { height: 8px; width: 8px; background: #40c057; border-radius: 50%; }
    .stylist-card { margin-top: 1.5rem; background: rgba(0,0,0,0.2); padding: 1rem; border-radius: 8px; margin-bottom: 1rem; }
    .service-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #373a40; font-size: 0.9rem; }
    .btn-book { width: 100%; margin-top: 1rem; padding: 10px; border-radius: 6px; background: var(--brand-color); color: #1a1b1e; border: none; font-weight: bold; cursor: pointer; }
    .btn-seed { background-color: #3498db; color: white; padding: 10px; border-radius: 6px; border: none; width: 100%; font-weight: bold; cursor: pointer; }
    .spinner { border: 4px solid rgba(255,255,255,0.1); border-top: 4px solid var(--brand-color); border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin: 0 auto 1rem; }
    @@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>