@page "/nethaircut"
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.EntityFrameworkCore
@using Dashboard
@inject Dashboard.AppDbContext Db
@inject NavigationManager NavManager
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))

<div class="app-container" style="--brand-color: @(currentShop?.BrandColor ?? "#D2B48C")">
    <header class="stylist-header">
        <div class="logo-circle">
            <i class="fas fa-cut"></i>
        </div>
        <h1>@FormattedName</h1>
        <p class="tagline">North East Texas Style & Booking</p>
    </header>

    <main class="booking-card">
        @* DIAGNOSTIC BOX *@
        <div style="background: #000; color: #0f0; padding: 5px; font-family: monospace; font-size: 10px; margin-bottom: 10px; border: 1px solid #333;">
            KEY: @CurrentStylist | SHOPS: @shops.Count | CLIENTS: @clients.Count | APPS: @appointments.Count
        </div>

        @if (isLoading)
        {
            <div class="spinner-box">
                <div class="spinner"></div>
                <p>Initialing Database & Loading Registry...</p>
            </div>
        }
        else if (currentShop == null)
        {
            <div class="seed-box">
                <i class="fas fa-database mb-3" style="font-size: 2rem; color: #e67e22;"></i>
                <h3>No Registry Found</h3>
                <p class="mb-4 text-sm">We couldn't find a registry for "<strong>@CurrentStylist</strong>".</p>
                @if (!string.IsNullOrEmpty(dbError))
                {
                    <p style="color: #ff4444; font-size: 0.8rem; margin-bottom: 1rem;">@dbError</p>
                }
                <button class="btn-seed" @onclick="SeedMissingData">🔧 Build Tables & Seed Clients</button>
            </div>
        }
        else
        {
            <section class="welcome-text">
                <h2>Welcome to @currentShop.BusinessName</h2>
                <div class="status-badge">
                    <span class="status-dot"></span> Online & Booking
                </div>
            </section>

            <div class="stylist-grid">
                @foreach (var stylist in currentShop.Stylists)
                {
                    <div class="stylist-card">
                        <div class="stylist-info">
                            <h3>@stylist.Name</h3>
                            <p class="bio">@stylist.Bio</p>
                        </div>
                        <div class="services-list">
                            @foreach (var service in stylist.Services)
                            {
                                <div class="service-row">
                                    <span class="service-name">@service.Name</span>
                                    <span class="service-price">$@service.Price.ToString("N2")</span>
                                </div>
                            }
                        </div>
                        <button class="btn-book">Book with @stylist.Name</button>
                    </div>
                }
            </div>
        }

        @* RAW DATA DUMP SECTION *@
        <div style="margin-top: 3rem; background: #111; padding: 1rem; border-radius: 8px; font-family: monospace; font-size: 0.65rem; color: #aaa; overflow-x: auto; line-height: 1.4;">
            <h4 style="color: #fff; border-bottom: 1px solid #333; padding-bottom: 5px;">FULL NETH DATA AUDIT</h4>
            
            <p style="color: #e67e22; margin-top: 10px; font-weight: bold;">[NETH_Shops]</p>
            @foreach(var s in shops) { <div>ID:@s.Id | Key:@s.UrlKey | Name:@s.BusinessName | PhoneID:@s.PhoneId</div> }

            <p style="color: #e67e22; margin-top: 10px; font-weight: bold;">[NETH_Stylists]</p>
            @foreach(var st in stylists) { <div>ID:@st.Id | ShopID:@st.ShopId | Name:@st.Name | PhoneID:@st.PhoneId</div> }

            <p style="color: #e67e22; margin-top: 10px; font-weight: bold;">[NETH_Services]</p>
            @foreach(var sv in services) { <div>ID:@sv.Id | StyID:@sv.StylistId | Name:@sv.Name | Price:@sv.Price</div> }

            <p style="color: #e67e22; margin-top: 10px; font-weight: bold;">[NETH_Clients]</p>
            @foreach(var c in clients) { <div>ID:@c.Id | Name:@c.FirstName @c.LastName | Email:@c.Email | PhoneID:@c.PhoneId</div> }

            <p style="color: #e67e22; margin-top: 10px; font-weight: bold;">[NETH_Appointments]</p>
            @foreach(var a in appointments) { <div>ID:@a.Id | ClientID:@a.ClientId | Start:@a.StartTime | End:@a.EndTime</div> }

            <p style="color: #e67e22; margin-top: 10px; font-weight: bold;">[NETH_Phones]</p>
            @foreach(var p in phones) { <div>ID:@p.Id | Num:@p.Number | Type:@p.Type</div> }
        </div>
    </main>
</div>

@code {
    private string CurrentStylist { get; set; } = "GENERAL";
    private string FormattedName => CurrentStylist.Replace("%20", " ").ToUpper();
    private bool isLoading = true;
    private string dbError = "";

    private List<NETH_Shop> shops = new();
    private List<NETH_Stylist> stylists = new();
    private List<NETH_Service> services = new();
    private List<NETH_Client> clients = new();
    private List<NETH_Appointment> appointments = new();
    private List<NETH_Phone> phones = new();
    
    private Dashboard.NETH_Shop? currentShop;

    protected override async Task OnInitializedAsync()
    {
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("stylist", out var name))
        {
            CurrentStylist = name.ToString();
        }

        try 
        {
            // SURGICAL FIX: Adding EndTime to Appointment and creating join table
            await Db.Database.ExecuteSqlRawAsync(@"
                CREATE TABLE IF NOT EXISTS ""NETH_Clients"" (
                    ""Id"" SERIAL PRIMARY KEY, ""FirstName"" TEXT NOT NULL, ""LastName"" TEXT NOT NULL, 
                    ""Email"" TEXT NOT NULL, ""PhoneId"" INTEGER NOT NULL REFERENCES ""NETH_Phones""(""Id"")
                );
                CREATE TABLE IF NOT EXISTS ""NETH_ClientNotes"" (
                    ""Id"" SERIAL PRIMARY KEY, ""ClientId"" INTEGER NOT NULL REFERENCES ""NETH_Clients""(""Id""), 
                    ""StylistId"" INTEGER NOT NULL REFERENCES ""NETH_Stylists""(""Id""), ""Note"" TEXT NOT NULL
                );
                CREATE TABLE IF NOT EXISTS ""NETH_Appointments"" (
                    ""Id"" SERIAL PRIMARY KEY, ""ClientId"" INTEGER NOT NULL REFERENCES ""NETH_Clients""(""Id""), 
                    ""StylistId"" INTEGER NOT NULL REFERENCES ""NETH_Stylists""(""Id""), 
                    ""StartTime"" TIMESTAMP NOT NULL, ""EndTime"" TIMESTAMP NOT NULL DEFAULT NOW()
                );
                CREATE TABLE IF NOT EXISTS ""NETH_AppointmentServices"" (
                    ""AppointmentId"" INTEGER NOT NULL REFERENCES ""NETH_Appointments""(""Id""),
                    ""ServiceId"" INTEGER NOT NULL REFERENCES ""NETH_Services""(""Id""),
                    PRIMARY KEY (""AppointmentId"", ""ServiceId"")
                );
                CREATE TABLE IF NOT EXISTS ""NETH_NoteTags"" (
                    ""Id"" SERIAL PRIMARY KEY, ""TagName"" TEXT NOT NULL, ""Color"" TEXT NOT NULL
                );
                CREATE TABLE IF NOT EXISTS ""NETH_Media"" (
                    ""Id"" SERIAL PRIMARY KEY, ""FileName"" TEXT NOT NULL
                );
            ");
        }
        catch (Exception ex) { Console.WriteLine($"Table Creation Error: {ex.Message}"); }

        await LoadAllData();
        isLoading = false;
    }

    private async Task LoadAllData()
    {
        try 
        {
            shops = await Db.NETH_Shops.AsNoTracking().ToListAsync();
            stylists = await Db.NETH_Stylists.AsNoTracking().ToListAsync();
            services = await Db.NETH_Services.AsNoTracking().ToListAsync();
            clients = await Db.NETH_Clients.AsNoTracking().ToListAsync();
            appointments = await Db.NETH_Appointments.AsNoTracking().ToListAsync();
            phones = await Db.NETH_Phones.AsNoTracking().ToListAsync();

            string key = CurrentStylist.ToLower().Trim();
            currentShop = await Db.NETH_Shops
                .AsNoTracking()
                .Include(s => s.Stylists).ThenInclude(st => st.Services)
                .FirstOrDefaultAsync(s => s.UrlKey.ToLower() == key);
        }
        catch (Exception ex) 
        { 
            dbError = $"Audit Error: {ex.Message}";
            Console.WriteLine(dbError); 
        }
    }

    private async Task SeedMissingData()
    {
        try 
        {
            var p = new NETH_Phone { Number = "9035559999", Type = "Mobile" };
            Db.NETH_Phones.Add(p);
            await Db.SaveChangesAsync();

            var c = new NETH_Client { FirstName = "John", LastName = "Doe", Email = "john@example.com", PhoneId = p.Id };
            Db.NETH_Clients.Add(c);
            await Db.SaveChangesAsync();

            var stylist = await Db.NETH_Stylists.FirstOrDefaultAsync();
            if (stylist != null)
            {
                var a = new NETH_Appointment { 
                    ClientId = c.Id, 
                    StylistId = stylist.Id, 
                    StartTime = DateTime.UtcNow.AddDays(1),
                    EndTime = DateTime.UtcNow.AddDays(1).AddMinutes(30)
                };
                Db.NETH_Appointments.Add(a);
                await Db.SaveChangesAsync();
            }

            NavManager.NavigateTo(NavManager.Uri, true);
        }
        catch (Exception ex) { dbError = $"Seed Error: {ex.Message}"; }
    }
}

<style>
    :root { --dark-bg: #1a1b1e; --card-bg: #25262b; --text-main: #c1c2c5; }
    .app-container { background-color: var(--dark-bg); color: var(--text-main); min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 2rem; font-family: 'Inter', sans-serif; }
    .stylist-header { text-align: center; margin-bottom: 2rem; }
    .logo-circle { width: 60px; height: 60px; background-color: var(--brand-color); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; font-size: 1.5rem; color: #1a1b1e; }
    .booking-card { background-color: var(--card-bg); border-radius: 12px; padding: 2rem; width: 100%; max-width: 450px; border: 1px solid #373a40; box-shadow: 0 10px 25px rgba(0,0,0,0.3); }
    .status-badge { font-size: 0.75rem; color: #40c057; display: flex; align-items: center; gap: 5px; margin-top: 5px; font-weight: bold; }
    .status-dot { height: 8px; width: 8px; background: #40c057; border-radius: 50%; }
    .stylist-card { margin-top: 1.5rem; background: rgba(0,0,0,0.2); padding: 1rem; border-radius: 8px; }
    .service-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #373a40; font-size: 0.9rem; }
    .btn-book { width: 100%; margin-top: 1rem; padding: 10px; border-radius: 6px; background: var(--brand-color); color: #1a1b1e; border: none; font-weight: bold; cursor: pointer; }
    .btn-seed { background-color: #e67e22; color: white; padding: 10px; border-radius: 6px; border: none; width: 100%; font-weight: bold; cursor: pointer; margin-top: 1rem; }
    .spinner { border: 4px solid rgba(255,255,255,0.1); border-top: 4px solid var(--brand-color); border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin: 0 auto 1rem; }
    @@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>