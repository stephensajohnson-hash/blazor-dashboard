@page "/nethaircut"
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.EntityFrameworkCore
@using Dashboard
@using System.Data
@inject Dashboard.AppDbContext Db
@inject NavigationManager NavManager
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))

<div style="background-color: #1a1b1e; color: #c1c2c5; min-height: 100vh; padding: 2rem; font-family: sans-serif;">
    <h2 style="color: #D2B48C;">NETH AUTO-RECOVERY MODE</h2>
    
    @* STEP-BY-STEP CONSOLE *@
    <div style="background: #000; padding: 15px; border: 1px solid #0f0; font-family: monospace; font-size: 12px; color: #0f0; line-height: 1.5; margin-bottom: 20px;">
        <div style="font-weight: bold; border-bottom: 1px solid #0f0; margin-bottom: 5px;">BOOT LOG:</div>
        @foreach (var line in consoleLogs)
        {
            <div>@line</div>
        }
    </div>

    @if (currentShop != null)
    {
        <div style="background: #25262b; padding: 20px; border-radius: 8px; border: 1px solid #444;">
            <h1 style="margin-top: 0;">@currentShop.BusinessName</h1>
            <p>Status: <span style="color: #40c057;">Online</span></p>
            
            <div style="margin-top: 20px; border-top: 1px solid #333; padding-top: 10px;">
                <h3>Active Stylists:</h3>
                <ul>
                    @foreach (var s in stylists)
                    {
                        <li><strong>@s.Name</strong> - @s.Bio</li>
                    }
                </ul>
            </div>
        </div>
    }

    @* DATA AUDIT *@
    <div style="margin-top: 2rem; background: #111; padding: 1rem; border-radius: 8px; font-family: monospace; font-size: 0.75rem; color: #888;">
        <div style="color: #fff; font-weight: bold; margin-bottom: 5px;">DATABASE AUDIT:</div>
        <div>Shops: @shops.Count</div>
        <div>Clients: @clients.Count</div>
        <div>Apps: @appointments.Count</div>
        <div>Phones: @phones.Count</div>
    </div>
</div>

@code {
    private List<string> consoleLogs = new();
    private string CurrentStylist = "GENERAL";
    private List<NETH_Shop> shops = new();
    private List<NETH_Stylist> stylists = new();
    private List<NETH_Client> clients = new();
    private List<NETH_Appointment> appointments = new();
    private List<NETH_Phone> phones = new();
    private NETH_Shop? currentShop;

    protected override async Task OnInitializedAsync()
    {
        Log("Initialize started...");
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("stylist", out var name)) CurrentStylist = name.ToString();

        try 
        {
            // FORCE RUN RECOVERY ON EVERY LOAD UNTIL DATA EXISTS
            var shopCount = await Db.NETH_Shops.CountAsync();
            if (shopCount == 0)
            {
                Log("No shops found. Running Nuke & Pave...");
                await ExecuteRecovery();
            }
            else 
            {
                Log("Database has data. Loading...");
            }

            await LoadData();
        }
        catch (Exception ex)
        {
            Log($"CRITICAL ERROR: {ex.Message}");
        }
    }

    private void Log(string msg) => consoleLogs.Add($"[{DateTime.Now:HH:mm:ss}] {msg}");

    private async Task ExecuteRecovery()
    {
        Log("Dropping tables...");
        await Db.Database.ExecuteSqlRawAsync(@"
            DROP TABLE IF EXISTS ""NETH_AppointmentServices""; DROP TABLE IF EXISTS ""NETH_Appointments"";
            DROP TABLE IF EXISTS ""NETH_ClientNotes""; DROP TABLE IF EXISTS ""NETH_NoteTags"";
            DROP TABLE IF EXISTS ""NETH_Clients""; DROP TABLE IF EXISTS ""NETH_Media"";
            DROP TABLE IF EXISTS ""NETH_Services""; DROP TABLE IF EXISTS ""NETH_Stylists"";
            DROP TABLE IF EXISTS ""NETH_Shops""; DROP TABLE IF EXISTS ""NETH_Phones"";
        ");

        Log("Recreating tables...");
        await Db.Database.ExecuteSqlRawAsync(@"
            CREATE TABLE ""NETH_Phones"" (""Id"" SERIAL PRIMARY KEY, ""Number"" TEXT NOT NULL, ""Type"" TEXT NOT NULL, ""IsBadNumber"" BOOLEAN NOT NULL DEFAULT FALSE);
            CREATE TABLE ""NETH_Shops"" (""Id"" SERIAL PRIMARY KEY, ""UrlKey"" TEXT NOT NULL, ""BusinessName"" TEXT NOT NULL, ""BrandColor"" TEXT NOT NULL, ""LogoMediaId"" INTEGER NULL, ""StripeAccountId"" TEXT NOT NULL, ""PhoneId"" INTEGER NOT NULL);
            CREATE TABLE ""NETH_Stylists"" (""Id"" SERIAL PRIMARY KEY, ""ShopId"" INTEGER NOT NULL, ""Name"" TEXT NOT NULL, ""Bio"" TEXT NOT NULL, ""IsIndependent"" BOOLEAN NOT NULL, ""StripeAccountId"" TEXT NOT NULL, ""PhoneId"" INTEGER NOT NULL);
            CREATE TABLE ""NETH_Clients"" (""Id"" SERIAL PRIMARY KEY, ""FirstName"" TEXT NOT NULL, ""LastName"" TEXT NOT NULL, ""Email"" TEXT NOT NULL, ""PhoneId"" INTEGER NOT NULL);
            CREATE TABLE ""NETH_Appointments"" (""Id"" SERIAL PRIMARY KEY, ""ShopId"" INTEGER NOT NULL, ""StylistId"" INTEGER NOT NULL, ""ClientId"" INTEGER NOT NULL, ""StartTime"" TIMESTAMP NOT NULL, ""EndTime"" TIMESTAMP NOT NULL, ""Status"" TEXT NOT NULL, ""TotalPrice"" DECIMAL NOT NULL, ""Notes"" TEXT NOT NULL, ""IsPaid"" BOOLEAN NOT NULL);
            CREATE TABLE ""NETH_Services"" (""Id"" SERIAL PRIMARY KEY, ""StylistId"" INTEGER NOT NULL, ""Name"" TEXT NOT NULL, ""Price"" DECIMAL NOT NULL, ""DurationMinutes"" INTEGER NOT NULL);
        ");

        Log("Inserting John Doe seed data...");
        await Db.Database.ExecuteSqlRawAsync(@"
            INSERT INTO ""NETH_Phones"" (""Number"", ""Type"") VALUES ('9035551111', 'Work'), ('9035552222', 'Mobile');
            INSERT INTO ""NETH_Shops"" (""UrlKey"", ""BusinessName"", ""BrandColor"", ""StripeAccountId"", ""PhoneId"") VALUES ('leatherandblades', 'Leather & Blades', '#D2B48C', '', 1);
            INSERT INTO ""NETH_Stylists"" (""ShopId"", ""Name"", ""Bio"", ""IsIndependent"", ""StripeAccountId"", ""PhoneId"") VALUES (1, 'Brandon', 'Master Barber', true, '', 2);
            INSERT INTO ""NETH_Clients"" (""FirstName"", ""LastName"", ""Email"", ""PhoneId"") VALUES ('John', 'Doe', 'john@test.com', 2);
            INSERT INTO ""NETH_Appointments"" (""ShopId"", ""StylistId"", ""ClientId"", ""StartTime"", ""EndTime"", ""Status"", ""TotalPrice"", ""Notes"", ""IsPaid"") 
            VALUES (1, 1, 1, NOW(), NOW() + interval '30 minutes', 'Booked', 35.00, 'Seeded Auto', false);
        ");
        Log("Recovery complete.");
    }

    private async Task LoadData()
    {
        Log("Loading lists into memory...");
        shops = await Db.NETH_Shops.AsNoTracking().ToListAsync();
        clients = await Db.NETH_Clients.AsNoTracking().ToListAsync();
        appointments = await Db.NETH_Appointments.AsNoTracking().ToListAsync();
        phones = await Db.NETH_Phones.AsNoTracking().ToListAsync();
        stylists = await Db.NETH_Stylists.AsNoTracking().ToListAsync();

        currentShop = shops.FirstOrDefault(s => s.UrlKey.ToLower() == CurrentStylist.ToLower());
        if (currentShop != null) Log($"Match found for {CurrentStylist}!");
        else Log($"No match found for {CurrentStylist}.");
    }
}