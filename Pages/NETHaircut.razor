@page "/nethaircut"

<div class="app-container">
    <header class="stylist-header">
        <div class="logo-circle">
            <i class="fas fa-cut"></i>
        </div>
        <h1>NETHaircut</h1>
        <p class="tagline">North East Texas Style & Booking</p>
    </header>

    <main class="booking-card">
        <section class="welcome-text">
            <h2>Welcome, Stephens!</h2>
            <p>Your frictionless booking platform is under construction.</p>
        </section>

        <div class="status-box">
            <span class="status-dot"></span>
            <span>System: PWA Ready (Render)</span>
        </div>

        <button class="btn-primary" @onclick="SimulateBooking">
            Browse Services
        </button>
    </main>

    <footer class="install-banner">
        <p>Install <strong>NETHaircut</strong> for 1-tap booking.</p>
        <button class="btn-sm">Add to Home Screen</button>
    </footer>
</div>

@code {
    private void SimulateBooking()
    {
        // This is where your C# logic for Twilio/Stripe will go
        Console.WriteLine("Booking engine initialized...");
    }
}

<style>
    :root {
        --primary-gold: #D2B48C; /* That wood/leather tan */
        --dark-bg: #1a1a1a;
        --card-bg: #2d2d2d;
        --text-light: #f4f4f4;
    }

    .app-container {
        background-color: var(--dark-bg);
        color: var(--text-light);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding: 20px;
    }

    .stylist-header {
        text-align: center;
        margin-top: 40px;
        margin-bottom: 30px;
    }

    .logo-circle {
        width: 80px;
        height: 80px;
        background-color: var(--primary-gold);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        font-size: 2rem;
        color: var(--dark-bg);
    }

    .booking-card {
        background-color: var(--card-bg);
        border-radius: 15px;
        padding: 30px;
        width: 100%;
        max-width: 400px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        text-align: center;
        border: 1px solid #444;
    }

    .btn-primary {
        background-color: var(--primary-gold);
        color: var(--dark-bg);
        border: none;
        padding: 15px 30px;
        border-radius: 8px;
        font-weight: bold;
        width: 100%;
        margin-top: 20px;
        cursor: pointer;
    }

    .status-box {
        margin-top: 20px;
        font-size: 0.8rem;
        color: #888;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .status-dot {
        height: 8px;
        width: 8px;
        background-color: #4CAF50;
        border-radius: 50%;
    }

    .install-banner {
        margin-top: auto;
        padding: 15px;
        background: #333;
        border-radius: 10px;
        display: flex;
        align-items: center;
        gap: 15px;
        font-size: 0.9rem;
    }
</style>