@page "/nethaircut"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.EntityFrameworkCore
@using Dashboard
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#1a1b1e] text-gray-300 p-6 font-sans">
    
    @* HEADER SECTION *@
    <div class="max-w-4xl mx-auto mb-8">
        <div class="bg-[#25262b] rounded-xl border border-gray-700 p-6 shadow-2xl">
            <h1 class="text-2xl font-black text-[#D2B48C] uppercase tracking-widest">NETH Terminal</h1>
            <p class="text-xs text-gray-500 font-mono mt-1">Status: @(isLoading ? "SYNCING_DB..." : "SYSTEM_READY") | Circuit: Connected</p>
        </div>
    </div>

    <div class="max-w-4xl mx-auto grid md:grid-cols-[1fr_300px] gap-6">
        
        @* MAIN CONTROL PANEL *@
        <div class="space-y-6">
            <div class="bg-[#25262b] rounded-xl border border-gray-700 overflow-hidden shadow-lg">
                <div class="p-4 bg-gray-800/50 border-b border-gray-700 flex justify-between items-center">
                    <span class="text-[10px] font-black uppercase tracking-widest text-gray-400">Database Operations</span>
                </div>
                <div class="p-6">
                    <div class="grid grid-cols-2 gap-4">
                        <button @onclick="HandleManualReset" class="bg-red-600/20 hover:bg-red-600 text-red-400 hover:text-white border border-red-500/50 py-4 rounded-lg text-xs font-black uppercase transition tracking-widest shadow-lg">
                            🔥 Factory Reset
                        </button>
                        <button @onclick="HandleManualSeed" class="bg-green-600/20 hover:bg-green-600 text-green-400 hover:text-white border border-green-500/50 py-4 rounded-lg text-xs font-black uppercase transition tracking-widest shadow-lg">
                            🌱 Seed John Doe
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="mt-4 p-3 bg-blue-500/10 border border-blue-500/30 rounded text-[11px] font-mono text-blue-400 animate-pulse">
                            > @statusMessage
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="mt-4 p-3 bg-red-500/10 border border-red-500/30 rounded text-[11px] font-mono text-red-400">
                            > ERROR: @errorMessage
                        </div>
                    }
                </div>
            </div>

            @* SHOP DISPLAY *@
            @if (currentShop != null)
            {
                <div class="bg-white rounded-xl shadow-2xl p-8 border border-gray-300 text-gray-800">
                    <div class="flex items-center gap-4 mb-6">
                        <div class="w-12 h-12 bg-[#D2B48C] rounded-full flex items-center justify-center text-white shadow-inner">
                            <i class="fas fa-cut"></i>
                        </div>
                        <div>
                            <h2 class="text-2xl font-black uppercase tracking-tight">@currentShop.BusinessName</h2>
                            <span class="text-[10px] bg-green-100 text-green-700 px-2 py-0.5 rounded font-black uppercase">Active Registry</span>
                        </div>
                    </div>

                    <div class="space-y-4">
                        @foreach (var s in stylists)
                        {
                            <div class="p-4 border border-gray-100 rounded-lg hover:bg-gray-50 transition flex justify-between items-center group">
                                <div>
                                    <div class="font-black text-gray-800 uppercase">@s.Name</div>
                                    <div class="text-xs text-gray-500">@s.Bio</div>
                                </div>
                                <button class="bg-blue-600 text-white px-6 py-2 rounded text-[10px] font-black uppercase tracking-widest opacity-0 group-hover:opacity-100 transition shadow-lg">Book</button>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        @* SIDEBAR AUDIT *@
        <div class="space-y-6">
            <div class="bg-[#282b30] rounded-xl border border-gray-700 shadow-2xl p-5">
                <h4 class="text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] mb-4">Ledger Audit</h4>
                <div class="space-y-3 font-mono text-xs">
                    <div class="flex justify-between border-b border-gray-700 pb-2">
                        <span class="text-gray-500">SHOPS</span>
                        <span class="text-white font-black">@shops.Count</span>
                    </div>
                    <div class="flex justify-between border-b border-gray-700 pb-2">
                        <span class="text-gray-500">CLIENTS</span>
                        <span class="text-white font-black">@clients.Count</span>
                    </div>
                    <div class="flex justify-between border-b border-gray-700 pb-2">
                        <span class="text-gray-500">APPOINTMENTS</span>
                        <span class="text-white font-black">@appointments.Count</span>
                    </div>
                </div>
            </div>

            <div class="bg-black/20 rounded-xl border border-dashed border-gray-700 p-5">
                <p class="text-[10px] text-gray-500 leading-relaxed italic">
                    Note: If buttons fail, ensure your circuit hasn't timed out. Refreshing the page will re-sync the session.
                </p>
            </div>
        </div>

    </div>
</div>

@code {
    private bool isLoading = true;
    private string statusMessage = "Standing by.";
    private string errorMessage = "";
    private string CurrentStylist = "leatherandblades";

    private List<NETH_Shop> shops = new();
    private List<NETH_Stylist> stylists = new();
    private List<NETH_Client> clients = new();
    private List<NETH_Appointment> appointments = new();
    private NETH_Shop? currentShop;

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("stylist", out var name)) CurrentStylist = name.ToString();

        await LoadAllData();
        isLoading = false;
    }

    private async Task LoadAllData()
    {
        try 
        {
            shops = await Db.NETH_Shops.AsNoTracking().ToListAsync();
            stylists = await Db.NETH_Stylists.AsNoTracking().ToListAsync();
            clients = await Db.NETH_Clients.AsNoTracking().ToListAsync();
            appointments = await Db.NETH_Appointments.AsNoTracking().ToListAsync();

            currentShop = shops.FirstOrDefault(s => s.UrlKey.ToLower() == CurrentStylist.ToLower());
        }
        catch (Exception ex) { errorMessage = "LOAD_ERR: " + ex.Message; }
    }

    private async Task HandleManualReset()
    {
        statusMessage = "INIT_NUKE_PROTOCOL...";
        errorMessage = "";
        StateHasChanged();

        try 
        {
            await Db.Database.ExecuteSqlRawAsync(@"
                DROP TABLE IF EXISTS ""NETH_AppointmentServices""; DROP TABLE IF EXISTS ""NETH_Appointments"";
                DROP TABLE IF EXISTS ""NETH_ClientNotes""; DROP TABLE IF EXISTS ""NETH_NoteTags"";
                DROP TABLE IF EXISTS ""NETH_Clients""; DROP TABLE IF EXISTS ""NETH_Media"";
                DROP TABLE IF EXISTS ""NETH_Services""; DROP TABLE IF EXISTS ""NETH_Stylists"";
                DROP TABLE IF EXISTS ""NETH_Shops""; DROP TABLE IF EXISTS ""NETH_Phones"";

                CREATE TABLE ""NETH_Phones"" (""Id"" SERIAL PRIMARY KEY, ""Number"" TEXT NOT NULL, ""Type"" TEXT NOT NULL, ""IsBadNumber"" BOOLEAN NOT NULL DEFAULT FALSE);
                CREATE TABLE ""NETH_Shops"" (""Id"" SERIAL PRIMARY KEY, ""UrlKey"" TEXT NOT NULL, ""BusinessName"" TEXT NOT NULL, ""BrandColor"" TEXT NOT NULL, ""LogoMediaId"" INTEGER NULL, ""StripeAccountId"" TEXT NOT NULL, ""PhoneId"" INTEGER NOT NULL);
                CREATE TABLE ""NETH_Stylists"" (""Id"" SERIAL PRIMARY KEY, ""ShopId"" INTEGER NOT NULL, ""Name"" TEXT NOT NULL, ""Bio"" TEXT NOT NULL, ""IsIndependent"" BOOLEAN NOT NULL, ""StripeAccountId"" TEXT NOT NULL, ""PhoneId"" INTEGER NOT NULL);
                CREATE TABLE ""NETH_Services"" (""Id"" SERIAL PRIMARY KEY, ""StylistId"" INTEGER NOT NULL, ""Name"" TEXT NOT NULL, ""Price"" DECIMAL NOT NULL, ""DurationMinutes"" INTEGER NOT NULL);
                CREATE TABLE ""NETH_Clients"" (""Id"" SERIAL PRIMARY KEY, ""FirstName"" TEXT NOT NULL, ""LastName"" TEXT NOT NULL, ""Email"" TEXT NOT NULL, ""PhoneId"" INTEGER NOT NULL);
                CREATE TABLE ""NETH_Appointments"" (""Id"" SERIAL PRIMARY KEY, ""ShopId"" INTEGER NOT NULL, ""StylistId"" INTEGER NOT NULL, ""ClientId"" INTEGER NOT NULL, ""StartTime"" TIMESTAMP NOT NULL, ""EndTime"" TIMESTAMP NOT NULL, ""Status"" TEXT NOT NULL, ""TotalPrice"" DECIMAL NOT NULL, ""Notes"" TEXT NOT NULL, ""IsPaid"" BOOLEAN NOT NULL);
            ");
            
            statusMessage = "NUKE_SUCCESS. REFRESHING...";
            await Task.Delay(1000);
            Nav.NavigateTo(Nav.Uri, true);
        }
        catch (Exception ex) { errorMessage = ex.Message; statusMessage = ""; }
    }

    private async Task HandleManualSeed()
    {
        statusMessage = "INJECTING_SEED_DATA...";
        errorMessage = "";
        StateHasChanged();

        try 
        {
            await Db.Database.ExecuteSqlRawAsync(@"
                INSERT INTO ""NETH_Phones"" (""Number"", ""Type"") VALUES ('9035551111', 'Work'), ('9035552222', 'Mobile');
                INSERT INTO ""NETH_Shops"" (""UrlKey"", ""BusinessName"", ""BrandColor"", ""StripeAccountId"", ""PhoneId"") VALUES ('leatherandblades', 'Leather & Blades', '#D2B48C', '', 1);
                INSERT INTO ""NETH_Stylists"" (""ShopId"", ""Name"", ""Bio"", ""IsIndependent"", ""StripeAccountId"", ""PhoneId"") VALUES (1, 'Brandon', 'Master Barber', true, '', 2);
                INSERT INTO ""NETH_Services"" (""StylistId"", ""Name"", ""Price"", ""DurationMinutes"") VALUES (1, 'Signature Fade', 35.00, 30);
                INSERT INTO ""NETH_Clients"" (""FirstName"", ""LastName"", ""Email"", ""PhoneId"") VALUES ('John', 'Doe', 'john@test.com', 2);
                INSERT INTO ""NETH_Appointments"" (""ShopId"", ""StylistId"", ""ClientId"", ""StartTime"", ""EndTime"", ""Status"", ""TotalPrice"", ""Notes"", ""IsPaid"") 
                VALUES (1, 1, 1, NOW(), NOW() + interval '30 minutes', 'Booked', 35.00, 'Seed', false);
            ");

            statusMessage = "SEED_SUCCESS. REFRESHING...";
            await Task.Delay(1000);
            Nav.NavigateTo(Nav.Uri, true);
        }
        catch (Exception ex) { errorMessage = ex.Message; statusMessage = ""; }
    }
}