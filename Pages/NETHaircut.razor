@page "/nethaircut"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using Dashboard.Components
@using System.Text.Json
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex font-sans">
    
    @if (isAuthenticated)
    {
        <NETHAdminSidebar />
    }

    <div class="flex-1 p-8">
        <div class="max-w-5xl mx-auto">
            <div class="bg-[#25262b] rounded-xl border border-gray-700 p-6 shadow-2xl flex justify-between items-center mb-8">
                <div>
                    <h1 class="text-2xl font-black text-[#D2B48C] uppercase tracking-widest">NETH Terminal</h1>
                    <p class="text-[10px] font-mono text-gray-500 mt-1 uppercase">Admin Registry Overview</p>
                </div>
                @if (isAuthenticated)
                {
                    <span class="text-[10px] font-mono text-green-500 bg-green-500/10 px-3 py-1 rounded border border-green-500/20">AUTH_LEVEL: ADMIN</span>
                }
            </div>

            @if (isLoading)
            {
                <div class="text-center py-20 animate-pulse font-black text-gray-600 uppercase tracking-widest">Syncing_System_Data...</div>
            }
            else if (!isAuthenticated)
            {
                <div class="max-w-md mx-auto bg-[#25262b] rounded-xl border border-gray-700 p-8 shadow-2xl mt-10">
                    <h2 class="text-center font-black uppercase tracking-widest text-gray-400 mb-6">Security Access</h2>
                    <div class="space-y-4">
                        <input @bind="loginUsername" placeholder="Username" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-3 text-white focus:border-[#D2B48C] outline-none" />
                        <input type="password" @bind="loginPassword" placeholder="Password" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-3 text-white focus:border-[#D2B48C] outline-none" />
                        <button @onclick="AttemptLogin" class="w-full bg-[#D2B48C] text-[#1a1b1e] py-3 rounded font-black uppercase tracking-widest transition hover:bg-[#c4a47c]">Authenticate</button>
                        @if (!string.IsNullOrEmpty(errorMessage)) { <p class="text-red-400 text-[10px] text-center mt-4 uppercase font-mono">!! @errorMessage !!</p> }
                    </div>
                </div>
            }
            else
            {
                @* DASHBOARD STATS *@
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <div class="bg-[#25262b] p-6 rounded-xl border border-gray-700 shadow-xl">
                        <div class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2">Total Users</div>
                        <div class="text-4xl font-black text-white">@stats.Users</div>
                        <div class="mt-4 h-1 w-full bg-gray-800 rounded-full overflow-hidden">
                            <div class="bg-blue-500 h-full" style="width: 70%"></div>
                        </div>
                    </div>

                    <div class="bg-[#25262b] p-6 rounded-xl border border-gray-700 shadow-xl">
                        <div class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2">Shops</div>
                        <div class="text-4xl font-black text-[#D2B48C]">@stats.Shops</div>
                        <div class="mt-4 h-1 w-full bg-gray-800 rounded-full overflow-hidden">
                            <div class="bg-[#D2B48C] h-full" style="width: 40%"></div>
                        </div>
                    </div>

                    <div class="bg-[#25262b] p-6 rounded-xl border border-gray-700 shadow-xl">
                        <div class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2">Active Stylists</div>
                        <div class="text-4xl font-black text-white">@stats.Stylists</div>
                        <div class="mt-4 h-1 w-full bg-gray-800 rounded-full overflow-hidden">
                            <div class="bg-green-500 h-full" style="width: 55%"></div>
                        </div>
                    </div>

                    <div class="bg-[#25262b] p-6 rounded-xl border border-gray-700 shadow-xl">
                        <div class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2">Appointments</div>
                        <div class="text-4xl font-black text-gray-500">@stats.Appointments</div>
                        <div class="mt-4 h-1 w-full bg-gray-800 rounded-full overflow-hidden">
                            <div class="bg-gray-600 h-full" style="width: 20%"></div>
                        </div>
                    </div>
                </div>

                <div class="mt-10 p-8 border-2 border-dashed border-gray-800 rounded-2xl text-center">
                    <p class="text-gray-600 font-mono text-xs uppercase tracking-widest">Select a module from the sidebar to modify system records.</p>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool isAuthenticated = false;
    private bool isLoading = true;
    private string loginUsername = "";
    private string loginPassword = "";
    private string errorMessage = "";
    private DashboardStats stats = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CheckSession();
            if (isAuthenticated) await LoadStats();
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task CheckSession()
    {
        try {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "neth_session");
            if (!string.IsNullOrEmpty(json)) isAuthenticated = true;
        } catch { }
    }

    private async Task LoadStats()
    {
        try {
            stats.Users = await Db.Database.SqlQueryRaw<int>(@"SELECT COUNT(*)::int as ""Value"" FROM ""NETH_Users""").FirstOrDefaultAsync();
            stats.Shops = await Db.NETH_Shops.CountAsync();
            stats.Stylists = await Db.NETH_Stylists.CountAsync();
            stats.Appointments = await Db.NETH_Appointments.CountAsync();
        } catch { }
    }

    private async Task AttemptLogin()
    {
        try {
            var user = await Db.Database.SqlQueryRaw<NETH_User_Lite>(
                @"SELECT ""Id"", ""Username"" FROM ""NETH_Users"" WHERE ""Username"" = {0} AND ""Password"" = {1} LIMIT 1", 
                loginUsername, loginPassword
            ).FirstOrDefaultAsync();

            if (user != null) {
                isAuthenticated = true;
                await JS.InvokeVoidAsync("localStorage.setItem", "neth_session", JsonSerializer.Serialize(new { user.Username }));
                await LoadStats();
            } else errorMessage = "INVALID_CREDENTIALS";
        } catch { errorMessage = "DB_ERROR"; }
    }

    public class DashboardStats { public int Users { get; set; } public int Shops { get; set; } public int Stylists { get; set; } public int Appointments { get; set; } }
    public class NETH_User_Lite { public int Id { get; set; } public string Username { get; set; } = ""; }
}