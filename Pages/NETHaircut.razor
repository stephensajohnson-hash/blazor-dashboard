@page "/nethaircut"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using Dashboard.Components
@using Dashboard.Services
@using System.Text.Json
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject NETHStateService State

@* Ensure FontAwesome is available *@
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<style>
    .neth-card {
        background: rgba(37, 38, 43, 0.8);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 1.25rem;
        padding: 1.75rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 140px;
        position: relative;
        overflow: hidden;
    }

    .neth-card:hover {
        transform: translateY(-5px);
        background: rgba(45, 46, 52, 0.95);
        border-color: #D2B48C;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
    }

    .stats-value {
        font-size: 2.2rem;
        font-weight: 900;
        color: white;
        line-height: 1.1;
        letter-spacing: -0.02em;
    }

    .stats-label {
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: #9ca3af;
        margin-top: 0.5rem;
    }

    .next-up-card {
        background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
        border-left: 4px solid #60a5fa;
        min-height: 160px;
        justify-content: flex-start;
    }
    
    .client-name-display {
        font-size: 1.8rem;
        font-weight: 900;
        color: white;
        line-height: 1.1;
        margin-top: 0.25rem;
        word-wrap: break-word;
    }

    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #374151; border-radius: 10px; }
</style>

<div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex font-sans">
    
    @if (isAuthenticated)
    {
        <NETHAdminSidebar />
    }

    <div class="flex-1 p-8">
        <div class="max-w-6xl mx-auto">
            
            @if (isLoading)
            {
                <div class="flex flex-col items-center justify-center py-40">
                    <div class="w-12 h-12 border-4 border-[#D2B48C] border-t-transparent rounded-full animate-spin"></div>
                    <div class="mt-4 font-black text-gray-600 uppercase tracking-widest text-xs">Syncing_Environment...</div>
                </div>
            }
            else if (!isAuthenticated)
            {
                <div class="max-w-md mx-auto bg-[#25262b] rounded-xl border border-gray-700 p-8 shadow-2xl mt-20">
                    <div class="text-center mb-8">
                        <div class="w-16 h-16 bg-[#D2B48C]/10 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="fa-solid fa-shield-halved text-[#D2B48C] text-2xl"></i>
                        </div>
                        <h2 class="font-black uppercase tracking-[0.2em] text-white">System Access</h2>
                    </div>
                    <div class="space-y-4">
                        <input @bind="loginUsername" placeholder="Username" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-3 text-white focus:border-[#D2B48C] outline-none transition-colors" />
                        <input type="password" @bind="loginPassword" @onkeyup="HandleKeyUp" placeholder="Password" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-3 text-white focus:border-[#D2B48C] outline-none transition-colors" />
                        <button @onclick="AttemptLogin" class="w-full bg-[#D2B48C] text-[#1a1b1e] py-3 rounded font-black uppercase tracking-widest transition hover:bg-[#c4a47c] shadow-lg">Authenticate</button>
                        @if (!string.IsNullOrEmpty(errorMessage)) { <p class="text-red-400 text-[10px] text-center mt-4 uppercase font-mono animate-pulse">!! @errorMessage !!</p> }
                    </div>
                </div>
            }
            else
            {
                @if (State.IsImpersonating)
                {
                    <div class="bg-orange-600 text-white p-4 mb-8 rounded-2xl flex justify-between items-center shadow-xl">
                        <div class="flex items-center gap-4">
                            <i class="fa-solid fa-user-secret text-xl"></i>
                            <div>
                                <p class="text-[10px] font-black uppercase tracking-widest opacity-80">Impersonation Mode</p>
                                <p class="text-sm font-black uppercase italic">Viewing as: @State.ImpersonatedName</p>
                            </div>
                        </div>
                        <button @onclick="ExitImpersonation" class="bg-white text-orange-600 px-6 py-2 rounded-xl font-black uppercase text-[10px] tracking-widest shadow-lg">Restore Admin</button>
                    </div>
                }

                <div class="bg-[#25262b] rounded-xl border border-gray-700 p-6 shadow-2xl flex justify-between items-center mb-8">
                    <div>
                        <h1 class="text-2xl font-black text-[#D2B48C] uppercase tracking-[0.2em]">Dashboard</h1>
                        <p class="text-[10px] font-mono text-gray-500 mt-1 uppercase">Central Command Console // @DateTime.Now.ToString("HH:mm")</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    
                    @if (!State.IsImpersonating)
                    {
                        <div class="neth-card" @onclick='() => Nav.NavigateTo("/admin/neth-shops")'>
                            <div class="stats-value">@stats.Shops</div>
                            <div class="stats-label">Registered Shops</div>
                        </div>
                        <div class="neth-card" @onclick='() => Nav.NavigateTo("/admin/neth-stylists")'>
                            <div class="stats-value">@stats.Stylists</div>
                            <div class="stats-label">Active Stylists</div>
                        </div>
                        <div class="neth-card" @onclick='() => Nav.NavigateTo("/admin/neth-users")'>
                            <div class="stats-value">@stats.Users</div>
                            <div class="stats-label">Admin Accounts</div>
                        </div>
                    }
                    else
                    {
                        <div class="neth-card next-up-card" @onclick='() => Nav.NavigateTo("/admin/neth-appointments")'>
                            @if (nextApp != null)
                            {
                                <div class="flex justify-between items-start w-full mb-2">
                                    <div class="text-blue-400 font-black text-lg uppercase tracking-widest">Next Up: @nextApp.StartTime.ToString("h:mm tt")</div>
                                    @if (hasNextAppNotes)
                                    {
                                        <button @onclick="GoToNextAppNotes" @onclick:stopPropagation="true" 
                                                class="bg-blue-500/20 hover:bg-blue-500 border border-blue-500/40 text-blue-100 px-3 py-1.5 rounded-lg text-[9px] font-black uppercase tracking-widest transition">
                                            <i class="fa-solid fa-clipboard-list mr-1"></i> History
                                        </button>
                                    }
                                </div>
                                <div class="client-name-display">@nextClientName</div>
                            }
                            else
                            {
                                <div class="stats-value text-gray-600">NONE</div>
                                <div class="stats-label">No remaining bookings</div>
                            }
                        </div>

                        <div class="neth-card" @onclick='() => Nav.NavigateTo("/admin/neth-appointments")'>
                            <div class="stats-value">@stats.TodayBusy% Busy</div>
                            <div class="text-green-500 font-mono font-black text-lg mt-1">$@stats.TodayIncome.ToString("N0") Expected Income</div>
                            <div class="stats-label">Today</div>
                        </div>

                        <div class="neth-card" @onclick='() => Nav.NavigateTo("/admin/neth-appointments")'>
                            <div class="stats-value">@stats.WeekBusy% Busy</div>
                            <div class="text-green-500 font-mono font-black text-lg mt-1">$@stats.WeekIncome.ToString("N0") Expected Income</div>
                            <div class="stats-label">This Week</div>
                        </div>
                    }

                    <div class="neth-card" @onclick='() => Nav.NavigateTo("/admin/neth-clients")'>
                        <div class="stats-value">@stats.Clients</div>
                        <div class="stats-label">@(State.IsImpersonating ? "My Clients" : "Total Clients")</div>
                    </div>

                    <div class="neth-card" @onclick='() => Nav.NavigateTo("/admin/neth-client-notes")'>
                        <div class="stats-value">@stats.Notes</div>
                        <div class="stats-label">Client Notes</div>
                    </div>

                    @if (!State.IsImpersonating)
                    {
                        <div class="neth-card" @onclick='() => Nav.NavigateTo("/admin/neth-appointments")'>
                            <div class="stats-value">@stats.Appointments</div>
                            <div class="stats-label">Live Bookings</div>
                        </div>
                    }
                </div>

                <div class="mt-10 bg-[#25262b] rounded-2xl border border-gray-800 overflow-hidden shadow-2xl">
                    <div class="p-4 border-b border-gray-800 bg-black/20 flex justify-between items-center">
                        <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-500">System Monitor</h3>
                        <span class="text-[9px] font-mono text-blue-500 uppercase">Scoped_Feed</span>
                    </div>
                    <div class="p-4 max-h-[350px] overflow-y-auto custom-scrollbar">
                        @foreach (var app in recentAppointments)
                        {
                            <div class="flex items-center gap-4 py-3 border-b border-gray-800/50 last:border-0 hover:bg-white/5 transition-colors px-2 rounded-lg">
                                <div class="w-1.5 h-1.5 rounded-full bg-blue-500 shadow-[0_0_8px_#3b82f6]"></div>
                                <div class="flex-1">
                                    <p class="text-[10px] font-black text-white uppercase">Appointment Confirmed</p>
                                    <p class="text-[9px] text-gray-500 font-mono">@app.StartTime.ToString("MMM dd, h:mm tt")</p>
                                </div>
                                <div class="text-[9px] font-mono text-gray-600">ID: #@app.Id</div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool isAuthenticated = false;
    private bool isLoading = true;
    private string loginUsername = "";
    private string loginPassword = "";
    private string errorMessage = "";
    private DashboardStats stats = new();
    private List<NETH_Appointment> recentAppointments = new();
    
    private NETH_Appointment? nextApp;
    private string nextClientName = "";
    private bool hasNextAppNotes = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CheckSession();
            if (isAuthenticated) await LoadStats();
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task CheckSession() { try { var json = await JS.InvokeAsync<string>("localStorage.getItem", "neth_session"); if (!string.IsNullOrEmpty(json)) isAuthenticated = true; } catch { } }
    private async Task HandleKeyUp(KeyboardEventArgs e) { if (e.Key == "Enter") await AttemptLogin(); }

    private async Task LoadStats()
    {
        try {
            int? filterId = State.ImpersonatedStylistId;

            if (!filterId.HasValue)
            {
                stats.Shops = await Db.NETH_Shops.CountAsync();
                stats.Stylists = await Db.NETH_Stylists.CountAsync();
                var userRes = await Db.Database.SqlQueryRaw<int>(@"SELECT COUNT(*)::int as ""Value"" FROM ""NETH_Users""").ToListAsync();
                stats.Users = userRes.FirstOrDefault();
                stats.Clients = await Db.NETH_Clients.CountAsync();
                stats.Appointments = await Db.NETH_Appointments.CountAsync();
                var noteRes = await Db.Database.SqlQueryRaw<int>(@"SELECT COUNT(*)::int as ""Value"" FROM ""NETH_ClientNotes""").ToListAsync();
                stats.Notes = noteRes.FirstOrDefault();
                recentAppointments = await Db.NETH_Appointments.OrderByDescending(x => x.Id).Take(8).ToListAsync();
            }
            else
            {
                var nowTx = GetTexasTime();
                var startOfWeek = nowTx.Date.AddDays(-(int)nowTx.DayOfWeek);

                nextApp = await Db.NETH_Appointments
                    .Where(x => x.StylistId == filterId && x.StartTime > nowTx)
                    .OrderBy(x => x.StartTime)
                    .FirstOrDefaultAsync();
                
                if (nextApp != null) {
                    var client = await Db.NETH_Clients.FindAsync(nextApp.ClientId);
                    nextClientName = client != null ? $"{client.FirstName} {client.LastName}" : "Unknown Client";
                    
                    var noteCount = await Db.Database.SqlQueryRaw<int>(
                        @"SELECT COUNT(*)::int as ""Value"" FROM ""NETH_ClientNotes"" WHERE ""StylistId"" = {0} AND ""ClientId"" = {1}", 
                        filterId, nextApp.ClientId
                    ).ToListAsync();
                    hasNextAppNotes = noteCount.FirstOrDefault() > 0;
                }

                var weekApps = await Db.NETH_Appointments
                    .Where(x => x.StylistId == filterId && x.StartTime >= startOfWeek && x.StartTime < startOfWeek.AddDays(7))
                    .ToListAsync();

                var todayApps = weekApps.Where(x => x.StartTime.Date == nowTx.Date).ToList();
                var schedules = await Db.NETH_Schedules.Where(x => x.StylistId == filterId).ToListAsync();

                stats.TodayIncome = todayApps.Sum(x => x.TotalPrice);
                stats.WeekIncome = weekApps.Sum(x => x.TotalPrice);
                stats.TodayBusy = CalculateBusy(todayApps, schedules, (int)nowTx.DayOfWeek);
                stats.WeekBusy = CalculateWeeklyBusy(weekApps, schedules, startOfWeek);

                stats.Clients = weekApps.Select(x => x.ClientId).Distinct().Count();
                
                var noteResTotal = await Db.Database.SqlQueryRaw<int>(@"SELECT COUNT(*)::int as ""Value"" FROM ""NETH_ClientNotes"" WHERE ""StylistId"" = {0}", filterId).ToListAsync();
                stats.Notes = noteResTotal.FirstOrDefault();
                recentAppointments = weekApps.OrderByDescending(x => x.Id).Take(8).ToList();
            }
        } catch { }
    }

    private void GoToNextAppNotes()
    {
        if (nextApp != null && State.ImpersonatedStylistId.HasValue)
        {
            Nav.NavigateTo($"/admin/neth-client-notes?StylistId={State.ImpersonatedStylistId}&ClientId={nextApp.ClientId}");
        }
    }

    private DateTime GetTexasTime() => TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, TimeZoneInfo.FindSystemTimeZoneById("Central Standard Time"));

    private int CalculateBusy(List<NETH_Appointment> apps, List<NETH_Schedule> schedules, int dayOfWeek) {
        var shifts = schedules.Where(s => s.DayOfWeek == dayOfWeek).ToList();
        if (!shifts.Any()) return 0;
        double shiftMins = shifts.Sum(s => (s.EndTime - s.StartTime).TotalMinutes);
        double bookMins = apps.Sum(a => (a.EndTime - a.StartTime).TotalMinutes);
        return shiftMins == 0 ? 0 : (int)Math.Min(100, Math.Round((bookMins / shiftMins) * 100));
    }

    private int CalculateWeeklyBusy(List<NETH_Appointment> apps, List<NETH_Schedule> schedules, DateTime start) {
        double shiftTotal = 0; double bookTotal = 0;
        for (int i = 0; i < 7; i++) {
            var date = start.AddDays(i);
            var dayShifts = schedules.Where(s => s.DayOfWeek == (int)date.DayOfWeek).ToList();
            shiftTotal += dayShifts.Sum(s => (s.EndTime - s.StartTime).TotalMinutes);
            bookTotal += apps.Where(a => a.StartTime.Date == date.Date).Sum(a => (a.EndTime - a.StartTime).TotalMinutes);
        }
        return shiftTotal == 0 ? 0 : (int)Math.Min(100, Math.Round((bookTotal / shiftTotal) * 100));
    }

    private async Task AttemptLogin()
    {
        if (string.IsNullOrEmpty(loginUsername) || string.IsNullOrEmpty(loginPassword)) return;
        try {
            var user = await Db.Database.SqlQueryRaw<NETH_User_Lite>(
                @"SELECT ""Id"", ""Username"" FROM ""NETH_Users"" WHERE ""Username"" = {0} AND ""Password"" = {1} LIMIT 1", 
                loginUsername, loginPassword
            ).FirstOrDefaultAsync();

            if (user != null) {
                isAuthenticated = true;
                await JS.InvokeVoidAsync("localStorage.setItem", "neth_session", JsonSerializer.Serialize(new { user.Username }));
                await LoadStats();
                errorMessage = "";
            } else errorMessage = "DENIED: INVALID_IDENTITY";
        } catch { errorMessage = "ERR: SYSTEM_TIMEOUT"; }
    }

    private async Task ExitImpersonation() { State.Clear(); await LoadStats(); StateHasChanged(); }

    public class DashboardStats { 
        public int Users { get; set; } public int Shops { get; set; } public int Stylists { get; set; } 
        public int Clients { get; set; } public int Appointments { get; set; } public int Notes { get; set; }
        public decimal TodayIncome { get; set; } public decimal WeekIncome { get; set; }
        public int TodayBusy { get; set; } public int WeekBusy { get; set; }
    }
    public class NETH_User_Lite { public int Id { get; set; } public string Username { get; set; } = ""; }
}