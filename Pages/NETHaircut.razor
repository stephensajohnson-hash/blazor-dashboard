@page "/nethaircut"
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.EntityFrameworkCore
@using Dashboard
@inject Dashboard.AppDbContext Db
@inject NavigationManager NavManager
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))

<div class="app-container" style="--brand-color: @(currentShop?.BrandColor ?? "#D2B48C")">
    <header class="stylist-header">
        <div class="logo-circle">
            <i class="fas fa-cut"></i>
        </div>
        <h1>@FormattedName</h1>
        <p class="tagline">North East Texas Style & Booking</p>
    </header>

    <main class="booking-card">
        @* DIAGNOSTIC BOX: Shows record counts from the tables *@
        <div style="background: #000; color: #0f0; padding: 5px; font-family: monospace; font-size: 10px; margin-bottom: 10px; border: 1px solid #333;">
            KEY: @CurrentStylist | 
            SHOPS: @shopCount | 
            STYLISTS: @stylistCount | 
            SERVICES: @serviceCount
        </div>

        @if (isLoading)
        {
            <div class="spinner-box">
                <div class="spinner"></div>
                <p>Loading Registry...</p>
            </div>
        }
        else if (currentShop == null)
        {
            <div class="seed-box">
                <i class="fas fa-search mb-3" style="font-size: 2rem; color: #e67e22;"></i>
                <h3>No Shop Found</h3>
                <p class="mb-4 text-sm">
                    We couldn't find a registry for "<strong>@CurrentStylist</strong>".
                </p>
            </div>
        }
        else
        {
            <section class="welcome-text">
                <h2>Welcome to @currentShop.BusinessName</h2>
                <div class="status-badge">
                    <span class="status-dot"></span> Online & Booking
                </div>
            </section>

            <div class="stylist-grid">
                @foreach (Dashboard.NETH_Stylist stylist in currentShop.Stylists)
                {
                    <div class="stylist-card">
                        <div class="stylist-info">
                            <h3>@stylist.Name</h3>
                            <p class="bio">@stylist.Bio</p>
                            @if (stylist.Phone != null)
                            {
                                <p class="text-xs opacity-70">@stylist.Phone.Number (@stylist.Phone.Type)</p>
                            }
                        </div>
                        
                        <div class="services-list">
                            @foreach (Dashboard.NETH_Service service in stylist.Services)
                            {
                                <div class="service-row">
                                    <span class="service-name">@service.Name (@service.DurationMinutes min)</span>
                                    <span class="service-price">$@service.Price.ToString("N2")</span>
                                </div>
                            }
                        </div>
                        <button class="btn-book">Book with @stylist.Name</button>
                    </div>
                }
            </div>
        }
    </main>
</div>

@code {
    private string CurrentStylist { get; set; } = "GENERAL";
    private string FormattedName => CurrentStylist.Replace("%20", " ").ToUpper();
    private bool isLoading = true;
    
    private int shopCount = 0;
    private int stylistCount = 0;
    private int serviceCount = 0;
    
    private Dashboard.NETH_Shop? currentShop;

    protected override async Task OnInitializedAsync()
    {
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("stylist", out var name))
        {
            CurrentStylist = name.ToString();
        }

        try 
        {
            // Get raw counts for debugging empty tables
            shopCount = await Db.NETH_Shops.CountAsync();
            stylistCount = await Db.NETH_Stylists.CountAsync();
            serviceCount = await Db.NETH_Services.CountAsync();
        }
        catch (Exception ex) 
        { 
            Console.WriteLine($"Count Error: {ex.Message}"); 
        }

        await LoadShopData();
        isLoading = false;
    }

    private async Task LoadShopData()
    {
        try 
        {
            var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
            var query = QueryHelpers.ParseQuery(uri.Query);
            string searchKey = query.TryGetValue("stylist", out var name) 
                ? name.ToString().ToLower().Trim() 
                : "leatherandblades";

            currentShop = await Db.NETH_Shops
                .AsNoTracking()
                .Include(s => s.Phone)
                .Include(s => s.Stylists)
                    .ThenInclude(st => st.Services)
                .Include(s => s.Stylists)
                    .ThenInclude(st => st.Phone)
                .FirstOrDefaultAsync(s => s.UrlKey.ToLower() == searchKey);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Load Error: {ex.Message}");
            currentShop = null; 
        }
    }
}

<style>
    :root { 
        --dark-bg: #1a1b1e; 
        --card-bg: #25262b; 
        --text-main: #c1c2c5; 
    }
    .app-container { 
        background-color: var(--dark-bg); 
        color: var(--text-main); 
        min-height: 100vh; 
        display: flex; 
        flex-direction: column; 
        align-items: center; 
        padding: 2rem; 
        font-family: 'Inter', sans-serif; 
    }
    .stylist-header { text-align: center; margin-bottom: 2rem; }
    .logo-circle { 
        width: 60px; height: 60px; 
        background-color: var(--brand-color); 
        border-radius: 50%; 
        display: flex; align-items: center; justify-content: center; 
        margin: 0 auto 1rem; font-size: 1.5rem; color: #1a1b1e; 
    }
    .booking-card { 
        background-color: var(--card-bg); 
        border-radius: 12px; 
        padding: 2rem; 
        width: 100%; 
        max-width: 450px; 
        border: 1px solid #373a40; 
        box-shadow: 0 10px 25px rgba(0,0,0,0.3); 
    }
    .status-badge { 
        font-size: 0.75rem; 
        color: #40c057; 
        display: flex; align-items: center; gap: 5px; 
        margin-top: 5px; font-weight: bold; 
    }
    .status-dot { 
        height: 8px; width: 8px; 
        background: #40c057; border-radius: 50%; 
    }
    .stylist-card { 
        margin-top: 1.5rem; 
        background: rgba(0,0,0,0.2); 
        padding: 1rem; border-radius: 8px; 
    }
    .service-row { 
        display: flex; 
        justify-content: space-between; 
        padding: 8px 0; 
        border-bottom: 1px solid #373a40; 
        font-size: 0.9rem; 
    }
    .btn-book { 
        width: 100%; margin-top: 1rem; padding: 10px; 
        border-radius: 6px; background: var(--brand-color); 
        color: #1a1b1e; border: none; font-weight: bold; 
        cursor: pointer; 
    }
    .btn-seed { 
        background-color: #e67e22; color: white; padding: 12px; 
        border-radius: 6px; border: none; width: 100%; 
        font-weight: bold; cursor: pointer; margin-top: 1rem; 
    }
    .seed-box { text-align: center; color: #909296; }
    .spinner { 
        border: 4px solid rgba(255,255,255,0.1); 
        border-top: 4px solid var(--brand-color); 
        border-radius: 50%; width: 40px; height: 40px; 
        animation: spin 1s linear infinite; margin: 0 auto 1rem; 
    }
    @@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>