@page "/nethaircut"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using Dashboard.Components @* Ensure this matches your component folder namespace *@
@using System.Text.Json
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex font-sans">
    
    @if (isAuthenticated)
    {
        <NETHAdminSidebar />
    }

    <div class="flex-1 p-6">
        <div class="max-w-4xl mx-auto mb-8">
            <div class="bg-[#25262b] rounded-xl border border-gray-700 p-6 shadow-2xl flex justify-between items-center">
                <h1 class="text-2xl font-black text-[#D2B48C] uppercase tracking-widest">NETH Terminal</h1>
                @if (isAuthenticated)
                {
                    <span class="text-[10px] font-mono text-green-500 bg-green-500/10 px-3 py-1 rounded border border-green-500/20">SESSION_ACTIVE</span>
                }
            </div>
        </div>

        @if (isLoading)
        {
            <div class="text-center py-20 animate-pulse font-black text-gray-600 uppercase tracking-widest">Verifying_Credentials...</div>
        }
        else if (!isAuthenticated)
        {
            <div class="max-w-md mx-auto bg-[#25262b] rounded-xl border border-gray-700 p-8 shadow-2xl mt-10">
                <h2 class="text-center font-black uppercase tracking-widest text-gray-400 mb-6">Security Access</h2>
                <div class="space-y-4">
                    <input @bind="loginUsername" placeholder="Username" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-3 text-white focus:border-[#D2B48C] outline-none" />
                    <input type="password" @bind="loginPassword" placeholder="Password" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-3 text-white focus:border-[#D2B48C] outline-none" />
                    <button @onclick="AttemptLogin" class="w-full bg-[#D2B48C] text-[#1a1b1e] py-3 rounded font-black uppercase tracking-widest transition hover:bg-[#c4a47c]">Authenticate</button>
                    @if (!string.IsNullOrEmpty(errorMessage)) { <p class="text-red-400 text-[10px] text-center mt-4 uppercase font-mono">!! @errorMessage !!</p> }
                </div>
            </div>
        }
        else
        {
            <div class="max-w-2xl mx-auto mt-10">
                <div class="bg-white p-10 rounded-xl shadow-2xl text-gray-800 border border-gray-300">
                    <div class="text-center mb-8">
                        <div class="inline-block p-4 rounded-full bg-[#D2B48C]/10 mb-4">
                            <i class="fas fa-shield-check text-4xl text-[#D2B48C]"></i>
                        </div>
                        <h3 class="font-black text-2xl uppercase tracking-tighter">Administrative Access</h3>
                        <p class="text-gray-500 text-sm mt-2">Select a module from the sidebar or the quick links below to begin.</p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <button @onclick='() => Nav.NavigateTo("/admin/neth-users")' class="flex flex-col items-center p-4 border border-gray-100 rounded-lg hover:bg-gray-50 transition group">
                            <i class="fas fa-users text-gray-400 group-hover:text-[#D2B48C] mb-2"></i>
                            <span class="text-[10px] font-black uppercase">Users</span>
                        </button>
                        <button @onclick='() => Nav.NavigateTo("/admin/neth-shops")' class="flex flex-col items-center p-4 border border-gray-100 rounded-lg hover:bg-gray-50 transition group">
                            <i class="fas fa-shop text-gray-400 group-hover:text-[#D2B48C] mb-2"></i>
                            <span class="text-[10px] font-black uppercase">Shops</span>
                        </button>
                        <button @onclick='() => Nav.NavigateTo("/admin/neth-stylists")' class="flex flex-col items-center p-4 border border-gray-100 rounded-lg hover:bg-gray-50 transition group">
                            <i class="fas fa-user-tie text-gray-400 group-hover:text-[#D2B48C] mb-2"></i>
                            <span class="text-[10px] font-black uppercase">Stylists</span>
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private bool isAuthenticated = false;
    private bool isLoading = true;
    private string loginUsername = "";
    private string loginPassword = "";
    private string errorMessage = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CheckSession();
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task CheckSession()
    {
        try 
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "neth_session");
            if (!string.IsNullOrEmpty(json))
            {
                var session = JsonSerializer.Deserialize<SessionData>(json);
                if (session != null && !string.IsNullOrEmpty(session.Username))
                {
                    isAuthenticated = true;
                }
            }
        } catch { }
    }

    private async Task AttemptLogin()
    {
        try {
            var user = await Db.Database.SqlQueryRaw<NETH_User_Lite>(
                @"SELECT ""Id"", ""Username"" FROM ""NETH_Users"" WHERE ""Username"" = {0} AND ""Password"" = {1} LIMIT 1", 
                loginUsername, loginPassword
            ).FirstOrDefaultAsync();

            if (user != null) 
            {
                isAuthenticated = true;
                var session = new SessionData { Username = user.Username, Role = "Admin" };
                await JS.InvokeVoidAsync("localStorage.setItem", "neth_session", JsonSerializer.Serialize(session));
            }
            else errorMessage = "INVALID_CREDENTIALS";
        } catch { errorMessage = "SYSTEM_UNAVAILABLE"; }
    }

    public class SessionData { public string Username { get; set; } = ""; public string Role { get; set; } = ""; }
    public class NETH_User_Lite { public int Id { get; set; } public string Username { get; set; } = ""; }
}