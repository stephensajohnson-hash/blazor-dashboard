@page "/nethaircut"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.EntityFrameworkCore
@using Dashboard
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#1a1b1e] text-gray-300 p-6 font-sans">
    <div class="max-w-4xl mx-auto mb-8">
        <div class="bg-[#25262b] rounded-xl border border-gray-700 p-6 shadow-2xl flex justify-between items-center">
            <h1 class="text-2xl font-black text-[#D2B48C] uppercase tracking-widest">NETH Terminal</h1>
            @if (isAuthenticated)
            {
                <button @onclick="Logout" class="text-[10px] font-black text-red-400 border border-red-400/30 px-3 py-1 rounded hover:bg-red-400 hover:text-white transition">Logout</button>
            }
        </div>
    </div>

    @if (!isAuthenticated)
    {
        <div class="max-w-md mx-auto bg-[#25262b] rounded-xl border border-gray-700 p-8 shadow-2xl">
            <h2 class="text-center font-black uppercase tracking-widest text-gray-400 mb-6">Security Access</h2>
            <div class="space-y-4">
                <input @bind="loginUsername" placeholder="Username" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-3 text-white focus:border-[#D2B48C] outline-none" />
                <input type="password" @bind="loginPassword" placeholder="Password" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-3 text-white focus:border-[#D2B48C] outline-none" />
                <button @onclick="AttemptLogin" class="w-full bg-[#D2B48C] text-[#1a1b1e] py-3 rounded font-black uppercase tracking-widest transition">Authenticate</button>
                @if (!string.IsNullOrEmpty(errorMessage)) { <p class="text-red-400 text-[10px] text-center mt-4">@errorMessage</p> }
            </div>
        </div>
    }
    else
    {
        <div class="max-w-md mx-auto space-y-4">
            <div class="bg-white p-8 rounded-xl shadow-2xl text-gray-800 text-center">
                <h3 class="font-black text-xl uppercase mb-6 tracking-tighter">System Access Verified</h3>
                <div class="grid gap-3">
                    <button @onclick='() => Nav.NavigateTo("/admin/neth-users")' class="w-full bg-[#1a1b1e] text-white py-4 rounded font-black uppercase tracking-widest text-xs shadow-lg hover:bg-black transition">Manage Users</button>
                    <button class="w-full bg-gray-100 text-gray-400 py-4 rounded font-black uppercase tracking-widest text-xs border border-gray-200 cursor-not-allowed">Manage Shop (Coming Soon)</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isAuthenticated = false;
    private string loginUsername = "";
    private string loginPassword = "";
    private string errorMessage = "";

    private async Task AttemptLogin()
    {
        try {
            var user = await Db.Database.SqlQueryRaw<int>(
                @"SELECT ""Id"" as ""Value"" FROM ""NETH_Users"" WHERE ""Username"" = {0} AND ""Password"" = {1} LIMIT 1", 
                loginUsername, loginPassword
            ).FirstOrDefaultAsync();

            if (user > 0) isAuthenticated = true;
            else errorMessage = "LOGIN_DENIED";
        } catch { errorMessage = "DATABASE_OFFLINE"; }
    }

    private void Logout() => isAuthenticated = false;
}