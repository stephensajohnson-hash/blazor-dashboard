@page "/nethaircut"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using Dashboard.Components
@using System.Text.Json
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex font-sans">
    
    @if (isAuthenticated)
    {
        <NETHAdminSidebar />
    }

    <div class="flex-1 p-8">
        <div class="max-w-5xl mx-auto">
            <div class="bg-[#25262b] rounded-xl border border-gray-700 p-6 shadow-2xl flex justify-between items-center mb-8">
                <div>
                    <h1 class="text-2xl font-black text-[#D2B48C] uppercase tracking-widest">NETH Terminal</h1>
                    <p class="text-[10px] font-mono text-gray-500 mt-1 uppercase">Central Command Console</p>
                </div>
                @if (isAuthenticated)
                {
                    <div class="flex items-center gap-3">
                        <span class="text-[9px] font-black text-gray-500 bg-black/30 px-3 py-1 rounded border border-gray-700 uppercase tracking-widest">System_Online</span>
                        <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                    </div>
                }
            </div>

            @if (isLoading)
            {
                <div class="flex flex-col items-center justify-center py-20">
                    <div class="w-12 h-12 border-4 border-[#D2B48C] border-t-transparent rounded-full animate-spin"></div>
                    <div class="mt-4 font-black text-gray-600 uppercase tracking-widest text-xs">Accessing_Encrypted_Ledger...</div>
                </div>
            }
            else if (!isAuthenticated)
            {
                <div class="max-w-md mx-auto bg-[#25262b] rounded-xl border border-gray-700 p-8 shadow-2xl mt-10">
                    <h2 class="text-center font-black uppercase tracking-widest text-gray-400 mb-6">Security Access</h2>
                    <div class="space-y-4">
                        <input @bind="loginUsername" placeholder="Username" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-3 text-white focus:border-[#D2B48C] outline-none" />
                        <input type="password" @bind="loginPassword" placeholder="Password" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-3 text-white focus:border-[#D2B48C] outline-none" />
                        <button @onclick="AttemptLogin" class="w-full bg-[#D2B48C] text-[#1a1b1e] py-3 rounded font-black uppercase tracking-widest transition hover:bg-[#c4a47c]">Authenticate</button>
                        @if (!string.IsNullOrEmpty(errorMessage)) { <p class="text-red-400 text-[10px] text-center mt-4 uppercase font-mono">!! @errorMessage !!</p> }
                    </div>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    @* STAT CARDS *@
                    <div class="bg-[#25262b] p-6 rounded-xl border border-gray-700 shadow-xl relative overflow-hidden group">
                        <div class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2">Users</div>
                        <div class="text-4xl font-black text-white">@stats.Users</div>
                        <i class="fas fa-users absolute -right-2 -bottom-2 text-4xl text-white/5 transform -rotate-12 group-hover:scale-110 transition"></i>
                    </div>

                    <div class="bg-[#25262b] p-6 rounded-xl border border-gray-700 shadow-xl relative overflow-hidden group">
                        <div class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2">Shops</div>
                        <div class="text-4xl font-black text-[#D2B48C]">@stats.Shops</div>
                        <i class="fas fa-shop absolute -right-2 -bottom-2 text-4xl text-[#D2B48C]/5 transform -rotate-12 group-hover:scale-110 transition"></i>
                    </div>

                    <div class="bg-[#25262b] p-6 rounded-xl border border-gray-700 shadow-xl relative overflow-hidden group">
                        <div class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2">Stylists</div>
                        <div class="text-4xl font-black text-white">@stats.Stylists</div>
                        <i class="fas fa-user-tie absolute -right-2 -bottom-2 text-4xl text-white/5 transform -rotate-12 group-hover:scale-110 transition"></i>
                    </div>

                    <div class="bg-[#25262b] p-6 rounded-xl border border-gray-700 shadow-xl relative overflow-hidden group">
                        <div class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2">Total Apps</div>
                        <div class="text-4xl font-black text-gray-600">@stats.Appointments</div>
                        <i class="fas fa-calendar absolute -right-2 -bottom-2 text-4xl text-white/5 transform -rotate-12 group-hover:scale-110 transition"></i>
                    </div>
                </div>

                <div class="mt-10 p-12 bg-[#25262b]/30 border-2 border-dashed border-gray-800 rounded-3xl text-center">
                    <div class="text-[#D2B48C] text-3xl mb-4"><i class="fas fa-fingerprint"></i></div>
                    <h3 class="text-white font-black uppercase tracking-tighter text-xl">Operational Dashboard</h3>
                    <p class="text-gray-500 text-sm max-w-md mx-auto mt-2 leading-relaxed">
                        Session validated. Use the sidebar to navigate between administrative modules.
                    </p>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool isAuthenticated = false;
    private bool isLoading = true;
    private string loginUsername = "";
    private string loginPassword = "";
    private string errorMessage = "";
    private DashboardStats stats = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CheckSession();
            if (isAuthenticated) await LoadStats();
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task CheckSession()
    {
        try {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "neth_session");
            if (!string.IsNullOrEmpty(json)) isAuthenticated = true;
        } catch { }
    }

private async Task LoadStats()
    {
        try {
            stats.Users = await Db.Database.SqlQueryRaw<int>(@"SELECT COUNT(*)::int as ""Value"" FROM ""NETH_Users""").FirstOrDefaultAsync();
            stats.Shops = await Db.NETH_Shops.CountAsync();
            stats.Stylists = await Db.NETH_Stylists.CountAsync();
            // Ensure this is using the correct table
            stats.Appointments = await Db.NETH_Clients.CountAsync(); // Or keep as Appointments if you prefer
        } catch { }
    }
    private async Task AttemptLogin()
    {
        try {
            var user = await Db.Database.SqlQueryRaw<NETH_User_Lite>(
                @"SELECT ""Id"", ""Username"" FROM ""NETH_Users"" WHERE ""Username"" = {0} AND ""Password"" = {1} LIMIT 1", 
                loginUsername, loginPassword
            ).FirstOrDefaultAsync();

            if (user != null) {
                isAuthenticated = true;
                await JS.InvokeVoidAsync("localStorage.setItem", "neth_session", JsonSerializer.Serialize(new { user.Username }));
                await LoadStats();
            } else errorMessage = "DENIED: INVALID_IDENTITY";
        } catch { errorMessage = "ERR: SYSTEM_TIMEOUT"; }
    }

    public class DashboardStats { public int Users { get; set; } public int Shops { get; set; } public int Stylists { get; set; } public int Appointments { get; set; } }
    public class NETH_User_Lite { public int Id { get; set; } public string Username { get; set; } = ""; }
}