@page "/nethaircut"
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.EntityFrameworkCore
@using Dashboard
@inject Dashboard.AppDbContext Db
@inject NavigationManager NavManager
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<div class="app-container" style="--brand-color: @(currentShop?.BrandColor ?? "#D2B48C")">
    <header class="stylist-header">
        <div class="logo-circle"><i class="fas fa-cut"></i></div>
        <h1>@FormattedName</h1>
        <p class="tagline">North East Texas Style & Booking</p>
    </header>

    <main class="booking-card">
        @if (isLoading) {
            <div class="spinner"></div>
            <p>Accessing Registry...</p>
        }
        else if (currentShop == null) {
            <div class="seed-box">
                <i class="fas fa-database mb-3" style="font-size: 2rem; color: #e67e22;"></i>
                <h3>No Registry Found</h3>
                <p class="mb-4 text-sm">We couldn't find a shop for "<strong>@CurrentStylist</strong>". Build the database and seed test data?</p>
                <button class="btn-seed" @onclick="SeedInitialData">🔧 Build NETH Database & Seed</button>
            </div>
        }
        else {
            <section class="welcome-text">
                <h2>@currentShop.BusinessName</h2>
                <div class="status-badge"><span class="status-dot"></span> Online & Booking</div>
            </section>

            <div class="stylist-grid">
                @foreach (Dashboard.NETH_Stylist stylist in currentShop.Stylists) {
                    <div class="stylist-card">
                        <div class="stylist-info">
                            <h3>@stylist.Name</h3>
                            <p class="bio">@stylist.Bio</p>
                        </div>
                        
                        <div class="services-list">
                            @foreach (Dashboard.NETH_Service service in stylist.Services) {
                                <div class="service-row">
                                    <span class="service-name">@service.Name</span>
                                    <span class="service-price">$@service.Price.ToString("N2")</span>
                                </div>
                            }
                        </div>
                        <button class="btn-book">Book with @stylist.Name</button>
                    </div>
                }
            </div>
        }
    </main>
</div>

@code {
    private string CurrentStylist { get; set; } = "GENERAL";
    private string FormattedName => CurrentStylist.Replace("%20", " ").ToUpper();
    private bool isLoading = true;
    private Dashboard.NETH_Shop? currentShop; // Using Full Type Reference

    protected override async Task OnInitializedAsync() {
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("stylist", out var name)) {
            CurrentStylist = name.ToString();
        }
        await LoadShopData();
    }

    private async Task LoadShopData() {
        isLoading = true;
        try {
            currentShop = await Db.NETH_Shops
                .AsNoTracking()
                .Include(s => s.Stylists).ThenInclude(st => st.Services)
                .Include(s => s.Phone)
                .FirstOrDefaultAsync(s => s.UrlKey.ToLower() == CurrentStylist.ToLower());
        } catch { currentShop = null; }
        finally { isLoading = false; StateHasChanged(); }
    }

    private async Task SeedInitialData() {
        isLoading = true;
        try {
            var shopPhone = new Dashboard.NETH_Phone { Number = "903-555-1111", Type = "Work" };
            var brandonPhone = new Dashboard.NETH_Phone { Number = "903-555-2222", Type = "Mobile" };
            Db.NETH_Phones.AddRange(shopPhone, brandonPhone);
            await Db.SaveChangesAsync();

            var shop = new Dashboard.NETH_Shop { UrlKey = "leatherandblades", BusinessName = "Leather & Blades", PhoneId = shopPhone.Id };
            Db.NETH_Shops.Add(shop);
            await Db.SaveChangesAsync();

            var brandon = new Dashboard.NETH_Stylist { ShopId = shop.Id, Name = "Brandon", Bio = "Master Barber", PhoneId = brandonPhone.Id };
            Db.NETH_Stylists.Add(brandon);
            await Db.SaveChangesAsync();

            Db.NETH_Services.AddRange(
                new Dashboard.NETH_Service { StylistId = brandon.Id, Name = "Standard Fade", Price = 30m, DurationMinutes = 30 },
                new Dashboard.NETH_Service { StylistId = brandon.Id, Name = "The Works", Price = 55m, DurationMinutes = 60 }
            );
            await Db.SaveChangesAsync();
            await LoadShopData();
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
        finally { isLoading = false; StateHasChanged(); }
    }
}

<style>
    :root { --dark-bg: #1a1b1e; --card-bg: #25262b; --text-main: #c1c2c5; }
    .app-container { background-color: var(--dark-bg); color: var(--text-main); min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 2rem; font-family: sans-serif; }
    .stylist-header { text-align: center; margin-bottom: 2rem; }
    .logo-circle { width: 50px; height: 50px; background-color: var(--brand-color); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: #1a1b1e; }
    .booking-card { background-color: var(--card-bg); border-radius: 12px; padding: 2rem; width: 100%; max-width: 400px; border: 1px solid #373a40; }
    .service-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #373a40; font-size: 0.9rem; }
    .btn-book { width: 100%; margin-top: 1rem; padding: 10px; border-radius: 6px; background: var(--brand-color); color: #1a1b1e; border: none; font-weight: bold; cursor: pointer; }
    .btn-seed { background-color: #e67e22; color: white; padding: 12px; border-radius: 6px; border: none; width: 100%; font-weight: bold; cursor: pointer; margin-top: 1rem; }
    .spinner { border: 4px solid rgba(255,255,255,0.1); border-top: 4px solid var(--brand-color); border-radius: 50%; width: 30px; height: 30px; animation: spin 1s linear infinite; margin: 0 auto 1rem; }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>