@page "/nethaircut"
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.EntityFrameworkCore
@using Dashboard
@inject Dashboard.AppDbContext Db
@inject NavigationManager NavManager
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))

<div class="app-container" style="--brand-color: @(currentShop?.BrandColor ?? "#D2B48C")">
    <header class="stylist-header">
        <div class="logo-circle">
            <i class="fas fa-cut"></i>
        </div>
        <h1>@FormattedName</h1>
        <p class="tagline">North East Texas Style & Booking</p>
    </header>

    <main class="booking-card">
        @if (isLoading)
        {
            <div class="spinner-box">
                <div class="spinner"></div>
                <p>Processing Database...</p>
            </div>
        }
        else if (currentShop == null)
        {
            <div class="seed-box">
                <i class="fas fa-database mb-3" style="font-size: 2rem; color: #e67e22;"></i>
                <h3>No Registry Found</h3>
                <p class="mb-4 text-sm">We couldn't find a shop for "<strong>@CurrentStylist</strong>". Click below to build the database tables and seed initial data.</p>
                @if (!string.IsNullOrEmpty(dbError))
                {
                    <p style="color: #ff4444; font-size: 0.8rem; margin-bottom: 1rem;">@dbError</p>
                }
                <button class="btn-seed" @onclick="SeedInitialData">
                    🔧 Build Tables & Seed Data
                </button>
            </div>
        }
        else
        {
            <section class="welcome-text">
                <h2>Welcome to @currentShop.BusinessName</h2>
                <div class="status-badge">
                    <span class="status-dot"></span> Online & Booking
                </div>
            </section>

            <div class="stylist-grid">
                @foreach (Dashboard.NETH_Stylist stylist in currentShop.Stylists)
                {
                    <div class="stylist-card">
                        <div class="stylist-info">
                            <h3>@stylist.Name</h3>
                            <p class="bio">@stylist.Bio</p>
                        </div>
                        
                        <div class="services-list">
                            @foreach (Dashboard.NETH_Service service in stylist.Services)
                            {
                                <div class="service-row">
                                    <span class="service-name">@service.Name</span>
                                    <span class="service-price">$@service.Price.ToString("N2")</span>
                                </div>
                            }
                        </div>
                        <button class="btn-book">Book with @stylist.Name</button>
                    </div>
                }
            </div>
        }
    </main>
</div>

@code {
    private string CurrentStylist { get; set; } = "GENERAL";
    private string FormattedName => CurrentStylist.Replace("%20", " ").ToUpper();
    private bool isLoading = true;
    private string dbError = ""; 
    private Dashboard.NETH_Shop? currentShop;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            // SURGICAL FIX: Drop and Recreate to fix the "Missing Column" error
            await Db.Database.ExecuteSqlRawAsync(@"
                DROP TABLE IF EXISTS ""NETH_Services"";
                DROP TABLE IF EXISTS ""NETH_Stylists"";
                DROP TABLE IF EXISTS ""NETH_Shops"";
                DROP TABLE IF EXISTS ""NETH_Phones"";

                CREATE TABLE ""NETH_Phones"" (
                    ""Id"" SERIAL PRIMARY KEY,
                    ""Number"" TEXT NOT NULL,
                    ""Type"" TEXT NOT NULL,
                    ""IsBadNumber"" BOOLEAN NOT NULL DEFAULT FALSE
                );
                CREATE TABLE ""NETH_Shops"" (
                    ""Id"" SERIAL PRIMARY KEY,
                    ""UrlKey"" TEXT NOT NULL,
                    ""BusinessName"" TEXT NOT NULL,
                    ""BrandColor"" TEXT NOT NULL,
                    ""LogoMediaId"" INTEGER NULL,
                    ""LogoId"" INTEGER NULL,
                    ""StripeAccountId"" TEXT NOT NULL DEFAULT '',
                    ""PhoneId"" INTEGER NOT NULL REFERENCES ""NETH_Phones""(""Id"")
                );
                CREATE TABLE ""NETH_Stylists"" (
                    ""Id"" SERIAL PRIMARY KEY,
                    ""ShopId"" INTEGER NOT NULL REFERENCES ""NETH_Shops""(""Id""),
                    ""Name"" TEXT NOT NULL,
                    ""Bio"" TEXT NOT NULL,
                    ""IsIndependent"" BOOLEAN NOT NULL,
                    ""StripeAccountId"" TEXT NOT NULL DEFAULT '',
                    ""PhoneId"" INTEGER NOT NULL REFERENCES ""NETH_Phones""(""Id"")
                );
                CREATE TABLE ""NETH_Services"" (
                    ""Id"" SERIAL PRIMARY KEY,
                    ""StylistId"" INTEGER NOT NULL REFERENCES ""NETH_Stylists""(""Id""),
                    ""NETH_StylistId"" INTEGER NULL REFERENCES ""NETH_Stylists""(""Id""),
                    ""Name"" TEXT NOT NULL,
                    ""Price"" DECIMAL NOT NULL,
                    ""DurationMinutes"" INTEGER NOT NULL
                );
            ");
        }
        catch (Exception ex) 
        {
            Console.WriteLine($"Critical Schema Error: {ex.Message}");
        }

        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("stylist", out var name))
        {
            CurrentStylist = name.ToString();
        }

        await LoadShopData();
        isLoading = false;
    }

    private async Task LoadShopData()
    {
        try 
        {
            currentShop = await Db.NETH_Shops
                .AsNoTracking()
                .Include(s => s.Stylists)
                    .ThenInclude(st => st.Services)
                .Include(s => s.Phone)
                .FirstOrDefaultAsync(s => s.UrlKey.ToLower() == CurrentStylist.ToLower());
        }
        catch (Exception ex)
        {
            dbError = $"DB Load Error: {ex.Message}";
            Console.WriteLine(dbError);
            currentShop = null; 
        }
    }

    private async Task SeedInitialData()
    {
        isLoading = true;
        dbError = "";
        StateHasChanged();

        try 
        {
            var shopPhone = new Dashboard.NETH_Phone { Number = "9035551111", Type = "Work" };
            var brandonPhone = new Dashboard.NETH_Phone { Number = "9035552222", Type = "Mobile" };
            Db.NETH_Phones.AddRange(shopPhone, brandonPhone);
            await Db.SaveChangesAsync();

            var shop = new Dashboard.NETH_Shop
            {
                UrlKey = "leatherandblades",
                BusinessName = "Leather & Blades",
                BrandColor = "#D2B48C",
                PhoneId = shopPhone.Id,
                StripeAccountId = ""
            };
            Db.NETH_Shops.Add(shop);
            await Db.SaveChangesAsync();

            var brandon = new Dashboard.NETH_Stylist
            {
                ShopId = shop.Id,
                Name = "Brandon",
                Bio = "Master Barber specializing in straight-razor fades.",
                IsIndependent = true,
                PhoneId = brandonPhone.Id,
                StripeAccountId = ""
            };
            Db.NETH_Stylists.Add(brandon);
            await Db.SaveChangesAsync();

            Db.NETH_Services.AddRange(
                new Dashboard.NETH_Service { StylistId = brandon.Id, Name = "Standard Fade", Price = 30.00m, DurationMinutes = 30 },
                new Dashboard.NETH_Service { StylistId = brandon.Id, Name = "The Works", Price = 55.00m, DurationMinutes = 60 }
            );

            await Db.SaveChangesAsync();
            await LoadShopData();
        }
        catch (Exception ex)
        {
            dbError = $"Seed Error: {ex.Message}";
            Console.WriteLine(dbError);
        }
        finally 
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}

<style>
    :root {
        --dark-bg: #1a1b1e;
        --card-bg: #25262b;
        --text-main: #c1c2c5;
    }

    .app-container {
        background-color: var(--dark-bg);
        color: var(--text-main);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem;
        font-family: 'Inter', sans-serif;
    }

    .stylist-header { text-align: center; margin-bottom: 2rem; }
    .logo-circle {
        width: 60px; height: 60px;
        background-color: var(--brand-color);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1rem; font-size: 1.5rem; color: #1a1b1e;
    }

    .booking-card {
        background-color: var(--card-bg);
        border-radius: 12px;
        padding: 2rem;
        width: 100%;
        max-width: 450px;
        border: 1px solid #373a40;
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    }

    .status-badge {
        font-size: 0.75rem; color: #40c057; 
        display: flex; align-items: center; gap: 5px;
        margin-top: 5px; font-weight: bold;
    }
    .status-dot { height: 8px; width: 8px; background: #40c057; border-radius: 50%; }

    .stylist-card {
        margin-top: 1.5rem;
        background: rgba(0,0,0,0.2);
        padding: 1rem;
        border-radius: 8px;
    }

    .service-row {
        display: flex; justify-content: space-between;
        padding: 8px 0; border-bottom: 1px solid #373a40;
        font-size: 0.9rem;
    }

    .btn-book {
        width: 100%; margin-top: 1rem;
        padding: 10px; border-radius: 6px;
        background: var(--brand-color); color: #1a1b1e;
        border: none; font-weight: bold; cursor: pointer;
    }

    .btn-seed {
        background-color: #e67e22; color: white;
        padding: 12px; border-radius: 6px; border: none;
        width: 100%; font-weight: bold; cursor: pointer;
        margin-top: 1rem;
    }

    .seed-box { text-align: center; color: #909296; }

    .spinner {
        border: 4px solid rgba(255,255,255,0.1);
        border-top: 4px solid var(--brand-color);
        border-radius: 50%; width: 40px; height: 40px;
        animation: spin 1s linear infinite;
        margin: 0 auto 1rem;
    }

    @@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>