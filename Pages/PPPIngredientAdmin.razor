@page "/ppp-ingredient-admin"
@using Dashboard
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject IJSRuntime JS

<div class="min-h-screen bg-[#0a0a0a] text-white p-6 font-black relative overflow-hidden">
    
    @* TOAST NOTIFICATION STACK *@
    <div class="fixed top-24 right-6 z-[100] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-2xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950/90 border-red-500 text-red-200" : "bg-emerald-950/90 border-emerald-500 text-emerald-200")">
                <div class="flex items-center gap-3">
                    <span>@(toast.IsError ? "❌" : "✅")</span>
                    <span class="text-xs uppercase tracking-widest">@toast.Message</span>
                </div>
            </div>
        }
    </div>

    @* Header *@
    <div class="flex justify-between items-center mb-10 bg-[#111] p-4 rounded-2xl border border-gray-800 shadow-xl">
        <div class="flex items-center gap-4">
            <span class="text-3xl">🥦</span>
            <div>
                <h1 class="text-xl uppercase tracking-tighter">Ingredient Master</h1>
                <p class="text-[9px] text-gray-500 uppercase tracking-[0.2em]">Global & Owner-Specific Macros</p>
            </div>
        </div>
        <div class="flex gap-4">
            <button @onclick="() => OpenModal()" class="bg-orange-600 hover:bg-orange-500 text-white px-6 py-2 rounded-xl text-[10px] uppercase tracking-widest transition shadow-lg">
                ＋ Add Ingredient
            </button>
            <a href="/ppp-dashboard" class="bg-gray-800 hover:bg-gray-700 text-white px-4 py-2 rounded-xl text-[10px] uppercase tracking-widest transition border border-gray-700">
                Back to PPP
            </a>
        </div>
    </div>

    @* Ingredient Table *@
    <div class="bg-[#111] border border-gray-800 rounded-3xl overflow-hidden shadow-2xl">
        <table class="w-full text-left">
            <thead>
                <tr class="text-[10px] font-black uppercase text-gray-500 bg-gray-900/50 border-b border-gray-800">
                    <th class="p-5">Ingredient</th>
                    <th class="p-5 text-center">Calories</th>
                    <th class="p-5 text-center">Protein</th>
                    <th class="p-5 text-center">Fat</th>
                    <th class="p-5 text-center">Net Carbs</th>
                    <th class="p-5">Ownership</th>
                    <th class="p-5 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800/50">
                @foreach (var ing in ingredients)
                {
                    <tr class="hover:bg-white/5 transition group">
                        <td class="p-5">
                            <div class="text-sm font-black uppercase tracking-tight">@ing.Name</div>
                            <div class="text-[9px] text-gray-500 font-mono">Per @(ing.Unit ?? "unit")</div>
                        </td>
                        <td class="p-5 text-center font-mono text-xs text-orange-400">@ing.Calories</td>
                        <td class="p-5 text-center font-mono text-xs text-blue-400">@ing.Protein g</td>
                        <td class="p-5 text-center font-mono text-xs text-yellow-500">@ing.Fat g</td>
                        <td class="p-5 text-center font-mono text-xs text-emerald-400">@ing.NetCarbs g</td>
                        <td class="p-5">
                            @if (ing.OwnerId == null)
                            {
                                <span class="px-2 py-0.5 rounded text-[8px] bg-purple-900/30 text-purple-400 border border-purple-800 uppercase">Universal</span>
                            }
                            else
                            {
                                <span class="px-2 py-0.5 rounded text-[8px] bg-gray-800 text-gray-400 border border-gray-700 uppercase">Owner: @ing.Owner?.BusinessName</span>
                            }
                        </td>
                        <td class="p-5 text-right">
                            <div class="flex justify-end gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                                <button @onclick="() => OpenModal(ing)" class="p-2 text-blue-400 hover:bg-blue-500/10 rounded-lg transition">✎</button>
                                <button @onclick="() => ConfirmDelete(ing)" class="p-2 text-red-500 hover:bg-red-500/10 rounded-lg transition">✕</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* MODAL *@
@if (showModal)
{
    <div class="fixed inset-0 bg-black/90 backdrop-blur-sm z-[200] flex items-center justify-center p-4">
        <div class="bg-[#111] w-full max-w-xl rounded-3xl border border-gray-800 shadow-2xl overflow-hidden animate-in zoom-in duration-200">
            <div class="p-6 bg-gray-900/50 border-b border-gray-800 flex justify-between items-center">
                <h3 class="text-lg uppercase tracking-widest font-black text-orange-400">
                    @(editingIng.Id == 0 ? "Create Ingredient" : "Update Ingredient")
                </h3>
                <button @onclick="CloseModal" class="text-gray-500 text-2xl hover:text-white">&times;</button>
            </div>
            
            <div class="p-8 grid grid-cols-2 gap-4">
                <div class="col-span-2">
                    <label class="text-[9px] uppercase text-gray-500 mb-2 block">Ingredient Name</label>
                    <input @bind="editingIng.Name" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-orange-500 outline-none uppercase font-black" />
                </div>
                <div>
                    <label class="text-[9px] uppercase text-gray-500 mb-2 block">Base Unit (e.g. 100g, 1oz)</label>
                    <input @bind="editingIng.Unit" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-orange-500 outline-none" />
                </div>
                <div>
                    <label class="text-[9px] uppercase text-gray-500 mb-2 block">Ownership Scope</label>
                    <select @bind="selectedOwnerId" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm text-white">
                        <option value="0">UNIVERSAL (ADMIN)</option>
                        @foreach(var owner in owners) {
                            <option value="@owner.Id">@owner.BusinessName</option>
                        }
                    </select>
                </div>

                <div class="col-span-2 grid grid-cols-5 gap-2 mt-4 bg-black/40 p-4 rounded-2xl border border-gray-800">
                    <div>
                        <label class="text-[8px] uppercase text-gray-500 mb-1 block">Cals</label>
                        <input type="number" @bind="editingIng.Calories" class="w-full bg-black border border-gray-800 p-2 text-xs font-mono text-orange-400" />
                    </div>
                    <div>
                        <label class="text-[8px] uppercase text-gray-500 mb-1 block">Prot</label>
                        <input type="number" @bind="editingIng.Protein" class="w-full bg-black border border-gray-800 p-2 text-xs font-mono text-blue-400" />
                    </div>
                    <div>
                        <label class="text-[8px] uppercase text-gray-500 mb-1 block">Fat</label>
                        <input type="number" @bind="editingIng.Fat" class="w-full bg-black border border-gray-800 p-2 text-xs font-mono text-yellow-500" />
                    </div>
                    <div>
                        <label class="text-[8px] uppercase text-gray-500 mb-1 block">Carb</label>
                        <input type="number" @bind="editingIng.Carbs" class="w-full bg-black border border-gray-800 p-2 text-xs font-mono text-red-400" />
                    </div>
                    <div>
                        <label class="text-[8px] uppercase text-gray-500 mb-1 block">Fiber</label>
                        <input type="number" @bind="editingIng.Fiber" class="w-full bg-black border border-gray-800 p-2 text-xs font-mono text-emerald-400" />
                    </div>
                </div>
            </div>

            <div class="p-6 bg-gray-900/50 border-t border-gray-800 flex justify-end gap-4">
                <button @onclick="CloseModal" class="text-[10px] text-gray-500 uppercase tracking-widest font-black px-6">Cancel</button>
                <button @onclick="SaveIngredient" class="bg-orange-600 hover:bg-orange-500 text-white text-[10px] uppercase tracking-widest font-black px-8 py-3 rounded-xl shadow-lg transition">
                    Commit Changes
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<PPP_Ingredient> ingredients = new();
    private List<PPP_Owner> owners = new();
    private bool showModal = false;
    private PPP_Ingredient editingIng = new();
    private int selectedOwnerId = 0;
    private List<ToastItem> toasts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        ingredients = await Db.PPP_Ingredients
            .Include(i => i.Owner)
            .OrderBy(i => i.Name)
            .ToListAsync();
        owners = await Db.PPP_Owners.OrderBy(o => o.BusinessName).ToListAsync();
    }

    private void OpenModal(PPP_Ingredient? ing = null)
    {
        if (ing == null) {
            editingIng = new PPP_Ingredient();
            selectedOwnerId = 0;
        } else {
            editingIng = new PPP_Ingredient {
                Id = ing.Id,
                Name = ing.Name,
                Unit = ing.Unit,
                Calories = ing.Calories,
                Protein = ing.Protein,
                Fat = ing.Fat,
                Carbs = ing.Carbs,
                Fiber = ing.Fiber,
                OwnerId = ing.OwnerId
            };
            selectedOwnerId = ing.OwnerId ?? 0;
        }
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private async Task SaveIngredient()
    {
        if (string.IsNullOrWhiteSpace(editingIng.Name)) 
        {
            _ = ShowToast("Name is required", true);
            return;
        }

        try 
        {
            Db.ChangeTracker.Clear();
            editingIng.OwnerId = selectedOwnerId == 0 ? null : selectedOwnerId;

            if (editingIng.Id == 0) {
                Db.PPP_Ingredients.Add(editingIng);
            } else {
                Db.Entry(editingIng).State = EntityState.Modified;
            }

            await Db.SaveChangesAsync();
            await LoadData();
            _ = ShowToast("Ingredient Saved");
            CloseModal();
        }
        catch (Exception ex)
        {
            _ = ShowToast("Save Error: " + ex.Message, true);
        }
    }

    private async Task ConfirmDelete(PPP_Ingredient ing)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Delete {ing.Name}?")) {
            try {
                Db.PPP_Ingredients.Remove(ing);
                await Db.SaveChangesAsync();
                await LoadData();
                _ = ShowToast("Ingredient Deleted");
            } catch (Exception ex) {
                _ = ShowToast("Delete Error: " + ex.Message, true);
            }
        }
    }

    private async Task ShowToast(string msg, bool isError = false)
    {
        var t = new ToastItem { Message = msg, IsError = isError };
        toasts.Add(t); StateHasChanged();
        await Task.Delay(3000);
        toasts.Remove(t); StateHasChanged();
    }

    private class ToastItem { public string Message { get; set; } = ""; public bool IsError { get; set; } }
}