@page "/ppp-ingredient-admin"
@using Dashboard
@using Dashboard.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject IJSRuntime JS

<div class="min-h-screen bg-[#0a0a0a] text-white p-6 font-black relative overflow-hidden">
    
    <PPPAdminNav CurrentPage="Ingredient Library" />

    <div class="fixed top-24 right-6 z-[100] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-2xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950/90 border-red-500 text-red-200" : "bg-emerald-950/90 border-emerald-500 text-emerald-200")">
                <div class="flex items-center gap-3">
                    <span>@(toast.IsError ? "❌" : "✅")</span>
                    <span class="text-xs uppercase tracking-widest">@toast.Message</span>
                </div>
            </div>
        }
    </div>

    @* Stats Section *@
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-black/40 border border-gray-800 p-5 rounded-2xl flex flex-col items-center">
            <span class="text-[9px] text-gray-500 uppercase tracking-widest mb-1">Total Library</span>
            <span class="text-3xl font-mono text-white">@ingredients.Count</span>
        </div>
        <div class="bg-black/40 border border-purple-900/30 p-5 rounded-2xl flex flex-col items-center">
            <span class="text-[9px] text-purple-500 uppercase tracking-widest mb-1">Universal (Global)</span>
            <span class="text-3xl font-mono text-purple-400">@ingredients.Count(i => i.OwnerId == null)</span>
        </div>
        <div class="bg-black/40 border border-blue-900/30 p-5 rounded-2xl flex flex-col items-center">
            <span class="text-[9px] text-blue-500 uppercase tracking-widest mb-1">Owner Custom</span>
            <span class="text-3xl font-mono text-blue-400">@ingredients.Count(i => i.OwnerId != null)</span>
        </div>
    </div>

    @* Table *@
    <div class="bg-[#111] border border-gray-800 rounded-3xl overflow-hidden shadow-2xl">
        <table class="w-full text-left">
            <thead>
                <tr class="text-[10px] font-black uppercase text-gray-500 bg-gray-900/50 border-b border-gray-800">
                    <th class="p-5">Ingredient</th>
                    <th class="p-5 text-center">Calories</th>
                    <th class="p-5 text-center">Protein</th>
                    <th class="p-5 text-center">Fat</th>
                    <th class="p-5 text-center">Net Carbs</th>
                    <th class="p-5">Ownership</th>
                    <th class="p-5 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800/50">
                @foreach (var ing in ingredients)
                {
                    <tr class="hover:bg-white/5 transition group">
                        <td class="p-5">
                            <div class="text-sm font-black uppercase tracking-tight @(ing.OwnerId != null ? "text-blue-400" : "text-white")">@ing.Name</div>
                            <div class="text-[9px] text-gray-500 font-mono">Per @(ing.Unit ?? "unit")</div>
                        </td>
                        <td class="p-5 text-center font-mono text-xs text-orange-400">@ing.Calories.ToString("N2")</td>
                        <td class="p-5 text-center font-mono text-xs text-blue-400">@ing.Protein.ToString("N2")g</td>
                        <td class="p-5 text-center font-mono text-xs text-yellow-500">@ing.Fat.ToString("N2")g</td>
                        <td class="p-5 text-center font-mono text-xs text-emerald-400">@ing.NetCarbs.ToString("N2")g</td>
                        <td class="p-5 text-center">
                             @if (ing.OwnerId == null) { <span class="px-2 py-0.5 rounded text-[8px] bg-purple-900/30 text-purple-400 border border-purple-800 uppercase">Universal</span> }
                             else { <span class="px-2 py-0.5 rounded text-[8px] bg-blue-900/30 text-blue-400 border border-blue-800 uppercase">@ing.Owner?.BusinessName</span> }
                        </td>
                        <td class="p-5 text-right">
                            <div class="flex justify-end gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                                @if (ing.OwnerId != null) { <button @onclick="() => PromoteToUniversal(ing)" class="p-2 text-purple-400 hover:bg-purple-500/10 rounded-lg transition" title="Promote">🌍</button> }
                                <button @onclick="() => OpenModal(ing)" class="p-2 text-blue-400 hover:bg-blue-500/10 rounded-lg transition">✎</button>
                                <button @onclick="() => ConfirmDelete(ing)" class="p-2 text-red-500 hover:bg-red-500/10 rounded-lg transition">✕</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* MODAL *@
@if (showModal)
{
    <div class="fixed inset-0 bg-black/90 backdrop-blur-sm z-[200] flex items-center justify-center p-4">
        <div class="bg-[#111] w-full max-w-xl rounded-3xl border border-gray-800 shadow-2xl overflow-hidden animate-in zoom-in duration-200">
            <div class="p-6 bg-gray-900/50 border-b border-gray-800 flex justify-between items-center">
                <h3 class="text-lg uppercase tracking-widest font-black text-orange-400">
                    @(isPromoting ? "Review Universal Promotion" : (editingIng.Id == 0 ? "Create Ingredient" : "Update Ingredient"))
                </h3>
                <button @onclick="CloseModal" class="text-gray-500 text-2xl hover:text-white">&times;</button>
            </div>
            
            <div class="p-8 grid grid-cols-2 gap-4">
                <div class="col-span-2">
                    <label class="text-[9px] uppercase text-gray-500 mb-2 block">Ingredient Name</label>
                    <input @bind="editingIng.Name" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-orange-500 outline-none uppercase font-black" />
                </div>
                <div>
                    <label class="text-[9px] uppercase text-gray-500 mb-2 block">Base Unit (e.g. lbs, each)</label>
                    <input @bind="editingIng.Unit" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-orange-500 outline-none" />
                </div>
                <div>
                    <label class="text-[9px] uppercase text-gray-500 mb-2 block">Ownership Scope</label>
                    <select @bind="selectedOwnerId" disabled="@isPromoting" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm text-white disabled:opacity-50">
                        <option value="0">UNIVERSAL (ADMIN)</option>
                        @foreach(var owner in owners) { <option value="@owner.Id">@owner.BusinessName</option> }
                    </select>
                </div>
                <div class="col-span-2 grid grid-cols-5 gap-2 mt-4 bg-black/40 p-4 rounded-2xl border border-gray-800">
                    @foreach (var field in new[] { "Cals", "Prot", "Fat", "Carb", "Fiber" }) {
                        <div>
                            <label class="text-[8px] uppercase text-gray-500 mb-1 block">@field</label>
                            @if(field == "Cals") { <input type="number" step="0.01" @bind="editingIng.Calories" class="w-full bg-black border border-gray-800 p-2 text-xs font-mono text-orange-400" /> }
                            @if(field == "Prot") { <input type="number" step="0.01" @bind="editingIng.Protein" class="w-full bg-black border border-gray-800 p-2 text-xs font-mono text-blue-400" /> }
                            @if(field == "Fat") { <input type="number" step="0.01" @bind="editingIng.Fat" class="w-full bg-black border border-gray-800 p-2 text-xs font-mono text-yellow-500" /> }
                            @if(field == "Carb") { <input type="number" step="0.01" @bind="editingIng.Carbs" class="w-full bg-black border border-gray-800 p-2 text-xs font-mono text-red-400" /> }
                            @if(field == "Fiber") { <input type="number" step="0.01" @bind="editingIng.Fiber" class="w-full bg-black border border-gray-800 p-2 text-xs font-mono text-emerald-400" /> }
                        </div>
                    }
                </div>
            </div>

            <div class="p-6 bg-gray-900/50 border-t border-gray-800 flex justify-end gap-4">
                <button @onclick="CloseModal" class="text-[10px] text-gray-500 uppercase tracking-widest font-black px-6">Cancel</button>
                <button @onclick="SaveIngredient" class="bg-orange-600 hover:bg-orange-500 text-white text-[10px] uppercase tracking-widest font-black px-8 py-3 rounded-xl shadow-lg transition">
                    @(isPromoting ? "Confirm Universal Copy" : "Save Changes")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<PPP_Ingredient> ingredients = new();
    private List<PPP_Owner> owners = new();
    private bool showModal = false;
    private bool isPromoting = false;
    private PPP_Ingredient editingIng = new();
    private int selectedOwnerId = 0;
    private List<ToastItem> toasts = new();

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData() {
        ingredients = await Db.PPP_Ingredients.Include(i => i.Owner).OrderBy(i => i.Name).ToListAsync();
        owners = await Db.PPP_Owners.OrderBy(o => o.BusinessName).ToListAsync();
    }

    private void OpenModal(PPP_Ingredient? ing = null) {
        isPromoting = false;
        if (ing == null) { editingIng = new PPP_Ingredient { CreatedAt = DateTime.UtcNow }; selectedOwnerId = 0; }
        else { editingIng = CloneIng(ing); selectedOwnerId = ing.OwnerId ?? 0; }
        showModal = true;
    }

    private void PromoteToUniversal(PPP_Ingredient ing) {
        editingIng = CloneIng(ing);
        editingIng.Id = 0;
        editingIng.OwnerId = null;
        editingIng.Name += " (Global)";
        selectedOwnerId = 0;
        isPromoting = true;
        showModal = true;
    }

    private PPP_Ingredient CloneIng(PPP_Ingredient s) => new() { Id = s.Id, Name = s.Name, Unit = s.Unit, Calories = s.Calories, Protein = s.Protein, Fat = s.Fat, Carbs = s.Carbs, Fiber = s.Fiber, OwnerId = s.OwnerId };

    private void CloseModal() => showModal = false;

    private async Task SaveIngredient() {
        if (string.IsNullOrWhiteSpace(editingIng.Name)) return;
        editingIng.OwnerId = selectedOwnerId == 0 ? null : selectedOwnerId;
        if (editingIng.Id == 0) Db.PPP_Ingredients.Add(editingIng);
        else Db.Entry(editingIng).State = EntityState.Modified;
        await Db.SaveChangesAsync();
        await LoadData();
        CloseModal();
    }

    private async Task ConfirmDelete(PPP_Ingredient ing) {
        if (await JS.InvokeAsync<bool>("confirm", $"Delete {ing.Name}?")) {
            Db.PPP_Ingredients.Remove(ing);
            await Db.SaveChangesAsync();
            await LoadData();
        }
    }

    private async Task ShowToast(string msg, bool err = false) {
        var t = new ToastItem { Message = msg, IsError = err };
        toasts.Add(t); StateHasChanged();
        await Task.Delay(3000);
        toasts.Remove(t); StateHasChanged();
    }
    private class ToastItem { public string Message { get; set; } = ""; public bool IsError { get; set; } }
}