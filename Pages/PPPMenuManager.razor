@page "/ppp-menu-manager/{OwnerId:int}"
@using Dashboard
@using Dashboard.Services
@using Dashboard.Components
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="min-h-screen bg-[#050505] text-slate-200 p-4 md:p-8 font-sans antialiased pb-20">
    <PPPAdminNav CurrentPage="Menu Vault" />

    @* Notification Stack *@
    <div class="fixed top-24 right-6 z-[100] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950 border-red-500 text-red-200" : "bg-emerald-950 border-emerald-500 text-emerald-200") backdrop-blur-md">
                <div class="flex items-center gap-3">
                    <span class="text-lg">@(toast.IsError ? "✕" : "✓")</span>
                    <span class="text-xs font-bold uppercase tracking-widest">@toast.Message</span>
                </div>
            </div>
        }
    </div>

    @if (owner != null)
    {
        @* Business Branding Header *@
        <div class="max-w-7xl mx-auto mb-12 flex flex-col md:flex-row md:items-center gap-6 border-b border-white/5 pb-8">
            @if (owner.LogoId.HasValue)
            {
                <div class="w-16 h-16 rounded-2xl overflow-hidden border border-slate-800 bg-black">
                    <img src="/db-images-ppp/@owner.LogoId" class="w-full h-full object-contain" />
                </div>
            }
            <div class="flex-1">
                <h1 class="text-4xl font-black text-white italic uppercase tracking-tighter">@owner.BusinessName</h1>
                <p class="text-[10px] text-emerald-500 font-black uppercase tracking-[0.3em]">Menu Management Portal</p>
            </div>
            <button @onclick='() => Nav.NavigateTo($"/ppp-menu-editor/{OwnerId}")' 
                    class="bg-emerald-600 hover:bg-emerald-500 text-white px-8 py-4 rounded-2xl font-black text-xs uppercase tracking-widest transition-all shadow-lg active:scale-95">
                ＋ Create New Menu
            </button>
        </div>

        @* Section: Current & Upcoming *@
        <div class="max-w-7xl mx-auto mb-20">
            <h3 class="text-xs font-black uppercase tracking-[0.4em] text-emerald-500 mb-8 px-4 flex items-center gap-4">
                Current & Upcoming <span class="h-[1px] flex-1 bg-emerald-500/20"></span>
            </h3>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                @foreach (var m in menus)
                {
                    @RenderMenuCard(m)
                }
            </div>
        </div>

        @* Section: Historical Archive *@
        <div class="max-w-7xl mx-auto">
            <h3 class="text-xs font-black uppercase tracking-[0.4em] text-slate-600 mb-8 px-4 flex items-center gap-4">
                Historical Archive <span class="h-[1px] flex-1 bg-white/5"></span>
            </h3>
            
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
                @foreach (var m in archivedMenus)
                {
                    @RenderMenuCard(m)
                }
            </div>

            @if (hasMoreArchive)
            {
                <div class="flex justify-center">
                    <button @onclick="LoadArchiveBatch" disabled="@isLoadingArchive" 
                            class="bg-white/5 hover:bg-white/10 text-slate-400 px-10 py-3 rounded-full text-[10px] font-black uppercase tracking-[0.3em] transition-all border border-white/5 shadow-xl">
                        @if (isLoadingArchive) { <span>Loading...</span> } else { <span>Load 5 Older Menus</span> }
                    </button>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int OwnerId { get; set; }
    private PPP_Owner? owner;
    private List<PPP_Menu> menus = new();
    private List<PPP_Menu> archivedMenus = new();
    private List<ToastItem> toasts = new();
    
    private int archiveSkip = 0;
    private bool hasMoreArchive = true;
    private bool isLoadingArchive = false;

    protected override async Task OnInitializedAsync()
    {
        owner = await Db.PPP_Owners.AsNoTracking().FirstOrDefaultAsync(o => o.Id == OwnerId);
        await LoadActiveMenus();
        await LoadArchiveBatch();
    }

    private async Task LoadActiveMenus()
    {
        var today = DateTime.Today.ToUniversalTime();
        menus = await Db.Set<PPP_Menu>()
            .AsNoTracking()
            .Include(m => m.Items).ThenInclude(i => i.Recipe)
            .Where(m => m.OwnerId == OwnerId && m.EndDate >= today)
            .OrderBy(m => m.StartDate)
            .ToListAsync();
    }

    private async Task LoadArchiveBatch()
    {
        if (isLoadingArchive) return;
        isLoadingArchive = true;
        
        var today = DateTime.Today.ToUniversalTime();
        var batch = await Db.Set<PPP_Menu>()
            .AsNoTracking()
            .Include(m => m.Items).ThenInclude(i => i.Recipe)
            .Where(m => m.OwnerId == OwnerId && m.EndDate < today)
            .OrderByDescending(m => m.EndDate)
            .Skip(archiveSkip)
            .Take(5)
            .ToListAsync();

        if (batch.Count < 5) hasMoreArchive = false;
        
        archivedMenus.AddRange(batch);
        archiveSkip += 5;
        isLoadingArchive = false;
    }

    private async Task DuplicateMenu(int menuId)
    {
        try 
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            
            var source = await db.Set<PPP_Menu>()
                .AsNoTracking()
                .Include(m => m.Items).ThenInclude(i => i.Timeframes)
                .Include(m => m.Items).ThenInclude(i => i.Sizes).ThenInclude(s => s.Options)
                .FirstOrDefaultAsync(m => m.Id == menuId);

            if (source == null) return;

            var clone = new PPP_Menu
            {
                OwnerId = OwnerId,
                Name = $"{source.Name} (Copy)",
                StartDate = DateTime.Today,
                EndDate = DateTime.Today,
                IsPublished = false,
                Items = source.Items.Select(i => new PPP_MenuItem
                {
                    RecipeId = i.RecipeId,
                    StartDate = DateTime.Today,
                    EndDate = DateTime.Today,
                    Timeframes = i.Timeframes.Select(tf => new PPP_MenuItemTimeframe { Name = tf.Name }).ToList(),
                    Sizes = i.Sizes.Select(s => new PPP_MenuItemSize 
                    { 
                        Name = s.Name, 
                        BasePrice = s.BasePrice,
                        Options = s.Options.Select(o => new PPP_MenuItemOption { Name = o.Name, AddOnPrice = o.AddOnPrice }).ToList()
                    }).ToList()
                }).ToList()
            };

            db.Add(clone);
            await db.SaveChangesAsync();
            Nav.NavigateTo($"/ppp-menu-editor/{OwnerId}/{clone.Id}");
        }
        catch (Exception ex) 
        {
            await ShowToast($"Error Cloning: {ex.Message}", true);
        }
    }

    private async Task ConfirmDeleteMenu(PPP_Menu m)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete the menu '{m.Name}'? This cannot be undone.");
        if (confirmed)
        {
            try
            {
                await using var db = await DbFactory.CreateDbContextAsync();
                var toDelete = await db.Set<PPP_Menu>().FirstOrDefaultAsync(x => x.Id == m.Id);
                if (toDelete != null)
                {
                    db.Remove(toDelete);
                    await db.SaveChangesAsync();
                    
                    // Refresh local lists
                    menus.RemoveAll(x => x.Id == m.Id);
                    archivedMenus.RemoveAll(x => x.Id == m.Id);
                    
                    await ShowToast("Menu Deleted Successfully");
                }
            }
            catch (Exception ex)
            {
                await ShowToast($"Delete Error: {ex.Message}", true);
            }
        }
    }

    private async Task ShowToast(string msg, bool isError = false)
    {
        var toast = new ToastItem { Message = msg, IsError = isError };
        toasts.Add(toast);
        StateHasChanged();
        await Task.Delay(4000);
        toasts.Remove(toast);
        StateHasChanged();
    }

    private class ToastItem { public string Message { get; set; } = ""; public bool IsError { get; set; } }

    private RenderFragment RenderMenuCard(PPP_Menu m) => __builder => {
        <div class="bg-[#111] border border-slate-800 rounded-[2.5rem] p-8 hover:border-white/10 transition-all group flex flex-col shadow-2xl relative">
            <div class="flex justify-between items-start mb-6">
                <div>
                    <span class="text-[10px] font-black uppercase tracking-widest @(m.IsPublished ? "text-emerald-500" : "text-amber-500")">
                        @(m.IsPublished ? "● Published" : "○ Draft")
                    </span>
                    <h2 class="text-2xl font-black text-white uppercase italic mt-1">@m.Name</h2>
                    <p class="text-xs text-slate-500 font-bold uppercase mt-1">@m.StartDate.ToString("MMM d") — @m.EndDate.ToString("MMM d, yyyy")</p>
                </div>
                <div class="flex gap-2">
                    <button @onclick="() => DuplicateMenu(m.Id)" class="p-3 bg-white/5 hover:bg-blue-600 rounded-xl transition-all" title="Clone Menu">👯</button>
                    <button @onclick='() => Nav.NavigateTo($"/ppp-menu-editor/{OwnerId}/{m.Id}")' class="p-3 bg-white/5 hover:bg-emerald-600 rounded-xl transition-all" title="Edit Menu">✎</button>
                    <button @onclick="() => ConfirmDeleteMenu(m)" class="p-3 bg-white/5 hover:bg-red-600 rounded-xl transition-all" title="Delete Menu">✕</button>
                </div>
            </div>

            <div class="flex-1 space-y-2 mb-4">
                @foreach (var item in m.Items.OrderBy(i => i.StartDate))
                {
                    <div class="flex items-center justify-between bg-black/40 p-3 rounded-xl border border-white/5">
                        <span class="text-[10px] font-mono text-emerald-500 font-bold">@item.StartDate.ToString("ddd M/d")</span>
                        <span class="text-[10px] text-slate-300 font-black uppercase tracking-tight">@(item.Recipe?.Name ?? "No Recipe Selected")</span>
                    </div>
                }
                @if(!m.Items.Any()){
                    <p class="text-[10px] text-slate-600 italic">No items scheduled</p>
                }
            </div>
        </div>
    };
}