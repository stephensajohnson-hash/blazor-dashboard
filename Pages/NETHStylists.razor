@page "/admin/neth-stylists"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using System.Text.Json
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

@if (isAuthorized)
{
    <div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex font-sans">
        <NETHAdminSidebar />

        <div class="flex-1 p-8">
            <div class="max-w-5xl mx-auto">
                <div class="flex justify-between items-end mb-8">
                    <div>
                        <h2 class="text-3xl font-black text-white uppercase tracking-tighter italic">Stylist Roster</h2>
                        <p class="text-[10px] text-gray-500 font-mono uppercase tracking-[0.2em]">Active Personnel: @allStylists.Count</p>
                    </div>
                    <div class="flex gap-3">
                        @* REPAIR DATABASE BUTTON *@
                        <button @onclick="RepairDatabase" class="bg-orange-600/10 hover:bg-orange-600 text-orange-500 hover:text-white text-[9px] font-black uppercase px-4 py-3 rounded-lg border border-orange-500/20 transition">
                            <i class="fa-solid fa-database mr-1"></i> Repair DB Schema
                        </button>
                        <button @onclick="OpenCreateModal" class="bg-blue-600 hover:bg-blue-500 text-white text-[10px] font-black uppercase px-6 py-3 rounded-lg shadow-xl transition tracking-widest">
                            ＋ Recruit Stylist
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="mb-6 p-4 rounded-lg font-mono text-[10px] uppercase flex justify-between items-center @(statusMessage.Contains("ERR") ? "bg-red-900/20 text-red-400 border border-red-500/30" : "bg-blue-900/20 text-blue-400 border border-blue-500/30")">
                        <span>@statusMessage</span>
                        <button @onclick='() => statusMessage = ""' class="opacity-50 hover:opacity-100 text-xl">&times;</button>
                    </div>
                }

                <div class="grid gap-4">
                    @foreach (var stylist in allStylists)
                    {
                        <div class="bg-[#25262b] rounded-xl border border-gray-700 p-5 flex items-center justify-between group hover:border-gray-500 transition-all relative">
                            <div class="flex items-center gap-5">
                                <div class="w-14 h-14 rounded-full overflow-hidden border-2 border-gray-800 bg-black flex items-center justify-center shadow-lg">
                                    @if (stylist.AvatarId.HasValue)
                                    {
                                        <img src="/neth-images/@stylist.AvatarId" class="w-full h-full object-cover" alt="Stylist Avatar" />
                                    }
                                    else
                                    {
                                        <i class="fa-solid fa-user-tie text-gray-700 text-xl"></i>
                                    }
                                </div>
                                <div>
                                    <h3 class="text-lg font-black text-white uppercase tracking-tight">@stylist.Name</h3>
                                    <p class="text-[10px] text-gray-500 font-mono uppercase">@stylist.Shop?.BusinessName // @(stylist.IsIndependent ? "Independent" : "Staff")</p>
                                </div>
                            </div>

                            <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                <button @onclick="() => OpenEditModal(stylist)" class="w-9 h-9 flex items-center justify-center bg-blue-600/20 hover:bg-blue-600 text-blue-400 hover:text-white rounded-lg border border-blue-500/30 transition-all">
                                    <i class="fa-solid fa-user-gear text-xs"></i>
                                </button>
                                <button @onclick="() => DeleteStylist(stylist.Id, stylist.AvatarId)" class="w-9 h-9 flex items-center justify-center bg-red-600/20 hover:bg-red-600 text-red-400 hover:text-white rounded-lg border border-red-500/30 transition-all">
                                    <i class="fa-solid fa-trash-can text-xs"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@if (showModal && editingStylist != null)
{
    <div class="fixed inset-0 bg-black/95 backdrop-blur-md z-50 flex items-center justify-center p-4">
        <div class="bg-[#25262b] w-full max-w-xl rounded-2xl border border-gray-700 shadow-2xl overflow-hidden animate-in zoom-in-95 duration-200">
            <div class="p-5 border-b border-gray-800 flex justify-between items-center bg-black/20">
                <h3 class="text-white font-black uppercase text-xs tracking-[0.3em]">Stylist Configuration</h3>
                <button @onclick="CloseModal" class="text-gray-500 hover:text-white text-2xl">&times;</button>
            </div>
            
            <div class="p-8 space-y-6">
                <div class="flex justify-center mb-6">
                    <div class="relative group">
                        <div class="w-24 h-24 rounded-full overflow-hidden border-4 border-gray-800 bg-black flex items-center justify-center shadow-2xl">
                            @if (avatarBuffer != null) { <img src="data:@avatarContentType;base64,@Convert.ToBase64String(avatarBuffer)" class="w-full h-full object-cover" /> }
                            else if (editingStylist.AvatarId.HasValue) { <img src="/neth-images/@editingStylist.AvatarId" class="w-full h-full object-cover" /> }
                            else { <i class="fa-solid fa-user-tie text-gray-700 text-3xl"></i> }
                        </div>
                        <label class="absolute inset-0 flex items-center justify-center bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer rounded-full">
                            <i class="fa-solid fa-camera text-white"></i>
                            <InputFile OnChange="HandleFileSelected" class="absolute inset-0 opacity-0 cursor-pointer" />
                        </label>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="col-span-2">
                        <label class="text-[9px] font-black uppercase text-gray-500 mb-1.5 block ml-1">Full Name</label>
                        <input @bind="editingStylist.Name" class="w-full bg-black/40 border border-gray-700 rounded-xl p-3 text-white outline-none focus:border-blue-500" />
                    </div>
                    <div>
                        <label class="text-[9px] font-black uppercase text-gray-500 mb-1.5 block ml-1">Assigned Shop</label>
                        <select @bind="editingStylist.ShopId" class="w-full bg-black/40 border border-gray-700 rounded-xl p-3 text-white outline-none focus:border-blue-500">
                            @foreach(var shop in allShops) { <option value="@shop.Id">@shop.BusinessName</option> }
                        </select>
                    </div>
                    <div class="flex items-end pb-3">
                        <label class="flex items-center gap-3 cursor-pointer">
                            <input type="checkbox" @bind="editingStylist.IsIndependent" class="w-4 h-4 rounded bg-black border-gray-700" />
                            <span class="text-[10px] font-black uppercase text-gray-400">Independent Contractor</span>
                        </label>
                    </div>
                </div>

                <div>
                    <label class="text-[9px] font-black uppercase text-gray-500 mb-1.5 block ml-1">Professional Bio</label>
                    <textarea @bind="editingStylist.Bio" class="w-full h-24 bg-black/40 border border-gray-700 rounded-xl p-4 text-white text-sm outline-none focus:border-blue-500 resize-none"></textarea>
                </div>
            </div>

            <div class="p-5 bg-black/20 border-t border-gray-800 flex justify-end gap-3">
                <button @onclick="CloseModal" class="text-[10px] text-gray-600 uppercase px-6 py-2 font-black hover:text-white transition">Cancel</button>
                <button @onclick="SaveStylist" class="bg-blue-600 hover:bg-blue-500 text-white text-[10px] uppercase px-10 py-3 rounded-xl font-black shadow-2xl transition">
                    @(isSaving ? "Uploading..." : "Commit_Personnel_Record")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool isAuthorized = false, isLoading = true, isSaving = false, showModal = false;
    private List<NETH_Stylist> allStylists = new();
    private List<NETH_Shop> allShops = new();
    private NETH_Stylist? editingStylist;
    private string statusMessage = "";

    private byte[]? avatarBuffer;
    private string avatarContentType = "";
    private string avatarFileName = "";

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "neth_session");
            if (string.IsNullOrEmpty(json)) Nav.NavigateTo("/nethaircut");
            else { isAuthorized = true; await LoadData(); isLoading = false; StateHasChanged(); }
        }
    }

    private async Task LoadData() { 
        try { 
            allStylists = await Db.NETH_Stylists.Include(s => s.Shop).AsNoTracking().ToListAsync(); 
            allShops = await Db.NETH_Shops.AsNoTracking().ToListAsync();
            StateHasChanged(); 
        } catch { } 
    }

    private async Task RepairDatabase() {
        try {
            await Db.Database.ExecuteSqlRawAsync(@"
                DO $$ BEGIN
                    IF NOT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_name='NETH_Stylists' AND column_name='AvatarId') THEN
                        ALTER TABLE ""NETH_Stylists"" ADD COLUMN ""AvatarId"" INTEGER;
                    END IF;
                END $$;");
            statusMessage = "SUCCESS: AvatarId column synchronized.";
        } catch (Exception ex) { statusMessage = "ERR: " + ex.Message; }
    }

    private void OpenCreateModal() { 
        editingStylist = new NETH_Stylist { ShopId = allShops.FirstOrDefault()?.Id ?? 0, PhoneId = 1 }; 
        avatarBuffer = null; showModal = true; 
    }
    
    private void OpenEditModal(NETH_Stylist stylist) { 
        editingStylist = new NETH_Stylist { 
            Id = stylist.Id, Name = stylist.Name, Bio = stylist.Bio, 
            ShopId = stylist.ShopId, IsIndependent = stylist.IsIndependent, 
            PhoneId = stylist.PhoneId, AvatarId = stylist.AvatarId 
        }; 
        avatarBuffer = null; showModal = true; 
    }

    private void CloseModal() { showModal = false; editingStylist = null; avatarBuffer = null; }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file == null) return;

            // Use a 3MB limit for safety
            long maxFileSize = 1024 * 1024 * 3; 
            
            // Use a MemoryStream to ensure the entire file is read properly
            using var ms = new MemoryStream();
            await file.OpenReadStream(maxFileSize).CopyToAsync(ms);
            
            avatarBuffer = ms.ToArray();
            avatarContentType = file.ContentType;
            avatarFileName = file.Name;
            
            statusMessage = "IMAGE_READY: " + file.Name;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            statusMessage = "FILE_ERR: " + ex.Message;
        }
    }

    private async Task SaveStylist() {
        if (editingStylist == null || isSaving) return;
        isSaving = true;
        try {
            int? finalAvatarId = editingStylist.AvatarId;

            if (avatarBuffer != null) {
                if (editingStylist.AvatarId.HasValue) {
                    await Db.Database.ExecuteSqlRawAsync(@"DELETE FROM ""NETH_StoredImages"" WHERE ""Id"" = {0}", editingStylist.AvatarId.Value);
                }
                var newImg = new NETH_StoredImage {
                    Data = avatarBuffer, ContentType = avatarContentType,
                    FileName = avatarFileName, Category = "StylistAvatar", UploadedAt = DateTime.UtcNow
                };
                Db.NETH_StoredImages.Add(newImg);
                await Db.SaveChangesAsync();
                finalAvatarId = newImg.Id;
            }

            if (editingStylist.Id == 0) {
                await Db.Database.ExecuteSqlRawAsync(
                    @"INSERT INTO ""NETH_Stylists"" (""Name"", ""Bio"", ""ShopId"", ""IsIndependent"", ""PhoneId"", ""StripeAccountId"", ""AvatarId"") 
                      VALUES ({0}, {1}, {2}, {3}, {4}, '', {5})", 
                    editingStylist.Name, editingStylist.Bio, editingStylist.ShopId, editingStylist.IsIndependent, editingStylist.PhoneId, finalAvatarId
                );
            } else {
                await Db.Database.ExecuteSqlRawAsync(
                    @"UPDATE ""NETH_Stylists"" SET ""Name"" = {0}, ""Bio"" = {1}, ""ShopId"" = {2}, ""IsIndependent"" = {3}, ""AvatarId"" = {4} 
                      WHERE ""Id"" = {5}", 
                    editingStylist.Name, editingStylist.Bio, editingStylist.ShopId, editingStylist.IsIndependent, finalAvatarId, editingStylist.Id
                );
            }
            
            await LoadData(); CloseModal();
            statusMessage = "PERSONNEL_RECORD_UPDATED";
        } catch (Exception ex) { statusMessage = "ERR: " + ex.Message; }
        finally { isSaving = false; }
    }

    private async Task DeleteStylist(int id, int? avatarId) { 
        if (await JS.InvokeAsync<bool>("confirm", "Delete stylist profile?")) {
            if (avatarId.HasValue) await Db.Database.ExecuteSqlRawAsync(@"DELETE FROM ""NETH_StoredImages"" WHERE ""Id"" = {0}", avatarId.Value);
            await Db.Database.ExecuteSqlRawAsync(@"DELETE FROM ""NETH_Stylists"" WHERE ""Id"" = {0}", id); 
            await LoadData(); 
        } 
    }
}