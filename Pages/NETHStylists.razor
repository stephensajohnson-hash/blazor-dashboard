@page "/admin/neth-stylists"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using System.Text.Json
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

@* Fail-safe FontAwesome Loader *@
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<style>
    .neth-stylist-card {
        background: #25262b;
        border-radius: 1rem;
        border: 1px solid #374151;
        overflow: hidden;
        position: relative;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        padding: 1.25rem;
    }

    .neth-stylist-card:hover {
        border-color: #4b5563;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.5);
    }

    /* Hover Action Container (Edit/Delete) */
    .stylist-hover-actions {
        position: absolute;
        top: 0.75rem;
        right: 0.75rem;
        display: flex;
        gap: 0.5rem;
        opacity: 0;
        transition: opacity 0.2s ease;
        z-index: 20;
    }
    .neth-stylist-card:hover .stylist-hover-actions { opacity: 1; }

    .action-btn-sm {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 0.5rem;
        transition: all 0.2s;
        color: white !important;
    }

    /* Avatar Styling */
    .avatar-frame {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        overflow: hidden;
        border: 2px solid #374151;
        background: #1a1b1e;
        flex-shrink: 0;
    }
    .avatar-frame img { width: 100%; height: 100%; object-fit: cover; }

    /* Operational Buttons (Always Visible) */
    .op-btn {
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        transition: all 0.2s;
        letter-spacing: 0.05em;
    }

    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #374151; border-radius: 10px; }
</style>

@if (isAuthorized)
{
    <div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex font-sans">
        <NETHAdminSidebar />

        <div class="flex-1 p-8">
            <div class="max-w-5xl mx-auto">
                <div class="flex justify-between items-end mb-10">
                    <div>
                        <h2 class="text-3xl font-black text-white uppercase tracking-tighter italic">Stylist Roster</h2>
                        <p class="text-[10px] text-gray-500 font-mono uppercase tracking-[0.2em]">Personnel_Total: @allStylists.Count</p>
                    </div>
                    <button @onclick="OpenCreateModal" class="bg-blue-600 hover:bg-blue-500 text-white text-[10px] font-black uppercase px-8 py-3 rounded-xl shadow-xl transition tracking-widest">
                        ＋ New Stylist
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="mb-6 p-4 rounded-lg font-mono text-[10px] uppercase flex justify-between items-center @(statusMessage.Contains("ERR") ? "bg-red-900/20 text-red-400 border border-red-500/30" : "bg-blue-900/20 text-blue-400 border border-blue-500/30")">
                        <span>@statusMessage</span>
                        <button @onclick='() => statusMessage = ""' class="opacity-50 hover:opacity-100 text-xl">&times;</button>
                    </div>
                }

                @if (isLoading)
                {
                    <div class="text-center py-20 animate-pulse font-black text-gray-600 uppercase tracking-widest">Scanning_Biometrics...</div>
                }
                else
                {
                    <div class="grid gap-4">
                        @foreach (var stylist in allStylists)
                        {
                            <div class="neth-stylist-card group">
                                @* AVATAR *@
                                <div class="avatar-frame mr-5">
                                    @if (stylist.AvatarId.HasValue)
                                    {
                                        <img src="/neth-images/@stylist.AvatarId" alt="@stylist.Name" />
                                    }
                                    else
                                    {
                                        <div class="w-full h-full flex items-center justify-center text-gray-700 bg-gray-900">
                                            <i class="fa-solid fa-user-tie text-2xl"></i>
                                        </div>
                                    }
                                </div>

                                @* INFO *@
                                <div class="flex-1">
                                    <h3 class="text-lg font-black text-white uppercase tracking-tight">@stylist.Name</h3>
                                    <p class="text-[9px] text-gray-500 font-mono uppercase tracking-widest">
                                        @stylist.Shop?.BusinessName // @(stylist.IsIndependent ? "Contractor" : "Staff")
                                    </p>
                                </div>

                                @* OPERATIONAL BUTTONS (Always Visible) *@
                                <div class="flex gap-2 mr-12">
                                    <button @onclick='() => Nav.NavigateTo($"/admin/neth-stylist-schedule/{stylist.Id}")' 
                                            class="op-btn bg-gray-800 hover:bg-gray-700 text-gray-300 border border-gray-700">
                                        <i class="fa-solid fa-clock mr-1.5 opacity-50"></i> Schedule
                                    </button>
                                    <button @onclick='() => Nav.NavigateTo($"/admin/neth-appointments/{stylist.Id}")' 
                                            class="op-btn bg-blue-600/10 hover:bg-blue-600 text-blue-400 hover:text-white border border-blue-500/30">
                                        <i class="fa-solid fa-calendar-plus mr-1.5 opacity-50"></i> Book
                                    </button>
                                </div>

                                @* HOVER ACTIONS (Edit/Delete) *@
                                <div class="stylist-hover-actions">
                                    <button @onclick="() => OpenEditModal(stylist)" class="action-btn-sm bg-blue-600/20 hover:bg-blue-600 border border-blue-500/30">
                                        <i class="fa-solid fa-pen-to-square text-xs"></i>
                                    </button>
                                    <button @onclick="() => DeleteStylist(stylist.Id, stylist.AvatarId)" class="action-btn-sm bg-red-600/20 hover:bg-red-600 border border-red-500/30">
                                        <i class="fa-solid fa-trash-can text-xs"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@* (Modal code remains identical to previous version, including HandleFileSelected fixes) *@
@if (showModal && editingStylist != null)
{
    <div class="fixed inset-0 bg-black/95 backdrop-blur-md z-50 flex items-center justify-center p-4">
        <div class="bg-[#25262b] w-full max-w-xl rounded-2xl border border-gray-700 shadow-2xl overflow-hidden animate-in zoom-in-95 duration-200">
            <div class="p-5 border-b border-gray-800 flex justify-between items-center bg-black/20">
                <h3 class="text-white font-black uppercase text-xs tracking-[0.3em]">Stylist Profile</h3>
                <button @onclick="CloseModal" class="text-gray-500 hover:text-white text-2xl">&times;</button>
            </div>
            
            <div class="p-8 space-y-6">
                @* Avatar Upload Circle *@
                <div class="flex justify-center mb-4">
                    <div class="relative group">
                        <div class="w-28 h-28 rounded-full overflow-hidden border-4 border-gray-800 bg-black flex items-center justify-center shadow-2xl">
                            @if (avatarBuffer != null) { <img src="data:@avatarContentType;base64,@Convert.ToBase64String(avatarBuffer)" class="w-full h-full object-cover" /> }
                            else if (editingStylist.AvatarId.HasValue) { <img src="/neth-images/@editingStylist.AvatarId" class="w-full h-full object-cover" /> }
                            else { <i class="fa-solid fa-user-tie text-gray-700 text-4xl"></i> }
                        </div>
                        <label class="absolute inset-0 flex items-center justify-center bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer rounded-full">
                            <i class="fa-solid fa-camera text-white text-xl"></i>
                            <InputFile OnChange="HandleFileSelected" class="absolute inset-0 opacity-0 cursor-pointer" />
                        </label>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-5">
                    <div class="col-span-2">
                        <label class="text-[9px] font-black uppercase text-gray-500 mb-1.5 block ml-1">Display Name</label>
                        <input @bind="editingStylist.Name" class="w-full bg-black/40 border border-gray-700 rounded-xl p-3 text-white outline-none focus:border-blue-500" placeholder="e.g. Stephens Johnson" />
                    </div>
                    <div>
                        <label class="text-[9px] font-black uppercase text-gray-500 mb-1.5 block ml-1">Primary Location</label>
                        <select @bind="editingStylist.ShopId" class="w-full bg-black/40 border border-gray-700 rounded-xl p-3 text-white outline-none focus:border-blue-500">
                            @foreach(var shop in allShops) { <option value="@shop.Id">@shop.BusinessName</option> }
                        </select>
                    </div>
                    <div class="flex items-center pt-5">
                        <label class="flex items-center gap-3 cursor-pointer">
                            <input type="checkbox" @bind="editingStylist.IsIndependent" class="w-4 h-4 rounded bg-black border-gray-700 text-blue-600 focus:ring-0" />
                            <span class="text-[10px] font-black uppercase text-gray-400">Independent</span>
                        </label>
                    </div>
                </div>

                <div>
                    <label class="text-[9px] font-black uppercase text-gray-500 mb-1.5 block ml-1">Stylist Bio</label>
                    <textarea @bind="editingStylist.Bio" class="w-full h-28 bg-black/40 border border-gray-700 rounded-xl p-4 text-white text-sm outline-none focus:border-blue-500 resize-none" placeholder="Experience, specialties..."></textarea>
                </div>
            </div>

            <div class="p-5 bg-black/20 border-t border-gray-800 flex justify-end gap-3">
                <button @onclick="CloseModal" class="text-[10px] text-gray-600 uppercase px-6 py-2 font-black hover:text-white transition">Cancel</button>
                <button @onclick="SaveStylist" class="bg-blue-600 hover:bg-blue-500 text-white text-[10px] uppercase px-10 py-3 rounded-xl font-black shadow-2xl transition tracking-widest">
                    @(isSaving ? "Saving..." : "Commit_Record")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool isAuthorized = false, isLoading = true, isSaving = false, showModal = false;
    private List<NETH_Stylist> allStylists = new();
    private List<NETH_Shop> allShops = new();
    private NETH_Stylist? editingStylist;
    private string statusMessage = "";

    private byte[]? avatarBuffer;
    private string avatarContentType = "";
    private string avatarFileName = "";

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "neth_session");
            if (string.IsNullOrEmpty(json)) Nav.NavigateTo("/nethaircut");
            else { isAuthorized = true; await LoadData(); isLoading = false; StateHasChanged(); }
        }
    }

    private async Task LoadData() { 
        try { 
            allStylists = await Db.NETH_Stylists.Include(s => s.Shop).AsNoTracking().ToListAsync(); 
            allShops = await Db.NETH_Shops.AsNoTracking().ToListAsync();
            StateHasChanged(); 
        } catch { } 
    }

    private void OpenCreateModal() { 
        editingStylist = new NETH_Stylist { ShopId = allShops.FirstOrDefault()?.Id ?? 0, PhoneId = 1 }; 
        avatarBuffer = null; showModal = true; 
    }
    
    private void OpenEditModal(NETH_Stylist stylist) { 
        editingStylist = new NETH_Stylist { 
            Id = stylist.Id, Name = stylist.Name, Bio = stylist.Bio, 
            ShopId = stylist.ShopId, IsIndependent = stylist.IsIndependent, 
            PhoneId = stylist.PhoneId, AvatarId = stylist.AvatarId 
        }; 
        avatarBuffer = null; showModal = true; 
    }

    private void CloseModal() { showModal = false; editingStylist = null; avatarBuffer = null; }

    private async Task HandleFileSelected(InputFileChangeEventArgs e) {
        try {
            var file = e.File;
            if (file == null) return;
            using var ms = new MemoryStream();
            await file.OpenReadStream(3 * 1024 * 1024).CopyToAsync(ms);
            avatarBuffer = ms.ToArray();
            avatarContentType = file.ContentType;
            avatarFileName = file.Name;
        } catch { statusMessage = "ERR: File too large."; }
    }

    private async Task SaveStylist() {
        if (editingStylist == null || isSaving) return;
        isSaving = true;
        try {
            int? finalAvatarId = editingStylist.AvatarId;

            if (avatarBuffer != null) {
                if (editingStylist.AvatarId.HasValue) {
                    await Db.Database.ExecuteSqlRawAsync(@"DELETE FROM ""NETH_StoredImages"" WHERE ""Id"" = {0}", editingStylist.AvatarId.Value);
                }
                var newImg = new NETH_StoredImage {
                    Data = avatarBuffer, ContentType = avatarContentType,
                    FileName = avatarFileName, Category = "StylistAvatar", UploadedAt = DateTime.UtcNow
                };
                Db.NETH_StoredImages.Add(newImg);
                await Db.SaveChangesAsync();
                finalAvatarId = newImg.Id;
            }

            if (editingStylist.Id == 0) {
                await Db.Database.ExecuteSqlRawAsync(
                    @"INSERT INTO ""NETH_Stylists"" (""Name"", ""Bio"", ""ShopId"", ""IsIndependent"", ""PhoneId"", ""StripeAccountId"", ""AvatarId"") 
                      VALUES ({0}, {1}, {2}, {3}, {4}, '', {5})", 
                    editingStylist.Name, editingStylist.Bio, editingStylist.ShopId, editingStylist.IsIndependent, editingStylist.PhoneId, finalAvatarId
                );
            } else {
                await Db.Database.ExecuteSqlRawAsync(
                    @"UPDATE ""NETH_Stylists"" SET ""Name"" = {0}, ""Bio"" = {1}, ""ShopId"" = {2}, ""IsIndependent"" = {3}, ""AvatarId"" = {4} 
                      WHERE ""Id"" = {5}", 
                    editingStylist.Name, editingStylist.Bio, editingStylist.ShopId, editingStylist.IsIndependent, finalAvatarId, editingStylist.Id
                );
            }
            
            await LoadData(); CloseModal();
            statusMessage = "Personnel Record Finalized.";
        } catch (Exception ex) { statusMessage = "ERR: " + ex.Message; }
        finally { isSaving = false; }
    }

    private async Task DeleteStylist(int id, int? avatarId) { 
        if (await JS.InvokeAsync<bool>("confirm", "Permanently remove stylist from registry?")) {
            if (avatarId.HasValue) await Db.Database.ExecuteSqlRawAsync(@"DELETE FROM ""NETH_StoredImages"" WHERE ""Id"" = {0}", avatarId.Value);
            await Db.Database.ExecuteSqlRawAsync(@"DELETE FROM ""NETH_Stylists"" WHERE ""Id"" = {0}", id); 
            await LoadData(); 
        } 
    }
}