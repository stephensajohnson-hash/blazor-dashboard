@page "/admin/neth-client-notes"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using Dashboard.Components
@using Dashboard.Services
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject NETHStateService State

@* FAIL-SAFE FontAwesome Loader *@
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<style>
    .note-card { 
        background: #25262b; 
        padding: 1.5rem; 
        border-radius: 0.75rem; 
        border: 1px solid #374151; 
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.4); 
        position: relative; 
        transition: all 0.2s ease;
        display: flex;
        gap: 1.25rem;
    }
    .note-card:hover { border-color: #4b5563; }

    .note-actions {
        position: absolute;
        top: 1rem;
        right: 1rem;
        display: flex;
        gap: 0.5rem;
        opacity: 0;
        transition: opacity 0.2s ease;
    }
    .note-card:hover .note-actions { opacity: 1; }

    .action-btn {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 0.5rem;
        transition: all 0.2s;
        color: white !important;
    }

    .stylist-header-avatar {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        border: 2px solid #374151;
        object-fit: cover;
        background: #25262b;
    }

    .client-note-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: 2px solid rgba(255,255,255,0.05);
        background: #1a1b1e;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        overflow: hidden;
        font-weight: 900;
        font-size: 13px;
        color: #D2B48C;
    }
    .client-note-avatar img { width: 100%; height: 100%; object-fit: cover; }

    .date-badge {
        background: #1a1b1e;
        color: #60a5fa;
        padding: 4px 10px;
        border-radius: 6px;
        font-family: ui-monospace, SFMono-Regular, monospace;
        font-size: 11px;
        font-weight: 800;
        border: 1px solid #1e293b;
    }

    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #374151; border-radius: 10px; }
</style>

<div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex font-sans">
    <NETHAdminSidebar />

    <div class="flex-1 p-8">
        <div class="max-w-4xl mx-auto">
            <div class="flex justify-between items-center mb-8">
                <div class="flex items-center gap-4">
                    @if (currentStylist?.AvatarId > 0)
                    {
                        <img src="/neth-images/@currentStylist.AvatarId" class="stylist-header-avatar shadow-2xl" />
                    }
                    <div>
                        <h2 class="text-2xl font-black text-white uppercase tracking-tight">
                            @(currentStylist?.Name != null ? $"{currentStylist.Name}'s Notes" : "Client History")
                        </h2>
                        <p class="text-[10px] text-[#D2B48C] font-mono uppercase tracking-widest">Formula Ledger // Page @(currentPage + 1)</p>
                    </div>
                </div>
                <button @onclick="() => OpenModal()" class="bg-blue-600 hover:bg-blue-500 text-white px-6 py-2 rounded font-black uppercase text-[10px] transition shadow-lg">
                    <i class="fa-solid fa-plus mr-2"></i> Create Entry
                </button>
            </div>

            @if (!string.IsNullOrEmpty(localError))
            {
                <div class="mb-4 p-3 bg-red-900/20 border border-red-500/50 text-red-400 text-[10px] font-mono uppercase">
                    @localError
                </div>
            }

            <div class="grid grid-cols-2 gap-4 mb-8">
                <div class="space-y-1">
                    <label class="text-[9px] font-black uppercase text-gray-500 ml-1">Stylist Filter</label>
                    @if (!State.ActiveStylistId.HasValue)
                    {
                        <select @onchange="OnStylistChanged" value="@selectedStylistId" class="w-full bg-[#25262b] border border-gray-700 rounded p-3 text-white text-xs outline-none focus:border-blue-500 transition-colors">
                            <option value="0">-- Select Stylist --</option>
                            @foreach(var s in allStylists) { <option value="@s.Id">@s.Name</option> }
                        </select>
                    }
                    else
                    {
                        <div class="w-full bg-blue-600/10 border border-blue-500/30 rounded p-3 flex items-center gap-3">
                            <i class="fa-solid fa-@(State.IsStylistLocked ? "lock" : "user-secret") text-blue-500 text-xs"></i>
                            <span class="text-blue-400 text-[10px] font-black uppercase tracking-widest">Account: @(State.ActiveName)</span>
                        </div>
                    }
                </div>
                <div class="space-y-1">
                    <label class="text-[9px] font-black uppercase text-gray-500 ml-1">Target Client</label>
                    <select @onchange="OnClientChanged" value="@selectedClientId" class="w-full bg-[#25262b] border border-gray-700 rounded p-3 text-white text-xs outline-none focus:border-blue-500 transition-colors">
                        <option value="-1">-- All My Clients --</option>
                        @foreach(var c in allClients) { <option value="@c.Id">@c.FirstName @c.LastName</option> }
                    </select>
                </div>
            </div>

            <div class="space-y-4">
                @foreach (var note in displayNotes)
                {
                    <div class="note-card group">
                        <div class="client-note-avatar">
                            @if (note.ClientAvatarId > 0)
                            {
                                <img src="/neth-images/@note.ClientAvatarId" alt="Client" />
                            }
                            else
                            {
                                <span>@GetInitials(note.ClientFirstName, note.ClientLastName)</span>
                            }
                        </div>

                        <div class="flex-1">
                            <div class="note-actions">
                                <button @onclick="() => OpenModal(note)" class="action-btn bg-blue-600/20 hover:bg-blue-600 border border-blue-500/30">
                                    <i class="fa-solid fa-pen-to-square text-xs text-white"></i>
                                </button>
                                <button @onclick="() => DeleteNote(note.Id)" class="action-btn bg-red-600/20 hover:bg-red-600 border border-red-500/30">
                                    <i class="fa-solid fa-trash-can text-xs text-white"></i>
                                </button>
                            </div>

                            <div class="flex items-center flex-wrap gap-3 mb-3">
                                <span class="date-badge">@note.DateDisplay</span>
                                <span class="text-[11px] font-black text-white uppercase tracking-tight">@note.ClientFirstName @note.ClientLastName</span>
                                @if (!string.IsNullOrEmpty(note.ShortDesc))
                                {
                                    <span class="text-[9px] font-black text-gray-500 uppercase tracking-[0.2em] border-l border-gray-700 pl-3">@note.ShortDesc</span>
                                }
                            </div>
                            <p class="text-gray-400 text-sm leading-relaxed whitespace-pre-wrap pr-16">@note.Text</p>
                        </div>
                    </div>
                }

                @if (displayNotes.Any() && (displayNotes.Count == 50 || currentPage > 0))
                {
                    <div class="flex justify-center items-center gap-6 pt-10">
                        <button @onclick="PrevPage" disabled="@(currentPage == 0)" class="bg-gray-800 hover:bg-gray-700 disabled:opacity-20 text-white px-6 py-2 rounded-xl font-black uppercase text-[10px] transition">Previous</button>
                        <span class="font-mono text-[10px] uppercase text-gray-500">Node_Page: @(currentPage + 1)</span>
                        <button @onclick="NextPage" disabled="@(displayNotes.Count < 50)" class="bg-gray-800 hover:bg-gray-700 disabled:opacity-20 text-white px-6 py-2 rounded-xl font-black uppercase text-[10px] transition">Next</button>
                    </div>
                }

                @if (!displayNotes.Any() && selectedStylistId > 0)
                {
                    <div class="text-center py-20 border-2 border-dashed border-gray-800 rounded-xl">
                        <p class="text-gray-600 text-xs uppercase font-black tracking-widest">No entries found for this selection.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (showModal)
{
    <div class="fixed inset-0 bg-black/90 backdrop-blur-sm z-[1000] flex items-center justify-center p-4">
        <div class="bg-[#25262b] w-full max-w-xl rounded-2xl border border-gray-700 shadow-2xl overflow-hidden">
            <div class="p-6 border-b border-gray-800 flex justify-between items-center bg-black/20">
                <h3 class="text-white font-black uppercase text-xs tracking-widest">
                    <i class="fa-solid @(editingNoteId == 0 ? "fa-plus" : "fa-pen") mr-2"></i>
                    @(editingNoteId == 0 ? "New Entry" : "Edit Entry")
                </h3>
                <button @onclick="() => showModal = false" class="text-gray-500 hover:text-white text-2xl">&times;</button>
            </div>
            <div class="p-8 space-y-5">
                @if (selectedClientId <= 0)
                {
                   <div class="p-4 bg-orange-900/20 border border-orange-500/30 rounded-xl mb-4">
                        <p class="text-[10px] font-black text-orange-400 uppercase tracking-widest">Warning: Please select a specific client before creating a note.</p>
                   </div>
                }
                
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-[9px] font-black uppercase text-gray-500">Date</label>
                        <input type="date" @bind="modalDate" class="w-full bg-black/40 border border-gray-700 rounded-lg p-3 text-white text-xs outline-none focus:border-blue-500" />
                    </div>
                    <div class="space-y-1">
                        <label class="text-[9px] font-black uppercase text-gray-500">Short Description</label>
                        <input type="text" @bind="modalShortDesc" placeholder="e.g. Highlights, Trim" 
                               class="w-full bg-black/40 border border-gray-700 rounded-lg p-3 text-white text-xs outline-none focus:border-blue-500" />
                    </div>
                </div>

                <div class="space-y-1">
                    <label class="text-[9px] font-black uppercase text-gray-500">Full Note / Formula</label>
                    <textarea @bind="modalFullNote" placeholder="Detailed history..." 
                              class="w-full h-48 bg-black/40 border border-gray-700 rounded-xl p-4 text-white text-sm outline-none focus:border-blue-500 resize-none"></textarea>
                </div>
                
                <div class="flex gap-3 pt-2">
                    <button @onclick="SaveEntry" disabled="@(selectedClientId <= 0)" class="flex-1 bg-blue-600 hover:bg-blue-500 disabled:opacity-30 text-white font-black uppercase text-[10px] py-4 rounded-xl transition shadow-xl tracking-widest">
                        <i class="fa-solid fa-check mr-2"></i> @(editingNoteId == 0 ? "Save to History" : "Update Entry")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool showModal = false;
    private int editingNoteId = 0;
    private int selectedStylistId = 0;
    private int selectedClientId = -1;
    private int currentPage = 0;
    private const int PageSize = 50;
    
    private DateTime modalDate = DateTime.Today;
    private string modalShortDesc = "";
    private string modalFullNote = "";
    
    private string localError = "";
    private List<NETH_Stylist> allStylists = new();
    private List<NETH_Client> allClients = new();
    private List<NoteDisplay> displayNotes = new();
    private NETH_Stylist? currentStylist;

    public class NoteDisplay {
        public int Id { get; set; }
        public int StylistId { get; set; }
        public string Text { get; set; } = "";
        public string ShortDesc { get; set; } = "";
        public DateTime EntryDate { get; set; }
        public string DateDisplay => EntryDate.ToString("ddd, MMM dd, yyyy");
        public int ClientId { get; set; }
        public string ClientFirstName { get; set; } = "";
        public string ClientLastName { get; set; } = "";
        public int? ClientAvatarId { get; set; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            allStylists = await Db.NETH_Stylists.AsNoTracking().ToListAsync();

            var uri = Nav.ToAbsoluteUri(Nav.Uri);
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
            
            if (State.ActiveStylistId.HasValue) {
                selectedStylistId = State.ActiveStylistId.Value;
            } else if (query.TryGetValue("StylistId", out var sId) && !string.IsNullOrEmpty(sId)) {
                selectedStylistId = int.Parse(sId.ToString());
            }

            if (query.TryGetValue("ClientId", out var cId) && !string.IsNullOrEmpty(cId)) {
                selectedClientId = int.Parse(cId.ToString());
            } else {
                selectedClientId = -1; 
            }

            currentStylist = allStylists.FirstOrDefault(x => x.Id == selectedStylistId);

            if (selectedStylistId > 0) {
                await LoadStylistClients();
                await LoadNotes();
            }
            StateHasChanged();
        }
    }

    private async Task LoadStylistClients()
    {
        allClients = await Db.NETH_Clients
            .Where(c => Db.NETH_Appointments.Any(a => a.ClientId == c.Id && a.StylistId == selectedStylistId))
            .OrderBy(c => c.LastName)
            .ToListAsync();
    }

    private string GetInitials(string? first, string? last) {
        if (string.IsNullOrWhiteSpace(first) && string.IsNullOrWhiteSpace(last)) return "??";
        var f = !string.IsNullOrEmpty(first) ? first[0].ToString() : "";
        var l = !string.IsNullOrEmpty(last) ? last[0].ToString() : "";
        return (f + l).ToUpper();
    }

    private async Task OnStylistChanged(ChangeEventArgs e)
    {
        displayNotes.Clear();
        currentPage = 0;
        selectedStylistId = int.Parse(e.Value?.ToString() ?? "0");
        currentStylist = allStylists.FirstOrDefault(x => x.Id == selectedStylistId);
        await LoadStylistClients();
        await LoadNotes();
    }

    private async Task OnClientChanged(ChangeEventArgs e)
    {
        displayNotes.Clear();
        currentPage = 0;
        selectedClientId = int.Parse(e.Value?.ToString() ?? "0");
        await LoadNotes();
    }

    private async Task NextPage() { currentPage++; await LoadNotes(); }
    private async Task PrevPage() { if (currentPage > 0) { currentPage--; await LoadNotes(); } }

    private async Task LoadNotes()
    {
        if (selectedStylistId == 0) {
            displayNotes.Clear();
            return;
        }
        
        try {
            string sqlQuery = "";
            List<object> parms = new List<object>();

            string baseSelect = @"SELECT n.""Id"", 
                                         n.""StylistId"",
                                         n.""NoteText"" as ""Text"", 
                                         n.""ShortDescription"" as ""ShortDesc"", 
                                         n.""ManualDate"" as ""EntryDate"", 
                                         c.""Id"" as ""ClientId"", 
                                         c.""FirstName"" as ""ClientFirstName"", 
                                         c.""LastName"" as ""ClientLastName"", 
                                         c.""AvatarId"" as ""ClientAvatarId""
                                  FROM ""NETH_ClientNotes"" n
                                  JOIN ""NETH_Clients"" c ON n.""ClientId"" = c.""Id""
                                  WHERE n.""StylistId"" = {0}";
            
            parms.Add(selectedStylistId);

            if (selectedClientId == -1) {
                sqlQuery = baseSelect + @" ORDER BY n.""ManualDate"" DESC
                                          LIMIT {1} OFFSET {2}";
                parms.Add(PageSize);
                parms.Add(currentPage * PageSize);
            } else {
                sqlQuery = baseSelect + @" AND n.""ClientId"" = {1}
                                          ORDER BY n.""ManualDate"" DESC
                                          LIMIT {2} OFFSET {3}";
                parms.Add(selectedClientId);
                parms.Add(PageSize);
                parms.Add(currentPage * PageSize);
            }

            displayNotes = await Db.Database.SqlQueryRaw<NoteDisplay>(sqlQuery, parms.ToArray()).ToListAsync();
        } catch (Exception ex) { localError = "LOAD_ERR: " + ex.Message; }
        StateHasChanged();
    }

    private void OpenModal(NoteDisplay? existing = null) {
        if (selectedStylistId == 0) {
            localError = "SELECT STYLIST FIRST";
            return;
        }
        
        if (existing != null) {
            editingNoteId = existing.Id;
            modalDate = existing.EntryDate;
            modalShortDesc = existing.ShortDesc;
            modalFullNote = existing.Text;
            selectedClientId = existing.ClientId; 
        } else {
            editingNoteId = 0;
            modalDate = DateTime.Today;
            modalShortDesc = "";
            modalFullNote = "";
        }

        localError = "";
        showModal = true;
    }

    private async Task SaveEntry()
    {
        if (string.IsNullOrWhiteSpace(modalFullNote) || selectedClientId <= 0) return;
        try {
            if (editingNoteId == 0) {
                await Db.Database.ExecuteSqlRawAsync(
                    @"INSERT INTO ""NETH_ClientNotes"" (""ClientId"", ""StylistId"", ""NoteText"", ""ShortDescription"", ""ManualDate"") 
                      VALUES ({0}, {1}, {2}, {3}, {4})",
                    selectedClientId, selectedStylistId, modalFullNote, modalShortDesc, modalDate.ToUniversalTime()
                );
            } else {
                await Db.Database.ExecuteSqlRawAsync(
                    @"UPDATE ""NETH_ClientNotes"" 
                      SET ""NoteText"" = {0}, ""ShortDescription"" = {1}, ""ManualDate"" = {2} 
                      WHERE ""Id"" = {3}",
                    modalFullNote, modalShortDesc, modalDate.ToUniversalTime(), editingNoteId
                );
            }
            
            showModal = false;
            await LoadNotes();
        } catch (Exception ex) { localError = "SAVE_ERR: " + ex.Message; }
    }

    private async Task DeleteNote(int id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this history entry?")) return;
        try {
            await Db.Database.ExecuteSqlRawAsync(@"DELETE FROM ""NETH_ClientNotes"" WHERE ""Id"" = {0}", id);
            await LoadNotes();
        } catch (Exception ex) { localError = "DEL_ERR: " + ex.Message; }
    }
}