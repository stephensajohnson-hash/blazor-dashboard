@page "/admin/neth-client-notes"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using Dashboard.Components
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex font-sans">
    <NETHAdminSidebar />

    <div class="flex-1 p-8">
        <div class="max-w-4xl mx-auto">
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h2 class="text-2xl font-black text-white uppercase tracking-tight">Client Notes</h2>
                    <p class="text-[10px] text-[#D2B48C] font-mono uppercase tracking-widest">History & Formulas</p>
                </div>
                <button @onclick="() => showAddModal = true" class="bg-blue-600 hover:bg-blue-500 text-white px-6 py-2 rounded font-black uppercase text-[10px] transition shadow-lg">
                    + Add New Note
                </button>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-8">
                <div class="space-y-1">
                    <label class="text-[9px] font-black uppercase text-gray-500 ml-1">Select Stylist</label>
                    <select @onchange="OnStylistChanged" value="@selectedStylistId" class="w-full bg-[#25262b] border border-gray-700 rounded p-3 text-white text-xs outline-none focus:border-blue-500">
                        <option value="0">-- Select Stylist --</option>
                        @foreach(var s in allStylists) { <option value="@s.Id">@s.Name</option> }
                    </select>
                </div>
                <div class="space-y-1">
                    <label class="text-[9px] font-black uppercase text-gray-500 ml-1">Select Client</label>
                    <select @onchange="OnClientChanged" value="@selectedClientId" class="w-full bg-[#25262b] border border-gray-700 rounded p-3 text-white text-xs outline-none focus:border-blue-500">
                        <option value="0">-- Select Client --</option>
                        @foreach(var c in allClients) { <option value="@c.Id">@c.FirstName @c.LastName</option> }
                    </select>
                </div>
            </div>

            @if (clientNotes.Any())
            {
                <div class="space-y-4">
                    @foreach (var note in clientNotes.OrderByDescending(n => n.CreatedAt))
                    {
                        <div class="bg-[#25262b] p-6 rounded-xl border border-gray-700 shadow-xl relative group">
                            <div class="flex justify-between items-start mb-4">
                                <span class="text-[10px] font-mono text-blue-400">@note.CreatedAt.ToString("MMM dd, yyyy")</span>
                                <button @onclick="() => DeleteNote(note.Id)" class="opacity-0 group-hover:opacity-100 text-red-500 hover:text-red-400 transition text-xs">Delete</button>
                            </div>
                            <p class="text-gray-200 text-sm leading-relaxed whitespace-pre-wrap">@note.NoteText</p>
                        </div>
                    }
                </div>
            }
            else if (selectedClientId > 0)
            {
                <div class="text-center py-20 border-2 border-dashed border-gray-800 rounded-xl">
                    <p class="text-gray-600 text-xs uppercase font-black tracking-widest">No notes found for this client.</p>
                </div>
            }
        </div>
    </div>
</div>

@if (showAddModal)
{
    <div class="fixed inset-0 bg-black/80 backdrop-blur-sm z-[1000] flex items-center justify-center p-4">
        <div class="bg-[#25262b] w-full max-w-lg rounded-2xl border border-gray-700 shadow-2xl overflow-hidden">
            <div class="p-6 border-b border-gray-800 flex justify-between items-center">
                <h3 class="text-white font-black uppercase text-xs tracking-widest">New Client Note</h3>
                <button @onclick="() => showAddModal = false" class="text-gray-500 hover:text-white">&times;</button>
            </div>
            <div class="p-6 space-y-4">
                <textarea @bind="newNoteText" placeholder="Enter formulas, preferences, or history..." 
                          class="w-full h-40 bg-black/20 border border-gray-700 rounded-xl p-4 text-white text-sm outline-none focus:border-blue-500 resize-none"></textarea>
                
                <div class="flex gap-3 pt-2">
                    <button @onclick="SaveNote" class="flex-1 bg-blue-600 hover:bg-blue-500 text-white font-black uppercase text-[10px] py-3 rounded-lg transition shadow-lg">Save Note</button>
                    <button @onclick="() => showAddModal = false" class="px-6 bg-gray-800 text-gray-400 font-black uppercase text-[10px] py-3 rounded-lg hover:bg-gray-700 transition">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool showAddModal = false;
    private int selectedStylistId = 0;
    private int selectedClientId = 0;
    private string newNoteText = "";
    private List<NETH_Stylist> allStylists = new();
    private List<NETH_Client> allClients = new();
    private List<NETH_ClientNote> clientNotes = new();

    protected override async Task OnInitializedAsync()
    {
        allStylists = await Db.NETH_Stylists.AsNoTracking().ToListAsync();
        allClients = await Db.NETH_Clients.AsNoTracking().ToListAsync();

        // Catch QueryString Parameters
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("StylistId", out var sId))
            selectedStylistId = int.Parse(sId);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("ClientId", out var cId))
            selectedClientId = int.Parse(cId);

        if (selectedClientId > 0) await LoadNotes();
    }

    private async Task OnStylistChanged(ChangeEventArgs e)
    {
        selectedStylistId = int.Parse(e.Value?.ToString() ?? "0");
        StateHasChanged();
    }

    private async Task OnClientChanged(ChangeEventArgs e)
    {
        selectedClientId = int.Parse(e.Value?.ToString() ?? "0");
        await LoadNotes();
    }

    private async Task LoadNotes()
    {
        if (selectedClientId == 0) return;
        clientNotes = await Db.NETH_ClientNotes
            .Where(x => x.ClientId == selectedClientId)
            .OrderByDescending(x => x.CreatedAt)
            .ToListAsync();
        StateHasChanged();
    }

    private async Task SaveNote()
    {
        if (selectedClientId == 0 || selectedStylistId == 0 || string.IsNullOrWhiteSpace(newNoteText)) return;

        var note = new NETH_ClientNote
        {
            ClientId = selectedClientId,
            StylistId = selectedStylistId,
            NoteText = newNoteText,
            CreatedAt = DateTime.UtcNow
        };

        Db.NETH_ClientNotes.Add(note);
        await Db.SaveChangesAsync();
        
        newNoteText = "";
        showAddModal = false;
        await LoadNotes();
    }

    private async Task DeleteNote(int id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this note?")) return;
        var note = await Db.NETH_ClientNotes.FindAsync(id);
        if (note != null)
        {
            Db.NETH_ClientNotes.Remove(note);
            await Db.SaveChangesAsync();
            await LoadNotes();
        }
    }
}