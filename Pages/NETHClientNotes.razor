@page "/admin/neth-client-notes"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using Dashboard.Components
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex font-sans">
    <NETHAdminSidebar />

    <div class="flex-1 p-8">
        <div class="max-w-4xl mx-auto">
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h2 class="text-2xl font-black text-white uppercase tracking-tight">Client History</h2>
                    <p class="text-[10px] text-[#D2B48C] font-mono uppercase tracking-widest">Formula Ledger</p>
                </div>
                <button @onclick="() => OpenModal()" class="bg-blue-600 hover:bg-blue-500 text-white px-6 py-2 rounded font-black uppercase text-[10px] transition shadow-lg">
                    + Create Entry
                </button>
            </div>

            @if (!string.IsNullOrEmpty(localError))
            {
                <div class="mb-4 p-3 bg-red-900/20 border border-red-500/50 text-red-400 text-[10px] font-mono uppercase">
                    @localError
                </div>
            }

            <div class="grid grid-cols-2 gap-4 mb-8">
                <div class="space-y-1">
                    <label class="text-[9px] font-black uppercase text-gray-500 ml-1">Stylist</label>
                    <select @onchange="OnStylistChanged" value="@selectedStylistId" class="w-full bg-[#25262b] border border-gray-700 rounded p-3 text-white text-xs outline-none focus:border-blue-500">
                        <option value="0">-- Select Stylist --</option>
                        @foreach(var s in allStylists) { <option value="@s.Id">@s.Name</option> }
                    </select>
                </div>
                <div class="space-y-1">
                    <label class="text-[9px] font-black uppercase text-gray-500 ml-1">Client</label>
                    <select @onchange="OnClientChanged" value="@selectedClientId" class="w-full bg-[#25262b] border border-gray-700 rounded p-3 text-white text-xs outline-none focus:border-blue-500">
                        <option value="0">-- Select Client --</option>
                        @foreach(var c in allClients) { <option value="@c.Id">@c.FirstName @c.LastName</option> }
                    </select>
                </div>
            </div>

            <div class="space-y-4">
                @foreach (var note in displayNotes)
                {
                    <div class="bg-[#25262b] p-6 rounded-xl border border-gray-700 shadow-xl relative group transition-all hover:border-gray-500">
                        @* Hover Actions *@
                        <div class="absolute top-4 right-4 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                            <button @onclick="() => OpenModal(note)" class="p-2 bg-blue-600/20 hover:bg-blue-600 text-blue-400 hover:text-white rounded-lg transition">
                                <i class="fas fa-edit text-xs"></i>
                            </button>
                            <button @onclick="() => DeleteNote(note.Id)" class="p-2 bg-red-600/20 hover:bg-red-600 text-red-400 hover:text-white rounded-lg transition">
                                <i class="fas fa-trash text-xs"></i>
                            </button>
                        </div>

                        <div class="flex items-center gap-3 mb-2">
                            <span class="text-[10px] font-black font-mono text-blue-500 uppercase">@note.DateDisplay</span>
                            @if (!string.IsNullOrEmpty(note.ShortDesc))
                            {
                                <span class="text-[10px] font-black text-white uppercase tracking-widest border-l border-gray-700 pl-3">@note.ShortDesc</span>
                            }
                        </div>
                        <p class="text-gray-400 text-sm leading-relaxed whitespace-pre-wrap">@note.Text</p>
                    </div>
                }

                @if (!displayNotes.Any() && selectedClientId > 0)
                {
                    <div class="text-center py-20 border-2 border-dashed border-gray-800 rounded-xl">
                        <p class="text-gray-600 text-xs uppercase font-black tracking-widest">No entries found.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (showModal)
{
    <div class="fixed inset-0 bg-black/90 backdrop-blur-sm z-[1000] flex items-center justify-center p-4">
        <div class="bg-[#25262b] w-full max-w-xl rounded-2xl border border-gray-700 shadow-2xl overflow-hidden animate-in zoom-in-95 duration-200">
            <div class="p-6 border-b border-gray-800 flex justify-between items-center bg-black/20">
                <h3 class="text-white font-black uppercase text-xs tracking-widest">@(editingNoteId == 0 ? "New Entry" : "Edit Entry")</h3>
                <button @onclick="() => showModal = false" class="text-gray-500 hover:text-white text-2xl">&times;</button>
            </div>
            <div class="p-8 space-y-5">
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-[9px] font-black uppercase text-gray-500">Date</label>
                        <input type="date" @bind="modalDate" class="w-full bg-black/40 border border-gray-700 rounded-lg p-3 text-white text-xs outline-none focus:border-blue-500" />
                    </div>
                    <div class="space-y-1">
                        <label class="text-[9px] font-black uppercase text-gray-500">Short Description</label>
                        <input type="text" @bind="modalShortDesc" placeholder="e.g. Highlights, Trim, etc." 
                               class="w-full bg-black/40 border border-gray-700 rounded-lg p-3 text-white text-xs outline-none focus:border-blue-500" />
                    </div>
                </div>

                <div class="space-y-1">
                    <label class="text-[9px] font-black uppercase text-gray-500">Full Note / Formula</label>
                    <textarea @bind="modalFullNote" placeholder="Detailed history..." 
                              class="w-full h-48 bg-black/40 border border-gray-700 rounded-xl p-4 text-white text-sm outline-none focus:border-blue-500 resize-none"></textarea>
                </div>
                
                <div class="flex gap-3 pt-2">
                    <button @onclick="SaveEntry" class="flex-1 bg-blue-600 hover:bg-blue-500 text-white font-black uppercase text-[10px] py-4 rounded-xl transition shadow-xl tracking-widest">
                        @(editingNoteId == 0 ? "Add to History" : "Update Entry")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool showModal = false;
    private int editingNoteId = 0;
    private int selectedStylistId = 0;
    private int selectedClientId = 0;
    
    private DateTime modalDate = DateTime.Today;
    private string modalShortDesc = "";
    private string modalFullNote = "";
    
    private string localError = "";
    private List<NETH_Stylist> allStylists = new();
    private List<NETH_Client> allClients = new();
    private List<NoteDisplay> displayNotes = new();

    public class NoteDisplay {
        public int Id { get; set; }
        public string Text { get; set; } = "";
        public string ShortDesc { get; set; } = "";
        public DateTime EntryDate { get; set; }
        public string DateDisplay => EntryDate.ToString("MMM dd, yyyy");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Update Schema on load to ensure new columns exist
            await Db.Database.ExecuteSqlRawAsync(@"
                ALTER TABLE ""NETH_ClientNotes"" ADD COLUMN IF NOT EXISTS ""ShortDescription"" TEXT;
                ALTER TABLE ""NETH_ClientNotes"" ADD COLUMN IF NOT EXISTS ""ManualDate"" TIMESTAMP DEFAULT CURRENT_TIMESTAMP;
            ");

            allStylists = await Db.NETH_Stylists.AsNoTracking().ToListAsync();
            allClients = await Db.NETH_Clients.AsNoTracking().ToListAsync();

            var uri = Nav.ToAbsoluteUri(Nav.Uri);
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
            
            if (query.TryGetValue("StylistId", out var sId) && !string.IsNullOrEmpty(sId)) selectedStylistId = int.Parse(sId.ToString());
            if (query.TryGetValue("ClientId", out var cId) && !string.IsNullOrEmpty(cId)) selectedClientId = int.Parse(cId.ToString());

            if (selectedClientId > 0) await LoadNotes();
            StateHasChanged();
        }
    }

    private async Task OnStylistChanged(ChangeEventArgs e)
    {
        selectedStylistId = int.Parse(e.Value?.ToString() ?? "0");
        StateHasChanged();
    }

    private async Task OnClientChanged(ChangeEventArgs e)
    {
        selectedClientId = int.Parse(e.Value?.ToString() ?? "0");
        await LoadNotes();
    }

    private async Task LoadNotes()
    {
        if (selectedClientId == 0) return;
        try {
            var rawData = await Db.Database.SqlQueryRaw<NoteSqlResult>(
                @"SELECT ""Id"", ""NoteText"", ""ShortDescription"", ""ManualDate"" 
                  FROM ""NETH_ClientNotes"" 
                  WHERE ""ClientId"" = {0} 
                  ORDER BY ""ManualDate"" DESC", 
                selectedClientId
            ).ToListAsync();

            displayNotes = rawData.Select(x => new NoteDisplay {
                Id = x.Id,
                Text = x.NoteText,
                ShortDesc = x.ShortDescription ?? "",
                EntryDate = x.ManualDate
            }).ToList();
        } catch (Exception ex) { localError = "LOAD_ERR: " + ex.Message; }
        StateHasChanged();
    }

    private void OpenModal(NoteDisplay? existing = null) {
        if (selectedClientId == 0 || selectedStylistId == 0) {
            localError = "SELECT STYLIST AND CLIENT FIRST";
            return;
        }
        
        if (existing != null) {
            editingNoteId = existing.Id;
            modalDate = existing.EntryDate;
            modalShortDesc = existing.ShortDesc;
            modalFullNote = existing.Text;
        } else {
            editingNoteId = 0;
            modalDate = DateTime.Today;
            modalShortDesc = "";
            modalFullNote = "";
        }

        localError = "";
        showModal = true;
    }

    private async Task SaveEntry()
    {
        if (string.IsNullOrWhiteSpace(modalFullNote)) return;
        try {
            if (editingNoteId == 0) {
                await Db.Database.ExecuteSqlRawAsync(
                    @"INSERT INTO ""NETH_ClientNotes"" (""ClientId"", ""StylistId"", ""NoteText"", ""ShortDescription"", ""ManualDate"") 
                      VALUES ({0}, {1}, {2}, {3}, {4})",
                    selectedClientId, selectedStylistId, modalFullNote, modalShortDesc, modalDate.ToUniversalTime()
                );
            } else {
                await Db.Database.ExecuteSqlRawAsync(
                    @"UPDATE ""NETH_ClientNotes"" 
                      SET ""NoteText"" = {0}, ""ShortDescription"" = {1}, ""ManualDate"" = {2} 
                      WHERE ""Id"" = {3}",
                    modalFullNote, modalShortDesc, modalDate.ToUniversalTime(), editingNoteId
                );
            }
            
            showModal = false;
            await LoadNotes();
        } catch (Exception ex) { localError = "SAVE_ERR: " + ex.Message; }
    }

    private async Task DeleteNote(int id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this history entry?")) return;
        try {
            await Db.Database.ExecuteSqlRawAsync(@"DELETE FROM ""NETH_ClientNotes"" WHERE ""Id"" = {0}", id);
            await LoadNotes();
        } catch (Exception ex) { localError = "DEL_ERR: " + ex.Message; }
    }

    private class NoteSqlResult {
        public int Id { get; set; }
        public string NoteText { get; set; } = "";
        public string? ShortDescription { get; set; }
        public DateTime ManualDate { get; set; }
    }
}