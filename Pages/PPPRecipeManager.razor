@page "/ppp-recipe-manager"
@page "/ppp-recipe-manager/{OwnerId:int}"
@using Dashboard
@using Dashboard.Components
@using Microsoft.EntityFrameworkCore
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#0a0a0a] text-white p-6 font-black relative overflow-hidden">
    
    <PPPAdminNav CurrentPage="Recipe Manager" />

    <div class="flex justify-between items-end mb-10">
        <div>
            <h2 class="text-2xl uppercase tracking-tighter">
                @(currentOwner != null ? $"{currentOwner.BusinessName} Recipes" : "All System Recipes")
            </h2>
            <p class="text-[10px] text-gray-500 uppercase tracking-widest mt-1">
                Cataloged Formulas & Macro Projections
            </p>
        </div>
        <button @onclick="CreateNew" class="bg-orange-600 hover:bg-orange-500 text-white px-8 py-3 rounded-xl text-[10px] uppercase tracking-widest transition shadow-lg">
            ＋ Create New Recipe
        </button>
    </div>

    @if (isLoading)
    {
        <div class="py-20 flex justify-center">
            <div class="w-10 h-10 border-4 border-orange-500 border-t-transparent rounded-full animate-spin"></div>
        </div>
    }
    else if (!recipes.Any())
    {
        <div class="bg-[#111] border-2 border-dashed border-gray-800 rounded-3xl p-20 text-center">
            <span class="text-5xl mb-4 block">🍳</span>
            <h3 class="text-gray-500 uppercase tracking-widest text-sm">No recipes found in this vault</h3>
            <button @onclick="CreateNew" class="mt-6 text-orange-500 text-[10px] uppercase border border-orange-500/30 px-4 py-2 rounded-lg hover:bg-orange-500/10 transition">Start first recipe</button>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
            @foreach (var r in recipes)
            {
                <div class="bg-[#111] border border-gray-800 rounded-3xl p-6 hover:border-orange-500/50 transition group relative overflow-hidden">
                    <div class="flex justify-between items-start mb-4">
                        <div>
                            <h4 class="text-lg uppercase tracking-tight text-white group-hover:text-orange-400 transition">@r.Name</h4>
                            <p class="text-[9px] text-gray-500 uppercase">@r.Owner?.BusinessName</p>
                        </div>
                        <div class="bg-black px-3 py-1 rounded-full border border-gray-800 text-[9px] font-mono text-emerald-400">
                            @r.Servings Servings
                        </div>
                    </div>

                    <p class="text-xs text-gray-400 font-light leading-relaxed mb-6 line-clamp-2 h-8">@r.Description</p>

                    <div class="flex justify-end items-center pt-4 border-t border-white/5 gap-2">
                        <button @onclick='() => Nav.NavigateTo($"/ppp-recipe-editor/{r.Id}")' class="p-2 bg-blue-600/10 text-blue-400 rounded-lg hover:bg-blue-600 hover:text-white transition" title="Edit">✎</button>
                        <button @onclick="() => ConfirmDelete(r)" class="p-2 bg-red-600/10 text-red-500 rounded-lg hover:bg-red-600 hover:text-white transition" title="Delete">✕</button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int? OwnerId { get; set; }
    private List<PPP_Recipe> recipes = new();
    private PPP_Owner? currentOwner;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try 
        {
            var query = Db.PPP_Recipes
                .Include(r => r.Owner)
                .AsNoTracking();

            if (OwnerId.HasValue)
            {
                recipes = await query.Where(r => r.OwnerId == OwnerId.Value).OrderBy(r => r.Name).ToListAsync();
                currentOwner = await Db.PPP_Owners.FindAsync(OwnerId.Value);
            }
            else
            {
                recipes = await query.OrderBy(r => r.Name).ToListAsync();
                currentOwner = null;
            }
        }
        catch (Exception) { }
        finally 
        {
            isLoading = false;
        }
    }

    private void CreateNew()
    {
        if (OwnerId.HasValue) Nav.NavigateTo($"/ppp-recipe-editor?ownerId={OwnerId}");
        else Nav.NavigateTo("/ppp-recipe-editor");
    }

    private async Task ConfirmDelete(PPP_Recipe r)
    {
        // Add JS confirm logic if needed
        Db.PPP_Recipes.Remove(r);
        await Db.SaveChangesAsync();
        await LoadData();
    }
}