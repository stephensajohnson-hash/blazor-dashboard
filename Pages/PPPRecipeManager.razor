@page "/ppp-recipe-manager"
@page "/ppp-recipe-manager/{OwnerId:int}"
@using Dashboard
@using Dashboard.Components
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#0a0a0a] text-white p-6 font-black relative overflow-hidden">
    
    <PPPAdminNav CurrentPage="Recipe Manager" />

    <div class="flex justify-between items-end mb-10">
        <div>
            <h2 class="text-2xl uppercase tracking-tighter">
                @(currentOwner != null ? $"{currentOwner.BusinessName} Recipes" : "All System Recipes")
            </h2>
            <p class="text-[10px] text-gray-500 uppercase tracking-widest mt-1">
                Visual Formula Catalog
            </p>
        </div>
        <button @onclick="CreateNew" class="bg-orange-600 hover:bg-orange-500 text-white px-8 py-3 rounded-xl text-[10px] uppercase tracking-widest transition shadow-lg">
            ＋ Create New Recipe
        </button>
    </div>

    @if (isLoading)
    {
        <div class="py-20 flex justify-center">
            <div class="w-10 h-10 border-4 border-orange-500 border-t-transparent rounded-full animate-spin"></div>
        </div>
    }
    else if (!recipes.Any())
    {
        <div class="bg-[#111] border-2 border-dashed border-gray-800 rounded-3xl p-20 text-center">
            <span class="text-5xl mb-4 block">🍳</span>
            <h3 class="text-gray-500 uppercase tracking-widest text-sm">No formulas found</h3>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
            @foreach (var r in recipes)
            {
                <div class="bg-[#111] border border-gray-800 rounded-3xl overflow-hidden hover:border-orange-500/50 transition group flex flex-col">
                    @* Recipe Image Header *@
                    <div class="aspect-video bg-black relative overflow-hidden border-b border-gray-800">
                        @if (r.ImageId.HasValue)
                        {
                            <img src="/db-images-ppp/@r.ImageId" class="w-full h-full object-cover group-hover:scale-105 transition duration-500" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center opacity-20">
                                <span class="text-4xl">🍲</span>
                            </div>
                        }
                        <div class="absolute top-4 right-4 bg-black/80 backdrop-blur-md px-3 py-1 rounded-full border border-gray-700 text-[9px] font-mono text-emerald-400">
                            @r.Servings Servings @(!string.IsNullOrEmpty(r.ServingSize) ? $"({r.ServingSize})" : "")
                        </div>
                    </div>

                    <div class="p-6 flex-1 flex flex-col">
                        <div class="mb-4">
                            <h4 class="text-lg uppercase tracking-tight text-white group-hover:text-orange-400 transition">@r.Name</h4>
                            <p class="text-[9px] text-gray-500 uppercase">@r.Owner?.BusinessName</p>
                        </div>

                        <div class="flex justify-end items-center mt-auto pt-6 border-t border-white/5 gap-2">
                            <button @onclick='() => Nav.NavigateTo($"/ppp-recipe-editor/{r.Id}")' class="px-4 py-2 bg-blue-600/10 text-blue-400 text-[10px] uppercase font-black rounded-lg hover:bg-blue-600 hover:text-white transition">Edit</button>
                            <button @onclick="() => ConfirmDelete(r)" class="p-2 bg-red-600/10 text-red-500 rounded-lg hover:bg-red-600 hover:text-white transition">✕</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int? OwnerId { get; set; }
    private List<PPP_Recipe> recipes = new();
    private PPP_Owner? currentOwner;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync() => await LoadData();

    private async Task LoadData() {
        isLoading = true;
        try {
            var query = Db.PPP_Recipes.Include(r => r.Owner).AsNoTracking();
            if (OwnerId.HasValue) {
                recipes = await query.Where(r => r.OwnerId == OwnerId.Value).OrderBy(r => r.Name).ToListAsync();
                currentOwner = await Db.PPP_Owners.FindAsync(OwnerId.Value);
            } else {
                recipes = await query.OrderBy(r => r.Name).ToListAsync();
                currentOwner = null;
            }
        } catch { }
        isLoading = false;
    }

    private void CreateNew() {
        if (OwnerId.HasValue) Nav.NavigateTo($"/ppp-recipe-editor?ownerId={OwnerId}");
        else Nav.NavigateTo("/ppp-recipe-editor");
    }

    private async Task ConfirmDelete(PPP_Recipe r) {
        Db.PPP_Recipes.Remove(r);
        await Db.SaveChangesAsync();
        await LoadData();
    }
}