@page "/ppp-recipe-manager/{OwnerId:int}"
@using Dashboard
@using Dashboard.Components
@using Dashboard.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#050505] text-slate-200 p-4 md:p-8 font-sans antialiased">
    <PPPAdminNav CurrentPage="Recipe Vault" />

    @if (owner != null)
    {
        @* Header Section *@
        <div class="max-w-7xl mx-auto mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div>
                <h1 class="text-5xl font-black tracking-tighter text-white italic uppercase">@owner.BusinessName</h1>
                <p class="text-emerald-500 font-bold tracking-[0.3em] text-xs mt-2">PROPRIETARY FORMULARY</p>
            </div>
            <button @onclick='() => Nav.NavigateTo($"/ppp-recipe-editor?ownerId={OwnerId}")' 
                    class="bg-emerald-600 hover:bg-emerald-500 text-white px-8 py-4 rounded-2xl font-black text-xs uppercase tracking-widest transition-all active:scale-95 shadow-lg shadow-emerald-900/20">
                ＋ Create New Recipe
            </button>
        </div>

        @* Recipe Cards Grid *@
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var recipe in recipes)
            {
                <div class="group bg-[#0a0a0a] border border-slate-800/50 rounded-[2.5rem] overflow-hidden hover:border-emerald-500/50 transition-all duration-500 shadow-2xl hover:shadow-emerald-900/10 flex flex-col">
                    @* Image Header *@
                    <div class="aspect-video w-full bg-slate-900 relative overflow-hidden">
                        @if (recipe.ImageId.HasValue)
                        {
                            <img src="/db-images-ppp/@recipe.ImageId" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center opacity-20">
                                <span class="text-4xl">🍳</span>
                            </div>
                        }
                        <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-transparent to-transparent"></div>
                    </div>

                    @* Content *@
                    <div class="p-8 flex-1 flex flex-col">
                        <h3 class="text-2xl font-black text-white tracking-tight mb-2 uppercase italic group-hover:text-emerald-400 transition-colors">@recipe.Name</h3>
                        
                        <div class="flex items-center gap-3 mb-6">
                            <span class="bg-emerald-500/10 text-emerald-500 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border border-emerald-500/20">
                                @recipe.Servings Servings
                            </span>
                            <span class="text-slate-500 text-[10px] font-bold uppercase tracking-widest">
                                @(string.IsNullOrEmpty(recipe.ServingSize) ? "Yield Volume" : recipe.ServingSize)
                            </span>
                        </div>

                        @* Macro Grid *@
                        <div class="grid grid-cols-3 gap-3 mb-8">
                            @{
                                var totals = CalculateTotals(recipe);
                                double perServing = Math.Max(1, recipe.Servings);
                            }
                            <div class="bg-white/5 rounded-2xl p-3 border border-white/5 text-center">
                                <span class="text-[8px] text-slate-500 uppercase font-black block mb-1">Cals</span>
                                <span class="text-sm font-mono font-bold text-white">@((totals.Cals / perServing).ToString("N0"))</span>
                            </div>
                            <div class="bg-white/5 rounded-2xl p-3 border border-white/5 text-center">
                                <span class="text-[8px] text-slate-500 uppercase font-black block mb-1">Prot</span>
                                <span class="text-sm font-mono font-bold text-blue-400">@((totals.Prot / perServing).ToString("N1"))g</span>
                            </div>
                            <div class="bg-white/5 rounded-2xl p-3 border border-white/5 text-center">
                                <span class="text-[8px] text-slate-500 uppercase font-black block mb-1">Fat</span>
                                <span class="text-sm font-mono font-bold text-yellow-500">@((totals.Fat / perServing).ToString("N1"))g</span>
                            </div>
                            <div class="bg-white/5 rounded-2xl p-3 border border-white/5 text-center">
                                <span class="text-[8px] text-slate-500 uppercase font-black block mb-1">Carb</span>
                                <span class="text-sm font-mono font-bold text-red-500">@((totals.Carb / perServing).ToString("N1"))g</span>
                            </div>
                            <div class="bg-white/5 rounded-2xl p-3 border border-white/5 text-center">
                                <span class="text-[8px] text-slate-500 uppercase font-black block mb-1">Fiber</span>
                                <span class="text-sm font-mono font-bold text-emerald-600">@((totals.Fiber / perServing).ToString("N1"))g</span>
                            </div>
                            <div class="bg-emerald-500/10 rounded-2xl p-3 border border-emerald-500/20 text-center">
                                <span class="text-[8px] text-emerald-500 uppercase font-black block mb-1">Net Carbs</span>
                                <span class="text-sm font-mono font-bold text-emerald-400">@(((totals.Carb - totals.Fiber) / perServing).ToString("N1"))g</span>
                            </div>
                        </div>

                        @* Action Button *@
                        <button @onclick='() => Nav.NavigateTo($"/ppp-recipe-editor/{recipe.Id}")'
                                class="w-full bg-slate-800 hover:bg-emerald-600 text-white py-4 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all group-hover:shadow-lg active:scale-[0.98]">
                            Edit
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int OwnerId { get; set; }
    private PPP_Owner? owner;
    private List<PPP_Recipe> recipes = new();

    protected override async Task OnInitializedAsync()
    {
        owner = await Db.PPP_Owners.AsNoTracking().FirstOrDefaultAsync(o => o.Id == OwnerId);
        recipes = await Db.PPP_Recipes
            .AsNoTracking()
            .Include(r => r.IngredientGroups)
                .ThenInclude(ig => ig.Ingredients)
                    .ThenInclude(m => m.Ingredient)
            .Where(r => r.OwnerId == OwnerId)
            .OrderBy(r => r.Name)
            .ToListAsync();
    }

    private (double Cals, double Prot, double Fat, double Carb, double Fiber) CalculateTotals(PPP_Recipe r)
    {
        double cals = 0, prot = 0, fat = 0, carb = 0, fiber = 0;
        foreach (var group in r.IngredientGroups)
        {
            foreach (var mapping in group.Ingredients)
            {
                if (mapping.Ingredient != null)
                {
                    double qty = mapping.Quantity;
                    double factor = qty; 
                    
                    if (!string.Equals(mapping.Unit, mapping.Ingredient.Unit, StringComparison.OrdinalIgnoreCase))
                    {
                        if (PPPUnitConverter.TryConvert(qty, mapping.Unit ?? "", mapping.Ingredient.Unit ?? "", out double norm))
                            factor = norm;
                    }

                    cals += mapping.Ingredient.Calories * factor;
                    prot += mapping.Ingredient.Protein * factor;
                    fat += mapping.Ingredient.Fat * factor;
                    carb += mapping.Ingredient.Carbs * factor;
                    fiber += mapping.Ingredient.Fiber * factor;
                }
            }
        }
        return (cals, prot, fat, carb, fiber);
    }
}