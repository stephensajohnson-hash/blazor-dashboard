@page "/ppp-recipe-manager"
@page "/ppp-recipe-manager/{OwnerId:int}"
@using Dashboard
@using Dashboard.Components
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#0a0a0a] text-white p-6 font-black relative overflow-hidden">
    
    <PPPAdminNav CurrentPage="Recipe Manager" />

    <div class="flex justify-between items-end mb-10">
        <div>
            <h2 class="text-2xl uppercase tracking-tighter">
                @(currentOwner != null ? $"{currentOwner.BusinessName} Recipes" : "All System Recipes")
            </h2>
            <p class="text-[10px] text-gray-500 uppercase tracking-widest mt-1">
                Visual Formula Catalog
            </p>
        </div>
        <button @onclick="CreateNew" class="bg-orange-600 hover:bg-orange-500 text-white px-8 py-3 rounded-xl text-[10px] uppercase tracking-widest transition shadow-lg">
            ＋ Create New Recipe
        </button>
    </div>

    @if (isLoading)
    {
        <div class="py-20 flex justify-center">
            <div class="w-10 h-10 border-4 border-orange-500 border-t-transparent rounded-full animate-spin"></div>
        </div>
    }
    else if (!recipes.Any())
    {
        <div class="bg-[#111] border-2 border-dashed border-gray-800 rounded-3xl p-20 text-center">
            <span class="text-5xl mb-4 block">🍳</span>
            <h3 class="text-gray-500 uppercase tracking-widest text-sm">No formulas found</h3>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
            @foreach (var r in recipes)
            {
                <div class="bg-[#111] border border-gray-800 rounded-3xl overflow-hidden hover:border-orange-500/50 transition group flex flex-col shadow-2xl">
                    @* Recipe Image Header *@
                    <div class="aspect-video bg-black relative overflow-hidden border-b border-gray-800">
                        @if (r.ImageId.HasValue)
                        {
                            <img src="/db-images-ppp/@r.ImageId" class="w-full h-full object-cover group-hover:scale-105 transition duration-500" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center opacity-20">
                                <span class="text-4xl">🍲</span>
                            </div>
                        }
                        <div class="absolute top-4 right-4 bg-black/80 backdrop-blur-md px-3 py-1 rounded-full border border-gray-700 text-[9px] font-mono text-emerald-400">
                            @r.Servings Servings @(!string.IsNullOrEmpty(r.ServingSize) ? $"({r.ServingSize})" : "")
                        </div>
                    </div>

                    <div class="p-6 flex-1 flex flex-col">
                        <div class="mb-6">
                            <h4 class="text-lg uppercase tracking-tight text-white group-hover:text-orange-400 transition mb-1">@r.Name</h4>
                            <p class="text-[9px] text-gray-500 uppercase tracking-widest">@r.Owner?.BusinessName</p>
                        </div>

                        @* Macro Quick-Look Display *@
                        <div class="grid grid-cols-4 gap-2 mb-6">
                            @{
                                var safe = Math.Max(1, r.Servings);
                                var totalCals = r.IngredientGroups.SelectMany(g => g.Ingredients).Sum(i => i.Quantity * (i.Ingredient?.Calories ?? 0));
                                var totalProt = r.IngredientGroups.SelectMany(g => g.Ingredients).Sum(i => i.Quantity * (i.Ingredient?.Protein ?? 0));
                                var totalFat = r.IngredientGroups.SelectMany(g => g.Ingredients).Sum(i => i.Quantity * (i.Ingredient?.Fat ?? 0));
                                var totalCarb = r.IngredientGroups.SelectMany(g => g.Ingredients).Sum(i => i.Quantity * (i.Ingredient?.Carbs ?? 0));
                                var totalFiber = r.IngredientGroups.SelectMany(g => g.Ingredients).Sum(i => i.Quantity * (i.Ingredient?.Fiber ?? 0));
                                var netCarb = totalCarb - totalFiber;
                            }
                            <div class="col-span-4 bg-white/5 rounded-xl p-3 border border-white/5 flex justify-between items-center mb-1">
                                <span class="text-[10px] text-gray-500 uppercase">Calories</span>
                                <span class="text-2xl font-black text-white">@((totalCals / safe).ToString("N0"))</span>
                            </div>
                            <div class="bg-blue-900/10 rounded-xl p-2 border border-blue-500/10 text-center">
                                <span class="text-[8px] text-blue-500 uppercase block">Prot</span>
                                <span class="text-[14px] font-bold text-blue-400">@((totalProt / safe).ToString("N1"))g</span>
                            </div>
                            <div class="bg-yellow-900/10 rounded-xl p-2 border border-yellow-500/10 text-center">
                                <span class="text-[8px] text-yellow-500 uppercase block">Fat</span>
                                <span class="text-[14px] font-bold text-yellow-500">@((totalFat / safe).ToString("N1"))g</span>
                            </div>
                            <div class="bg-red-900/10 rounded-xl p-2 border border-red-500/10 text-center">
                                <span class="text-[8px] text-red-500 uppercase block">Carb</span>
                                <span class="text-[14px] font-bold text-red-400">@((totalCarb / safe).ToString("N1"))g</span>
                            </div>
                            <div class="bg-emerald-900/10 rounded-xl p-2 border border-emerald-500/10 text-center">
                                <span class="text-[8px] text-emerald-500 uppercase block">Net</span>
                                <span class="text-[14px] font-bold text-emerald-400">@((netCarb / safe).ToString("N1"))g</span>
                            </div>
                        </div>

                        <div class="flex justify-end items-center mt-auto pt-6 border-t border-white/5 gap-2">
                            <button @onclick='() => Nav.NavigateTo($"/ppp-recipe-editor/{r.Id}")' class="px-6 py-2 bg-blue-600/10 text-blue-400 text-[10px] uppercase font-black rounded-lg hover:bg-blue-600 hover:text-white transition">Edit Formula</button>
                            <button @onclick="() => ConfirmDelete(r)" class="p-2 bg-red-600/10 text-red-500 rounded-lg hover:bg-red-600 hover:text-white transition">✕</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int? OwnerId { get; set; }
    private List<PPP_Recipe> recipes = new();
    private PPP_Owner? currentOwner;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync() => await LoadData();

    private async Task LoadData() {
        isLoading = true;
        try {
            // Updated query to Include ingredients so macros calculate correctly
            var query = Db.PPP_Recipes
                .Include(r => r.Owner)
                .Include(r => r.IngredientGroups)
                    .ThenInclude(ig => ig.Ingredients)
                        .ThenInclude(m => m.Ingredient)
                .AsNoTracking();

            if (OwnerId.HasValue) {
                recipes = await query.Where(r => r.OwnerId == OwnerId.Value).OrderBy(r => r.Name).ToListAsync();
                currentOwner = await Db.PPP_Owners.FindAsync(OwnerId.Value);
            } else {
                recipes = await query.OrderBy(r => r.Name).ToListAsync();
                currentOwner = null;
            }
        } catch (Exception ex) {
            Console.WriteLine($"Error loading manager data: {ex.Message}");
        }
        isLoading = false;
    }

    private void CreateNew() {
        if (OwnerId.HasValue) Nav.NavigateTo($"/ppp-recipe-editor?ownerId={OwnerId}");
        else Nav.NavigateTo("/ppp-recipe-editor");
    }

    private async Task ConfirmDelete(PPP_Recipe r) {
        Db.PPP_Recipes.Remove(r);
        await Db.SaveChangesAsync();
        await LoadData();
    }
}