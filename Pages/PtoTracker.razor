@page "/pto-tracker"
@using Dashboard.Components.Bullet
@using Microsoft.AspNetCore.Components.Web

<BulletHeader ShowControls="false" CustomDateText="PTO & Leave Tracker" />

<div class="min-h-screen bg-[#0a0a0a] text-white font-sans p-6">
    <div class="max-w-4xl mx-auto flex flex-col items-center justify-center h-[50vh] border-2 border-dashed border-gray-800 rounded-2xl bg-[#111] p-10 text-center shadow-2xl">
        <span class="text-5xl mb-4">🌴</span>
        <h2 class="text-2xl font-black uppercase tracking-widest text-gray-400 mb-2">PTO Tracker Under Construction</h2>
        <p class="text-sm text-gray-500 mb-8 font-medium">The backend models and ledger services are currently being wired up.</p>
        
        @* Temporary DB Creation Button *@
        <button @onclick="TestDbCreation" class="bg-purple-900/30 hover:bg-purple-900/50 text-purple-400 border border-purple-800/50 px-8 py-4 rounded-xl text-xs font-black uppercase tracking-widest transition active:scale-95 shadow-lg">
            ⚙️ Initialize PTO Database Tables
        </button>
        
        @if (showTestMessage)
        {
            <div class="mt-8 p-4 bg-emerald-900/20 border border-emerald-800/50 rounded-lg text-emerald-400 text-xs font-mono font-black uppercase tracking-widest animate-in fade-in zoom-in duration-300">
                [Simulation: Database Schema Created Successfully]
            </div>
        }
    </div>
</div>

@code {
    private bool showTestMessage = false;

    private void TestDbCreation()
    {
        // Placeholder for future DbContext logic:
        // await db.Database.ExecuteSqlRawAsync(@"CREATE TABLE IF NOT EXISTS ""PtoPolicies""...");
        // await db.Database.ExecuteSqlRawAsync(@"CREATE TABLE IF NOT EXISTS ""PtoEntries""...");
        
        showTestMessage = true;
    }
}