@page "/pto-tracker"
@using Dashboard
@using Dashboard.Services
@using Dashboard.Components.Bullet
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@inject PtoService PtoService
@inject IJSRuntime JS
@inject NavigationManager Nav

<BulletHeader ShowControls="false" CustomDateText="@($"{currentYear} PTO Ledger")" />

<div class="min-h-screen bg-[#0a0a0a] text-white font-sans p-4">
    @if (isLoading)
    {
        <div class="flex flex-col items-center justify-center h-[60vh]">
            <div class="w-16 h-16 border-4 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
            <div class="text-gray-500 mt-6 font-black uppercase tracking-widest text-xs">Syncing Accruals...</div>
        </div>
    }
    else if (policy == null)
    {
        <div class="max-w-2xl mx-auto mt-20 p-10 border-2 border-dashed border-gray-800 rounded-3xl bg-[#111] text-center shadow-2xl">
            <div class="text-5xl mb-6">🗓️</div>
            <h2 class="text-2xl font-black uppercase tracking-tighter mb-4">Initialize @currentYear Policy</h2>
            <p class="text-gray-500 mb-8 font-medium">No PTO rules found for this year. Let's set your allowance and accrual schedule to begin tracking.</p>
            <button @onclick="OpenSetupModal" class="bg-blue-600 hover:bg-blue-500 text-white px-10 py-4 rounded-xl font-black uppercase tracking-widest transition shadow-lg active:scale-95">
                Setup @currentYear Policy
            </button>
        </div>
    }
    else
    {
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
            <div class="bg-[#111] border border-gray-800 p-4 rounded-2xl shadow-xl">
                <div class="text-[9px] text-gray-500 uppercase font-black mb-1">Total Available</div>
                <div class="text-xl font-mono font-black text-blue-400">@totalAvailable.ToString("N1")<span class="text-[10px] ml-1 text-gray-600 uppercase">Hrs</span></div>
            </div>
            <div class="bg-[#111] border border-gray-800 p-4 rounded-2xl shadow-xl">
                <div class="text-[9px] text-emerald-500 uppercase font-black mb-1">Earned to Date</div>
                <div class="text-xl font-mono font-black text-emerald-400">@earnedToDate.ToString("N1")<span class="text-[10px] ml-1 text-gray-600 uppercase">Hrs</span></div>
            </div>
            <div class="bg-[#111] border border-gray-800 p-4 rounded-2xl shadow-xl border-l-4 border-l-orange-600">
                <div class="text-[9px] text-orange-500 uppercase font-black mb-1">Current Balance</div>
                <div class="text-xl font-mono font-black text-orange-400">@currentBalance.ToString("N1")<span class="text-[10px] ml-1 text-gray-600 uppercase">Hrs</span></div>
            </div>
            <div class="bg-[#111] border border-gray-800 p-4 rounded-2xl shadow-xl">
                <div class="text-[9px] text-gray-500 uppercase font-black mb-1">Spent to Date</div>
                <div class="text-xl font-mono font-black text-gray-400">@spentToDate.ToString("N1")<span class="text-[10px] ml-1 text-gray-600 uppercase">Hrs</span></div>
            </div>
            <div class="bg-[#111] border border-gray-800 p-4 rounded-2xl shadow-xl">
                <div class="text-[9px] text-blue-500 uppercase font-black mb-1">PTO Burn</div>
                <div class="text-xl font-mono font-black">@ptoBurnPct.ToString("P0")</div>
                <div class="w-full h-1 bg-gray-800 rounded-full mt-2 overflow-hidden">
                    <div class="bg-blue-500 h-full" style="width: @(ptoBurnPct * 100)%"></div>
                </div>
            </div>
            <div class="bg-[#111] border border-gray-800 p-4 rounded-2xl shadow-xl">
                <div class="text-[9px] text-purple-500 uppercase font-black mb-1">Year Elapsed</div>
                <div class="text-xl font-mono font-black">@yearBurnPct.ToString("P0")</div>
                <div class="w-full h-1 bg-gray-800 rounded-full mt-2 overflow-hidden">
                    <div class="bg-purple-500 h-full" style="width: @(yearBurnPct * 100)%"></div>
                </div>
            </div>
        </div>

        <div class="flex justify-between items-center mb-6">
            <div class="flex gap-2">
                <button @onclick="RefreshData" class="p-2 bg-gray-900 border border-gray-800 rounded-lg hover:bg-gray-800 transition">🔄</button>
                <div class="bg-gray-900 border border-gray-800 rounded-lg flex items-center px-3 gap-4">
                    <button @onclick="() => ChangeYear(-1)" class="text-gray-500 hover:text-white transition font-black">◀</button>
                    <span class="text-xs font-black uppercase tracking-widest">@currentYear</span>
                    <button @onclick="() => ChangeYear(1)" class="text-gray-500 hover:text-white transition font-black">▶</button>
                </div>
            </div>
            <div class="flex gap-3">
                <button @onclick="OpenEditPolicyModal" class="bg-gray-800 hover:bg-gray-700 px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest border border-gray-700 transition">⚙️ Policy</button>
                <button @onclick="() => OpenEntryModal(null)" class="bg-blue-600 hover:bg-blue-500 px-6 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition shadow-lg">+ Add Time Off</button>
            </div>
        </div>

        <div class="bg-[#111] rounded-2xl border border-gray-800 shadow-2xl overflow-hidden mb-20">
            <div class="grid grid-cols-[100px_1fr_100px_100px_120px] gap-4 p-4 border-b border-gray-800 text-[10px] font-black uppercase tracking-widest text-gray-500">
                <span>Date</span>
                <span>Description</span>
                <span class="text-right">Amount</span>
                <span class="text-right">Balance</span>
                <span class="text-center">Status</span>
            </div>
            
            <div class="max-h-[60vh] overflow-y-auto scrollbar-hide">
                @{
                    decimal runningBal = policy.CarryOverHours;
                    <Virtualize Items="@policy.Entries.OrderBy(e => e.Date).ToList()" Context="entry">
                        @{
                            runningBal += entry.Amount;
                            var rowBalance = runningBal;
                            
                            <div class="grid grid-cols-[100px_1fr_100px_100px_120px] gap-4 p-4 border-b border-gray-800/50 hover:bg-white/5 transition items-center text-sm font-medium">
                                <div class="font-mono text-xs text-gray-500">@entry.Date.ToString("MMM dd, yy")</div>
                                <div class="flex flex-col">
                                    <span class="font-black uppercase tracking-tight text-white">@entry.Description</span>
                                    @if(!string.IsNullOrEmpty(entry.Notes)){<span class="text-[10px] text-gray-500">@entry.Notes</span>}
                                </div>
                                <div class="text-right font-mono font-black @(entry.Amount > 0 ? "text-emerald-500" : entry.Amount < 0 ? "text-orange-500" : "text-blue-500")">
                                    @(entry.Amount > 0 ? "+" : "")@entry.Amount.ToString("N1")
                                </div>
                                <div class="text-right font-mono font-black text-gray-400">@rowBalance.ToString("N1")</div>
                                <div class="flex justify-center gap-2 items-center">
                                    <span class="px-2 py-0.5 rounded text-[8px] font-black uppercase tracking-tighter @GetStatusClass(entry)">
                                        @entry.Status
                                    </span>
                                    @if (entry.EntryType != PtoEntryType.Accrual)
                                    {
                                        <button @onclick="() => OpenEntryModal(entry)" class="text-gray-500 hover:text-blue-400 transition">✎</button>
                                        <button @onclick="() => DeleteEntry(entry)" class="text-gray-500 hover:text-red-400 transition">✕</button>
                                    }
                                </div>
                            </div>
                        }
                    </Virtualize>
                }
            </div>
        </div>
    }

    @* POLICY SETTINGS MODAL *@
    @if (showPolicyModal && editPolicy != null)
    {
        <div class="fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4 backdrop-blur-sm">
            <div class="bg-[#111] rounded-2xl shadow-2xl w-full max-w-lg border border-gray-800 font-black">
                <div class="bg-gray-900 px-6 py-4 border-b border-gray-800 flex justify-between items-center text-sm uppercase tracking-widest text-gray-300">
                    <span>@currentYear Policy Settings</span>
                    <button @onclick="() => showPolicyModal = false" class="text-gray-500 hover:text-white text-xl">&times;</button>
                </div>
                <div class="p-6 space-y-5">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[10px] text-gray-500 uppercase mb-2">Total Allowance (Hrs)</label>
                            <input type="number" @bind="editPolicy.TotalAllowanceHours" step="0.5" class="w-full bg-black border border-gray-800 rounded-lg p-3 text-sm font-mono text-blue-400 outline-none focus:border-blue-500" />
                        </div>
                        <div>
                            <label class="block text-[10px] text-gray-500 uppercase mb-2">Carryover (Hrs)</label>
                            <input type="number" @bind="editPolicy.CarryOverHours" step="0.5" class="w-full bg-black border border-gray-800 rounded-lg p-3 text-sm font-mono text-emerald-400 outline-none focus:border-emerald-500" />
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[10px] text-gray-500 uppercase mb-2">Accrual Interval</label>
                            <select @bind="editPolicy.Interval" class="w-full bg-black border border-gray-800 rounded-lg p-3 text-sm text-white outline-none focus:border-blue-500">
                                @foreach (var interval in Enum.GetValues<PtoAccrualInterval>())
                                {
                                    <option value="@interval">@interval.ToString()</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="block text-[10px] text-gray-500 uppercase mb-2">Start Date</label>
                            <input type="date" @bind="editPolicy.AccrualStartDate" class="w-full bg-black border border-gray-800 rounded-lg p-3 text-sm text-white outline-none focus:border-blue-500" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-[10px] text-gray-500 uppercase mb-2">Standard Work Day (Hrs)</label>
                        <input type="number" @bind="editPolicy.HoursPerWorkDay" step="0.5" class="w-full bg-black border border-gray-800 rounded-lg p-3 text-sm font-mono text-white outline-none focus:border-blue-500" />
                    </div>
                </div>
                <div class="bg-gray-900 px-6 py-4 flex justify-end gap-3 border-t border-gray-800">
                    <button @onclick="() => showPolicyModal = false" class="px-5 py-2 text-xs text-gray-500 hover:text-white uppercase tracking-widest transition">Cancel</button>
                    <button @onclick="SavePolicy" class="bg-blue-600 hover:bg-blue-500 text-white px-8 py-2 rounded-lg text-xs uppercase tracking-widest transition shadow-lg">Save & Generate</button>
                </div>
            </div>
        </div>
    }

    @* TIME OFF ENTRY MODAL *@
    @if (showEntryModal && editEntry != null)
    {
        <div class="fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4 backdrop-blur-sm">
            <div class="bg-[#111] rounded-2xl shadow-2xl w-full max-w-lg border border-gray-800 font-black">
                <div class="bg-gray-900 px-6 py-4 border-b border-gray-800 flex justify-between items-center text-sm uppercase tracking-widest text-gray-300">
                    <span>Ledger Entry</span>
                    <button @onclick="() => showEntryModal = false" class="text-gray-500 hover:text-white text-xl">&times;</button>
                </div>
                <div class="p-6 space-y-5">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[10px] text-gray-500 uppercase mb-2">Type</label>
                            <select @bind="editEntry.EntryType" class="w-full bg-black border border-gray-800 rounded-lg p-3 text-sm text-white outline-none focus:border-blue-500">
                                <option value="@PtoEntryType.TimeOff">Time Off (Deduction)</option>
                                <option value="@PtoEntryType.Holiday">Holiday (No Deduction)</option>
                                <option value="@PtoEntryType.Adjustment">Adjustment (Bonus/Correction)</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-[10px] text-gray-500 uppercase mb-2">Status</label>
                            <select @bind="editEntry.Status" class="w-full bg-black border border-gray-800 rounded-lg p-3 text-sm text-white outline-none focus:border-blue-500">
                                @foreach (var status in Enum.GetValues<PtoEntryStatus>())
                                {
                                    <option value="@status">@status.ToString()</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="block text-[10px] text-gray-500 uppercase mb-2">Description</label>
                        <input @bind="editEntry.Description" class="w-full bg-black border border-gray-800 rounded-lg p-3 text-sm text-white outline-none focus:border-blue-500" placeholder="e.g., Summer Vacation" />
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[10px] text-gray-500 uppercase mb-2">Date</label>
                            <input type="date" @bind="editEntry.Date" class="w-full bg-black border border-gray-800 rounded-lg p-3 text-sm text-white outline-none focus:border-blue-500" />
                        </div>
                        <div>
                            <label class="block text-[10px] text-gray-500 uppercase mb-2">Impact Amount (Hrs)</label>
                            <input type="number" @bind="uiEntryAmount" step="0.5" class="w-full bg-black border border-gray-800 rounded-lg p-3 text-sm font-mono text-orange-400 outline-none focus:border-orange-500" placeholder="e.g. 8" />
                            <div class="text-[8px] text-gray-600 mt-1 text-right">Positive number (e.g. 8)</div>
                        </div>
                    </div>
                </div>
                <div class="bg-gray-900 px-6 py-4 flex justify-end gap-3 border-t border-gray-800">
                    <button @onclick="() => showEntryModal = false" class="px-5 py-2 text-xs text-gray-500 hover:text-white uppercase tracking-widest transition">Cancel</button>
                    <button @onclick="SaveEntry" class="bg-blue-600 hover:bg-blue-500 text-white px-8 py-2 rounded-lg text-xs uppercase tracking-widest transition shadow-lg">Save Entry</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private int currentYear = DateTime.Now.Year;
    private int userId = 1; // Temporary: In production, pull from session
    private PtoPolicy? policy;
    private bool isLoading = true;

    // Modal State
    private bool showPolicyModal = false;
    private PtoPolicy? editPolicy;
    
    private bool showEntryModal = false;
    private PtoEntry? editEntry;
    private decimal uiEntryAmount = 8m; // Used to collect the positive absolute value from user

    // Cached Totals
    private decimal totalAvailable;
    private decimal earnedToDate;
    private decimal spentToDate;
    private decimal currentBalance;
    private double ptoBurnPct;
    private double yearBurnPct;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RefreshData();
        }
    }

    private async Task RefreshData()
    {
        isLoading = true;
        StateHasChanged();

        policy = await PtoService.GetPolicyAsync(userId, currentYear);
        
        if (policy != null)
        {
            CalculateMetrics();
        }

        isLoading = false;
        StateHasChanged();
    }

    private void CalculateMetrics()
    {
        if (policy == null) return;

        var entries = policy.Entries.OrderBy(e => e.Date).ToList();
        
        totalAvailable = policy.TotalAllowanceHours + policy.CarryOverHours;
        
        earnedToDate = policy.CarryOverHours + entries
            .Where(e => e.EntryType == PtoEntryType.Accrual && e.Date <= DateTime.Today)
            .Sum(e => e.Amount);
            
        spentToDate = entries
            .Where(e => e.EntryType == PtoEntryType.TimeOff && (e.Status == PtoEntryStatus.Taken || e.Date <= DateTime.Today))
            .Sum(e => Math.Abs(e.Amount));

        currentBalance = earnedToDate - spentToDate;

        ptoBurnPct = totalAvailable > 0 ? (double)(spentToDate / totalAvailable) : 0;
        yearBurnPct = (double)DateTime.Today.DayOfYear / (DateTime.IsLeapYear(currentYear) ? 366.0 : 365.0);
    }

    private async Task ChangeYear(int delta)
    {
        currentYear += delta;
        await RefreshData();
    }

    // --- MODAL ACTIONS ---

    private async Task OpenSetupModal()
    {
        // Creates the DB tables if this is the very first time
        await PtoService.InitializeDatabaseAsync();

        editPolicy = new PtoPolicy
        {
            UserId = userId,
            Year = currentYear,
            TotalAllowanceHours = 120, // Example sensible default
            CarryOverHours = 0,
            Interval = PtoAccrualInterval.Monthly,
            AccrualStartDate = new DateTime(currentYear, 1, 1),
            HoursPerWorkDay = 8
        };
        showPolicyModal = true;
    }

    private void OpenEditPolicyModal()
    {
        if (policy == null) return;
        editPolicy = new PtoPolicy
        {
            Id = policy.Id,
            UserId = policy.UserId,
            Year = policy.Year,
            TotalAllowanceHours = policy.TotalAllowanceHours,
            CarryOverHours = policy.CarryOverHours,
            Interval = policy.Interval,
            AccrualStartDate = policy.AccrualStartDate,
            HoursPerWorkDay = policy.HoursPerWorkDay
        };
        showPolicyModal = true;
    }

    private async Task SavePolicy()
    {
        if (editPolicy == null) return;

        if (editPolicy.Id == 0)
        {
            policy = await PtoService.CreatePolicyAsync(editPolicy);
        }
        else
        {
            policy = await PtoService.UpdatePolicyAsync(editPolicy);
        }
        
        await PtoService.GenerateAccrualScheduleAsync(policy.Id);
        showPolicyModal = false;
        await RefreshData();
    }

    private void OpenEntryModal(PtoEntry? entry)
    {
        if (policy == null) return;

        if (entry == null)
        {
            editEntry = new PtoEntry
            {
                PtoPolicyId = policy.Id,
                Date = DateTime.Today,
                EntryType = PtoEntryType.TimeOff,
                Status = PtoEntryStatus.Planned,
                Amount = 0
            };
            uiEntryAmount = policy.HoursPerWorkDay; // Default to 1 full day
        }
        else
        {
            editEntry = new PtoEntry
            {
                Id = entry.Id,
                PtoPolicyId = entry.PtoPolicyId,
                Date = entry.Date,
                Description = entry.Description,
                EntryType = entry.EntryType,
                Status = entry.Status,
                Notes = entry.Notes,
                Amount = entry.Amount
            };
            uiEntryAmount = Math.Abs(entry.Amount);
        }
        showEntryModal = true;
    }

    private async Task SaveEntry()
    {
        if (editEntry == null) return;

        // Correct the signage based on the type
        if (editEntry.EntryType == PtoEntryType.TimeOff)
        {
            editEntry.Amount = -Math.Abs(uiEntryAmount); // Always negative deduction
        }
        else if (editEntry.EntryType == PtoEntryType.Holiday)
        {
            editEntry.Amount = 0; // Holidays don't burn PTO
        }
        else
        {
            editEntry.Amount = uiEntryAmount; // Adjustments/Bonus are positive
        }

        await PtoService.SaveEntryAsync(editEntry);
        showEntryModal = false;
        await RefreshData();
    }

    private async Task DeleteEntry(PtoEntry entry)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Delete this entry?"))
        {
            await PtoService.DeleteEntryAsync(entry.Id);
            await RefreshData();
        }
    }

    private string GetStatusClass(PtoEntry e) => e.Status switch
    {
        PtoEntryStatus.Taken => "bg-emerald-900/30 text-emerald-500 border border-emerald-800",
        PtoEntryStatus.Approved => "bg-blue-900/30 text-blue-400 border border-blue-800",
        PtoEntryStatus.Requested => "bg-orange-900/30 text-orange-400 border border-orange-800",
        _ => "bg-gray-800 text-gray-500 border border-gray-700"
    };
}