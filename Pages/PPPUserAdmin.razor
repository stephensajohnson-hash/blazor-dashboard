@page "/ppp-user-admin"
@using Dashboard
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="min-h-screen bg-[#0a0a0a] text-white p-6 font-black relative overflow-hidden">
    
    @* TOAST NOTIFICATION STACK *@
    <div class="fixed top-24 right-6 z-[100] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-2xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950/90 border-red-500 text-red-200" : "bg-emerald-950/90 border-emerald-500 text-emerald-200")">
                <div class="flex items-center gap-3">
                    <span>@(toast.IsError ? "❌" : "✅")</span>
                    <span class="text-xs uppercase tracking-widest">@toast.Message</span>
                </div>
            </div>
        }
    </div>

    @* Header *@
    <div class="flex justify-between items-center mb-10 bg-[#111] p-4 rounded-2xl border border-gray-800 shadow-xl">
        <div class="flex items-center gap-4">
            <span class="text-3xl">🛡️</span>
            <div>
                <h1 class="text-xl uppercase tracking-tighter">PPP User Registry</h1>
                <p class="text-[9px] text-gray-500 uppercase tracking-[0.2em]">Administrative Access Overrides Enabled</p>
            </div>
        </div>
        <div class="flex gap-4">
            <button @onclick="() => OpenModal()" class="bg-blue-600 hover:bg-blue-500 text-white px-6 py-2 rounded-xl text-[10px] uppercase tracking-widest transition shadow-lg">
                ＋ Add New User
            </button>
            <a href="/ppp-dashboard" class="bg-gray-800 hover:bg-gray-700 text-white px-4 py-2 rounded-xl text-[10px] uppercase tracking-widest transition border border-gray-700">
                Back to PPP
            </a>
        </div>
    </div>

    @* User Table *@
    <div class="bg-[#111] border border-gray-800 rounded-3xl overflow-hidden shadow-2xl">
        @if (isLoading)
        {
            <div class="py-20 flex flex-col items-center justify-center gap-4">
                <div class="w-12 h-12 border-4 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
                <div class="text-xs uppercase tracking-[0.4em] text-gray-600">Syncing_Records...</div>
            </div>
        }
        else
        {
            <table class="w-full text-left">
                <thead>
                    <tr class="text-[10px] font-black uppercase text-gray-500 bg-gray-900/50 border-b border-gray-800">
                        <th class="p-5">User Profile</th>
                        <th class="p-5">Contact Info</th>
                        <th class="p-5">Role / Status</th>
                        <th class="p-5">Rewards</th>
                        <th class="p-5 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-800/50">
                    @foreach (var user in users)
                    {
                        <tr class="hover:bg-white/5 transition group">
                            <td class="p-5">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-gray-700 to-gray-900 border border-gray-700 flex items-center justify-center text-xs">
                                        @(string.IsNullOrEmpty(user.FirstName) ? "?" : user.FirstName[0])@(string.IsNullOrEmpty(user.LastName) ? "?" : user.LastName[0])
                                    </div>
                                    <div>
                                        <div class="text-sm font-black uppercase tracking-tight">@user.FirstName @user.LastName</div>
                                        <div class="text-[9px] text-gray-500 font-mono">ID: #@user.Id</div>
                                    </div>
                                </div>
                            </td>
                            <td class="p-5 font-mono text-xs text-gray-400">
                                <div>@user.Email</div>
                                <div class="text-[10px] text-gray-600">@user.Phone</div>
                            </td>
                            <td class="p-5">
                                <button @onclick="() => ToggleRole(user)" class="px-3 py-1 rounded text-[9px] font-black uppercase transition hover:brightness-125 @(user.Role == "Owner" ? "bg-purple-900/30 text-purple-400 border border-purple-800" : "bg-blue-900/30 text-blue-400 border border-blue-800")">
                                    @user.Role
                                </button>
                                @if (!string.IsNullOrEmpty(user.PreferredPlan))
                                {
                                    <div class="text-[8px] text-gray-600 uppercase mt-1">Plan: @user.PreferredPlan</div>
                                }
                            </td>
                            <td class="p-5">
                                <div class="text-sm font-mono text-emerald-500">@user.RewardPoints.ToString("N0")</div>
                                <div class="text-[8px] text-gray-600 uppercase">Points Earned</div>
                            </td>
                            <td class="p-5 text-right">
                                <div class="flex justify-end gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <button @onclick="() => OpenModal(user)" class="p-2 text-blue-400 hover:bg-blue-500/10 rounded-lg transition" title="Edit">✎</button>
                                    <button @onclick="() => ConfirmDelete(user)" class="p-2 text-red-500 hover:bg-red-500/10 rounded-lg transition" title="Delete">✕</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@* EDIT/CREATE MODAL *@
@if (showModal)
{
    <div class="fixed inset-0 bg-black/90 backdrop-blur-sm z-[200] flex items-center justify-center p-4">
        <div class="bg-[#111] w-full max-w-xl rounded-3xl border border-gray-800 shadow-[0_0_50px_rgba(0,0,0,0.8)] overflow-hidden animate-in zoom-in duration-200">
            <div class="p-6 bg-gray-900/50 border-b border-gray-800 flex justify-between items-center">
                <h3 class="text-lg uppercase tracking-widest font-black text-blue-400">
                    @(editingUser.Id == 0 ? "Register New User" : "Update Profile")
                </h3>
                <button @onclick="CloseModal" class="text-gray-500 hover:text-white text-2xl font-light">&times;</button>
            </div>
            
            <div class="p-8 grid grid-cols-2 gap-6">
                <div>
                    <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">First Name</label>
                    <input @bind="editingUser.FirstName" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-blue-500 outline-none transition" />
                </div>
                <div>
                    <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">Last Name</label>
                    <input @bind="editingUser.LastName" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-blue-500 outline-none transition" />
                </div>
                <div class="col-span-2">
                    <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">Email Address</label>
                    <input @bind="editingUser.Email" type="email" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-blue-500 outline-none transition font-mono" />
                </div>
                <div>
                    <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">Phone</label>
                    <input @bind="editingUser.Phone" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-blue-500 outline-none transition font-mono" />
                </div>
                <div>
                    <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">Role</label>
                    <select @bind="editingUser.Role" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-blue-500 outline-none transition">
                        <option value="Customer">Customer</option>
                        <option value="Owner">Owner</option>
                        <option value="Staff">Staff</option>
                    </select>
                </div>
                <div>
                    <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">Reward Points</label>
                    <input @bind="editingUser.RewardPoints" type="number" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-emerald-500 outline-none transition font-mono text-emerald-400" />
                </div>
                <div class="col-span-2">
                    <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">Meal Plan</label>
                    <input @bind="editingUser.PreferredPlan" placeholder="e.g. Clean Eating 10" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-blue-500 outline-none transition" />
                </div>
            </div>

            <div class="p-6 bg-gray-900/50 border-t border-gray-800 flex justify-end gap-4">
                <button @onclick="CloseModal" class="text-[10px] text-gray-500 uppercase tracking-widest font-black px-6">Cancel</button>
                <button @onclick="SaveUser" class="bg-blue-600 hover:bg-blue-500 text-white text-[10px] uppercase tracking-widest font-black px-8 py-3 rounded-xl shadow-lg transition">
                    Commit Changes
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<PPP_User> users = new();
    private bool isLoading = true;
    private bool showModal = false;
    private PPP_User editingUser = new();
    private List<ToastItem> toasts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        isLoading = true;
        try {
            // Using AsNoTracking to prevent collisions during updates
            users = await Db.PPP_Users.AsNoTracking().OrderBy(u => u.LastName).ToListAsync();
        } catch (Exception ex) {
            await ShowToast("Load Error: " + ex.Message, true);
        } finally {
            isLoading = false;
        }
    }

    private void OpenModal(PPP_User? user = null)
    {
        if (user == null)
        {
            editingUser = new PPP_User { CreatedAt = DateTime.UtcNow, Role = "Customer" };
        }
        else
        {
            editingUser = new PPP_User
            {
                Id = user.Id,
                FirstName = user.FirstName,
                LastName = user.LastName,
                Email = user.Email,
                Phone = user.Phone,
                Role = user.Role,
                RewardPoints = user.RewardPoints,
                PreferredPlan = user.PreferredPlan,
                CreatedAt = user.CreatedAt
            };
        }
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private async Task SaveUser()
    {
        if (string.IsNullOrWhiteSpace(editingUser.FirstName) || string.IsNullOrWhiteSpace(editingUser.Email))
        {
            await ShowToast("Name and Email required", true);
            return;
        }

        try {
            // THE FIX: Clear tracker to prevent collisions
            Db.ChangeTracker.Clear();

            if (editingUser.Id == 0) {
                Db.PPP_Users.Add(editingUser);
                await Db.SaveChangesAsync();
                await ShowToast("User created successfully");
            } else {
                Db.PPP_Users.Update(editingUser);
                await Db.SaveChangesAsync();
                await ShowToast("User profile updated");
            }
            await LoadUsers();
            CloseModal();
        } catch (Exception ex) {
            await ShowToast("Save Error: " + ex.Message, true);
            Console.WriteLine($"Save Error: {ex}");
        }
    }

    private async Task ToggleRole(PPP_User user)
    {
        try {
            Db.ChangeTracker.Clear();
            user.Role = user.Role == "Owner" ? "Customer" : "Owner";
            Db.PPP_Users.Update(user);
            await Db.SaveChangesAsync();
            await ShowToast($"{user.FirstName} role changed to {user.Role}");
            await LoadUsers();
        } catch (Exception ex) {
            await ShowToast("Toggle Error: " + ex.Message, true);
        }
    }

    private async Task ConfirmDelete(PPP_User user)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Permanently remove {user.FirstName} {user.LastName}?"))
        {
            try {
                Db.ChangeTracker.Clear();
                Db.PPP_Users.Remove(user);
                await Db.SaveChangesAsync();
                await ShowToast("User deleted");
                await LoadUsers();
            } catch (Exception ex) {
                await ShowToast("Delete Error: " + ex.Message, true);
            }
        }
    }

    private async Task ShowToast(string msg, bool isError = false)
    {
        var toast = new ToastItem { Message = msg, IsError = isError };
        toasts.Add(toast);
        StateHasChanged();
        await Task.Delay(4000);
        toasts.Remove(toast);
        StateHasChanged();
    }

    private class ToastItem { public string Message { get; set; } = ""; public bool IsError { get; set; } }
}