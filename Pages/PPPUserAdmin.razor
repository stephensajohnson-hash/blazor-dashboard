@page "/ppp-user-admin"
@using Dashboard
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using System.Diagnostics
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="min-h-screen bg-[#0a0a0a] text-white p-6 font-black relative overflow-hidden">
    
    @* TOAST NOTIFICATION STACK *@
    <div class="fixed top-24 right-6 z-[100] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-2xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950/90 border-red-500 text-red-200" : "bg-emerald-950/90 border-emerald-500 text-emerald-200")">
                <div class="flex items-center gap-3">
                    <span>@(toast.IsError ? "❌" : "✅")</span>
                    <span class="text-xs uppercase tracking-widest">@toast.Message</span>
                </div>
            </div>
        }
    </div>

    @* Header *@
    <div class="flex justify-between items-center mb-10 bg-[#111] p-4 rounded-2xl border border-gray-800 shadow-xl">
        <div class="flex items-center gap-4">
            <span class="text-3xl">🛡️</span>
            <div>
                <h1 class="text-xl uppercase tracking-tighter">PPP User Registry</h1>
                <p class="text-[9px] text-gray-500 uppercase tracking-[0.2em]">Administrative Access Overrides Enabled</p>
            </div>
        </div>
        <div class="flex gap-4">
            <button @onclick="() => OpenModal()" class="bg-blue-600 hover:bg-blue-500 text-white px-6 py-2 rounded-xl text-[10px] uppercase tracking-widest transition shadow-lg">
                ＋ Add New User
            </button>
            <a href="/ppp-dashboard" class="bg-gray-800 hover:bg-gray-700 text-white px-4 py-2 rounded-xl text-[10px] uppercase tracking-widest transition border border-gray-700">
                Back to PPP
            </a>
        </div>
    </div>

    @* User Table *@
    <div class="bg-[#111] border border-gray-800 rounded-3xl overflow-hidden shadow-2xl">
        @if (isLoading)
        {
            <div class="py-20 flex flex-col items-center justify-center gap-4">
                <div class="w-12 h-12 border-4 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
                <div class="text-xs uppercase tracking-[0.4em] text-gray-600">Syncing_Records...</div>
            </div>
        }
        else
        {
            <table class="w-full text-left">
                <thead>
                    <tr class="text-[10px] font-black uppercase text-gray-500 bg-gray-900/50 border-b border-gray-800">
                        <th class="p-5">User Profile</th>
                        <th class="p-5">Location</th>
                        <th class="p-5">Role</th>
                        <th class="p-5 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-800/50">
                    @foreach (var user in users)
                    {
                        <tr class="hover:bg-white/5 transition group">
                            <td class="p-5">
                                <div class="flex items-center gap-3">
                                    @if (user.AvatarId.HasValue)
                                    {
                                        <img src="/db-images-ppp/@user.AvatarId" class="w-10 h-10 rounded-full object-cover border border-gray-700" />
                                    }
                                    else
                                    {
                                        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-gray-700 to-gray-900 border border-gray-700 flex items-center justify-center text-[10px] text-gray-400">
                                            @(string.IsNullOrEmpty(user.FirstName) ? "?" : user.FirstName[0])@(string.IsNullOrEmpty(user.LastName) ? "?" : user.LastName[0])
                                        </div>
                                    }
                                    <div>
                                        <div class="text-sm font-black uppercase tracking-tight">@user.FirstName @user.LastName</div>
                                        <div class="text-[9px] text-gray-500 font-mono">@user.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td class="p-5 font-mono text-[10px] text-gray-400">
                                @if (user.Address != null)
                                {
                                    <div>@user.Address.City, @user.Address.State</div>
                                    <div class="text-gray-600">@user.Address.ZipCode</div>
                                }
                                else
                                {
                                    <span class="text-gray-700 italic">No Address</span>
                                }
                            </td>
                            <td class="p-5">
                                <span class="px-3 py-1 rounded text-[9px] font-black uppercase @GetRoleClass(user.Role)">
                                    @user.Role
                                </span>
                            </td>
                            <td class="p-5 text-right">
                                <div class="flex justify-end gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <button @onclick="() => OpenModal(user)" class="p-2 text-blue-400 hover:bg-blue-500/10 rounded-lg transition" title="Edit">✎</button>
                                    <button @onclick="() => ConfirmDelete(user)" class="p-2 text-red-500 hover:bg-red-500/10 rounded-lg transition" title="Delete">✕</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@* EDIT/CREATE MODAL *@
@if (showModal)
{
    <div class="fixed inset-0 bg-black/90 backdrop-blur-sm z-[200] flex items-center justify-center p-4">
        <div class="bg-[#111] w-full max-w-2xl rounded-3xl border border-gray-800 shadow-[0_0_50px_rgba(0,0,0,0.8)] overflow-hidden animate-in zoom-in duration-200">
            <div class="p-6 bg-gray-900/50 border-b border-gray-800 flex justify-between items-center">
                <h3 class="text-lg uppercase tracking-widest font-black text-blue-400">
                    @(editingUser.Id == 0 ? "Register New User" : "Update Profile")
                </h3>
                <button @onclick="CloseModal" class="text-gray-500 hover:text-white text-2xl font-light">&times;</button>
            </div>
            
            <div class="p-8 grid grid-cols-2 gap-6 max-h-[75vh] overflow-y-auto">
                @* Avatar Section *@
                <div class="col-span-2 flex items-center gap-6 bg-black/30 p-4 rounded-2xl border border-gray-800">
                    @if (editingUser.AvatarId.HasValue)
                    {
                        <img src="/db-images-ppp/@editingUser.AvatarId" class="w-20 h-20 rounded-2xl object-cover border-2 border-blue-500/50" />
                    }
                    else
                    {
                        <div class="w-20 h-20 rounded-2xl bg-gray-900 border-2 border-dashed border-gray-700 flex items-center justify-center text-2xl">👤</div>
                    }
                    <div class="flex-1">
                        <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">Profile Image</label>
                        <InputFile OnChange="HandleImageUpload" class="text-xs text-gray-400 file:bg-blue-600 file:text-white file:border-0 file:px-3 file:py-1 file:rounded-lg file:mr-4 file:font-black file:uppercase file:text-[9px] cursor-pointer" />
                    </div>
                </div>

                @* Basic Info *@
                <div>
                    <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">First Name</label>
                    <input @bind="editingUser.FirstName" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-blue-500 outline-none transition font-black uppercase" />
                </div>
                <div>
                    <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">Last Name</label>
                    <input @bind="editingUser.LastName" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-blue-500 outline-none transition font-black uppercase" />
                </div>
                <div>
                    <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">Email</label>
                    <input @bind="editingUser.Email" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-blue-500 outline-none transition font-mono" />
                </div>
                <div>
                    <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">Phone</label>
                    <input @bind="editingUser.Phone" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-blue-500 outline-none transition font-mono" />
                </div>
                <div class="col-span-2">
                    <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">Role</label>
                    <select @bind="editingUser.Role" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-blue-500 outline-none transition font-black uppercase">
                        <option value="Customer">Customer</option>
                        <option value="Staff">Staff</option>
                        <option value="Owner">Owner</option>
                        <option value="Admin">Admin</option>
                    </select>
                </div>

                @* Address Section *@
                <div class="col-span-2 mt-4 pt-4 border-t border-gray-800">
                    <h4 class="text-[10px] uppercase tracking-[0.2em] text-gray-500 mb-4 font-black">Physical Address</h4>
                    <div class="grid grid-cols-2 gap-4 bg-white/5 p-4 rounded-2xl border border-gray-800">
                        <div class="col-span-2">
                            <label class="text-[9px] uppercase text-gray-600 mb-1 block">Street Address</label>
                            <input @bind="editingUser.Address.Street" class="w-full bg-black border border-gray-800 rounded-lg p-2 text-xs focus:border-blue-500 outline-none" />
                        </div>
                        <div>
                            <label class="text-[9px] uppercase text-gray-600 mb-1 block">City</label>
                            <input @bind="editingUser.Address.City" class="w-full bg-black border border-gray-800 rounded-lg p-2 text-xs focus:border-blue-500 outline-none" />
                        </div>
                        <div class="grid grid-cols-2 gap-2">
                            <div>
                                <label class="text-[9px] uppercase text-gray-600 mb-1 block">State</label>
                                <input @bind="editingUser.Address.State" maxlength="2" class="w-full bg-black border border-gray-800 rounded-lg p-2 text-xs focus:border-blue-500 outline-none text-center uppercase" />
                            </div>
                            <div>
                                <label class="text-[9px] uppercase text-gray-600 mb-1 block">Zip</label>
                                <input @bind="editingUser.Address.ZipCode" class="w-full bg-black border border-gray-800 rounded-lg p-2 text-xs focus:border-blue-500 outline-none font-mono" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="p-6 bg-gray-900/50 border-t border-gray-800 flex justify-end gap-4">
                <button @onclick="CloseModal" class="text-[10px] text-gray-500 uppercase tracking-widest font-black px-6">Cancel</button>
                <button @onclick="SaveUser" class="bg-blue-600 hover:bg-blue-500 text-white text-[10px] uppercase tracking-widest font-black px-8 py-3 rounded-xl shadow-lg transition">
                    Save Profile
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<PPP_User> users = new();
    private bool isLoading = true;
    private bool showModal = false;
    private PPP_User editingUser = new();
    private List<ToastItem> toasts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        isLoading = true;
        try {
            users = await Db.PPP_Users
                .Include(u => u.Address)
                .AsNoTracking()
                .OrderBy(u => u.LastName)
                .ToListAsync();
        } catch (Exception ex) {
            _ = ShowToast("Load Error: " + ex.Message, true);
        } finally {
            isLoading = false;
        }
    }

    private string GetRoleClass(string role) => role switch {
        "Admin" => "bg-red-900/30 text-red-400 border border-red-800",
        "Owner" => "bg-purple-900/30 text-purple-400 border border-purple-800",
        "Staff" => "bg-emerald-900/30 text-emerald-400 border border-emerald-800",
        _ => "bg-blue-900/30 text-blue-400 border border-blue-800"
    };

    private void OpenModal(PPP_User? user = null)
    {
        if (user == null)
        {
            editingUser = new PPP_User { 
                CreatedAt = DateTime.UtcNow, 
                Role = "Customer",
                Address = new PPP_Address() 
            };
        }
        else
        {
            editingUser = new PPP_User
            {
                Id = user.Id,
                FirstName = user.FirstName,
                LastName = user.LastName,
                Email = user.Email,
                Phone = user.Phone,
                Role = user.Role,
                CreatedAt = user.CreatedAt,
                AvatarId = user.AvatarId,
                AddressId = user.AddressId,
                Address = user.Address ?? new PPP_Address()
            };
        }
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        try {
            var file = e.File;
            if (file == null) return;

            using var ms = new System.IO.MemoryStream();
            await file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 2).CopyToAsync(ms);

            var newImage = new PPP_StoredImage
            {
                Data = ms.ToArray(),
                ContentType = file.ContentType,
                FileName = file.Name,
                UploadedAt = DateTime.UtcNow
            };

            if (editingUser.AvatarId.HasValue)
            {
                var oldId = editingUser.AvatarId.Value;
                bool isUsedByOthers = await Db.PPP_Users.AnyAsync(u => u.Id != editingUser.Id && u.AvatarId == oldId);
                if (!isUsedByOthers)
                {
                    var oldImg = await Db.PPP_StoredImages.FindAsync(oldId);
                    if (oldImg != null) Db.PPP_StoredImages.Remove(oldImg);
                }
            }

            Db.PPP_StoredImages.Add(newImage);
            await Db.SaveChangesAsync();
            
            editingUser.AvatarId = newImage.Id;
            _ = ShowToast("Avatar uploaded");
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex) {
            _ = ShowToast("Upload failed: " + ex.Message, true);
        }
    }

    private async Task SaveUser()
    {
        if (string.IsNullOrWhiteSpace(editingUser.FirstName) || string.IsNullOrWhiteSpace(editingUser.Email))
        {
            _ = ShowToast("Name and Email required", true);
            return;
        }

        var sw = Stopwatch.StartNew();
        try {
            Db.ChangeTracker.Clear();

            // Handle Address logic
            if (editingUser.Address != null)
            {
                if (!string.IsNullOrWhiteSpace(editingUser.Address.Street))
                {
                    if (editingUser.Address.Id == 0)
                        Db.PPP_Addresses.Add(editingUser.Address);
                    else
                        Db.PPP_Addresses.Update(editingUser.Address);

                    await Db.SaveChangesAsync();
                    editingUser.AddressId = editingUser.Address.Id;
                }
                else if (editingUser.Address.Id != 0)
                {
                    editingUser.AddressId = null;
                }
            }

            // Save User
            if (editingUser.Id == 0) {
                Db.PPP_Users.Add(editingUser);
                await Db.SaveChangesAsync();
            } else {
                Db.Entry(editingUser).State = EntityState.Modified;
                await Db.SaveChangesAsync();
            }

            await LoadUsers();
            _ = ShowToast("User record updated");
            CloseModal(); 
        } catch (Exception ex) {
            _ = ShowToast("Save Error: " + ex.Message, true);
            Console.WriteLine($"Save Error: {ex}");
        } finally {
            sw.Stop();
            Console.WriteLine($"[TIMING] SaveUser Total: {sw.ElapsedMilliseconds}ms");
        }
    }

    private async Task ConfirmDelete(PPP_User user)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Permanently remove {user.FirstName} {user.LastName}?"))
        {
            try {
                Db.ChangeTracker.Clear();
                
                if (user.AvatarId.HasValue)
                {
                    var imgId = user.AvatarId.Value;
                    bool isUsedByOthers = await Db.PPP_Users.AnyAsync(u => u.Id != user.Id && u.AvatarId == imgId);
                    if (!isUsedByOthers)
                    {
                        var img = await Db.PPP_StoredImages.FindAsync(imgId);
                        if (img != null) Db.PPP_StoredImages.Remove(img);
                    }
                }

                Db.PPP_Users.Remove(user);
                await Db.SaveChangesAsync();
                await LoadUsers();
                _ = ShowToast("User deleted");
            } catch (Exception ex) {
                _ = ShowToast("Delete Error: " + ex.Message, true);
            }
        }
    }

    private async Task ShowToast(string msg, bool isError = false)
    {
        var toast = new ToastItem { Message = msg, IsError = isError };
        toasts.Add(toast);
        await InvokeAsync(StateHasChanged);
        await Task.Delay(4000);
        toasts.Remove(toast);
        await InvokeAsync(StateHasChanged);
    }

    private class ToastItem { public string Message { get; set; } = ""; public bool IsError { get; set; } }
}