@page "/admin/neth-services/{StylistId:int}"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using Dashboard.Components
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

@if (isAuthorized)
{
    <div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex font-sans">
        
        <NETHAdminSidebar />

        <div class="flex-1 p-8">
            <div class="max-w-5xl mx-auto">
                <div class="flex justify-between items-end mb-8">
                    <div>
                        <h2 class="text-2xl font-black text-white uppercase tracking-tight">@stylistName Offered Services</h2>
                        <p class="text-xs text-gray-500 font-mono">Manage pricing, durations, and calendar colors</p>
                    </div>
                    <div class="flex gap-4">
                        @* ONE TIME REPAIR BUTTON *@
                        <button @onclick="RepairTable" class="text-[9px] text-gray-600 hover:text-orange-400 font-mono border border-gray-800 px-3 py-1 rounded uppercase transition">Sync_Database_Schema</button>
                        <button @onclick="OpenCreateModal" class="bg-blue-600 hover:bg-blue-500 text-white text-[10px] font-black uppercase px-6 py-3 rounded shadow-xl transition">＋ Add Service</button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(dbError))
                {
                    <div class="mb-6 p-4 @(dbError.Contains("SUCCESS") ? "bg-green-900/20 border-green-500/50 text-green-400" : "bg-red-900/20 border-red-500/50 text-red-400") rounded font-mono text-[10px] uppercase">
                        @dbError
                    </div>
                }

                @if (isLoading)
                {
                    <div class="text-center py-20 animate-pulse font-black text-gray-600 uppercase tracking-widest">Accessing_Service_List...</div>
                }
                else
                {
                    <div class="bg-[#25262b] rounded-xl border border-gray-700 overflow-hidden shadow-2xl">
                        <table class="w-full text-left">
                            <thead>
                                <tr class="text-[10px] font-black uppercase text-gray-500 bg-black/20">
                                    <th class="p-4 w-16 text-center">Color</th>
                                    <th class="p-4">Service Name</th>
                                    <th class="p-4">Price</th>
                                    <th class="p-4">Duration</th>
                                    <th class="p-4 text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm">
                                @if (!stylistServices.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="p-10 text-center text-gray-600 font-black uppercase tracking-widest">No Services Found</td>
                                    </tr>
                                }
                                @foreach (var svc in stylistServices)
                                {
                                    <tr class="border-b border-gray-800 hover:bg-white/5 transition">
                                        <td class="p-4 text-center">
                                            <div class="w-6 h-6 rounded-full border border-white/10 mx-auto" style="background-color: @svc.Color"></div>
                                        </td>
                                        <td class="p-4 font-black text-white uppercase">@svc.Name</td>
                                        <td class="p-4 font-mono text-[#D2B48C]">$@svc.Price.ToString("N2")</td>
                                        <td class="p-4 font-mono text-gray-500">@svc.DurationMinutes min</td>
                                        <td class="p-4 text-right">
                                            <button @onclick="() => OpenEditModal(svc)" class="text-blue-400 hover:underline text-xs font-black uppercase mr-4">Edit</button>
                                            <button @onclick="() => DeleteService(svc.Id)" class="text-red-500/50 hover:text-red-500 transition text-xs font-black uppercase">Delete</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}

@if (showModal && editingService != null)
{
    <div class="fixed inset-0 bg-black/90 backdrop-blur-sm z-50 flex items-center justify-center p-4 text-gray-300">
        <div class="bg-[#25262b] w-full max-w-md rounded-xl border border-gray-700 shadow-2xl overflow-hidden font-black">
            <div class="p-4 bg-gray-800/50 border-b border-gray-700 flex justify-between items-center uppercase text-[11px] tracking-widest text-[#D2B48C]">
                <span>@(editingService.Id == 0 ? "New Service Entry" : "Update Service")</span>
                <button @onclick="CloseModal" class="text-gray-500 hover:text-white">&times;</button>
            </div>
            <div class="p-6 space-y-4">
                <div>
                    <label class="text-[9px] uppercase text-gray-500 mb-1 block tracking-widest">Service Name</label>
                    <input @bind="editingService.Name" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-2 text-white outline-none focus:border-blue-500" />
                </div>

                <div>
                    <label class="text-[9px] uppercase text-gray-500 mb-1 block tracking-widest">Calendar Display Color</label>
                    <div class="flex gap-3">
                        <input type="color" @bind="editingService.Color" class="w-12 h-10 bg-transparent border-none cursor-pointer" />
                        <input @bind="editingService.Color" class="flex-1 bg-[#1a1b1e] border border-gray-700 rounded p-2 text-white font-mono text-xs uppercase outline-none" placeholder="#3B82F6" />
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="text-[9px] uppercase text-gray-500 mb-1 block tracking-widest">Price ($)</label>
                        <input type="number" step="0.01" @bind="editingService.Price" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-2 text-white outline-none focus:border-[#D2B48C] font-mono" />
                    </div>
                    <div>
                        <label class="text-[9px] uppercase text-gray-500 mb-1 block tracking-widest">Duration (Min)</label>
                        <input type="number" @bind="editingService.DurationMinutes" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-2 text-white outline-none focus:border-[#D2B48C] font-mono" />
                    </div>
                </div>
            </div>
            <div class="p-4 bg-black/20 border-t border-gray-700 flex justify-end gap-3">
                <button @onclick="CloseModal" class="text-[10px] text-gray-500 uppercase px-4 py-2 font-black">Cancel</button>
                <button @onclick="SaveService" class="bg-green-600 hover:bg-green-500 text-white text-[10px] uppercase px-6 py-2 rounded font-black shadow-xl">Update_Service</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int StylistId { get; set; }
    private bool isAuthorized = false;
    private bool isLoading = true;
    private bool showModal = false;
    private string stylistName = "";
    private string dbError = "";
    private List<NETH_Service> stylistServices = new();
    private NETH_Service? editingService;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "neth_session");
            if (string.IsNullOrEmpty(json)) Nav.NavigateTo("/nethaircut");
            else { isAuthorized = true; await LoadAllData(); isLoading = false; StateHasChanged(); }
        }
    }

    private async Task LoadAllData()
    {
        try {
            dbError = "";
            var stylist = await Db.NETH_Stylists.AsNoTracking().FirstOrDefaultAsync(x => x.Id == StylistId);
            stylistName = stylist?.Name ?? "Unknown";
            stylistServices = await Db.NETH_Services.AsNoTracking().Where(x => x.StylistId == StylistId).ToListAsync();
        } catch (Exception ex) { dbError = ex.Message; }
    }

    private void OpenCreateModal() { editingService = new NETH_Service { StylistId = StylistId, Name = "", Price = 0, DurationMinutes = 30, Color = "#3b82f6" }; showModal = true; }
    private void OpenEditModal(NETH_Service svc) { editingService = new NETH_Service { Id = svc.Id, StylistId = svc.StylistId, Name = svc.Name, Price = svc.Price, DurationMinutes = svc.DurationMinutes, Color = string.IsNullOrEmpty(svc.Color) ? "#3b82f6" : svc.Color }; showModal = true; }
    private void CloseModal() { showModal = false; editingService = null; }

    private async Task SaveService()
    {
        if (editingService == null) return;
        try {
            if (editingService.Id == 0) 
            {
                await Db.Database.ExecuteSqlRawAsync(
                    @"INSERT INTO ""NETH_Services"" (""StylistId"", ""Name"", ""Price"", ""DurationMinutes"", ""Color"") VALUES ({0}, {1}, {2}, {3}, {4})", 
                    editingService.StylistId, editingService.Name, editingService.Price, editingService.DurationMinutes, editingService.Color
                );
            }
            else 
            {
                await Db.Database.ExecuteSqlRawAsync(
                    @"UPDATE ""NETH_Services"" SET ""Name"" = {0}, ""Price"" = {1}, ""DurationMinutes"" = {2}, ""Color"" = {3} WHERE ""Id"" = {4}", 
                    editingService.Name, editingService.Price, editingService.DurationMinutes, editingService.Color, editingService.Id
                );
            }
            await LoadAllData(); 
            CloseModal();
        } catch (Exception ex) {
            dbError = "SAVE_FAILED: " + ex.Message;
        }
    }

    private async Task RepairTable()
    {
        try {
            // This SQL adds the column ONLY if it doesn't exist
            await Db.Database.ExecuteSqlRawAsync(@"
                DO $$ 
                BEGIN 
                    IF NOT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_name='NETH_Services' AND column_name='Color') THEN
                        ALTER TABLE ""NETH_Services"" ADD COLUMN ""Color"" TEXT DEFAULT '#3b82f6';
                    END IF;
                END $$;
            ");
            await LoadAllData();
            dbError = "DATABASE_SYNC_SUCCESSFUL";
        } catch (Exception ex) { dbError = "SCHEMA_REPAIR_FAILED: " + ex.Message; }
    }

    private async Task DeleteService(int id) 
    { 
        if (await JS.InvokeAsync<bool>("confirm", "Delete this service?")) 
        { 
            try {
                await Db.Database.ExecuteSqlRawAsync(@"DELETE FROM ""NETH_Services"" WHERE ""Id"" = {0}", id); 
                await LoadAllData(); 
            } catch (Exception ex) { dbError = ex.Message; }
        } 
    }
}