@page "/admin/neth-users"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using System.Text.Json
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

@if (isAuthorized)
{
    <div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex font-sans">
        
        <NETHAdminSidebar />

        <div class="flex-1 p-8">
            <div class="max-w-5xl mx-auto">
                <div class="flex justify-between items-end mb-8">
                    <div>
                        <h2 class="text-2xl font-black text-white uppercase tracking-tight">Identity Management</h2>
                        <p class="text-xs text-gray-500 font-mono">Manage system access levels and credentials</p>
                    </div>
                    <button @onclick="() => showUserModal = true" class="bg-blue-600 hover:bg-blue-500 text-white text-[10px] font-black uppercase px-6 py-3 rounded shadow-xl transition">＋ Create New Identity</button>
                </div>

                @if (isLoading)
                {
                    <div class="text-center py-20 animate-pulse font-black text-gray-600 uppercase tracking-widest">Loading_NETH_Registry...</div>
                }
                else
                {
                    <div class="bg-[#25262b] rounded-xl border border-gray-700 overflow-hidden shadow-2xl">
                        <table class="w-full text-left">
                            <thead>
                                <tr class="text-[10px] font-black uppercase text-gray-500 bg-black/20">
                                    <th class="p-4">ID</th>
                                    <th class="p-4">Username</th>
                                    <th class="p-4">Role</th>
                                    <th class="p-4">Created</th>
                                    <th class="p-4 text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm">
                                @foreach (var user in allUsers)
                                {
                                    <tr class="border-b border-gray-800 hover:bg-white/5 transition">
                                        <td class="p-4 font-mono text-gray-500">#@user.Id</td>
                                        <td class="p-4 font-black text-white uppercase">@user.Username</td>
                                        <td class="p-4">
                                            <span class="px-2 py-0.5 rounded text-[10px] font-black uppercase @GetRoleClass(user.Role)">@user.Role</span>
                                        </td>
                                        <td class="p-4 text-xs text-gray-500 font-mono">@user.CreatedDate.ToString("yyyy-MM-dd")</td>
                                        <td class="p-4 text-right">
                                            <button @onclick="() => OpenPasswordReset(user)" class="text-blue-400 hover:underline text-xs font-black uppercase mr-4">Reset_Pass</button>
                                            @if(user.Username != "admin")
                                            {
                                                <button @onclick="() => DeleteUser(user.Id)" class="text-red-500/50 hover:text-red-500 transition text-xs font-black uppercase">Delete</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}

@if (showUserModal)
{
    <div class="fixed inset-0 bg-black/90 backdrop-blur-sm z-50 flex items-center justify-center p-4 text-gray-300">
        <div class="bg-[#25262b] w-full max-w-md rounded-xl border border-gray-700 shadow-2xl overflow-hidden font-black">
            <div class="p-4 bg-gray-800/50 border-b border-gray-700 flex justify-between items-center uppercase text-[11px] tracking-widest text-[#D2B48C]">
                <span>@(isResetMode ? "Security Override" : "Register New Identity")</span>
                <button @onclick="CloseModal" class="text-gray-500 hover:text-white">&times;</button>
            </div>
            <div class="p-6 space-y-4">
                @if (!isResetMode)
                {
                    <div>
                        <label class="text-[9px] uppercase text-gray-500 mb-1 block">Username</label>
                        <input @bind="newUserName" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-2 text-white outline-none focus:border-blue-500" />
                    </div>
                    <div>
                        <label class="text-[9px] uppercase text-gray-500 mb-1 block">Role</label>
                        <select @bind="newUserRole" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-2 text-white outline-none">
                            <option value="Admin">Admin</option>
                            <option value="Stylist">Stylist</option>
                            <option value="Client">Client</option>
                        </select>
                    </div>
                }
                else
                {
                    <div class="p-3 bg-blue-900/20 border border-blue-500/30 rounded text-blue-400 text-[10px] font-mono uppercase tracking-widest">
                        TARGET: @selectedUser?.Username
                    </div>
                }
                <div>
                    <label class="text-[9px] uppercase text-gray-500 mb-1 block">@(isResetMode ? "New Password" : "Password")</label>
                    <input type="password" @bind="newUserPass" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-2 text-white outline-none focus:border-green-500" />
                </div>
            </div>
            <div class="p-4 bg-black/20 border-t border-gray-700 flex justify-end gap-3">
                <button @onclick="CloseModal" class="text-[10px] text-gray-500 uppercase px-4 py-2 font-black">Cancel</button>
                <button @onclick="SaveUser" class="bg-blue-600 hover:bg-blue-500 text-white text-[10px] uppercase px-6 py-2 rounded font-black shadow-xl">Confirm_Execute</button>
            </div>
        </div>
    </div>
}

@code {
    private bool isAuthorized = false;
    private bool isLoading = true;
    private List<NETH_User> allUsers = new();
    private bool showUserModal = false;
    private bool isResetMode = false;
    private NETH_User? selectedUser;
    private string newUserName = "";
    private string newUserPass = "";
    private string newUserRole = "Client";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "neth_session");
            if (string.IsNullOrEmpty(json)) Nav.NavigateTo("/nethaircut");
            else { isAuthorized = true; await LoadAllData(); isLoading = false; StateHasChanged(); }
        }
    }

    private async Task LoadAllData() { try { allUsers = await Db.Database.SqlQueryRaw<NETH_User>(@"SELECT * FROM ""NETH_Users"" ORDER BY ""Id"" DESC").ToListAsync(); } catch { } }

    private string GetRoleClass(string role) => role switch {
        "Admin" => "bg-red-900/20 text-red-400 border border-red-500/30",
        "Stylist" => "bg-[#D2B48C]/20 text-[#D2B48C] border border-[#D2B48C]/30",
        _ => "bg-blue-900/20 text-blue-400 border border-blue-500/30"
    };

    private void OpenPasswordReset(NETH_User user) { selectedUser = user; isResetMode = true; newUserPass = ""; showUserModal = true; }
    private void CloseModal() { showUserModal = false; isResetMode = false; selectedUser = null; newUserName = ""; newUserPass = ""; }

    private async Task SaveUser() {
        if (string.IsNullOrWhiteSpace(newUserPass)) return;
        try {
            if (isResetMode && selectedUser != null) await Db.Database.ExecuteSqlRawAsync(@"UPDATE ""NETH_Users"" SET ""Password"" = {0} WHERE ""Id"" = {1}", newUserPass, selectedUser.Id);
            else await Db.Database.ExecuteSqlRawAsync(@"INSERT INTO ""NETH_Users"" (""Username"", ""Password"", ""Role"", ""CreatedDate"") VALUES ({0}, {1}, {2}, NOW())", newUserName, newUserPass, newUserRole);
            await LoadAllData(); CloseModal();
        } catch { }
    }

    private async Task DeleteUser(int id) { try { await Db.Database.ExecuteSqlRawAsync(@"DELETE FROM ""NETH_Users"" WHERE ""Id"" = {0}", id); await LoadAllData(); } catch { } }

    public class NETH_User {
        public int Id { get; set; }
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
        public string Role { get; set; } = "";
        public DateTime CreatedDate { get; set; }
    }
}