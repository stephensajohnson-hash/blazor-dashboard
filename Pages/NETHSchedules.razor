@page "/admin/neth-schedules"
@page "/admin/neth-schedules/{DefaultStylistId:int}"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using Dashboard.Components
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex font-sans relative">
    
    @* FLOATING SUCCESS TOAST *@
    @if (showToast)
    {
        <div class="fixed top-8 left-1/2 -translate-x-1/2 z-[100] animate-in slide-in-from-top duration-300">
            <div class="bg-green-600 text-white px-8 py-4 rounded-full shadow-2xl flex items-center gap-3 border border-green-400/30">
                <i class="fas fa-check-circle"></i>
                <span class="text-xs font-black uppercase tracking-widest">Schedule Saved Successfully</span>
            </div>
        </div>
    }

    @if (isAuthorized)
    {
        <NETHAdminSidebar />

        <div class="flex-1 p-8">
            <div class="max-w-5xl mx-auto">
                <div class="flex justify-between items-end mb-8">
                    <div>
                        <h2 class="text-2xl font-black text-white uppercase tracking-tight">Shift Commander</h2>
                        <p class="text-xs text-gray-500 font-mono">Manage weekly operating hours</p>
                    </div>
                    <div class="flex gap-4">
                        <select @onchange="OnStylistChanged" value="@selectedStylistId" class="bg-[#25262b] border border-gray-700 rounded px-4 py-2 text-white text-[10px] font-black uppercase outline-none focus:border-[#D2B48C]">
                            <option value="0">-- Select Stylist --</option>
                            @foreach(var s in allStylists) { <option value="@s.Id">@s.Name</option> }
                        </select>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="mb-6 p-4 bg-red-900/40 border border-red-500/50 text-red-200 rounded font-mono text-[10px] uppercase">
                        ERR: @errorMessage
                    </div>
                }

                @if (selectedStylistId > 0)
                {
                    <div class="space-y-6">
                        @foreach (var day in DayNames)
                        {
                            var shifts = allSchedules.Where(x => x.DayOfWeek == day.Key).ToList();
                            
                            <div class="bg-[#25262b] rounded-xl border border-gray-700 overflow-hidden shadow-xl">
                                <div class="p-4 bg-black/20 border-b border-gray-800 flex justify-between items-center">
                                    <div class="flex items-center gap-4">
                                        <h3 class="font-black text-[#D2B48C] uppercase tracking-widest text-xs">@day.Value</h3>
                                        @if (shifts.Any())
                                        {
                                            <button @onclick="() => OpenCopyModal(day.Key)" class="text-[9px] text-gray-500 hover:text-white flex items-center gap-1 uppercase transition">
                                                <i class="fas fa-copy"></i> Copy
                                            </button>
                                            <button @onclick="() => ClearDay(day.Key)" class="text-[9px] text-red-500/50 hover:text-red-500 flex items-center gap-1 uppercase transition ml-2">
                                                <i class="fas fa-trash-alt"></i> Clear Day
                                            </button>
                                        }
                                    </div>
                                    <button @onclick="() => AddShift(day.Key)" class="text-[9px] font-black bg-blue-600/20 text-blue-400 border border-blue-500/30 px-3 py-1 rounded hover:bg-blue-600 hover:text-white transition">＋ Add Shift Block</button>
                                </div>

                                <div class="p-4 space-y-3">
                                    @if (!shifts.Any())
                                    {
                                        <div class="text-center py-4 text-gray-600 italic text-[10px] uppercase tracking-widest">Off / No Shifts</div>
                                    }
                                    else
                                    {
                                        @foreach (var s in shifts)
                                        {
                                            @* REFACTORED TO GRID FOR STABILITY *@
                                            <div class="grid grid-cols-[1fr_auto_1fr_auto] items-center gap-4 bg-white/5 p-3 rounded-lg border border-white/5">
                                                <div class="flex items-center gap-2">
                                                    <span class="text-[9px] text-gray-500 uppercase font-mono">Start</span>
                                                    <input type="time" 
                                                           value="@s.StartTime.ToString("HH:mm")" 
                                                           @onchange="@((ChangeEventArgs e) => s.StartTime = UpdateTime(s.StartTime, e.Value?.ToString()))"
                                                           class="w-full bg-black/40 border border-gray-700 rounded px-2 py-1 text-sm text-[#D2B48C] font-mono" />
                                                </div>
                                                
                                                <div class="text-gray-700 font-black">➔</div>
                                                
                                                <div class="flex items-center gap-2">
                                                    <span class="text-[9px] text-gray-500 uppercase font-mono">End</span>
                                                    <input type="time" 
                                                           value="@s.EndTime.ToString("HH:mm")" 
                                                           @onchange="@((ChangeEventArgs e) => s.EndTime = UpdateTime(s.EndTime, e.Value?.ToString()))"
                                                           class="w-full bg-black/40 border border-gray-700 rounded px-2 py-1 text-sm text-[#D2B48C] font-mono" />
                                                </div>

                                                <button @onclick="() => RemoveShift(s)" class="w-10 h-10 flex items-center justify-center rounded-lg bg-red-500/10 text-red-500/60 hover:bg-red-500 hover:text-white transition-all shadow-inner" title="Remove Shift">
                                                    <i class="fas fa-trash-can text-sm"></i>
                                                </button>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        }

                        <div class="flex justify-end pt-6">
                            <button @onclick="SaveSchedules" class="bg-blue-600 hover:bg-blue-500 text-white font-black uppercase text-xs px-12 py-4 rounded-xl shadow-2xl transition tracking-widest">Save Schedule</button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-32 border-2 border-dashed border-gray-800 rounded-3xl">
                        <i class="fas fa-clock text-4xl text-gray-800 mb-4"></i>
                        <p class="text-gray-600 font-black uppercase tracking-widest text-xs">Awaiting Stylist Selection...</p>
                    </div>
                }
            </div>
        </div>
    }
</div>

@* COPY TO MODAL *@
@if (showCopyModal)
{
    <div class="fixed inset-0 bg-black/90 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-[#25262b] w-full max-w-sm rounded-xl border border-gray-700 shadow-2xl overflow-hidden font-black">
            <div class="p-4 bg-gray-800/50 border-b border-gray-700 flex justify-between items-center uppercase text-[10px] tracking-widest text-[#D2B48C]">
                <span>Copy @DayNames[sourceDay] Schedule To:</span>
                <button @onclick="() => showCopyModal = false" class="text-gray-500 hover:text-white text-xl">&times;</button>
            </div>
            <div class="p-6 grid grid-cols-1 gap-2 text-gray-300">
                @foreach (var day in DayNames.Where(x => x.Key != sourceDay))
                {
                    <label class="flex items-center gap-3 p-3 bg-white/5 rounded border border-white/5 cursor-pointer hover:bg-white/10 transition">
                        <input type="checkbox" checked="@targetDays.Contains(day.Key)" @onchange="((e) => ToggleTargetDay(day.Key, e.Value))" class="w-4 h-4" />
                        <span class="text-xs uppercase tracking-tight">@day.Value</span>
                    </label>
                }
            </div>
            <div class="p-4 bg-black/20 border-t border-gray-700 flex justify-end gap-3">
                <button @onclick="() => showCopyModal = false" class="text-[10px] text-gray-500 uppercase px-4 py-2 font-black">Cancel</button>
                <button @onclick="ExecuteCopy" class="bg-blue-600 hover:bg-blue-500 text-white text-[10px] uppercase px-6 py-2 rounded font-black shadow-xl">Apply_Clone</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int DefaultStylistId { get; set; }
    private bool isAuthorized = false, isLoading = true, showCopyModal = false, showToast = false;
    private int selectedStylistId = 0, sourceDay = 0;
    private string errorMessage = "";
    private List<NETH_Stylist> allStylists = new();
    private List<NETH_Schedule> allSchedules = new();
    private List<NETH_Schedule> deletedSchedules = new();
    private List<int> targetDays = new();

    private Dictionary<int, string> DayNames = new() {
        {0, "Sunday"}, {1, "Monday"}, {2, "Tuesday"}, {3, "Wednesday"}, {4, "Thursday"}, {5, "Friday"}, {6, "Saturday"}
    };

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "neth_session");
            if (string.IsNullOrEmpty(json)) Nav.NavigateTo("/nethaircut");
            else { 
                isAuthorized = true; 
                await LoadInitialData(); 
                if (DefaultStylistId > 0) {
                    selectedStylistId = DefaultStylistId;
                    await LoadStylistSchedule(selectedStylistId);
                }
                isLoading = false; 
                StateHasChanged(); 
            }
        }
    }

    private async Task LoadInitialData() {
        try { allStylists = await Db.NETH_Stylists.AsNoTracking().ToListAsync(); } catch { errorMessage = "DATABASE_SYNC_FAILED"; }
    }

    private async Task OnStylistChanged(ChangeEventArgs e) {
        selectedStylistId = int.Parse(e.Value?.ToString() ?? "0");
        if (selectedStylistId > 0) await LoadStylistSchedule(selectedStylistId);
    }

    private async Task LoadStylistSchedule(int id) {
        try {
            allSchedules = await Db.Database.SqlQueryRaw<NETH_Schedule>(@"SELECT * FROM ""NETH_Schedules"" WHERE ""StylistId"" = {0}", id).ToListAsync();
            deletedSchedules.Clear();
            errorMessage = "";
        } catch { errorMessage = "TABLE_ERROR: ACCESS DENIED OR MISSING RELATION"; }
    }

    private DateTime UpdateTime(DateTime existing, string? timeString) {
        if (TimeSpan.TryParse(timeString, out var ts)) return existing.Date.Add(ts);
        return existing;
    }

    private void AddShift(int day) {
        allSchedules.Add(new NETH_Schedule { StylistId = selectedStylistId, DayOfWeek = day, StartTime = DateTime.Today.AddHours(9), EndTime = DateTime.Today.AddHours(17), IsWorkDay = true });
    }

    private void RemoveShift(NETH_Schedule s) {
        if (s.Id != 0) deletedSchedules.Add(s);
        allSchedules.Remove(s);
    }

    private void ClearDay(int dayOfWeek) {
        var toRemove = allSchedules.Where(x => x.DayOfWeek == dayOfWeek).ToList();
        foreach (var s in toRemove) {
            if (s.Id != 0) deletedSchedules.Add(s);
            allSchedules.Remove(s);
        }
    }

    private void OpenCopyModal(int day) {
        sourceDay = day;
        targetDays.Clear();
        showCopyModal = true;
    }

    private void ToggleTargetDay(int day, object? value) {
        if ((bool)(value ?? false)) targetDays.Add(day);
        else targetDays.Remove(day);
    }

    private void ExecuteCopy() {
        var shiftsToCopy = allSchedules.Where(x => x.DayOfWeek == sourceDay).ToList();
        foreach (var targetDay in targetDays) {
            ClearDay(targetDay);
            foreach (var s in shiftsToCopy) {
                allSchedules.Add(new NETH_Schedule { StylistId = selectedStylistId, DayOfWeek = targetDay, StartTime = s.StartTime, EndTime = s.EndTime, IsWorkDay = true });
            }
        }
        showCopyModal = false;
    }

    private async Task SaveSchedules() {
        try {
            errorMessage = "";
            foreach (var d in deletedSchedules) await Db.Database.ExecuteSqlRawAsync(@"DELETE FROM ""NETH_Schedules"" WHERE ""Id"" = {0}", d.Id);
            deletedSchedules.Clear();

            foreach (var s in allSchedules) {
                if (s.Id == 0) await Db.Database.ExecuteSqlRawAsync(@"INSERT INTO ""NETH_Schedules"" (""StylistId"", ""DayOfWeek"", ""StartTime"", ""EndTime"", ""IsWorkDay"") VALUES ({0}, {1}, {2}, {3}, {4})", s.StylistId, s.DayOfWeek, s.StartTime, s.EndTime, s.IsWorkDay);
                else await Db.Database.ExecuteSqlRawAsync(@"UPDATE ""NETH_Schedules"" SET ""StartTime"" = {0}, ""EndTime"" = {1}, ""IsWorkDay"" = {2} WHERE ""Id"" = {3}", s.StartTime, s.EndTime, s.IsWorkDay, s.Id);
            }
            
            await LoadStylistSchedule(selectedStylistId);
            await TriggerToast();
        } catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task TriggerToast() {
        showToast = true;
        StateHasChanged();
        await Task.Delay(3000);
        showToast = false;
        StateHasChanged();
    }
}