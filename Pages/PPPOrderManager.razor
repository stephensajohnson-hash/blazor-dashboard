@page "/ppp-order-manager/{OwnerId:int}"
@using Dashboard
@using Dashboard.Services
@using Dashboard.Components
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IDbContextFactory<AppDbContext> DbFactory

<div class="min-h-screen bg-[#050505] text-slate-200 p-8 font-sans antialiased pb-40">
    <PPPAdminNav CurrentPage="Orders" />

    <div class="max-w-6xl mx-auto mb-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <h1 class="text-4xl font-black text-white italic uppercase tracking-tighter">Kitchen Production</h1>
            <p class="text-emerald-500 text-[10px] font-black uppercase tracking-[0.3em] mt-1">Live Production Feed</p>
        </div>
        <div class="bg-[#111] border border-slate-800 px-6 py-3 rounded-2xl">
            <span class="text-[9px] text-slate-500 uppercase font-black block">Active Items</span>
            <span class="text-xl font-mono font-bold text-white">@ProductionQueue.Count</span>
        </div>
    </div>

    <div class="max-w-6xl mx-auto space-y-16">
        @if (!ProductionQueue.Any())
        {
            <div class="py-20 text-center bg-[#111] rounded-[3rem] border border-slate-800 border-dashed">
                <span class="text-4xl block mb-4">🍳</span>
                <p class="text-xs font-black uppercase tracking-widest text-slate-600">No orders found.</p>
            </div>
        }
        else
        {
            @foreach (var dayGroup in ProductionQueue.GroupBy(x => x.ScheduledDate.Date).OrderBy(x => x.Key))
            {
                <div class="space-y-6">
                    <h2 class="text-xl font-black text-white uppercase tracking-widest flex items-center gap-4">
                        <span class="text-emerald-500">@dayGroup.Key.ToString("dddd, MMM d")</span>
                        <span class="h-[1px] flex-1 bg-white/5"></span>
                    </h2>

                    @foreach (var timeGroup in dayGroup.GroupBy(x => x.TimeframeName).OrderBy(x => x.Key))
                    {
                        <div class="bg-[#111] border border-slate-800 rounded-[2.5rem] overflow-hidden">
                            <div class="bg-white/5 p-6 border-b border-white/5 flex justify-between items-center">
                                <h3 class="text-sm font-black text-white uppercase italic">Window: @(string.IsNullOrEmpty(timeGroup.Key) ? "Standard" : timeGroup.Key)</h3>
                                <span class="text-[10px] bg-white/10 text-slate-300 px-4 py-1.5 rounded-full font-black">@timeGroup.Count() Items</span>
                            </div>

                            <div class="divide-y divide-white/5">
                                @foreach (var itemRow in timeGroup)
                                {
                                    <div class="p-6 flex flex-col md:flex-row justify-between items-center gap-6">
                                        <div class="flex items-center gap-6">
                                            <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-xl @(itemRow.FulfillmentMethod == "Pickup" ? "bg-emerald-950/30 text-emerald-500" : "bg-blue-950/30 text-blue-500")">
                                                @(itemRow.FulfillmentMethod == "Pickup" ? "🏢" : "🚚")
                                            </div>
                                            <div>
                                                <p class="text-white font-black uppercase text-base">@itemRow.RecipeName</p>
                                                <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">
                                                    @itemRow.SizeName • @(itemRow.FulfillmentMethod == "Pickup" ? GetLocation(itemRow.PickupLocationId) : "Delivery")
                                                </p>
                                            </div>
                                        </div>

                                        <div class="flex items-center gap-6">
                                            <div class="text-right">
                                                <p class="text-[9px] text-slate-500 font-black uppercase">Customer</p>
                                                <p class="text-xs font-mono text-white opacity-60">@GetCustId(itemRow)</p>
                                            </div>
                                            <button class="bg-emerald-600 hover:bg-emerald-500 text-white px-6 py-3 rounded-xl text-[9px] font-black uppercase tracking-widest transition-all">Mark Ready</button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public int OwnerId { get; set; }
    private List<PPP_OrderItem> ProductionQueue = new();
    private List<PPP_PickupLocation> LocationsLookup = new();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        
        // Use the NEW Property Name: ParentOrderContainer
        ProductionQueue = await db.Set<PPP_OrderItem>()
            .Include(i => i.ParentOrderContainer) 
            .Include(i => i.SelectedOptions)
            .Where(i => i.ParentOrderContainer != null && i.ParentOrderContainer.OwnerId == OwnerId && i.ParentOrderContainer.IsCheckedOut)
            .ToListAsync();

        LocationsLookup = await db.Set<PPP_PickupLocation>().Where(l => l.OwnerId == OwnerId).ToListAsync();
    }

    private string GetLocation(int? id) => id.HasValue ? LocationsLookup.FirstOrDefault(l => l.Id == id)?.Name ?? "Shop" : "Shop";

    private string GetCustId(PPP_OrderItem item)
    {
        var id = item.ParentOrderContainer?.CustomerIdentifier;
        if (string.IsNullOrEmpty(id)) return "GUEST";
        return id.Length > 8 ? id.Substring(0, 8).ToUpper() : id.ToUpper();
    }
}