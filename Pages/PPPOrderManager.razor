@page "/ppp-order-manager/{OwnerId:int}"
@using Dashboard
@using Dashboard.Services
@using Dashboard.Components
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IDbContextFactory<AppDbContext> DbFactory

<div class="min-h-screen bg-[#050505] text-slate-200 p-8 font-sans antialiased pb-40">
    <PPPAdminNav CurrentPage="Orders" />

    @* Header Section *@
    <div class="max-w-6xl mx-auto mb-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <h1 class="text-4xl font-black text-white italic uppercase tracking-tighter">Kitchen Production</h1>
            <p class="text-emerald-500 text-[10px] font-black uppercase tracking-[0.3em] mt-1">Live Production Feed</p>
        </div>
        <div class="bg-[#111] border border-slate-800 px-6 py-3 rounded-2xl">
            <span class="text-[9px] text-slate-500 uppercase font-black block">Active Items</span>
            <span class="text-xl font-mono font-bold text-white">@MasterKitchenQueue.Count</span>
        </div>
    </div>

    @* Production Schedule View *@
    <div class="max-w-6xl mx-auto space-y-16">
        @if (!MasterKitchenQueue.Any())
        {
            <div class="py-20 text-center bg-[#111] rounded-[3rem] border border-slate-800 border-dashed">
                <span class="text-4xl block mb-4">🍳</span>
                <p class="text-xs font-black uppercase tracking-widest text-slate-600">No active production items found.</p>
            </div>
        }
        else
        {
            @foreach (var dayBucket in MasterKitchenQueue.GroupBy(x => x.ScheduledDate.Date).OrderBy(x => x.Key))
            {
                <div class="space-y-6">
                    <h2 class="text-xl font-black text-white uppercase tracking-widest flex items-center gap-4">
                        <span class="text-emerald-500">@dayBucket.Key.ToString("dddd, MMM d")</span>
                        <span class="h-[1px] flex-1 bg-white/5"></span>
                    </h2>

                    @foreach (var timeBucket in dayBucket.GroupBy(x => x.TimeframeName).OrderBy(x => x.Key))
                    {
                        <div class="bg-[#111] border border-slate-800 rounded-[2.5rem] overflow-hidden shadow-2xl">
                            <div class="bg-white/5 p-6 border-b border-white/5 flex justify-between items-center">
                                <div class="flex items-center gap-3">
                                    <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
                                    <h3 class="text-sm font-black text-white uppercase italic tracking-widest">Window: @(string.IsNullOrEmpty(timeBucket.Key) ? "Standard" : timeBucket.Key)</h3>
                                </div>
                                <span class="text-[10px] bg-white/10 text-slate-300 px-4 py-1.5 rounded-full font-black uppercase">
                                    @timeBucket.Count() Units
                                </span>
                            </div>

                            <div class="divide-y divide-white/5">
                                @foreach (var lineItem in timeBucket)
                                {
                                    <div class="p-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 group hover:bg-white/[0.02] transition-all">
                                        <div class="flex items-center gap-6">
                                            <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-xl @(lineItem.FulfillmentMethod == "Pickup" ? "bg-emerald-950/30 text-emerald-500" : "bg-blue-950/30 text-blue-500")">
                                                @(lineItem.FulfillmentMethod == "Pickup" ? "🏢" : "🚚")
                                            </div>

                                            <div>
                                                <div class="flex items-center gap-3 mb-1">
                                                    <p class="text-white font-black uppercase text-base">@lineItem.RecipeName</p>
                                                    <span class="text-[9px] font-mono text-slate-600">ID: @lineItem.Id</span>
                                                </div>
                                                <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">
                                                    @lineItem.SizeName 
                                                    @if (lineItem.SelectedOptions != null && lineItem.SelectedOptions.Any())
                                                    {
                                                        <span class="text-blue-400"> + @GetOptionString(lineItem)</span>
                                                    }
                                                </p>
                                                
                                                <div class="mt-2 text-[10px] font-black uppercase tracking-tighter">
                                                    @if (lineItem.FulfillmentMethod == "Pickup")
                                                    {
                                                        <span class="text-emerald-500/80 italic">Spot: @GetSpotName(lineItem.PickupLocationId)</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-blue-500/80 italic">Delivery Fee: $@lineItem.DeliveryFee.ToString("N2")</span>
                                                    }
                                                </div>
                                            </div>
                                        </div>

                                        <div class="flex items-center gap-4 w-full md:w-auto border-t md:border-t-0 border-white/5 pt-4 md:pt-0">
                                            <div class="text-right flex-1 md:flex-none mr-4">
                                                <p class="text-[9px] text-slate-500 font-black uppercase mb-1">Customer</p>
                                                <p class="text-xs font-mono text-white opacity-60">@GetSafeCustId(lineItem)</p>
                                            </div>
                                            
                                            <div class="flex items-center gap-2">
                                                @* Edit Button *@
                                                <button @onclick="() => StartEdit(lineItem)" 
                                                        class="bg-blue-500/10 hover:bg-blue-600 text-blue-500 hover:text-white w-12 h-12 rounded-xl flex items-center justify-center transition-all border border-blue-500/20 active:scale-90">
                                                    <span class="text-lg">✏️</span>
                                                </button>

                                                @* Delete Button - Changed to Red X *@
                                                <button @onclick="() => DeleteOrderItem(lineItem.Id)" 
                                                        class="bg-red-500/10 hover:bg-red-600 text-red-500 hover:text-white w-12 h-12 rounded-xl flex items-center justify-center transition-all border border-red-500/20 active:scale-90"
                                                        title="Delete Order Item">
                                                    <span class="text-xl font-bold">✕</span>
                                                </button>

                                                @* Status Button *@
                                                <button class="bg-emerald-600/10 hover:bg-emerald-600 text-emerald-500 hover:text-white px-6 py-3 rounded-xl text-[9px] font-black uppercase tracking-widest transition-all border border-emerald-500/20 active:scale-95">
                                                    Mark Ready
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>

    @* Edit Modal Overlay *@
    @if (editingItem != null)
    {
        <div class="fixed inset-0 bg-black/90 backdrop-blur-md z-[600] flex items-center justify-center p-4">
            <div class="bg-[#111] border border-slate-800 w-full max-w-lg rounded-[2.5rem] p-8 shadow-2xl animate-in fade-in zoom-in-95 duration-200">
                <div class="flex justify-between items-start mb-8">
                    <div>
                        <h2 class="text-2xl font-black text-white uppercase italic tracking-tighter">Edit Item</h2>
                        <p class="text-[10px] text-emerald-500 font-black uppercase">Production Correction</p>
                    </div>
                    <button @onclick="() => editingItem = null" class="text-slate-500 hover:text-white text-2xl">&times;</button>
                </div>

                <div class="space-y-6">
                    <div>
                        <label class="text-[9px] font-black uppercase text-slate-500 mb-2 block">Production Date</label>
                        <input type="date" @bind="editingItem.ScheduledDate" class="w-full bg-black border border-slate-800 rounded-xl p-4 text-xs text-white outline-none focus:border-emerald-500" />
                    </div>

                    <div>
                        <label class="text-[9px] font-black uppercase text-slate-500 mb-2 block">Timeframe Window</label>
                        <input type="text" @bind="editingItem.TimeframeName" class="w-full bg-black border border-slate-800 rounded-xl p-4 text-xs text-white outline-none focus:border-emerald-500" placeholder="e.g. Lunch, Dinner" />
                    </div>

                    <div>
                        <label class="text-[9px] font-black uppercase text-slate-500 mb-2 block">Fulfillment Method</label>
                        <select @bind="editingItem.FulfillmentMethod" class="w-full bg-black border border-slate-800 rounded-xl p-4 text-xs text-white outline-none focus:border-emerald-500">
                            <option value="Pickup">Pickup</option>
                            <option value="Delivery">Delivery</option>
                        </select>
                    </div>

                    @if (editingItem.FulfillmentMethod == "Pickup")
                    {
                        <div>
                            <label class="text-[9px] font-black uppercase text-slate-500 mb-2 block">Pickup Location</label>
                            <select @bind="editingItem.PickupLocationId" class="w-full bg-black border border-slate-800 rounded-xl p-4 text-xs text-white outline-none focus:border-emerald-500">
                                <option value="">-- Main Shop --</option>
                                @foreach (var loc in LocationsLookup)
                                {
                                    <option value="@loc.Id">@loc.Name</option>
                                }
                            </select>
                        </div>
                    }
                    else
                    {
                        <div>
                            <label class="text-[9px] font-black uppercase text-slate-500 mb-2 block">Delivery Fee</label>
                            <input type="number" step="0.01" @bind="editingItem.DeliveryFee" class="w-full bg-black border border-slate-800 rounded-xl p-4 text-xs text-white outline-none focus:border-emerald-500" />
                        </div>
                    }
                </div>

                <div class="mt-10 flex gap-3">
                    <button @onclick="() => editingItem = null" class="flex-1 bg-white/5 hover:bg-white/10 text-slate-400 py-4 rounded-2xl text-[9px] font-black uppercase tracking-widest transition-all">Cancel</button>
                    <button @onclick="SaveEdit" class="flex-1 bg-emerald-600 hover:bg-emerald-500 text-white py-4 rounded-2xl text-[9px] font-black uppercase tracking-widest transition-all shadow-xl">Save Changes</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int OwnerId { get; set; }
    
    private List<PPP_OrderItem> MasterKitchenQueue = new();
    private List<PPP_PickupLocation> LocationsLookup = new();
    private PPP_OrderItem? editingItem;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        
        MasterKitchenQueue = await db.Set<PPP_OrderItem>()
            .Include(i => i.ParentOrderContainer)
            .Include(i => i.SelectedOptions)
            .Where(i => i.ParentOrderContainer != null && i.ParentOrderContainer.OwnerId == OwnerId && i.ParentOrderContainer.IsCheckedOut)
            .ToListAsync();

        LocationsLookup = await db.Set<PPP_PickupLocation>()
            .Where(l => l.OwnerId == OwnerId)
            .ToListAsync();
    }

    private void StartEdit(PPP_OrderItem item)
    {
        editingItem = new PPP_OrderItem
        {
            Id = item.Id,
            OrderId = item.OrderId,
            ScheduledDate = item.ScheduledDate,
            TimeframeName = item.TimeframeName,
            FulfillmentMethod = item.FulfillmentMethod,
            PickupLocationId = item.PickupLocationId,
            DeliveryFee = item.DeliveryFee,
            RecipeName = item.RecipeName,
            SizeName = item.SizeName
        };
    }

    private async Task SaveEdit()
    {
        if (editingItem == null) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var dbItem = await db.Set<PPP_OrderItem>().FindAsync(editingItem.Id);

        if (dbItem != null)
        {
            dbItem.ScheduledDate = editingItem.ScheduledDate.ToUniversalTime();
            dbItem.TimeframeName = editingItem.TimeframeName;
            dbItem.FulfillmentMethod = editingItem.FulfillmentMethod;
            dbItem.PickupLocationId = editingItem.PickupLocationId;
            dbItem.DeliveryFee = editingItem.DeliveryFee;

            await db.SaveChangesAsync();
            editingItem = null;
            await LoadData();
        }
    }

    private async Task DeleteOrderItem(int itemId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var item = await db.Set<PPP_OrderItem>().FindAsync(itemId);
        
        if (item != null)
        {
            db.Remove(item);
            await db.SaveChangesAsync();
            await LoadData();
        }
    }

    private string GetOptionString(PPP_OrderItem item)
    {
        if (item.SelectedOptions == null) return "";
        return string.Join(", ", item.SelectedOptions.Select(o => o.OptionName));
    }

    private string GetSpotName(int? id)
    {
        if (!id.HasValue) return "Default Location";
        return LocationsLookup.FirstOrDefault(l => l.Id == id.Value)?.Name ?? "Main Location";
    }

    private string GetSafeCustId(PPP_OrderItem item)
    {
        var parentData = item.ParentOrderContainer;
        if (parentData == null) return "GUEST";
        var cid = parentData.CustomerIdentifier;
        if (string.IsNullOrEmpty(cid)) return "GUEST";
        return cid.Length > 8 ? cid.Substring(0, 8).ToUpper() : cid.ToUpper();
    }
}