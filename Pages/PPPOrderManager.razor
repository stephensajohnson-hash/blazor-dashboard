@page "/ppp-order-manager/{OwnerId:int}"
@using Dashboard
@using Dashboard.Services
@using Dashboard.Components
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IDbContextFactory<AppDbContext> DbFactory

<div class="min-h-screen bg-[#050505] text-slate-200 p-8 font-sans antialiased pb-40">
    <PPPAdminNav CurrentPage="Orders" />

    @* Header Section *@
    <div class="max-w-6xl mx-auto mb-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <h1 class="text-4xl font-black text-white italic uppercase tracking-tighter">Kitchen Production</h1>
            <p class="text-emerald-500 text-[10px] font-black uppercase tracking-[0.3em] mt-1">Live Production Feed</p>
        </div>

        @* Status Filter Toggle *@
        <div class="flex bg-[#111] border border-slate-800 p-1 rounded-2xl">
            <button @onclick='() => SetFilter("pending")' class="px-6 py-2 rounded-xl text-[10px] font-black uppercase transition-all @(activeFilter == "pending" ? "bg-emerald-600 text-white shadow-lg" : "text-slate-500 hover:text-slate-300")">Pending</button>
            <button @onclick='() => SetFilter("ready")' class="px-6 py-2 rounded-xl text-[10px] font-black uppercase transition-all @(activeFilter == "ready" ? "bg-blue-600 text-white shadow-lg" : "text-slate-500 hover:text-slate-300")">Ready</button>
            <button @onclick='() => SetFilter("all")' class="px-6 py-2 rounded-xl text-[10px] font-black uppercase transition-all @(activeFilter == "all" ? "bg-slate-700 text-white shadow-lg" : "text-slate-500 hover:text-slate-300")">All</button>
        </div>

        <div class="bg-[#111] border border-slate-800 px-6 py-3 rounded-2xl">
            <span class="text-[9px] text-slate-500 uppercase font-black block">Active Items</span>
            <span class="text-xl font-mono font-bold text-white">@MasterKitchenQueue.Count</span>
        </div>
    </div>

    @* Production Schedule View *@
    <div class="max-w-6xl mx-auto space-y-16">
        @if (!MasterKitchenQueue.Any())
        {
            <div class="py-20 text-center bg-[#111] rounded-[3rem] border border-slate-800 border-dashed">
                <span class="text-4xl block mb-4">🍳</span>
                <p class="text-xs font-black uppercase tracking-widest text-slate-600">No production items found.</p>
            </div>
        }
        else
        {
            @foreach (var dayBucket in MasterKitchenQueue.GroupBy(x => x.ScheduledDate.Date).OrderBy(x => x.Key))
            {
                <div class="space-y-6">
                    <h2 class="text-xl font-black text-white uppercase tracking-widest flex items-center gap-4">
                        <span class="text-emerald-500">@dayBucket.Key.ToString("dddd, MMM d")</span>
                        <span class="h-[1px] flex-1 bg-white/5"></span>
                    </h2>

                    @foreach (var timeBucket in dayBucket.GroupBy(x => x.TimeframeName).OrderBy(x => x.Key))
                    {
                        <div class="bg-[#111] border border-slate-800 rounded-[2.5rem] overflow-hidden shadow-2xl">
                            <div class="bg-white/5 p-6 border-b border-white/5 flex justify-between items-center">
                                <div class="flex items-center gap-3">
                                    <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
                                    <h3 class="text-sm font-black text-white uppercase italic tracking-widest">Window: @(string.IsNullOrEmpty(timeBucket.Key) ? "Standard" : timeBucket.Key)</h3>
                                </div>
                                <span class="text-[10px] bg-white/10 text-slate-300 px-4 py-1.5 rounded-full font-black uppercase">
                                    @timeBucket.Count() Units
                                </span>
                            </div>

                            <div class="divide-y divide-white/5">
                                @foreach (var lineItem in timeBucket)
                                {
                                    <div class="p-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 group hover:bg-white/[0.02] transition-all">
                                        <div class="flex items-center gap-6">
                                            @* Restored Image Section *@
                                            <div class="w-20 h-20 rounded-2xl overflow-hidden bg-black border border-slate-800 shrink-0 shadow-inner">
                                                @if (lineItem.MenuItem?.Recipe?.ImageId != null)
                                                {
                                                    <img src="/db-images-ppp/@lineItem.MenuItem.Recipe.ImageId" class="w-full h-full object-cover" />
                                                }
                                                else
                                                {
                                                    <div class="w-full h-full flex items-center justify-center text-2xl bg-white/5 text-slate-700">🥘</div>
                                                }
                                            </div>

                                            <div>
                                                <div class="flex items-center gap-3 mb-1">
                                                    <p class="text-white font-black uppercase text-base @(lineItem.IsReady ? "line-through opacity-40" : "")">@lineItem.RecipeName</p>
                                                    
                                                    @if (!string.IsNullOrEmpty(lineItem.LabelName))
                                                    {
                                                        <span class="bg-emerald-500 text-black text-[9px] px-3 py-0.5 rounded-full font-black uppercase tracking-tighter">
                                                            FOR: @lineItem.LabelName
                                                        </span>
                                                    }
                                                    
                                                    <span class="text-[9px] font-mono text-slate-600">ID: @lineItem.Id</span>
                                                    @if (lineItem.IsReady)
                                                    {
                                                        <span class="bg-blue-500/20 text-blue-400 text-[8px] px-2 py-0.5 rounded font-black uppercase tracking-tighter">Ready</span>
                                                    }
                                                </div>
                                                <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">
                                                    @lineItem.SizeName 
                                                    @if (lineItem.SelectedOptions != null && lineItem.SelectedOptions.Any())
                                                    {
                                                        <span class="text-blue-400"> + @GetOptionString(lineItem)</span>
                                                    }
                                                </p>
                                                
                                                <div class="mt-2 flex flex-col gap-1">
                                                    @if (lineItem.FulfillmentMethod == "Pickup")
                                                    {
                                                        <span class="text-[10px] font-black uppercase text-emerald-500/80 italic">Spot: @GetSpotName(lineItem.PickupLocationId)</span>
                                                    }
                                                    else
                                                    {
                                                        <div class="flex flex-col">
                                                            <span class="text-[10px] font-black uppercase text-blue-500/80 italic">Delivery: @GetAddressInfo(lineItem)</span>
                                                            @if (UserLookup.TryGetValue(lineItem.ParentOrderContainer?.CustomerIdentifier ?? "", out var u))
                                                            {
                                                                var addr = u.Addresses.FirstOrDefault(a => a.IsDefault) ?? u.Addresses.FirstOrDefault();
                                                                if (addr != null && !string.IsNullOrEmpty(addr.DeliveryInstructions))
                                                                {
                                                                    <span class="text-[9px] text-amber-500 font-bold uppercase mt-1 italic">Note: @addr.DeliveryInstructions</span>
                                                                }
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>

                                        <div class="flex items-center gap-4 w-full md:w-auto border-t md:border-t-0 border-white/5 pt-4 md:pt-0">
                                            <div class="text-right flex-1 md:flex-none mr-4">
                                                <p class="text-[9px] text-slate-500 font-black uppercase mb-1">Customer</p>
                                                <p class="text-xs font-mono text-white opacity-60">@GetSafeCustId(lineItem)</p>
                                            </div>
                                            
                                            <div class="flex items-center gap-2">
                                                <button @onclick="() => StartEdit(lineItem)" 
                                                        class="bg-blue-500/10 hover:bg-blue-600 text-blue-500 hover:text-white w-12 h-12 rounded-xl flex items-center justify-center transition-all border border-blue-500/20 active:scale-90">
                                                    <span class="text-lg">✏️</span>
                                                </button>

                                                <button @onclick="() => DeleteOrderItem(lineItem.Id)" 
                                                        class="bg-red-500/10 hover:bg-red-600 text-red-500 hover:text-white w-12 h-12 rounded-xl flex items-center justify-center transition-all border border-red-500/20 active:scale-90"
                                                        title="Delete Order Item">
                                                    <span class="text-xl font-bold">✕</span>
                                                </button>

                                                <button @onclick="() => ToggleReady(lineItem.Id)"
                                                        class="px-6 py-3 rounded-xl text-[9px] font-black uppercase tracking-widest transition-all border @(lineItem.IsReady ? "bg-slate-800 text-slate-400 border-slate-700" : "bg-emerald-600/10 text-emerald-500 border-emerald-500/20 hover:bg-emerald-600 hover:text-white")">
                                                    @(lineItem.IsReady ? "Undo Ready" : "Mark Ready")
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>

    @* Edit Modal Overlay *@
    @if (editingItem != null)
    {
        <div class="fixed inset-0 bg-black/90 backdrop-blur-md z-[600] flex items-center justify-center p-4">
            <div class="bg-[#111] border border-slate-800 w-full max-w-lg rounded-[2.5rem] p-8 shadow-2xl animate-in fade-in zoom-in-95 duration-200">
                <div class="flex justify-between items-start mb-8">
                    <div>
                        <h2 class="text-2xl font-black text-white uppercase italic tracking-tighter">Edit Item</h2>
                        <p class="text-[10px] text-emerald-500 font-black uppercase">Production Correction</p>
                    </div>
                    <button @onclick="() => editingItem = null" class="text-slate-500 hover:text-white text-2xl">&times;</button>
                </div>

                <div class="space-y-6">
                    <div>
                        <label class="text-[9px] font-black uppercase text-slate-500 mb-2 block">Item Label (For Whom?)</label>
                        <input type="text" @bind="editingItem.LabelName" class="w-full bg-black border border-slate-800 rounded-xl p-4 text-xs text-white outline-none focus:border-emerald-500" />
                    </div>

                    <div>
                        <label class="text-[9px] font-black uppercase text-slate-500 mb-2 block">Production Date</label>
                        <input type="date" @bind="editingItem.ScheduledDate" class="w-full bg-black border border-slate-800 rounded-xl p-4 text-xs text-white outline-none focus:border-emerald-500" />
                    </div>

                    <div>
                        <label class="text-[9px] font-black uppercase text-slate-500 mb-2 block">Timeframe Window</label>
                        <input type="text" @bind="editingItem.TimeframeName" class="w-full bg-black border border-slate-800 rounded-xl p-4 text-xs text-white outline-none focus:border-emerald-500" placeholder="Lunch, Dinner, etc." />
                    </div>

                    <div>
                        <label class="text-[9px] font-black uppercase text-slate-500 mb-2 block">Fulfillment Method</label>
                        <select @bind="editingItem.FulfillmentMethod" class="w-full bg-black border border-slate-800 rounded-xl p-4 text-xs text-white outline-none focus:border-emerald-500">
                            <option value="Pickup">Pickup</option>
                            <option value="Delivery">Delivery</option>
                        </select>
                    </div>
                </div>

                <div class="mt-10 flex gap-3">
                    <button @onclick="() => editingItem = null" class="flex-1 bg-white/5 hover:bg-white/10 text-slate-400 py-4 rounded-2xl text-[9px] font-black uppercase text-slate-500">Cancel</button>
                    <button @onclick="SaveEdit" class="flex-1 bg-emerald-600 hover:bg-emerald-500 text-white py-4 rounded-2xl text-[9px] font-black uppercase tracking-widest shadow-xl">Save Changes</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int OwnerId { get; set; }
    
    private List<PPP_OrderItem> MasterKitchenQueue = new();
    private List<PPP_PickupLocation> LocationsLookup = new();
    private Dictionary<string, PPP_User> UserLookup = new();
    private PPP_OrderItem? editingItem;
    private string activeFilter = "pending";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task SetFilter(string filter)
    {
        activeFilter = filter;
        await LoadData();
    }

    private async Task LoadData()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        
        var query = db.Set<PPP_OrderItem>()
            .Include(i => i.ParentOrderContainer)
            .Include(i => i.SelectedOptions)
            .Include(i => i.MenuItem).ThenInclude(m => m.Recipe)
            .Where(i => i.ParentOrderContainer != null && i.ParentOrderContainer.OwnerId == OwnerId && i.ParentOrderContainer.IsCheckedOut);

        if (activeFilter == "pending") query = query.Where(i => !i.IsReady);
        else if (activeFilter == "ready") query = query.Where(i => i.IsReady);

        MasterKitchenQueue = await query.ToListAsync();
        LocationsLookup = await db.Set<PPP_PickupLocation>().Where(l => l.OwnerId == OwnerId).ToListAsync();

        // Build User/Address Lookup for orders
        var emails = MasterKitchenQueue.Select(x => x.ParentOrderContainer?.CustomerIdentifier).Distinct().ToList();
        var users = await db.PPP_Users
            .Include(u => u.Addresses)
            .Where(u => emails.Contains(u.Email))
            .ToListAsync();
        
        UserLookup = users.ToDictionary(u => u.Email, u => u, StringComparer.OrdinalIgnoreCase);
    }

    private string GetAddressInfo(PPP_OrderItem item)
    {
        var email = item.ParentOrderContainer?.CustomerIdentifier;
        if (string.IsNullOrEmpty(email)) return "GUEST (No Address)";

        if (UserLookup.TryGetValue(email, out var user))
        {
            var addr = user.Addresses.FirstOrDefault(a => a.IsDefault) ?? user.Addresses.FirstOrDefault();
            if (addr != null)
            {
                return $"[{addr.Label}] {addr.Street}, {addr.City}";
            }
        }
        return "Address Not Found";
    }

    private async Task ToggleReady(int itemId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var item = await db.Set<PPP_OrderItem>().FindAsync(itemId);
        if (item != null)
        {
            item.IsReady = !item.IsReady;
            await db.SaveChangesAsync();
            await LoadData();
        }
    }

    private void StartEdit(PPP_OrderItem item)
    {
        editingItem = new PPP_OrderItem
        {
            Id = item.Id,
            OrderId = item.OrderId,
            LabelName = item.LabelName,
            ScheduledDate = item.ScheduledDate,
            TimeframeName = item.TimeframeName,
            FulfillmentMethod = item.FulfillmentMethod,
            PickupLocationId = item.PickupLocationId,
            DeliveryFee = item.DeliveryFee,
            RecipeName = item.RecipeName,
            SizeName = item.SizeName
        };
    }

    private async Task SaveEdit()
    {
        if (editingItem == null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var dbItem = await db.Set<PPP_OrderItem>().FindAsync(editingItem.Id);

        if (dbItem != null)
        {
            dbItem.LabelName = editingItem.LabelName;
            dbItem.ScheduledDate = editingItem.ScheduledDate.ToUniversalTime();
            dbItem.TimeframeName = editingItem.TimeframeName;
            dbItem.FulfillmentMethod = editingItem.FulfillmentMethod;
            dbItem.PickupLocationId = editingItem.PickupLocationId;
            dbItem.DeliveryFee = editingItem.DeliveryFee;

            await db.SaveChangesAsync();
            editingItem = null;
            await LoadData();
        }
    }

    private async Task DeleteOrderItem(int itemId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var item = await db.Set<PPP_OrderItem>().FindAsync(itemId);
        if (item != null)
        {
            db.Remove(item);
            await db.SaveChangesAsync();
            await LoadData();
        }
    }

    private string GetOptionString(PPP_OrderItem item) => (item.SelectedOptions == null) ? "" : string.Join(", ", item.SelectedOptions.Select(o => o.OptionName));
    private string GetSpotName(int? id) => id.HasValue ? (LocationsLookup.FirstOrDefault(l => l.Id == id.Value)?.Name ?? "Main Location") : "Main Location";

    private string GetSafeCustId(PPP_OrderItem item)
    {
        var parentData = item.ParentOrderContainer;
        if (parentData == null) return "GUEST";
        var cid = parentData.CustomerIdentifier;
        if (string.IsNullOrEmpty(cid)) return "GUEST";
        return cid.Length > 8 ? cid.Substring(0, 8).ToUpper() : cid.ToUpper();
    }
}