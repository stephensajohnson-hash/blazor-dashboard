@page "/ppp-order-manager/{OwnerId:int}"
@using Dashboard
@using Dashboard.Services
@using Dashboard.Components
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IDbContextFactory<AppDbContext> DbFactory

<div class="min-h-screen bg-[#050505] text-slate-200 p-8 font-sans antialiased pb-40">
    <PPPAdminNav CurrentPage="Orders" />

    @* Header Section *@
    <div class="max-w-6xl mx-auto mb-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <h1 class="text-4xl font-black text-white italic uppercase tracking-tighter">Kitchen Production</h1>
            <p class="text-emerald-500 text-[10px] font-black uppercase tracking-[0.3em] mt-1">Live Order Stream & Fulfillment</p>
        </div>
        <div class="flex gap-4">
            <div class="bg-[#111] border border-slate-800 px-6 py-3 rounded-2xl">
                <span class="text-[9px] text-slate-500 uppercase font-black block">Active Items</span>
                <span class="text-xl font-mono font-bold text-white">@allOrderedItems.Count</span>
            </div>
            <div class="bg-[#111] border border-slate-800 px-6 py-3 rounded-2xl">
                <span class="text-[9px] text-slate-500 uppercase font-black block">Revenue</span>
                <span class="text-xl font-mono font-bold text-emerald-400">$@allOrderedItems.Sum(i => i.BasePrice + i.DeliveryFee).ToString("N2")</span>
            </div>
        </div>
    </div>

    @* Production Schedule View *@
    <div class="max-w-6xl mx-auto space-y-16">
        @if (!allOrderedItems.Any())
        {
            <div class="py-20 text-center bg-[#111] rounded-[3rem] border border-slate-800 border-dashed">
                <span class="text-4xl block mb-4">🍳</span>
                <p class="text-xs font-black uppercase tracking-widest text-slate-600">The kitchen is quiet. No orders found.</p>
            </div>
        }
        else
        {
            @* FIXED: Explicitly casting to avoid 'Order' method collision *@
            @foreach (var dateGroup in allOrderedItems
                .GroupBy(i => i.ScheduledDate.Date)
                .OrderBy(g => g.Key))
            {
                <div class="space-y-6">
                    <h2 class="text-xl font-black text-white uppercase tracking-widest flex items-center gap-4">
                        <span class="text-emerald-500">@dateGroup.Key.ToString("dddd")</span>
                        <span>@dateGroup.Key.ToString("MMMM d, yyyy")</span>
                        <span class="h-[1px] flex-1 bg-white/5"></span>
                    </h2>

                    @foreach (var timeframeGroup in dateGroup
                        .GroupBy(i => i.TimeframeName)
                        .OrderBy(g => g.Key))
                    {
                        <div class="bg-[#111] border border-slate-800 rounded-[2.5rem] overflow-hidden shadow-2xl">
                            <div class="bg-white/5 p-6 border-b border-white/5 flex justify-between items-center">
                                <div class="flex items-center gap-3">
                                    <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
                                    <h3 class="text-sm font-black text-white uppercase italic tracking-widest">Window: @(string.IsNullOrEmpty(timeframeGroup.Key) ? "Anytime" : timeframeGroup.Key)</h3>
                                </div>
                                <span class="text-[10px] bg-white/10 text-slate-300 px-4 py-1.5 rounded-full font-black uppercase">
                                    @timeframeGroup.Count() Units
                                </span>
                            </div>

                            <div class="divide-y divide-white/5">
                                @foreach (var item in timeframeGroup)
                                {
                                    <div class="p-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 group hover:bg-white/[0.02] transition-all">
                                        <div class="flex items-center gap-6">
                                            <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-xl shadow-inner @(item.FulfillmentMethod == "Pickup" ? "bg-emerald-950/30 text-emerald-500 border border-emerald-900/50" : "bg-blue-950/30 text-blue-500 border border-blue-900/50")">
                                                @(item.FulfillmentMethod == "Pickup" ? "🏢" : "🚚")
                                            </div>

                                            <div>
                                                <div class="flex items-center gap-3 mb-1">
                                                    <p class="text-white font-black uppercase text-base">@item.RecipeName</p>
                                                    <span class="text-[9px] font-mono text-slate-600">#@item.OrderId</span>
                                                </div>
                                                <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">
                                                    @item.SizeName 
                                                    @if (item.SelectedOptions.Any())
                                                    {
                                                        <span class="text-blue-400"> + @string.Join(", ", item.SelectedOptions.Select(o => o.OptionName))</span>
                                                    }
                                                </p>
                                                
                                                <div class="mt-2 text-[10px] font-black uppercase tracking-tighter">
                                                    @if (item.FulfillmentMethod == "Pickup")
                                                    {
                                                        <span class="text-emerald-500/80 italic">Pickup: @(pickupLocations.FirstOrDefault(l => l.Id == item.PickupLocationId)?.Name ?? "Main Shop")</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-blue-500/80 italic">Delivery Fee: $@item.DeliveryFee.ToString("N2")</span>
                                                    }
                                                </div>
                                            </div>
                                        </div>

                                        <div class="flex items-center gap-4 w-full md:w-auto border-t md:border-t-0 border-white/5 pt-4 md:pt-0">
                                            <div class="text-right">
                                                <p class="text-[9px] text-slate-500 font-black uppercase mb-1">Customer</p>
                                                <p class="text-xs font-mono text-white opacity-60">@GetShortId(item.Order?.CustomerIdentifier)</p>
                                            </div>
                                            <button class="bg-emerald-600/10 hover:bg-emerald-600 text-emerald-500 hover:text-white px-6 py-3 rounded-xl text-[9px] font-black uppercase transition-all active:scale-95">
                                                Mark Ready
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public int OwnerId { get; set; }
    private List<PPP_OrderItem> allOrderedItems = new();
    private List<PPP_PickupLocation> pickupLocations = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadProductionData();
    }

    private async Task LoadProductionData()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        
        allOrderedItems = await db.Set<PPP_OrderItem>()
            .Include(i => i.Order)
            .Include(i => i.SelectedOptions)
            .Where(i => i.Order != null && i.Order.OwnerId == OwnerId && i.Order.IsCheckedOut)
            .ToListAsync();

        pickupLocations = await db.Set<PPP_PickupLocation>()
            .Where(l => l.OwnerId == OwnerId)
            .ToListAsync();
    }

    private string GetShortId(string? id) => string.IsNullOrEmpty(id) ? "Guest" : (id.Length > 8 ? id.Substring(0, 8).ToUpper() : id.ToUpper());
}