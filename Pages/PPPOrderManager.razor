@page "/ppp-order-manager/{OwnerId:int}"
@using Dashboard
@using Dashboard.Services
@using Dashboard.Components
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IDbContextFactory<AppDbContext> DbFactory

<div class="min-h-screen bg-[#050505] text-slate-200 p-8 font-sans antialiased pb-40">
    <PPPAdminNav CurrentPage="Orders" />

    <div class="max-w-6xl mx-auto mb-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <h1 class="text-4xl font-black text-white italic uppercase tracking-tighter">Kitchen Production</h1>
            <p class="text-emerald-500 text-[10px] font-black uppercase tracking-[0.3em] mt-1">Live Order Stream</p>
        </div>
        <div class="flex gap-4">
            <div class="bg-[#111] border border-slate-800 px-6 py-3 rounded-2xl">
                <span class="text-[9px] text-slate-500 uppercase font-black block">Active Items</span>
                <span class="text-xl font-mono font-bold text-white">@ProductionList.Count</span>
            </div>
        </div>
    </div>

    <div class="max-w-6xl mx-auto space-y-16">
        @if (!ProductionList.Any())
        {
            <div class="py-20 text-center bg-[#111] rounded-[3rem] border border-slate-800 border-dashed">
                <span class="text-4xl block mb-4">🍳</span>
                <p class="text-xs font-black uppercase tracking-widest text-slate-600">No active production items found.</p>
            </div>
        }
        else
        {
            @* Use 'grpDate' instead of 'dateGroup' to avoid naming collisions *@
            @foreach (var grpDate in ProductionList.GroupBy(x => x.ScheduledDate.Date).OrderBy(x => x.Key))
            {
                <div class="space-y-6">
                    <h2 class="text-xl font-black text-white uppercase tracking-widest flex items-center gap-4">
                        <span class="text-emerald-500">@grpDate.Key.ToString("dddd")</span>
                        <span>@grpDate.Key.ToString("MMMM d, yyyy")</span>
                        <span class="h-[1px] flex-1 bg-white/5"></span>
                    </h2>

                    @foreach (var grpTime in grpDate.GroupBy(x => x.TimeframeName).OrderBy(x => x.Key))
                    {
                        <div class="bg-[#111] border border-slate-800 rounded-[2.5rem] overflow-hidden shadow-2xl">
                            <div class="bg-white/5 p-6 border-b border-white/5 flex justify-between items-center">
                                <div class="flex items-center gap-3">
                                    <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
                                    <h3 class="text-sm font-black text-white uppercase italic tracking-widest">Window: @(string.IsNullOrEmpty(grpTime.Key) ? "Standard" : grpTime.Key)</h3>
                                </div>
                                <span class="text-[10px] bg-white/10 text-slate-300 px-4 py-1.5 rounded-full font-black uppercase">
                                    @grpTime.Count() Units
                                </span>
                            </div>

                            <div class="divide-y divide-white/5">
                                @foreach (var entry in grpTime)
                                {
                                    <div class="p-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 group hover:bg-white/[0.02] transition-all">
                                        <div class="flex items-center gap-6">
                                            <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-xl @(entry.FulfillmentMethod == "Pickup" ? "bg-emerald-950/30 text-emerald-500" : "bg-blue-950/30 text-blue-500")">
                                                @(entry.FulfillmentMethod == "Pickup" ? "🏢" : "🚚")
                                            </div>

                                            <div>
                                                <div class="flex items-center gap-3 mb-1">
                                                    <p class="text-white font-black uppercase text-base">@entry.RecipeName</p>
                                                    <span class="text-[9px] font-mono text-slate-600">Order# @entry.OrderId</span>
                                                </div>
                                                <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">
                                                    @entry.SizeName 
                                                    @if (entry.SelectedOptions != null && entry.SelectedOptions.Any())
                                                    {
                                                        <span class="text-blue-400"> + @string.Join(", ", entry.SelectedOptions.Select(o => o.OptionName))</span>
                                                    }
                                                </p>
                                                
                                                <div class="mt-2 text-[10px] font-black uppercase tracking-tighter">
                                                    @if (entry.FulfillmentMethod == "Pickup")
                                                    {
                                                        <span class="text-emerald-500/80 italic">Spot: @(GetSpotName(entry.PickupLocationId))</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-blue-500/80 italic">Delivery Fee: $@entry.DeliveryFee.ToString("N2")</span>
                                                    }
                                                </div>
                                            </div>
                                        </div>

                                        <div class="flex items-center gap-4 w-full md:w-auto border-t md:border-t-0 border-white/5 pt-4 md:pt-0">
                                            <div class="text-right flex-1 md:flex-none">
                                                <p class="text-[9px] text-slate-500 font-black uppercase mb-1">Customer Identifier</p>
                                                <p class="text-xs font-mono text-white opacity-60">@GetCustId(entry)</p>
                                            </div>
                                            <button class="bg-emerald-600/10 hover:bg-emerald-600 text-emerald-500 hover:text-white px-6 py-3 rounded-xl text-[9px] font-black uppercase tracking-widest transition-all">
                                                Mark Ready
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public int OwnerId { get; set; }
    
    // Renamed collection to avoid conflict with Order model name
    private List<PPP_OrderItem> ProductionList = new();
    private List<PPP_PickupLocation> LocationsLookup = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        
        ProductionList = await db.Set<PPP_OrderItem>()
            .Include(i => i.Order)
            .Include(i => i.SelectedOptions)
            .Where(i => i.Order != null && i.Order.OwnerId == OwnerId && i.Order.IsCheckedOut)
            .ToListAsync();

        LocationsLookup = await db.Set<PPP_PickupLocation>()
            .Where(l => l.OwnerId == OwnerId)
            .ToListAsync();
    }

    private string GetSpotName(int? id)
    {
        if (!id.HasValue) return "Default Shop";
        return LocationsLookup.FirstOrDefault(l => l.Id == id.Value)?.Name ?? "Main Location";
    }

    private string GetCustId(PPP_OrderItem item)
    {
        // Explicitly accessing the property through a method to prevent LINQ method collision in markup
        var cid = item.Order?.CustomerIdentifier;
        if (string.IsNullOrEmpty(cid)) return "GUEST";
        return cid.Length > 8 ? cid.Substring(0, 8).ToUpper() : cid.ToUpper();
    }
}