@inject NavigationManager Nav

<div class="flex justify-between items-center mb-10 bg-[#111] p-4 rounded-2xl border border-gray-800 shadow-xl">
    <div class="flex items-center gap-4 cursor-pointer" @onclick='() => Nav.NavigateTo("/ppp-dashboard")'>
        <span class="text-3xl">👨‍🍳</span>
        <div>
            <h1 class="text-xl uppercase tracking-tighter">PPP Admin</h1>
            <p class="text-[9px] text-gray-500 uppercase tracking-widest">@CurrentPage</p>
        </div>
    </div>
    
    <div class="flex gap-3 flex-wrap justify-end">
        <NavLink href="/ppp-recipe-editor" class="nav-btn bg-orange-600 hover:bg-orange-500 text-white">Recipes</NavLink>
        <NavLink href="/ppp-ingredient-admin" class="nav-btn bg-amber-600 hover:bg-amber-500 text-white">Ingredients</NavLink>
        <NavLink href="/ppp-owner-admin" class="nav-btn bg-emerald-600 hover:bg-emerald-500 text-white">Owners</NavLink>
        <NavLink href="/ppp-user-admin" class="nav-btn bg-blue-600 hover:bg-blue-500 text-white">Users</NavLink>
        <NavLink href="/ppp-dashboard" class="nav-btn bg-purple-600 hover:bg-purple-500 text-white">System</NavLink>
        <a href="/" class="nav-btn bg-gray-800 hover:bg-gray-700 text-white border border-gray-700">Exit</a>
    </div>
</div>

<style>
    .nav-btn {
        padding: 0.5rem 1rem;
        border-radius: 0.75rem;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        text-decoration: none !important;
    }
    .nav-btn:hover { transform: translateY(-1px); }
</style>

@code {
    [Parameter] public string CurrentPage { get; set; } = "Dashboard";
}