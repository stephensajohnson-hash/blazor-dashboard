@inject NavigationManager Nav

<div class="flex justify-between items-center mb-10 bg-[#111] p-4 rounded-2xl border border-gray-800 shadow-xl">
    @* Branding - Forced reload to ensure DB stats refresh *@
    <div class="flex items-center gap-4 cursor-pointer group" @onclick='() => Nav.NavigateTo("/ppp-dashboard", forceLoad: true)'>
        <span class="text-3xl transition group-hover:scale-110">👨‍🍳</span>
        <div>
            <h1 class="text-xl uppercase tracking-tighter group-hover:text-emerald-400 transition">PPP Admin</h1>
            <p class="text-[9px] text-gray-500 uppercase tracking-widest">@CurrentPage</p>
        </div>
    </div>
    
    @* Navigation Links *@
    <div class="flex gap-3 flex-wrap justify-end">
        <a href="/ppp-recipe-editor" class="nav-btn bg-orange-600 hover:bg-orange-500 text-white">Recipes</a>
        <a href="/ppp-ingredient-admin" class="nav-btn bg-amber-600 hover:bg-amber-500 text-white">Ingredients</a>
        <a href="/ppp-owner-admin" class="nav-btn bg-emerald-600 hover:bg-emerald-500 text-white">Owners</a>
        <a href="/ppp-user-admin" class="nav-btn bg-blue-600 hover:bg-blue-500 text-white">Users</a>
        <a href="/ppp-dashboard" class="nav-btn bg-purple-600 hover:bg-purple-500 text-white">System</a>
        <a href="/" class="nav-btn bg-gray-800 hover:bg-gray-700 text-white border border-gray-700">Exit</a>
    </div>
</div>

<style>
    .nav-btn {
        padding: 0.6rem 1.2rem;
        border-radius: 0.75rem;
        font-size: 10px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
        text-decoration: none !important;
        color: white !important;
        cursor: pointer;
    }

    .nav-btn:hover { 
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.4);
        filter: brightness(1.1);
    }

    .nav-btn:active {
        transform: translateY(0);
    }
</style>

@code {
    [Parameter] public string CurrentPage { get; set; } = "Dashboard";
}