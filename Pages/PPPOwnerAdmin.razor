@page "/ppp-owner-admin"
@using Dashboard
@using Dashboard.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using System.Diagnostics
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="min-h-screen bg-[#0a0a0a] text-white p-6 font-black relative overflow-hidden">
    
    @* TOAST NOTIFICATION STACK *@
    <div class="fixed top-24 right-6 z-[100] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-2xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950/90 border-red-500 text-red-200" : "bg-emerald-950/90 border-emerald-500 text-emerald-200")">
                <div class="flex items-center gap-3">
                    <span>@(toast.IsError ? "❌" : "✅")</span>
                    <span class="text-xs uppercase tracking-widest">@toast.Message</span>
                </div>
            </div>
        }
    </div>

    @* Header *@
    <div class="flex justify-between items-center mb-10 bg-[#111] p-4 rounded-2xl border border-gray-800 shadow-xl">
        <div class="flex items-center gap-4">
            <span class="text-3xl">🏬</span>
            <div>
                <h1 class="text-xl uppercase tracking-tighter">Business Registry</h1>
                <p class="text-[9px] text-gray-500 uppercase tracking-[0.2em]">Manage PPP Multi-Tenant Owners</p>
            </div>
        </div>
        <div class="flex gap-4">
            <button @onclick="() => OpenModal()" class="bg-emerald-600 hover:bg-emerald-500 text-white px-6 py-2 rounded-xl text-[10px] uppercase tracking-widest transition shadow-lg">
                ＋ Register Business
            </button>
            <a href="/ppp-dashboard" class="bg-gray-800 hover:bg-gray-700 text-white px-4 py-2 rounded-xl text-[10px] uppercase tracking-widest transition border border-gray-700">
                Back to Dashboard
            </a>
        </div>
    </div>

    @* Owners Table *@
    <div class="bg-[#111] border border-gray-800 rounded-3xl overflow-hidden shadow-2xl">
        @if (isLoading)
        {
            <div class="py-20 flex flex-col items-center justify-center gap-4">
                <div class="w-12 h-12 border-4 border-emerald-500 border-t-transparent rounded-full animate-spin"></div>
                <div class="text-xs uppercase tracking-[0.4em] text-gray-600">Querying_Business_Database...</div>
            </div>
        }
        else
        {
            <table class="w-full text-left">
                <thead>
                    <tr class="text-[10px] font-black uppercase text-gray-500 bg-gray-900/50 border-b border-gray-800">
                        <th class="p-5">Business</th>
                        <th class="p-5">Location</th>
                        <th class="p-5">Primary Owner</th>
                        <th class="p-5 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-800/50">
                    @foreach (var owner in owners)
                    {
                        <tr class="hover:bg-white/5 transition group">
                            <td class="p-5">
                                <div class="flex items-center gap-3">
                                    @if (owner.LogoId.HasValue)
                                    {
                                        <img src="/db-images-ppp/@owner.LogoId" class="w-10 h-10 rounded-lg object-cover border border-gray-700" />
                                    }
                                    else
                                    {
                                        <div class="w-10 h-10 rounded-lg bg-gray-800 border border-gray-700 flex items-center justify-center text-[10px] text-gray-500 italic">No Logo</div>
                                    }
                                    <div class="text-sm font-black uppercase tracking-tight text-emerald-400">@owner.BusinessName</div>
                                </div>
                            </td>
                            <td class="p-5 font-mono text-[10px] text-gray-400">
                                @if (owner.Address != null)
                                {
                                    <div>@owner.Address.City, @owner.Address.State</div>
                                }
                                else
                                {
                                    <span class="text-gray-700 italic">No Address Set</span>
                                }
                            </td>
                            <td class="p-5">
                                <div class="text-sm font-black uppercase">@owner.OwnerName</div>
                                <div class="text-[9px] text-gray-500 font-mono">@owner.Email</div>
                            </td>
                            <td class="p-5 text-right">
                                <div class="flex justify-end gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <button @onclick="() => OpenModal(owner)" class="p-2 text-blue-400 hover:bg-blue-500/10 rounded-lg transition">✎</button>
                                    <button @onclick="() => ConfirmDelete(owner)" class="p-2 text-red-500 hover:bg-red-500/10 rounded-lg transition">✕</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@* MODAL *@
@if (showModal)
{
    <div class="fixed inset-0 bg-black/90 backdrop-blur-sm z-[200] flex items-center justify-center p-4">
        <div class="bg-[#111] w-full max-w-2xl rounded-3xl border border-gray-800 shadow-[0_0_50px_rgba(0,0,0,0.8)] overflow-hidden animate-in zoom-in duration-200">
            <div class="p-6 bg-gray-900/50 border-b border-gray-800 flex justify-between items-center">
                <h3 class="text-lg uppercase tracking-widest font-black text-emerald-500">
                    @(editingOwner.Id == 0 ? "Register New Business" : "Update Business Profile")
                </h3>
                <button @onclick="CloseModal" class="text-gray-500 hover:text-white text-2xl font-light">&times;</button>
            </div>
            
            <div class="p-8 grid grid-cols-2 gap-6 max-h-[75vh] overflow-y-auto">
                @* Logo Section *@
                <div class="col-span-2 flex items-center gap-6 bg-black/30 p-4 rounded-2xl border border-gray-800">
                    @if (editingOwner.LogoId.HasValue)
                    {
                        <img src="/db-images-ppp/@editingOwner.LogoId" class="w-20 h-20 rounded-2xl object-cover border-2 border-emerald-500/50" />
                    }
                    else
                    {
                        <div class="w-20 h-20 rounded-2xl bg-gray-900 border-2 border-dashed border-gray-700 flex items-center justify-center text-2xl">🏢</div>
                    }
                    <div class="flex-1">
                        <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">Business Logo</label>
                        <InputFile OnChange="HandleLogoUpload" class="text-xs text-gray-400 file:bg-emerald-600 file:text-white file:border-0 file:px-3 file:py-1 file:rounded-lg file:mr-4 file:font-black file:uppercase file:text-[9px] cursor-pointer" />
                    </div>
                </div>

                @* Basic Details *@
                <div class="col-span-2">
                    <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">Business Name</label>
                    <input @bind="editingOwner.BusinessName" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-emerald-500 outline-none transition uppercase font-black" />
                </div>
                <div>
                    <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">Contact Name</label>
                    <input @bind="editingOwner.OwnerName" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-emerald-500 outline-none transition" />
                </div>
                <div>
                    <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">Phone</label>
                    <input value="@editingOwner.Phone" 
                           @onchange="@(e => editingOwner.Phone = PPPUtils.FormatPhoneNumber(e.Value?.ToString()))"
                           placeholder="903-555-1212"
                           class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-emerald-500 outline-none transition font-mono" />
                </div>
                <div class="col-span-2">
                    <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">Email Address</label>
                    <input @bind="editingOwner.Email" type="email" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-emerald-500 outline-none transition font-mono" />
                </div>

                @* Address Section *@
                <div class="col-span-2 mt-4 pt-4 border-t border-gray-800">
                    <h4 class="text-[10px] uppercase tracking-[0.2em] text-gray-500 mb-4 font-black">Business Address</h4>
                    <div class="grid grid-cols-2 gap-4 bg-white/5 p-4 rounded-2xl border border-gray-800">
                        <div class="col-span-2">
                            <label class="text-[9px] uppercase text-gray-600 mb-1 block">Street</label>
                            <input @bind="editingOwner.Address.Street" class="w-full bg-black border border-gray-800 rounded-lg p-2 text-xs focus:border-emerald-500 outline-none" />
                        </div>
                        <div>
                            <label class="text-[9px] uppercase text-gray-600 mb-1 block">City</label>
                            <input @bind="editingOwner.Address.City" class="w-full bg-black border border-gray-800 rounded-lg p-2 text-xs focus:border-emerald-500 outline-none" />
                        </div>
                        <div class="grid grid-cols-2 gap-2">
                            <div>
                                <label class="text-[9px] uppercase text-gray-600 mb-1 block">State</label>
                                <input @bind="editingOwner.Address.State" maxlength="2" class="w-full bg-black border border-gray-800 rounded-lg p-2 text-xs focus:border-emerald-500 outline-none text-center uppercase" />
                            </div>
                            <div>
                                <label class="text-[9px] uppercase text-gray-600 mb-1 block">Zip</label>
                                <input @bind="editingOwner.Address.ZipCode" class="w-full bg-black border border-gray-800 rounded-lg p-2 text-xs focus:border-emerald-500 outline-none font-mono" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-span-2">
                    <label class="text-[9px] uppercase text-gray-500 tracking-widest mb-2 block">Bio / Description</label>
                    <textarea @bind="editingOwner.Bio" rows="3" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-emerald-500 outline-none transition"></textarea>
                </div>
            </div>

            <div class="p-6 bg-gray-900/50 border-t border-gray-800 flex justify-end gap-4">
                <button @onclick="CloseModal" class="text-[10px] text-gray-500 uppercase tracking-widest font-black px-6">Cancel</button>
                <button @onclick="SaveOwner" class="bg-emerald-600 hover:bg-emerald-500 text-white text-[10px] uppercase tracking-widest font-black px-8 py-3 rounded-xl shadow-lg transition">
                    Save Business
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<PPP_Owner> owners = new();
    private bool isLoading = true;
    private bool showModal = false;
    private PPP_Owner editingOwner = new();
    private List<ToastItem> toasts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadOwners();
    }

    private async Task LoadOwners()
    {
        isLoading = true;
        try {
            owners = await Db.PPP_Owners
                .Include(o => o.Address)
                .AsNoTracking()
                .OrderBy(o => o.BusinessName)
                .ToListAsync();
        } catch (Exception ex) {
            _ = ShowToast("Load Error: " + ex.Message, true);
        } finally {
            isLoading = false;
        }
    }

    private void OpenModal(PPP_Owner? owner = null)
    {
        if (owner == null)
        {
            editingOwner = new PPP_Owner { 
                CreatedAt = DateTime.UtcNow,
                Address = new PPP_Address()
            };
        }
        else
        {
            editingOwner = new PPP_Owner
            {
                Id = owner.Id,
                BusinessName = owner.BusinessName,
                OwnerName = owner.OwnerName,
                Email = owner.Email,
                Phone = owner.Phone,
                Bio = owner.Bio,
                CreatedAt = owner.CreatedAt,
                LogoId = owner.LogoId,
                AddressId = owner.AddressId,
                Address = owner.Address ?? new PPP_Address()
            };
        }
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private async Task HandleLogoUpload(InputFileChangeEventArgs e)
    {
        try {
            var file = e.File;
            if (file == null) return;

            using var ms = new System.IO.MemoryStream();
            await file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 2).CopyToAsync(ms);

            var newImage = new PPP_StoredImage
            {
                Data = ms.ToArray(),
                ContentType = file.ContentType,
                FileName = file.Name,
                UploadedAt = DateTime.UtcNow
            };

            if (editingOwner.LogoId.HasValue)
            {
                var oldId = editingOwner.LogoId.Value;
                bool isShared = await Db.PPP_Owners.AnyAsync(o => o.Id != editingOwner.Id && o.LogoId == oldId)
                             || await Db.PPP_Users.AnyAsync(u => u.AvatarId == oldId);
                
                if (!isShared)
                {
                    var oldImg = await Db.PPP_StoredImages.FindAsync(oldId);
                    if (oldImg != null) Db.PPP_StoredImages.Remove(oldImg);
                }
            }

            Db.PPP_StoredImages.Add(newImage);
            await Db.SaveChangesAsync();
            
            editingOwner.LogoId = newImage.Id;
            _ = ShowToast("Logo uploaded");
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex) {
            _ = ShowToast("Upload failed: " + ex.Message, true);
        }
    }

    private async Task SaveOwner()
    {
        // Enforce Formatting
        editingOwner.Phone = PPPUtils.FormatPhoneNumber(editingOwner.Phone);

        if (string.IsNullOrWhiteSpace(editingOwner.BusinessName) || 
            editingOwner.Phone.Length != 12) // Format is ###-###-####
        {
            _ = ShowToast("Business Name and 10-digit Phone required", true);
            return;
        }

        try {
            Db.ChangeTracker.Clear();

            // Save Address Logic
            if (editingOwner.Address != null)
            {
                if (!string.IsNullOrWhiteSpace(editingOwner.Address.Street))
                {
                    if (editingOwner.Address.Id == 0)
                        Db.PPP_Addresses.Add(editingOwner.Address);
                    else
                        Db.PPP_Addresses.Update(editingOwner.Address);

                    await Db.SaveChangesAsync();
                    editingOwner.AddressId = editingOwner.Address.Id;
                }
                else if (editingOwner.Address.Id != 0)
                {
                    editingOwner.AddressId = null;
                }
            }

            if (editingOwner.Id == 0) {
                Db.PPP_Owners.Add(editingOwner);
                await Db.SaveChangesAsync();
            } else {
                Db.Entry(editingOwner).State = EntityState.Modified;
                await Db.SaveChangesAsync();
            }

            await LoadOwners();
            _ = ShowToast("Business record updated");
            CloseModal(); 
        } catch (Exception ex) {
            _ = ShowToast("Save Error: " + ex.Message, true);
        }
    }

    private async Task ConfirmDelete(PPP_Owner owner)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Permanently remove {owner.BusinessName}?"))
        {
            try {
                Db.ChangeTracker.Clear();
                
                if (owner.LogoId.HasValue)
                {
                    var imgId = owner.LogoId.Value;
                    bool isShared = await Db.PPP_Owners.AnyAsync(o => o.Id != owner.Id && o.LogoId == imgId)
                                 || await Db.PPP_Users.AnyAsync(u => u.AvatarId == imgId);
                    if (!isShared)
                    {
                        var img = await Db.PPP_StoredImages.FindAsync(imgId);
                        if (img != null) Db.PPP_StoredImages.Remove(img);
                    }
                }

                Db.PPP_Owners.Remove(owner);
                await Db.SaveChangesAsync();
                await LoadOwners();
                _ = ShowToast("Business deleted");
            } catch (Exception ex) {
                _ = ShowToast("Delete Error: " + ex.Message, true);
            }
        }
    }

    private async Task ShowToast(string msg, bool isError = false)
    {
        var toast = new ToastItem { Message = msg, IsError = isError };
        toasts.Add(toast);
        await InvokeAsync(StateHasChanged);
        await Task.Delay(4000);
        toasts.Remove(toast);
        await InvokeAsync(StateHasChanged);
    }

    private class ToastItem { public string Message { get; set; } = ""; public bool IsError { get; set; } }
}