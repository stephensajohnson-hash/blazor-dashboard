@page "/ppp-store/{OwnerId:int}"
@using Dashboard
@using Dashboard.Services
@using Dashboard.Components
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="min-h-screen bg-[#050505] text-slate-200 font-sans antialiased pb-32">
    @* Notification Stack *@
    <div class="fixed top-6 right-6 z-[500] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-2xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950 border-red-500 text-red-200" : "bg-emerald-950 border-emerald-500 text-emerald-200") backdrop-blur-md">
                <div class="flex items-center gap-3">
                    <span class="text-lg">@(toast.IsError ? "✕" : "✓")</span>
                    <span class="text-[10px] font-black uppercase tracking-widest">@toast.Message</span>
                </div>
            </div>
        }
    </div>

    @if (owner != null)
    {
        @* Hero Branding Section *@
        <div class="relative h-56 bg-emerald-900/10 overflow-hidden border-b border-white/5">
            <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#050505]"></div>
            <div class="absolute bottom-8 left-8 flex items-center gap-6">
                @if (owner.LogoId.HasValue)
                {
                    <div class="w-24 h-24 rounded-[2rem] overflow-hidden border-2 border-slate-800 bg-black shadow-2xl">
                        <img src="/db-images-ppp/@owner.LogoId" class="w-full h-full object-contain" />
                    </div>
                }
                <div>
                    <h1 class="text-4xl font-black text-white italic uppercase tracking-tighter">@owner.BusinessName</h1>
                    <p class="text-[10px] text-emerald-500 font-black uppercase tracking-[0.4em] flex items-center gap-2">
                        <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span> Ordering Portal
                    </p>
                </div>
            </div>
        </div>

        <div class="max-w-3xl mx-auto px-4 mt-12">
            @if (!activeMenus.Any())
            {
                <div class="py-20 text-center opacity-40">
                    <span class="text-5xl block mb-4">🍳</span>
                    <p class="text-xs font-black uppercase tracking-widest">No active menus available right now.</p>
                </div>
            }
            else
            {
                @foreach (var menu in activeMenus)
                {
                    @foreach (var dayGroup in menu.Items.OrderBy(i => i.StartDate).GroupBy(i => i.StartDate.Date))
                    {
                        <div class="mb-12">
                            <h3 class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-500 mb-6 flex items-center gap-4">
                                @dayGroup.Key.ToString("dddd, MMM d") 
                                <span class="h-[1px] flex-1 bg-white/5"></span>
                            </h3>

                            <div class="grid grid-cols-1 gap-4">
                                @foreach (var item in dayGroup)
                                {
                                    bool soldOut = IsItemSoldOut(item);
                                    bool pastCutoff = IsPastCutoff(item);

                                    <div @onclick="() => SelectItem(item)" class="bg-[#111] border border-slate-800 rounded-[2.5rem] overflow-hidden flex flex-col md:flex-row cursor-pointer transition-all group shadow-xl @(soldOut || pastCutoff ? "opacity-50 grayscale pointer-events-none" : "hover:border-emerald-500/40")">
                                        @if (item.Recipe?.ImageId != null)
                                        {
                                            <div class="w-full md:w-44 aspect-square bg-black overflow-hidden shrink-0">
                                                <img src="/db-images-ppp/@item.Recipe.ImageId" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                                            </div>
                                        }
                                        <div class="p-6 flex-1 flex flex-col">
                                            <div class="flex justify-between items-start mb-2">
                                                <h4 class="text-xl font-black text-white uppercase italic tracking-tight">@item.Recipe?.Name</h4>
                                                <div class="flex flex-col items-end gap-1">
                                                    @if (soldOut) { <span class="text-red-500 text-[10px] font-black uppercase tracking-widest">Sold Out</span> }
                                                    else if (pastCutoff) { <span class="text-amber-500 text-[10px] font-black uppercase tracking-widest">Deadline Passed</span> }
                                                    else if (item.Sizes.Any())
                                                    {
                                                        <span class="text-emerald-500 font-mono font-bold bg-emerald-500/5 px-3 py-1 rounded-lg border border-emerald-500/10">
                                                            $@item.Sizes.Min(s => s.BasePrice).ToString("N2")+
                                                        </span>
                                                    }
                                                </div>
                                            </div>
                                            <p class="text-xs text-slate-500 leading-relaxed line-clamp-2">@item.Recipe?.Description</p>
                                            
                                            <div class="mt-6 flex flex-wrap gap-2">
                                                <span class="text-[8px] bg-emerald-950/20 text-emerald-400 border border-emerald-900/30 px-3 py-1 rounded-full font-black uppercase tracking-tighter">
                                                    Order By: @(item.CutoffTime.ToString("h:mm tt")) on @item.StartDate.Date.AddDays(-1).ToString("MMM d")
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            }
        </div>
    }

    @* Persistent Cart Floating Bar *@
    @if (cart != null && cart.Items.Any())
    {
        <div class="fixed bottom-8 left-1/2 -translate-x-1/2 z-[150] w-full max-w-lg px-4">
            <button @onclick="() => showCart = true" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white p-6 rounded-[2rem] flex justify-between items-center shadow-[0_20px_50px_rgba(0,0,0,0.6)] transition-all active:scale-95 border border-emerald-400/20">
                <div class="flex items-center gap-4">
                    <span class="bg-white/20 px-3 py-1 rounded-lg font-black text-xs">@cart.Items.Count</span>
                    <span class="text-xs font-black uppercase tracking-widest">View Your Cart</span>
                </div>
                <span class="font-mono font-bold">$@cart.Items.Sum(i => i.BasePrice + i.SelectedOptions.Sum(o => o.AddOnPrice)).ToString("N2")</span>
            </button>
        </div>
    }

    @* Cart Detail Overlay *@
    @if (showCart && cart != null)
    {
        <div class="fixed inset-0 bg-black/95 backdrop-blur-md z-[600] flex items-end justify-center" @onclick="SaveCartNotes">
            <div @onclick:stopPropagation="true" class="bg-[#0f0f0f] w-full max-w-2xl rounded-t-[3rem] border-t border-slate-800 p-10 shadow-2xl animate-in slide-in-from-bottom duration-300 max-h-[95vh] flex flex-col">
                <div class="flex justify-between items-start mb-8 shrink-0">
                    <div>
                        <h2 class="text-3xl font-black text-white uppercase italic tracking-tighter">Your Cart</h2>
                        <p class="text-[10px] text-emerald-500 font-black uppercase tracking-[0.2em] mt-1">Review and Checkout</p>
                    </div>
                    <button @onclick="SaveCartNotes" class="bg-white/5 w-12 h-12 rounded-2xl text-slate-400 hover:text-white flex items-center justify-center text-2xl transition-all">&times;</button>
                </div>

                <div class="flex-1 overflow-y-auto space-y-6 pr-2">
                    @foreach (var item in cart.Items.OrderBy(i => i.ScheduledDate))
                    {
                        <div class="bg-white/5 border border-white/5 rounded-3xl p-6 relative group">
                            <div class="flex justify-between items-start mb-2">
                                <span class="text-[9px] font-black text-emerald-500 uppercase tracking-widest">@item.ScheduledDate.ToString("ddd, MMM d")</span>
                                <button @onclick="() => RemoveFromCart(item.Id)" class="text-slate-600 hover:text-red-500 transition-colors text-xs">✕ Remove</button>
                            </div>
                            <h4 class="text-lg font-black text-white uppercase italic tracking-tight">@item.RecipeName</h4>
                            <p class="text-[10px] text-slate-400 font-bold uppercase mt-1">@item.SizeName — $@item.BasePrice.ToString("N2")</p>
                            
                            @if (item.SelectedOptions.Any())
                            {
                                <div class="mt-4 pt-4 border-t border-white/5 space-y-1">
                                    @foreach (var opt in item.SelectedOptions)
                                    {
                                        <div class="flex justify-between text-[10px] uppercase">
                                            <span class="text-slate-500">+ @opt.OptionName</span>
                                            <span class="text-slate-300 font-mono">+$@opt.AddOnPrice.ToString("N2")</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @* Logistics Section *@
                    <div class="pt-6 border-t border-white/10">
                        <label class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 mb-4 block">Fulfillment</label>
                        
                        @if (owner.OffersPickup && owner.OffersDelivery)
                        {
                            <div class="flex gap-2 mb-6 bg-black p-1 rounded-2xl border border-slate-800">
                                <button @onclick='() => fulfillmentMethod = "Pickup"' 
                                        class="flex-1 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all @(fulfillmentMethod == "Pickup" ? "bg-emerald-600 text-white" : "text-slate-500")">
                                    Pickup
                                </button>
                                <button @onclick='() => fulfillmentMethod = "Delivery"' 
                                        class="flex-1 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all @(fulfillmentMethod == "Delivery" ? "bg-blue-600 text-white" : "text-slate-500")">
                                    Delivery
                                </button>
                            </div>
                        }

                        @if (fulfillmentMethod == "Pickup")
                        {
                            <div class="space-y-3 animate-in fade-in slide-in-from-top-2">
                                @foreach (var loc in pickupLocations)
                                {
                                    <div @onclick="() => selectedPickupId = loc.Id" 
                                         class="p-4 rounded-2xl border transition-all cursor-pointer @(selectedPickupId == loc.Id ? "border-emerald-500 bg-emerald-500/5" : "border-slate-800 bg-black/40 hover:border-slate-600")">
                                        <span class="text-xs font-black uppercase block text-white">@loc.Name</span>
                                        <span class="text-[10px] text-slate-500 block">@loc.Address</span>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="animate-in fade-in slide-in-from-top-2">
                                <input @bind="deliveryZip" @bind:event="oninput" placeholder="Enter Delivery Zip Code" 
                                       class="w-full bg-black border border-slate-800 rounded-xl p-4 text-sm font-mono text-white outline-none focus:border-blue-500" />
                                
                                @if (!string.IsNullOrEmpty(deliveryZip))
                                {
                                    var fee = GetDeliveryFee(deliveryZip);
                                    <p class="text-[10px] mt-2 @(fee >= 0 ? "text-blue-400" : "text-red-500") font-black uppercase">
                                        @(fee == 0 ? "✓ Free Delivery!" : fee > 0 ? $"✓ Delivery Fee: ${fee:N2}" : "✕ Sorry, we don't deliver to " + deliveryZip)
                                    </p>
                                }
                            </div>
                        }
                    </div>

                    <div class="pt-6">
                        <label class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 mb-3 block">Order Notes</label>
                        <textarea @bind="cart.Notes" @bind:event="oninput" maxlength="500" rows="3" 
                                  placeholder="Allergies, delivery instructions, or gate codes..."
                                  class="w-full bg-black border border-slate-800 rounded-2xl p-4 text-sm focus:border-emerald-500 outline-none transition-all resize-none text-slate-300"></textarea>
                        <div class="text-right text-[9px] text-slate-600 mt-1 uppercase font-bold">@((cart.Notes?.Length ?? 0)) / 500</div>
                    </div>
                </div>

                <div class="mt-8 pt-8 border-t border-white/10 shrink-0">
                    <div class="flex justify-between items-end mb-8">
                        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-500">Grand Total</span>
                        <span class="text-3xl font-black text-white italic tracking-tighter font-mono">
                            $@((cart.Items.Sum(i => i.BasePrice + i.SelectedOptions.Sum(o => o.AddOnPrice)) + Math.Max(0, GetDeliveryFee(deliveryZip))).ToString("N2"))
                        </span>
                    </div>
                    <button @onclick="ProcessCheckout" 
                            disabled="@(!IsCheckoutReady())"
                            class="w-full bg-emerald-600 hover:bg-emerald-500 disabled:opacity-20 disabled:grayscale text-white py-6 rounded-3xl font-black text-xs uppercase tracking-[0.5em] transition-all shadow-xl active:scale-95">
                        Place Order
                    </button>
                </div>
            </div>
        </div>
    }

    @* Selection Modal *@
    @if (selectedItem != null)
    {
        <div class="fixed inset-0 bg-black/95 backdrop-blur-md z-[400] flex items-end justify-center" @onclick="() => selectedItem = null">
            <div @onclick:stopPropagation="true" class="bg-[#0f0f0f] w-full max-w-2xl rounded-t-[3rem] border-t border-slate-800 p-10 shadow-2xl animate-in slide-in-from-bottom duration-300 max-h-[90vh] overflow-y-auto">
                <div class="flex justify-between items-start mb-10">
                    <div>
                        <h2 class="text-3xl font-black text-white uppercase italic tracking-tighter">@selectedItem.Recipe?.Name</h2>
                        <p class="text-[10px] text-emerald-500 font-black uppercase tracking-[0.2em] mt-1">Customize your meal</p>
                    </div>
                    <button @onclick="() => selectedItem = null" class="bg-white/5 w-12 h-12 rounded-2xl text-slate-400 hover:text-white flex items-center justify-center text-2xl transition-all">&times;</button>
                </div>

                <div class="space-y-12">
                    <section>
                        <h5 class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-500 mb-6 flex items-center gap-3">
                            Size <span class="h-[1px] flex-1 bg-white/5"></span>
                        </h5>
                        <div class="grid grid-cols-1 gap-3">
                            @foreach (var sz in selectedItem.Sizes)
                            {
                                <div @onclick="() => SetSize(sz)" class="p-5 rounded-2xl border transition-all cursor-pointer @(currentSize?.Id == sz.Id ? "border-emerald-500 bg-emerald-500/5" : "border-slate-800 bg-black/40 hover:border-slate-600") flex justify-between items-center group">
                                    <span class="font-black text-xs uppercase tracking-widest @(currentSize?.Id == sz.Id ? "text-emerald-400" : "text-slate-300")">@sz.Name</span>
                                    <span class="font-mono text-sm @(currentSize?.Id == sz.Id ? "text-white" : "text-slate-500")">$@sz.BasePrice.ToString("N2")</span>
                                </div>
                            }
                        </div>
                    </section>

                    @if (currentSize != null && currentSize.Options.Any())
                    {
                        <section>
                            <h5 class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-500 mb-6 flex items-center gap-3">
                                Add-ons <span class="h-[1px] flex-1 bg-white/5"></span>
                            </h5>
                            <div class="space-y-3">
                                @foreach (var opt in currentSize.Options)
                                {
                                    <div @onclick="() => ToggleOption(opt)" class="flex items-center justify-between p-5 bg-black/40 border border-slate-800 rounded-2xl cursor-pointer hover:border-slate-600 transition-all @(selectedOptionIds.Contains(opt.Id) ? "border-emerald-500/50 bg-emerald-500/5" : "")">
                                        <div>
                                            <span class="text-xs font-black uppercase @(selectedOptionIds.Contains(opt.Id) ? "text-white" : "text-slate-400")">@opt.Name</span>
                                            <span class="text-[10px] text-slate-600 block mt-1">+$@opt.AddOnPrice.ToString("N2")</span>
                                        </div>
                                        <div class="w-6 h-6 rounded-lg border-2 flex items-center justify-center transition-all @(selectedOptionIds.Contains(opt.Id) ? "bg-emerald-500 border-emerald-500" : "border-slate-700")">
                                            @if(selectedOptionIds.Contains(opt.Id)) { <span class="text-white text-[10px]">✓</span> }
                                        </div>
                                    </div>
                                }
                            </div>
                        </section>
                    }
                </div>

                <div class="mt-16 pt-8 border-t border-white/5">
                    <button @onclick="AddToCart" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white py-6 rounded-3xl font-black text-xs uppercase tracking-[0.4em] transition-all shadow-xl active:scale-95 flex justify-between items-center px-10">
                        <span>Add to Order</span>
                        <span class="font-mono">$@GetConfigTotal().ToString("N2")</span>
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int OwnerId { get; set; }
    private PPP_Owner? owner;
    private List<PPP_Menu> activeMenus = new();
    private List<ToastItem> toasts = new();
    private Dictionary<int, int> soldCounts = new();
    
    private PPP_Order? cart;
    private string? customerId;
    private bool showCart = false;

    // Logistics
    private string fulfillmentMethod = "Pickup";
    private int selectedPickupId = 0;
    private string deliveryZip = "";
    private List<PPP_PickupLocation> pickupLocations = new();
    private List<PPP_DeliveryZipCode> ownerZips = new();

    // Selection
    private PPP_MenuItem? selectedItem;
    private PPP_MenuItemSize? currentSize;
    private HashSet<int> selectedOptionIds = new();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        owner = await db.PPP_Owners.AsNoTracking().FirstOrDefaultAsync(o => o.Id == OwnerId);
        
        var today = DateTime.Today.ToUniversalTime();
        activeMenus = await db.Set<PPP_Menu>()
            .AsNoTracking()
            .Include(m => m.Items).ThenInclude(i => i.Recipe)
            .Include(m => m.Items).ThenInclude(i => i.Timeframes)
            .Include(m => m.Items).ThenInclude(i => i.Sizes).ThenInclude(s => s.Options)
            .Where(m => m.OwnerId == OwnerId && m.IsPublished && m.EndDate >= today)
            .OrderBy(m => m.StartDate)
            .ToListAsync();

        var menuItemIds = activeMenus.SelectMany(m => m.Items).Select(i => i.Id).ToList();
        soldCounts = await db.Set<PPP_OrderItem>()
            .Where(i => menuItemIds.Contains(i.MenuItemId))
            .GroupBy(i => i.MenuItemId)
            .Select(g => new { Id = g.Key, Count = g.Count() })
            .ToDictionaryAsync(x => x.Id, x => x.Count);

        pickupLocations = await db.Set<PPP_PickupLocation>().Where(l => l.OwnerId == OwnerId).ToListAsync();
        ownerZips = await db.Set<PPP_DeliveryZipCode>().Where(z => z.OwnerId == OwnerId).ToListAsync();

        if (owner != null)
        {
            if (!owner.OffersPickup && owner.OffersDelivery) fulfillmentMethod = "Delivery";
            else fulfillmentMethod = "Pickup";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try 
            {
                customerId = await JS.InvokeAsync<string>("localStorage.getItem", "ppp_customer_id");
                if (string.IsNullOrEmpty(customerId))
                {
                    customerId = Guid.NewGuid().ToString();
                    await JS.InvokeVoidAsync("localStorage.setItem", "ppp_customer_id", customerId);
                }
                await LoadCart();
                StateHasChanged();
            }
            catch (Exception) { }
        }
    }

    private bool IsPastCutoff(PPP_MenuItem item)
    {
        var cutoffSpan = item.CutoffTime.ToTimeSpan();
        var deadline = item.StartDate.Date.AddDays(-1).Add(cutoffSpan);
        return DateTime.Now > deadline;
    }

    private bool IsItemSoldOut(PPP_MenuItem item)
    {
        if (item.IsUnlimited) return false;
        soldCounts.TryGetValue(item.Id, out int count);
        return count >= item.MaxQuantity;
    }

    private double GetDeliveryFee(string zip)
    {
        if (fulfillmentMethod == "Pickup") return 0;
        if (string.IsNullOrWhiteSpace(zip)) return -1;
        var match = ownerZips.FirstOrDefault(z => z.ZipCode == zip.Trim());
        return match?.Fee ?? -1;
    }

    private bool IsCheckoutReady()
    {
        if (fulfillmentMethod == "Pickup") return selectedPickupId > 0;
        if (fulfillmentMethod == "Delivery") return GetDeliveryFee(deliveryZip) >= 0;
        return false;
    }

    private async Task LoadCart()
    {
        if (string.IsNullOrEmpty(customerId)) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        cart = await db.Set<PPP_Order>()
            .Include(o => o.Items).ThenInclude(i => i.SelectedOptions)
            .FirstOrDefaultAsync(o => o.OwnerId == OwnerId && o.CustomerIdentifier == customerId && !o.IsCheckedOut);

        if (cart == null)
        {
            cart = new PPP_Order { OwnerId = OwnerId, CustomerIdentifier = customerId, CreatedAt = DateTime.UtcNow };
            db.Add(cart);
            await db.SaveChangesAsync();
        }
    }

    private async Task SaveCartNotes()
    {
        if (cart == null) { showCart = false; return; }
        try 
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var dbOrder = await db.Set<PPP_Order>().FirstOrDefaultAsync(o => o.Id == cart.Id);
            if (dbOrder != null) { dbOrder.Notes = cart.Notes; await db.SaveChangesAsync(); }
        }
        catch (Exception) { }
        finally { showCart = false; }
    }

    private void SelectItem(PPP_MenuItem item)
    {
        if (IsPastCutoff(item) || IsItemSoldOut(item)) return;
        selectedItem = item;
        currentSize = item.Sizes.FirstOrDefault();
        selectedOptionIds.Clear();
        StateHasChanged();
    }

    private void SetSize(PPP_MenuItemSize sz)
    {
        currentSize = sz;
        selectedOptionIds.Clear(); 
        StateHasChanged();
    }

    private void ToggleOption(PPP_MenuItemOption opt)
    {
        if (selectedOptionIds.Contains(opt.Id)) selectedOptionIds.Remove(opt.Id);
        else selectedOptionIds.Add(opt.Id);
        StateHasChanged();
    }

    private double GetConfigTotal()
    {
        if (currentSize == null) return 0;
        var addons = currentSize.Options.Where(o => selectedOptionIds.Contains(o.Id)).Sum(o => o.AddOnPrice);
        return currentSize.BasePrice + addons;
    }

    private async Task AddToCart()
    {
        if (selectedItem == null || currentSize == null || cart == null) return;
        if (IsItemSoldOut(selectedItem)) { await ShowToast("Item sold out!", true); return; }

        try 
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var orderItem = new PPP_OrderItem
            {
                OrderId = cart.Id,
                MenuItemId = selectedItem.Id,
                RecipeName = selectedItem.Recipe?.Name ?? "Item",
                SizeName = currentSize.Name,
                BasePrice = currentSize.BasePrice,
                ScheduledDate = selectedItem.StartDate.ToUniversalTime(),
                SelectedOptions = currentSize.Options
                    .Where(o => selectedOptionIds.Contains(o.Id))
                    .Select(o => new PPP_OrderItemOption { OptionName = o.Name, AddOnPrice = o.AddOnPrice })
                    .ToList()
            };
            db.Add(orderItem);
            await db.SaveChangesAsync();
            await LoadCart(); 
            selectedItem = null;
            _ = ShowToast("Added to order");
        }
        catch (Exception ex) { await ShowToast("Error: " + ex.Message, true); }
    }

    private async Task RemoveFromCart(int orderItemId)
    {
        try 
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var item = await db.Set<PPP_OrderItem>().FirstOrDefaultAsync(i => i.Id == orderItemId);
            if (item != null) { db.Remove(item); await db.SaveChangesAsync(); await LoadCart(); _ = ShowToast("Item removed"); }
        }
        catch (Exception ex) { await ShowToast("Error: " + ex.Message, true); }
    }
private async Task ProcessCheckout()
{
    if (cart == null || !IsCheckoutReady()) return;

    try 
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var dbOrder = await db.PPP_Orders.FirstOrDefaultAsync(o => o.Id == cart.Id);
        
        if (dbOrder != null)
        {
            dbOrder.IsCheckedOut = true;
            dbOrder.CheckedOutAt = DateTime.UtcNow;
            
            // Capture fulfillment details in the notes or a new field? 
            // For now, let's prepend them to the notes snapshot for the owner.
            var fulfillmentSummary = fulfillmentMethod == "Pickup" 
                ? $"[PICKUP: {pickupLocations.FirstOrDefault(l => l.Id == selectedPickupId)?.Name}] "
                : $"[DELIVERY to {deliveryZip} - Fee: ${GetDeliveryFee(deliveryZip):N2}] ";
            
            dbOrder.Notes = fulfillmentSummary + (cart.Notes ?? "");

            await db.SaveChangesAsync();
            
            // Clear local UI state
            cart = null;
            showCart = false;
            deliveryZip = "";
            selectedPickupId = 0;
            
            _ = ShowToast("Order placed successfully! Check your email soon.");
            
            // Optional: Generate new empty cart for next time
            await LoadCart();
        }
    }
    catch (Exception ex)
    {
        await ShowToast("Checkout Error: " + ex.Message, true);
    }
}

    private async Task ShowToast(string msg, bool isError = false)
    {
        var toast = new ToastItem { Message = msg, IsError = isError };
        toasts.Add(toast); StateHasChanged();
        await Task.Delay(4000); toasts.Remove(toast); StateHasChanged();
    }
    private class ToastItem { public string Message { get; set; } = ""; public bool IsError { get; set; } }
}