@page "/ppp-store/{OwnerId:int}"
@using Dashboard
@using Dashboard.Services
@using Dashboard.Components
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="min-h-screen bg-[#050505] text-slate-200 font-sans antialiased pb-32">
    @* Notification Stack *@
    <div class="fixed top-6 right-6 z-[900] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-2xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950 border-red-500 text-red-200" : "bg-emerald-950 border-emerald-500 text-emerald-200") backdrop-blur-md">
                <div class="flex items-center gap-3">
                    <span class="text-lg">@(toast.IsError ? "✕" : "✓")</span>
                    <span class="text-[10px] font-black uppercase tracking-widest">@toast.Message</span>
                </div>
            </div>
        }
    </div>

    @if (owner != null)
    {
        <div class="relative h-56 bg-emerald-900/10 overflow-hidden border-b border-white/5">
            <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#050505]"></div>
            <div class="absolute bottom-8 left-8 flex items-center gap-6">
                @if (owner.LogoId.HasValue)
                {
                    <div class="w-24 h-24 rounded-[2rem] overflow-hidden border-2 border-slate-800 bg-black shadow-2xl">
                        <img src="/db-images-ppp/@owner.LogoId" class="w-full h-full object-contain" />
                    </div>
                }
                <div>
                    <h1 class="text-4xl font-black text-white italic uppercase tracking-tighter">@owner.BusinessName</h1>
                    <p class="text-[10px] text-emerald-500 font-black uppercase tracking-[0.4em] flex items-center gap-2">
                        <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span> Marketplace
                    </p>
                </div>
            </div>
        </div>

        <div class="max-w-3xl mx-auto px-4 mt-12">
            @foreach (var menu in activeMenus)
            {
                @foreach (var dayGroup in menu.Items.OrderBy(i => i.StartDate).GroupBy(i => i.StartDate.Date))
                {
                    <div class="mb-12">
                        <h3 class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-500 mb-6 flex items-center gap-4">
                            @dayGroup.Key.ToString("dddd, MMM d") 
                            <span class="h-[1px] flex-1 bg-white/5"></span>
                        </h3>

                        <div class="grid grid-cols-1 gap-4">
                            @foreach (var item in dayGroup)
                            {
                                bool soldOut = IsItemSoldOut(item);
                                bool pastCutoff = IsPastCutoff(item);

                                <div @onclick="() => SelectItem(item)" class="bg-[#111] border border-slate-800 rounded-[2.5rem] overflow-hidden flex flex-col md:flex-row cursor-pointer transition-all group shadow-xl @(soldOut || pastCutoff ? "opacity-50 grayscale pointer-events-none" : "hover:border-emerald-500/40")">
                                    @if (item.Recipe?.ImageId != null)
                                    {
                                        <div class="w-full md:w-44 aspect-square bg-black overflow-hidden shrink-0">
                                            <img src="/db-images-ppp/@item.Recipe.ImageId" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                                        </div>
                                    }
                                    <div class="p-6 flex-1 flex flex-col">
                                        <div class="flex justify-between items-start mb-2">
                                            <h4 class="text-xl font-black text-white uppercase italic tracking-tight">@item.Recipe?.Name</h4>
                                            @if (soldOut) { <span class="text-red-500 text-[10px] font-black uppercase">Sold Out</span> }
                                            else if (pastCutoff) { <span class="text-amber-500 text-[10px] font-black uppercase">Cutoff Passed</span> }
                                        </div>
                                        <p class="text-xs text-slate-500 leading-relaxed line-clamp-2">@item.Recipe?.Description</p>
                                        <div class="mt-auto pt-4 flex items-center gap-2">
                                            <span class="text-[8px] bg-emerald-950/20 text-emerald-400 border border-emerald-900/30 px-3 py-1 rounded-full font-black uppercase">
                                                By @item.CutoffTime.ToString("h:mm tt") @item.StartDate.Date.AddDays(-1).ToString("MMM d")
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    }

    @* Persistent Cart Floating Bar *@
    @if (cart != null && cart.Items.Any())
    {
        <div class="fixed bottom-8 left-1/2 -translate-x-1/2 z-[150] w-full max-w-lg px-4">
            <button @onclick="() => showCart = true" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white p-6 rounded-[2rem] flex justify-between items-center shadow-2xl transition-all active:scale-95 border border-emerald-400/20">
                <div class="flex items-center gap-4">
                    <span class="bg-white/20 px-3 py-1 rounded-lg font-black text-xs">@cart.Items.Count</span>
                    <span class="text-xs font-black uppercase tracking-widest">Review & Checkout</span>
                </div>
                <span class="font-mono font-bold">$@cart.Items.Sum(i => i.BasePrice + i.DeliveryFee + i.SelectedOptions.Sum(o => o.AddOnPrice)).ToString("N2")</span>
            </button>
        </div>
    }

    @* Cart Detail Overlay *@
    @if (showCart && cart != null)
    {
        <div class="fixed inset-0 bg-black/95 backdrop-blur-md z-[600] flex items-end justify-center" @onclick="SaveCartNotes">
            <div @onclick:stopPropagation="true" class="bg-[#0f0f0f] w-full max-w-2xl rounded-t-[3rem] border-t border-slate-800 p-10 shadow-2xl animate-in slide-in-from-bottom duration-300 max-h-[92vh] flex flex-col">
                <div class="flex justify-between items-start mb-8 shrink-0">
                    <div>
                        <h2 class="text-3xl font-black text-white uppercase italic tracking-tighter">Your Cart</h2>
                    </div>
                    <button @onclick="SaveCartNotes" class="bg-white/5 w-12 h-12 rounded-2xl text-slate-400 hover:text-white flex items-center justify-center text-2xl transition-all">&times;</button>
                </div>

                <div class="flex-1 overflow-y-auto space-y-4 pr-2">
                    @foreach (var item in cart.Items.OrderBy(i => i.ScheduledDate))
                    {
                        <div class="bg-white/5 border border-white/5 rounded-3xl p-6 relative group">
                            <div class="flex justify-between items-start mb-2">
                                <span class="text-[9px] font-black text-emerald-500 uppercase">@item.ScheduledDate.ToString("ddd, MMM d") — @item.TimeframeName</span>
                                <button @onclick="() => RemoveFromCart(item.Id)" class="text-slate-600 hover:text-red-500 text-xs">✕</button>
                            </div>
                            <h4 class="text-lg font-black text-white uppercase italic">
                                @item.RecipeName 
                                @if(!string.IsNullOrEmpty(item.LabelName)) { <span class="text-emerald-400 text-sm ml-2">(@item.LabelName)</span> }
                            </h4>
                            <div class="flex justify-between items-center mt-2">
                                <span class="text-[9px] text-slate-400 font-bold uppercase">@item.SizeName (@item.FulfillmentMethod)</span>
                                <span class="text-xs font-mono">$@GetItemTotal(item).ToString("N2")</span>
                            </div>
                        </div>
                    }

                    <div class="pt-6">
                        <label class="text-[10px] font-black uppercase text-slate-500 mb-3 block">Final Notes for Owner</label>
                        <textarea @bind="cart.Notes" @bind:event="oninput" maxlength="500" rows="3" 
                                  placeholder="Gate codes or general notes..."
                                  class="w-full bg-black border border-slate-800 rounded-2xl p-4 text-sm focus:border-emerald-500 outline-none transition-all resize-none text-slate-300"></textarea>
                    </div>
                </div>

                <div class="mt-8 pt-8 border-t border-white/10 shrink-0">
                    <div class="flex justify-between items-end mb-8">
                        <span class="text-[10px] font-black uppercase text-slate-500">Order Total</span>
                        <span class="text-3xl font-black text-white italic font-mono">$@GetCartTotal().ToString("N2")</span>
                    </div>
                    <button @onclick="ProcessCheckout" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white py-6 rounded-3xl font-black text-xs uppercase tracking-[0.5em] transition-all shadow-xl active:scale-95">
                        Place Order
                    </button>
                </div>
            </div>
        </div>
    }

    @* Configuration Modal *@
    @if (selectedItem != null && currentSize != null)
    {
        <div class="fixed inset-0 bg-black/95 backdrop-blur-md z-[400] flex items-end justify-center" @onclick="() => selectedItem = null">
            <div @onclick:stopPropagation="true" class="bg-[#0f0f0f] w-full max-w-2xl rounded-t-[3rem] border-t border-slate-800 p-10 shadow-2xl animate-in slide-in-from-bottom duration-300 max-h-[95vh] overflow-y-auto">
                <div class="flex justify-between items-start mb-8">
                    <div>
                        <h2 class="text-3xl font-black text-white uppercase italic tracking-tighter">@selectedItem.Recipe?.Name</h2>
                        <p class="text-[10px] text-emerald-500 font-black uppercase mt-1">Configure Delivery & Options</p>
                    </div>
                    <button @onclick="() => selectedItem = null" class="bg-white/5 w-12 h-12 rounded-2xl text-slate-400 flex items-center justify-center text-2xl transition-all">&times;</button>
                </div>

                <div class="space-y-10">
                    @* Name Label Section *@
                    <section>
                        <h5 class="text-[10px] font-black uppercase text-emerald-500 mb-4 tracking-widest">Who is this for?</h5>
                        <input @bind="selLabelName" placeholder="Optional: e.g. Bob, Lisa, Leigh..." 
                               class="w-full bg-black border border-slate-800 rounded-2xl p-4 text-sm text-white outline-none focus:border-emerald-500 transition-all font-bold italic" />
                    </section>

                    @* 1. Time Slot *@
                    <section>
                        <h5 class="text-[10px] font-black uppercase text-slate-500 mb-4">Choose Time Slot</h5>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var tf in selectedItem.Timeframes)
                            {
                                <button @onclick="() => selTimeframe = tf.Name" 
                                        class="px-5 py-2.5 rounded-xl border text-[10px] font-black uppercase transition-all @(selTimeframe == tf.Name ? "bg-emerald-600 border-emerald-600 text-white shadow-[0_0_15px_rgba(16,185,129,0.3)]" : "border-slate-800 text-slate-500 hover:border-slate-600")">
                                    @tf.Name
                                </button>
                            }
                        </div>
                    </section>

                    @* 2. Logistics Selection *@
                    <section>
                        <h5 class="text-[10px] font-black uppercase text-slate-500 mb-4">Fulfillment for this day</h5>
                        @if (owner.OffersPickup && owner.OffersDelivery)
                        {
                            <div class="flex gap-2 mb-4 bg-black p-1 rounded-2xl border border-slate-800">
                                <button @onclick='() => selFulfillment = "Pickup"' class="flex-1 py-3 rounded-xl text-[10px] font-black uppercase @(selFulfillment == "Pickup" ? "bg-white text-black" : "text-slate-500")">Pickup</button>
                                <button @onclick='() => selFulfillment = "Delivery"' class="flex-1 py-3 rounded-xl text-[10px] font-black uppercase @(selFulfillment == "Delivery" ? "bg-blue-600 text-white" : "text-slate-500")">Delivery</button>
                            </div>
                        }

                        @if (selFulfillment == "Pickup")
                        {
                            <select @bind="selPickupId" class="w-full bg-black border border-slate-800 rounded-xl p-4 text-xs text-white">
                                <option value="0">-- Select Pickup Location --</option>
                                @foreach (var loc in pickupLocations) { <option value="@loc.Id">@loc.Name (@loc.Address)</option> }
                            </select>
                        }
                        else
                        {
                            <div class="relative">
                                <input @bind="selZip" @oninput="HandleFeeZipInput" maxlength="5" placeholder="Zip Code for Delivery" 
                                       class="w-full bg-black border border-slate-800 rounded-xl p-4 text-sm font-mono text-white outline-none focus:border-blue-500" />
                                @if (isLookupLoading) { <div class="absolute right-3 top-4 scale-75 border-2 border-emerald-500 border-t-transparent rounded-full w-4 h-4 animate-spin"></div> }
                            </div>
                            @if(!string.IsNullOrEmpty(selZip)) {
                                var fee = GetDeliveryFee(selZip);
                                <p class="text-[10px] mt-2 font-black uppercase @(fee >= 0 ? "text-blue-400" : "text-red-500")">
                                    @(fee >= 0 ? $"✓ Delivery Fee: ${fee:N2}" : "✕ No delivery to " + selZip)
                                </p>
                            }
                        }
                    </section>

                    @* 3. Size Selection *@
                    <section>
                        <h5 class="text-[10px] font-black uppercase text-slate-500 mb-4">Size</h5>
                        <div class="space-y-2">
                            @foreach (var sz in selectedItem.Sizes)
                            {
                                <div @onclick="() => SetSize(sz)" class="p-4 rounded-2xl border transition-all cursor-pointer @(currentSize?.Id == sz.Id ? "border-emerald-500 bg-emerald-500/5" : "border-slate-800 bg-black/40") flex justify-between items-center">
                                    <span class="font-black text-xs uppercase @(currentSize?.Id == sz.Id ? "text-emerald-400" : "text-slate-300")">@sz.Name</span>
                                    <span class="font-mono text-xs">$@sz.BasePrice.ToString("N2")</span>
                                </div>
                            }
                        </div>
                    </section>

                    @* 4. Add-ons / Options *@
                    @if (currentSize?.Options != null && currentSize.Options.Any())
                    {
                        <section>
                            <h5 class="text-[10px] font-black uppercase text-slate-500 mb-4">Add-ons</h5>
                            <div class="space-y-2">
                                @foreach (var opt in currentSize.Options)
                                {
                                    <div @onclick="() => ToggleOption(opt)" class="p-4 bg-black/40 border @(selectedOptionIds.Contains(opt.Id) ? "border-emerald-500/50" : "border-slate-800") rounded-2xl cursor-pointer flex justify-between items-center transition-all">
                                        <div class="flex items-center gap-3">
                                            <div class="w-5 h-5 rounded border border-slate-700 flex items-center justify-center @(selectedOptionIds.Contains(opt.Id) ? "bg-emerald-500 border-emerald-500" : "")">
                                                @if(selectedOptionIds.Contains(opt.Id)) { <span class="text-white text-[10px]">✓</span> }
                                            </div>
                                            <span class="text-xs font-bold uppercase @(selectedOptionIds.Contains(opt.Id) ? "text-white" : "text-slate-500")">@opt.Name</span>
                                        </div>
                                        <span class="text-[10px] font-mono">+$@opt.AddOnPrice.ToString("N2")</span>
                                    </div>
                                }
                            </div>
                        </section>
                    }
                </div>

                <div class="mt-12 pt-8 border-t border-white/5">
                    <button @onclick="AddToCart" 
                            disabled="@(!IsConfigValid())"
                            class="w-full bg-emerald-600 hover:bg-emerald-500 disabled:opacity-20 text-white py-6 rounded-3xl font-black text-xs uppercase tracking-[0.4em] transition-all shadow-xl flex justify-between items-center px-10">
                        <span>Add to Cart</span>
                        <span class="font-mono">$@GetConfigTotal().ToString("N2")</span>
                    </button>
                </div>
            </div>
        </div>
    }

    @* Identity & Checkout Review Modal *@
    @if (showContactForm)
    {
        <div class="fixed inset-0 bg-black/95 backdrop-blur-md z-[800] flex items-center justify-center p-4">
            <div class="bg-[#0f0f0f] w-full max-w-lg rounded-[3rem] border border-slate-800 p-10 shadow-2xl animate-in zoom-in-95 duration-200">
                <div class="flex justify-between items-start mb-6">
                    <div>
                        <h2 class="text-2xl font-black text-white uppercase italic tracking-tighter mb-2">Final Review</h2>
                        <p class="text-[10px] text-slate-500 font-black uppercase">Confirm details for order completion</p>
                    </div>
                    <button @onclick="() => showContactForm = false" class="text-slate-600 hover:text-white text-2xl">&times;</button>
                </div>
                
                <div class="space-y-6 max-h-[60vh] overflow-y-auto pr-2">
                    @* Contact Details *@
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="text-[8px] uppercase text-emerald-500 font-black mb-1 block">First Name</label>
                            <input @bind="tempUser.FirstName" placeholder="Required" class="w-full bg-black border border-slate-800 rounded-xl p-4 text-sm text-white outline-none focus:border-emerald-500 transition-all" />
                        </div>
                        <div>
                            <label class="text-[8px] uppercase text-emerald-500 font-black mb-1 block">Last Name</label>
                            <input @bind="tempUser.LastName" placeholder="Required" class="w-full bg-black border border-slate-800 rounded-xl p-4 text-sm text-white outline-none focus:border-emerald-500 transition-all" />
                        </div>
                    </div>

                    <div>
                        <label class="text-[8px] uppercase text-emerald-500 font-black mb-1 block">Email Address</label>
                        <input @bind="tempUser.Email" type="email" placeholder="Required for magic link" class="w-full bg-black border border-slate-800 rounded-xl p-4 text-sm text-white outline-none focus:border-emerald-500 transition-all" />
                    </div>

                    <div>
                        <label class="text-[8px] uppercase text-emerald-500 font-black mb-1 block">Phone Number</label>
                        <input @bind="tempUser.Phone" type="tel" placeholder="Required" class="w-full bg-black border border-slate-800 rounded-xl p-4 text-sm text-white outline-none focus:border-emerald-500 transition-all" />
                    </div>
                    
                    @* Address Selection Logic *@
                    @if (cart?.Items != null && cart.Items.Any(i => i.FulfillmentMethod == "Delivery"))
                    {
                        <div class="pt-6 border-t border-white/5 space-y-4">
                            <div class="flex justify-between items-end">
                                <label class="text-[9px] font-black uppercase text-emerald-500">Delivery Location</label>
                                @if (currentUser?.Addresses != null && currentUser.Addresses.Any())
                                {
                                    <select @onchange="SelectSavedAddress" class="bg-emerald-950/40 text-[9px] text-emerald-400 font-black uppercase border border-emerald-500/20 rounded px-2 py-1 outline-none">
                                        <option value="0">Saved Addresses</option>
                                        @foreach(var a in currentUser.Addresses) 
                                        { 
                                            <option value="@a.Id">@a.Label (@a.Street)</option> 
                                        }
                                        <option value="-1">+ New Address</option>
                                    </select>
                                }
                            </div>

                            <input @bind="tempAddress.Label" placeholder="Address Nickname (e.g. Home, Work)" class="w-full bg-black border border-slate-800 rounded-xl p-4 text-xs text-white outline-none focus:border-emerald-500" />
                            <input @bind="tempAddress.Street" placeholder="Street Address" class="w-full bg-black border border-slate-800 rounded-xl p-4 text-sm text-white outline-none focus:border-emerald-500" />
                            
                            <div class="grid grid-cols-3 gap-3">
                                <input @bind="tempAddress.City" placeholder="City" class="bg-black border border-slate-800 rounded-xl p-4 text-xs text-white outline-none" />
                                <input @bind="tempAddress.State" maxlength="2" placeholder="ST" class="bg-black border border-slate-800 rounded-xl p-4 text-xs text-white outline-none text-center" />
                                <div class="relative">
                                    <input @bind="tempAddress.ZipCode" @oninput="HandleCheckoutZipLookup" maxlength="5" placeholder="Zip" class="w-full bg-black border border-slate-800 rounded-xl p-4 text-xs text-white outline-none font-mono focus:border-emerald-500" />
                                    @if (isLookupLoading) { <div class="absolute right-3 top-4 scale-50 border-2 border-emerald-500 border-t-transparent rounded-full w-4 h-4 animate-spin"></div> }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-10 pt-8 border-t border-white/5 flex gap-4">
                    <button @onclick="() => showContactForm = false" class="flex-1 bg-white/5 hover:bg-white/10 text-slate-500 py-5 rounded-3xl text-[10px] font-black uppercase tracking-widest transition-all">Back</button>
                    <button @onclick="FinalizeOrder" class="flex-[2] bg-emerald-600 hover:bg-emerald-500 text-white py-5 rounded-3xl text-[10px] font-black uppercase tracking-[0.3em] shadow-xl transition-all active:scale-95">Complete Order</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int OwnerId { get; set; }
    
    private PPP_Owner? owner;
    private List<PPP_Menu> activeMenus = new();
    private List<ToastItem> toasts = new();
    private Dictionary<int, int> soldCounts = new();
    private PPP_Order? cart;
    private string? customerId;
    private bool showCart = false;
    private bool showContactForm = false;
    private bool isLookupLoading = false;

    // Configuration Selections
    private string selTimeframe = "";
    private string selFulfillment = "Pickup";
    private int selPickupId = 0;
    private string selZip = "";
    private string selLabelName = "";
    private PPP_MenuItem? selectedItem;
    private PPP_MenuItemSize? currentSize;
    private HashSet<int> selectedOptionIds = new();

    private List<PPP_PickupLocation> pickupLocations = new();
    private List<PPP_DeliveryZipCode> ownerZips = new();

    // Identity/Auth States
    private PPP_User? currentUser;
    private PPP_User tempUser = new();
    private PPP_Address tempAddress = new() { Label = "Home" };

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        owner = await db.PPP_Owners.AsNoTracking().FirstOrDefaultAsync(o => o.Id == OwnerId);
        
        var today = DateTime.Today.ToUniversalTime();
        activeMenus = await db.Set<PPP_Menu>().AsNoTracking()
            .Include(m => m.Items).ThenInclude(i => i.Recipe)
            .Include(m => m.Items).ThenInclude(i => i.Timeframes)
            .Include(m => m.Items).ThenInclude(i => i.Sizes).ThenInclude(s => s.Options)
            .Where(m => m.OwnerId == OwnerId && m.IsPublished && m.EndDate >= today)
            .OrderBy(m => m.StartDate)
            .ToListAsync();

        pickupLocations = await db.Set<PPP_PickupLocation>().Where(l => l.OwnerId == OwnerId).ToListAsync();
        ownerZips = await db.Set<PPP_DeliveryZipCode>().Where(z => z.OwnerId == OwnerId).ToListAsync();

        if (owner != null) 
        {
            selFulfillment = owner.OffersPickup ? "Pickup" : "Delivery";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            customerId = await JS.InvokeAsync<string>("localStorage.getItem", "ppp_customer_id");
            if (string.IsNullOrEmpty(customerId))
            {
                customerId = Guid.NewGuid().ToString();
                await JS.InvokeVoidAsync("localStorage.setItem", "ppp_customer_id", customerId);
            }

            await ShowToast("Auth: Checking for session...");
            
            var token = await JS.InvokeAsync<string>("eval", @"
                (function() {
                    var name = 'ppp_token=';
                    var ca = document.cookie.split(';');
                    for(var i = 0; i < ca.length; i++) {
                        var c = ca[i].trim();
                        if (c.indexOf(name) == 0) return c.substring(name.length, c.length);
                    }
                    return null;
                })()");

            if (!string.IsNullOrEmpty(token))
            {
                await using var db = await DbFactory.CreateDbContextAsync();
                currentUser = await db.PPP_Users
                    .Include(u => u.Addresses)
                    .FirstOrDefaultAsync(u => u.MagicToken == token && u.TokenExpiresAt > DateTime.UtcNow);

                if (currentUser != null) 
                {
                    await ShowToast("Auth: Magic token found");
                    tempUser.FirstName = currentUser.FirstName;
                    tempUser.LastName = currentUser.LastName;
                    tempUser.Email = currentUser.Email;
                    tempUser.Phone = currentUser.Phone;

                    var addr = currentUser.Addresses.FirstOrDefault(a => a.IsDefault) ?? currentUser.Addresses.FirstOrDefault();
                    if (addr != null)
                    {
                        tempAddress.Label = addr.Label;
                        tempAddress.Street = addr.Street;
                        tempAddress.City = addr.City;
                        tempAddress.State = addr.State;
                        tempAddress.ZipCode = addr.ZipCode;
                        selZip = addr.ZipCode; 
                    }
                }
                else 
                {
                    await ShowToast("Auth: No valid session found", true);
                }
            }
            else 
            {
                await ShowToast("Auth: No session detected");
            }

            await LoadCart();
            StateHasChanged();
        }
    }

    private void SelectSavedAddress(ChangeEventArgs e)
    {
        int id = int.Parse(e.Value?.ToString() ?? "0");
        if (id == -1) 
        { 
            tempAddress = new PPP_Address { Label = "Home" }; 
            return; 
        }

        var addr = currentUser?.Addresses.FirstOrDefault(a => a.Id == id);
        if (addr != null)
        {
            tempAddress.Label = addr.Label;
            tempAddress.Street = addr.Street;
            tempAddress.City = addr.City;
            tempAddress.State = addr.State;
            tempAddress.ZipCode = addr.ZipCode;
            StateHasChanged();
        }
    }

    private async Task HandleFeeZipInput(ChangeEventArgs e)
    {
        var zip = e.Value?.ToString() ?? "";
        selZip = zip;
        tempAddress.ZipCode = zip; 
        if (zip.Length == 5) 
        {
            await LookupZip(zip, true);
        }
    }

    private async Task HandleCheckoutZipLookup(ChangeEventArgs e)
    {
        var zip = e.Value?.ToString() ?? "";
        tempAddress.ZipCode = zip;
        if (zip.Length == 5) 
        {
            await LookupZip(zip, false);
        }
    }

    private async Task LookupZip(string zip, bool isFeeCheck)
    {
        isLookupLoading = true;
        try 
        {
            using var http = new HttpClient();
            var res = await http.GetFromJsonAsync<ZipResponse>($"https://api.zippopotam.us/us/{zip}");
            if (res?.Places != null && res.Places.Any())
            {
                var p = res.Places.First();
                tempAddress.City = p.PlaceName;
                tempAddress.State = p.StateAbbreviation;
                if (!isFeeCheck) 
                {
                    await ShowToast($"Located: {p.PlaceName}, {p.StateAbbreviation}");
                }
            }
        }
        catch { /* Silent fail */ }
        finally 
        { 
            isLookupLoading = false; 
            StateHasChanged(); 
        }
    }

    private void SelectItem(PPP_MenuItem item)
    {
        selectedItem = item;
        currentSize = item.Sizes?.OrderBy(s => s.BasePrice).FirstOrDefault();
        selTimeframe = item.Timeframes?.FirstOrDefault()?.Name ?? "Standard";
        selectedOptionIds.Clear();
        
        // DEFAULTS Label to User's Name if they are logged in
        if (currentUser != null && !string.IsNullOrEmpty(currentUser.FirstName))
        {
            selLabelName = currentUser.FirstName;
        }
        else
        {
            selLabelName = "";
        }
        
        selZip = tempAddress.ZipCode;

        if (owner != null) 
        {
            selFulfillment = owner.OffersPickup ? "Pickup" : "Delivery";
        }
        selPickupId = pickupLocations.FirstOrDefault()?.Id ?? 0;

        StateHasChanged();
    }

    private double GetDeliveryFee(string zip)
    {
        var match = ownerZips.FirstOrDefault(z => z.ZipCode == zip.Trim());
        if (match == null) return -1;
        return match.Fee;
    }

    private bool IsConfigValid()
    {
        if (string.IsNullOrEmpty(selTimeframe)) return false;
        if (selFulfillment == "Pickup" && selPickupId == 0) return false;
        if (selFulfillment == "Delivery" && GetDeliveryFee(selZip) < 0) return false;
        return true;
    }

    private double GetConfigTotal()
    {
        if (currentSize == null) return 0;
        double fee = selFulfillment == "Delivery" ? Math.Max(0, GetDeliveryFee(selZip)) : 0;
        var addons = currentSize.Options.Where(o => selectedOptionIds.Contains(o.Id)).Sum(o => o.AddOnPrice);
        return currentSize.BasePrice + fee + addons;
    }

    private async Task AddToCart()
    {
        if (selectedItem == null || currentSize == null || cart == null || selectedItem.Recipe == null) return;
        
        try 
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var newEntry = new PPP_OrderItem
            {
                OrderId = cart.Id,
                MenuItemId = selectedItem.Id,
                RecipeName = selectedItem.Recipe?.Name ?? "Selected Item",
                SizeName = currentSize?.Name ?? "Standard",
                BasePrice = currentSize?.BasePrice ?? 0,
                ScheduledDate = selectedItem.StartDate.ToUniversalTime(),
                TimeframeName = selTimeframe,
                FulfillmentMethod = selFulfillment,
                PickupLocationId = selFulfillment == "Pickup" ? selPickupId : null,
                DeliveryFee = selFulfillment == "Delivery" ? Math.Max(0, GetDeliveryFee(selZip)) : 0,
                LabelName = selLabelName,
                SelectedOptions = currentSize?.Options
                    .Where(o => selectedOptionIds.Contains(o.Id))
                    .Select(o => new PPP_OrderItemOption { OptionName = o.Name, AddOnPrice = o.AddOnPrice })
                    .ToList() ?? new List<PPP_OrderItemOption>()
            };

            db.Add(newEntry);
            await db.SaveChangesAsync();
            
            await LoadCart(); 
            selectedItem = null;
            selectedOptionIds.Clear();
            await ShowToast("Added to cart!");
        }
        catch (Exception ex) 
        { 
            await ShowToast("Error: " + ex.Message, true); 
        }
    }

    private async Task ProcessCheckout()
    {
        showContactForm = true;
    }

    private async Task FinalizeOrder()
    {
        if (string.IsNullOrWhiteSpace(tempUser.Email) || string.IsNullOrWhiteSpace(tempUser.FirstName))
        {
            await ShowToast("Email and Name are required", true);
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var user = await db.PPP_Users
            .Include(u => u.Addresses)
            .FirstOrDefaultAsync(u => u.Email.ToLower() == tempUser.Email.ToLower());
        
        if (user == null)
        {
            user = new PPP_User 
            { 
                Email = tempUser.Email.ToLower(), 
                FirstName = tempUser.FirstName, 
                LastName = tempUser.LastName, 
                Phone = tempUser.Phone,
                MagicToken = Guid.NewGuid().ToString("N"), 
                TokenExpiresAt = DateTime.UtcNow.AddMonths(6)
            };
            db.PPP_Users.Add(user);
            await db.SaveChangesAsync(); // get ID
        }
        else
        {
            user.FirstName = tempUser.FirstName; 
            user.LastName = tempUser.LastName; 
            user.Phone = tempUser.Phone;
            if (string.IsNullOrEmpty(user.MagicToken)) user.MagicToken = Guid.NewGuid().ToString("N");
            user.TokenExpiresAt = DateTime.UtcNow.AddMonths(6);
        }

        // Save/Update Address if delivery is selected
        if (cart.Items.Any(i => i.FulfillmentMethod == "Delivery") && !string.IsNullOrEmpty(tempAddress.Street))
        {
            var exists = user.Addresses.Any(a => a.Street == tempAddress.Street);
            if (!exists)
            {
                db.Set<PPP_Address>().Add(new PPP_Address 
                { 
                    UserId = user.Id, 
                    Label = tempAddress.Label, 
                    Street = tempAddress.Street, 
                    City = tempAddress.City, 
                    State = tempAddress.State, 
                    ZipCode = tempAddress.ZipCode,
                    IsDefault = true
                });
            }
        }

        var dbOrder = await db.PPP_Orders.FirstOrDefaultAsync(o => o.Id == cart.Id);
        if (dbOrder != null) 
        {
            dbOrder.IsCheckedOut = true; 
            dbOrder.CheckedOutAt = DateTime.UtcNow;
            dbOrder.CustomerIdentifier = user.Email;
            dbOrder.Notes = cart.Notes;
            await db.SaveChangesAsync();
            
            // Persistent Cookie Write
            await JS.InvokeVoidAsync("eval", $@"
                document.cookie = 'ppp_token={user.MagicToken}; max-age={60*60*24*180}; path=/; SameSite=Lax';
            ");
            
            await ShowToast("Order placed successfully!");
            cart = null; 
            showCart = false; 
            showContactForm = false;
            await LoadCart();
        }
    }

    private async Task LoadCart()
    {
        try 
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var identifier = currentUser?.Email ?? customerId;

            var existingOrder = await db.Set<PPP_Order>()
                .FirstOrDefaultAsync(o => o.OwnerId == OwnerId && 
                                         o.CustomerIdentifier == identifier && 
                                         !o.IsCheckedOut);
            if (existingOrder == null)
            {
                existingOrder = new PPP_Order { OwnerId = OwnerId, CustomerIdentifier = identifier, CreatedAt = DateTime.UtcNow };
                db.Add(existingOrder);
                await db.SaveChangesAsync();
            }
            existingOrder.Items = await db.Set<PPP_OrderItem>()
                .Where(i => i.OrderId == existingOrder.Id)
                .Include(i => i.SelectedOptions)
                .ToListAsync();
            cart = existingOrder;
        }
        catch (Exception ex) 
        { 
            Console.WriteLine($"Cart Load Error: {ex.Message}"); 
        }
    }

    private double GetCartTotal()
    {
        if (cart == null) return 0;
        return cart.Items.Sum(i => i.BasePrice + i.DeliveryFee + i.SelectedOptions.Sum(o => o.AddOnPrice));
    }

    private double GetItemTotal(PPP_OrderItem item)
    {
        return item.BasePrice + item.DeliveryFee + item.SelectedOptions.Sum(o => o.AddOnPrice);
    }

    private async Task SaveCartNotes()
    {
        showCart = false;
    }

    private async Task RemoveFromCart(int id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var item = await db.PPP_OrderItems.FindAsync(id);
        if (item != null) 
        { 
            db.Remove(item); 
            await db.SaveChangesAsync(); 
            await LoadCart(); 
        }
    }

