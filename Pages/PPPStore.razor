    {
        currentSize = sz; 
        selectedOptionIds.Clear();
    }

    private void ToggleOption(PPP_MenuItemOption opt)
    {
        if (selectedOptionIds.Contains(opt.Id)) 
        {
            selectedOptionIds.Remove(opt.Id);
        }
        else 
        {
            selectedOptionIds.Add(opt.Id);
        }
    }

    private bool IsPastCutoff(PPP_MenuItem i)
    {
        return DateTime.Now > i.StartDate.Date.AddDays(-1).Add(i.CutoffTime.ToTimeSpan());
    }

    private bool IsItemSoldOut(PPP_MenuItem i)
    {
        return false;
    }

    private async Task ShowToast(string msg, bool err = false) 
    { 
        var t = new ToastItem { Message = msg, IsError = err };
        toasts.Add(t); 
        StateHasChanged(); 
        await Task.Delay(3000); 
        toasts.Remove(t); 
        StateHasChanged(); 
    }

    private class ToastItem { public string Message { get; set; } = ""; public bool IsError { get; set; } }
    public class ZipResponse { [System.Text.Json.Serialization.JsonPropertyName("places")] public List<ZipPlace> Places { get; set; } = new(); }
    public class ZipPlace { [System.Text.Json.Serialization.JsonPropertyName("place name")] public string PlaceName { get; set; } = ""; [System.Text.Json.Serialization.JsonPropertyName("state abbreviation")] public string StateAbbreviation { get; set; } = ""; }
