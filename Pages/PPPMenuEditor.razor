@page "/ppp-menu-editor/{OwnerId:int}/{MenuId:int?}"
@using Dashboard
@using Dashboard.Components
@using Dashboard.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Forms
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#050505] text-slate-200 p-4 md:p-8 font-sans antialiased pb-32">
    <PPPAdminNav CurrentPage="Menu Architect" />

    @* Notification Stack *@
    <div class="fixed top-24 right-6 z-[100] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950/90 border-red-500/50 text-red-200" : "bg-emerald-950/90 border-emerald-500/50 text-emerald-200") backdrop-blur-md">
                <div class="flex items-center gap-3">
                    <span class="text-lg">@(toast.IsError ? "✕" : "✓")</span>
                    <span class="text-xs font-bold uppercase tracking-widest">@toast.Message</span>
                </div>
            </div>
        }
    </div>

    <div class="max-w-7xl mx-auto mb-10">
        <h1 class="text-4xl font-black tracking-tighter text-white uppercase italic">Menu Architect</h1>
        <p class="text-slate-500 text-sm uppercase tracking-[0.2em] mt-1">Schedule and Price your offerings</p>
    </div>

    <div class="max-w-7xl mx-auto grid grid-cols-12 gap-8">
        @* Sidebar: Menu Configuration *@
        <div class="col-span-12 lg:col-span-4 space-y-6">
            <div class="bg-[#111] border border-slate-800 rounded-3xl p-8 shadow-xl">
                <h2 class="text-xs font-black uppercase tracking-[0.2em] text-emerald-500 mb-6">Menu Identity</h2>
                <div class="space-y-4">
                    <div>
                        <label class="text-[10px] text-slate-500 uppercase font-bold mb-2 block">Menu Name</label>
                        <input @bind="menu.Name" placeholder="e.g. Week of April 13th" class="w-full bg-black border border-slate-800 rounded-2xl p-4 text-sm focus:border-emerald-500 outline-none" />
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="text-[10px] text-slate-500 uppercase font-bold mb-2 block">Start Date</label>
                            <input type="date" @bind="menu.StartDate" class="w-full bg-black border border-slate-800 rounded-2xl p-4 text-sm text-white" />
                        </div>
                        <div>
                            <label class="text-[10px] text-slate-500 uppercase font-bold mb-2 block">End Date</label>
                            <input type="date" @bind="menu.EndDate" class="w-full bg-black border border-slate-800 rounded-2xl p-4 text-sm text-white" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Main Content: Added Recipes *@
        <div class="col-span-12 lg:col-span-8 space-y-6">
            <div class="flex items-center justify-between px-4">
                <h2 class="text-xs font-black uppercase tracking-[0.2em] text-slate-400">Scheduled Recipes (@menu.Items.Count)</h2>
                <div class="relative">
                    <select @onchange="AddRecipeToMenu" class="bg-emerald-600 hover:bg-emerald-500 text-white px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest outline-none cursor-pointer transition-all">
                        <option value="0">＋ Add Recipe to Menu</option>
                        @foreach (var r in availableRecipes) { 
                            <option value="@r.Id">@r.Name</option> 
                        }
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                @foreach (var item in menu.Items)
                {
                    <div class="bg-[#111] border border-slate-800 rounded-2xl p-5 flex items-center justify-between group hover:border-emerald-500/50 transition-all shadow-lg">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-xl bg-black border border-slate-800 flex items-center justify-center overflow-hidden">
                                @if (item.Recipe?.ImageId != null) {
                                    <img src="/db-images-ppp/@item.Recipe.ImageId" class="w-full h-full object-cover" />
                                } else {
                                    <span class="text-xl">🍲</span>
                                }
                            </div>
                            <div>
                                <h3 class="text-white font-black text-xs uppercase tracking-tight">@item.Recipe?.Name</h3>
                                <p class="text-[9px] text-slate-500 font-bold uppercase mt-0.5">@item.Sizes.Count Sizes • @item.Timeframes.Count Slots</p>
                            </div>
                        </div>
                        <div class="flex gap-2">
                            <button @onclick="() => OpenConfig(item)" class="p-2 bg-white/5 hover:bg-emerald-600 text-slate-400 hover:text-white rounded-lg transition-all" title="Edit Pricing & Scheduling">⚙️</button>
                            <button @onclick="() => menu.Items.Remove(item)" class="p-2 bg-white/5 hover:bg-red-600 text-slate-400 hover:text-white rounded-lg transition-all">✕</button>
                        </div>
                    </div>
                }
            </div>
            
            @if(menu.Items.Any())
            {
                <div class="pt-10 border-t border-slate-800/50 flex justify-end">
                    <button @onclick="SaveMenu" class="bg-emerald-600 hover:bg-emerald-500 text-white px-12 py-5 rounded-2xl font-black text-xs uppercase tracking-[0.4em] transition-all shadow-2xl active:scale-95">
                        Save Menu
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@* Modal: Item Configuration Details *@
@if (activeItem != null)
{
    <div class="fixed inset-0 bg-black/90 backdrop-blur-md z-[200] flex items-center justify-center p-4">
        <div class="bg-[#111] w-full max-w-4xl rounded-[2.5rem] border border-slate-800 shadow-[0_0_50px_rgba(0,0,0,0.8)] overflow-hidden animate-in zoom-in duration-200">
            <div class="p-6 bg-white/5 border-b border-slate-800 flex justify-between items-center">
                <h3 class="text-xl font-black text-white uppercase italic tracking-tighter">Configuring: @activeItem.Recipe?.Name</h3>
                <button @onclick="() => activeItem = null" class="text-slate-500 hover:text-white text-3xl font-light">&times;</button>
            </div>
            
            <div class="p-8 grid grid-cols-1 md:grid-cols-2 gap-10 max-h-[70vh] overflow-y-auto">
                @* LEFT: Scheduling *@
                <div class="space-y-6">
                    <div>
                        <p class="text-[10px] text-emerald-500 font-black uppercase tracking-widest mb-4">Availability Window</p>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="text-[8px] text-slate-500 uppercase font-bold block mb-1">Start</label>
                                <input type="date" @bind="activeItem.StartDate" class="w-full bg-black border border-slate-800 rounded-xl p-3 text-xs text-white" />
                            </div>
                            <div>
                                <label class="text-[8px] text-slate-500 uppercase font-bold block mb-1">End</label>
                                <input type="date" @bind="activeItem.EndDate" class="w-full bg-black border border-slate-800 rounded-xl p-3 text-xs text-white" />
                            </div>
                        </div>
                    </div>

                    <div>
                        <div class="flex justify-between items-center mb-4">
                            <p class="text-[10px] text-emerald-500 font-black uppercase tracking-widest">Daily Time Slots</p>
                            <button @onclick="() => AddTimeframe(activeItem)" class="text-[8px] bg-emerald-500/10 text-emerald-500 px-3 py-1 rounded-full border border-emerald-500/20 font-black uppercase">Add Slot</button>
                        </div>
                        <div class="space-y-2">
                            @foreach(var tf in activeItem.Timeframes) {
                                <div class="flex gap-2 items-center bg-black/40 p-2 rounded-xl border border-slate-800">
                                    <input @bind="tf.Name" placeholder="Lunch" class="flex-1 bg-transparent text-[10px] font-bold outline-none" />
                                    <input @bind="tf.TimeRange" placeholder="11am-2pm" class="flex-1 bg-transparent text-[10px] outline-none text-slate-400" />
                                    <button @onclick="() => activeItem.Timeframes.Remove(tf)" class="text-red-900 hover:text-red-500 px-2 font-bold">✕</button>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                @* RIGHT: Pricing / Sizes *@
                <div class="space-y-6">
                    <div class="flex justify-between items-center mb-4">
                        <p class="text-[10px] text-emerald-500 font-black uppercase tracking-widest">Sizes & Options</p>
                        <button @onclick="() => AddSize(activeItem)" class="text-[8px] bg-blue-500/10 text-blue-500 px-3 py-1 rounded-full border border-blue-500/20 font-black uppercase">Add Size</button>
                    </div>

                    @foreach(var size in activeItem.Sizes) {
                        <div class="bg-black/40 p-4 rounded-2xl border border-slate-800 space-y-4">
                            <div class="flex gap-3">
                                <input @bind="size.Name" placeholder="Small" class="flex-1 bg-[#111] border border-slate-800 rounded-lg p-2 text-xs font-black text-white uppercase" />
                                <div class="relative w-24">
                                    <span class="absolute left-2.5 top-2 text-slate-600 text-xs">$</span>
                                    <input type="number" @bind="size.BasePrice" class="w-full bg-[#111] border border-slate-800 rounded-lg p-2 pl-6 text-xs font-mono text-emerald-400" />
                                </div>
                                <button @onclick="() => activeItem.Sizes.Remove(size)" class="text-slate-700 hover:text-red-500">✕</button>
                            </div>

                            @* Options *@
                            <div class="pl-4 border-l-2 border-slate-800 space-y-2">
                                @foreach(var opt in size.Options) {
                                    <div class="flex gap-2 items-center">
                                        <input @bind="opt.Name" placeholder="Add Protein" class="flex-1 bg-transparent border-b border-slate-800 p-1 text-[10px] text-slate-300" />
                                        <div class="flex items-center gap-1">
                                            <span class="text-[8px] text-slate-600">+$</span>
                                            <input type="number" @bind="opt.AddOnPrice" class="w-14 bg-transparent border-b border-slate-800 text-[10px] font-mono text-blue-400" />
                                        </div>
                                        <button @onclick="() => size.Options.Remove(opt)" class="text-slate-700">✕</button>
                                    </div>
                                }
                                <button @onclick="() => AddOption(size)" class="text-[8px] text-blue-500 font-black uppercase tracking-widest mt-1 hover:text-blue-400">＋ Add Option</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
            
            <div class="p-8 bg-black/50 border-t border-slate-800 flex justify-end">
                <button @onclick="() => activeItem = null" class="bg-emerald-600 hover:bg-emerald-500 text-white px-10 py-3 rounded-xl font-black text-[10px] uppercase tracking-widest transition-all">Confirm Details</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int OwnerId { get; set; }
    [Parameter] public int? MenuId { get; set; }

    private PPP_Menu menu = new();
    private List<PPP_Recipe> availableRecipes = new();
    private List<ToastItem> toasts = new();
    private PPP_MenuItem? activeItem;

    protected override async Task OnInitializedAsync()
    {
        availableRecipes = await Db.PPP_Recipes.AsNoTracking().Where(r => r.OwnerId == OwnerId).OrderBy(r => r.Name).ToListAsync();

        if (MenuId.HasValue) {
            var existing = await Db.Set<PPP_Menu>()
                .Include(m => m.Items).ThenInclude(i => i.Recipe)
                .Include(m => m.Items).ThenInclude(i => i.Timeframes)
                .Include(m => m.Items).ThenInclude(i => i.Sizes).ThenInclude(s => s.Options)
                .FirstOrDefaultAsync(m => m.Id == MenuId.Value);
            if (existing != null) menu = existing;
        } else {
            menu.OwnerId = OwnerId;
            menu.StartDate = DateTime.Today;
            menu.EndDate = DateTime.Today.AddDays(6);
        }
    }

    private void AddRecipeToMenu(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int rid) && rid > 0) {
            var recipe = availableRecipes.FirstOrDefault(r => r.Id == rid);
            if (recipe != null) {
                menu.Items.Add(new PPP_MenuItem { 
                    RecipeId = rid, 
                    Recipe = recipe, 
                    StartDate = menu.StartDate, 
                    EndDate = menu.EndDate 
                });
            }
        }
    }

    private void OpenConfig(PPP_MenuItem item) => activeItem = item;
    private void AddTimeframe(PPP_MenuItem item) => item.Timeframes.Add(new PPP_MenuItemTimeframe { Name = "Lunch", TimeRange = "11:00 AM - 2:00 PM" });
    private void AddSize(PPP_MenuItem item) => item.Sizes.Add(new PPP_MenuItemSize { Name = "Standard", BasePrice = 10.00 });
    private void AddOption(PPP_MenuItemSize size) => size.Options.Add(new PPP_MenuItemOption { Name = "Add Protein", AddOnPrice = 3.00 });

    private async Task SaveMenu()
    {
        if (string.IsNullOrWhiteSpace(menu.Name)) { await ShowToast("Name the menu before saving", true); return; }
        
        try {
            await using var db = await DbFactory.CreateDbContextAsync();
            
            // PREVENT RE-SAVING MASTER DATA
            foreach(var item in menu.Items) item.Recipe = null;

            if (menu.Id == 0) db.Set<PPP_Menu>().Add(menu);
            else db.Entry(menu).State = EntityState.Modified;

            // Granular logic to avoid tracking collisions
            foreach(var item in menu.Items) {
                if (item.Id == 0) db.Add(item); else db.Entry(item).State = EntityState.Modified;
                
                foreach(var tf in item.Timeframes) {
                    if (tf.Id == 0) db.Add(tf); else db.Entry(tf).State = EntityState.Modified;
                }
                
                foreach(var sz in item.Sizes) {
                    if (sz.Id == 0) db.Add(sz); else db.Entry(sz).State = EntityState.Modified;
                    foreach(var opt in sz.Options) {
                        if (opt.Id == 0) db.Add(opt); else db.Entry(opt).State = EntityState.Modified;
                    }
                }
            }

            await db.SaveChangesAsync();
            _ = ShowToast("Menu Saved.");
            await Task.Delay(1000);
            Nav.NavigateTo($"/ppp-owner-admin");
        } catch (Exception ex) {
            await ShowToast($"Save Error: {ex.InnerException?.Message ?? ex.Message}", true);
        }
    }

    private async Task ShowToast(string msg, bool isError = false) {
        var toast = new ToastItem { Message = msg, IsError = isError };
        toasts.Add(toast); StateHasChanged();
        await Task.Delay(4000); toasts.Remove(toast); StateHasChanged();
    }
    private class ToastItem { public string Message { get; set; } = ""; public bool IsError { get; set; } }
}