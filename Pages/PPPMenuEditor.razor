@page "/ppp-menu-editor/{OwnerId:int}/{MenuId:int?}"
@using Dashboard
@using Dashboard.Components
@using Dashboard.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Forms
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#050505] text-slate-200 p-4 md:p-8 font-sans antialiased">
    <PPPAdminNav CurrentPage="Menu Architect" />

    @* Notification Stack *@
    <div class="fixed top-24 right-6 z-[100] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950 border-red-500 text-red-200" : "bg-emerald-950 border-emerald-500 text-emerald-200") backdrop-blur-md">
                <div class="flex items-center gap-3">
                    <span class="text-lg">@(toast.IsError ? "✕" : "✓")</span>
                    <span class="text-xs font-bold uppercase tracking-widest">@toast.Message</span>
                </div>
            </div>
        }
    </div>

    <div class="max-w-7xl mx-auto mb-10 flex justify-between items-end">
        <div>
            <h1 class="text-4xl font-black tracking-tighter text-white uppercase italic">Menu Architect</h1>
            <p class="text-slate-500 text-sm uppercase tracking-[0.2em] mt-1">Design scheduling and pricing tiers</p>
        </div>
        <button @onclick="SaveMenu" class="bg-emerald-600 hover:bg-emerald-500 text-white px-10 py-4 rounded-2xl font-black text-xs uppercase tracking-[0.3em] transition-all shadow-xl active:scale-95">
            Publish Menu
        </button>
    </div>

    <div class="max-w-7xl mx-auto grid grid-cols-12 gap-8">
        @* Left Column: Config *@
        <div class="col-span-12 lg:col-span-4 space-y-6">
            <div class="bg-[#111] border border-slate-800 rounded-3xl p-8 shadow-xl">
                <h2 class="text-xs font-black uppercase tracking-[0.2em] text-emerald-500 mb-6">Menu Identity</h2>
                <div class="space-y-4">
                    <div>
                        <label class="text-[10px] text-slate-500 uppercase font-bold mb-2 block">Menu Name</label>
                        <input @bind="menu.Name" placeholder="Week of..." class="w-full bg-black border border-slate-800 rounded-2xl p-4 text-sm focus:border-emerald-500 outline-none" />
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="text-[10px] text-slate-500 uppercase font-bold mb-2 block">Start</label>
                            <input type="date" @bind="menu.StartDate" class="w-full bg-black border border-slate-800 rounded-2xl p-4 text-sm text-white" />
                        </div>
                        <div>
                            <label class="text-[10px] text-slate-500 uppercase font-bold mb-2 block">End</label>
                            <input type="date" @bind="menu.EndDate" class="w-full bg-black border border-slate-800 rounded-2xl p-4 text-sm text-white" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Right Column: Items *@
        <div class="col-span-12 lg:col-span-8 space-y-6">
            <div class="flex items-center justify-between px-4">
                <h2 class="text-xs font-black uppercase tracking-[0.2em] text-slate-400">Scheduled Offerings</h2>
                <select @onchange="AddRecipeToMenu" class="bg-[#111] border border-slate-800 rounded-xl p-3 text-[10px] font-black uppercase tracking-widest text-emerald-500 outline-none cursor-pointer">
                    <option value="0">＋ Add Recipe to Menu</option>
                    @foreach (var r in availableRecipes) { <option value="@r.Id">@r.Name</option> }
                </select>
            </div>

            @foreach (var item in menu.Items)
            {
                <div class="bg-[#111] border border-slate-800 rounded-3xl overflow-hidden shadow-lg border-l-4 border-l-emerald-500">
                    <div class="bg-white/5 px-6 py-4 border-b border-slate-800 flex justify-between items-center">
                        <span class="text-white font-black text-lg italic uppercase">@item.Recipe?.Name</span>
                        <button @onclick="() => menu.Items.Remove(item)" class="text-[10px] text-red-500 font-black uppercase tracking-widest">Remove Item</button>
                    </div>
                    
                    <div class="p-6 space-y-8">
                        @* Availability & Times *@
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div class="space-y-3">
                                <p class="text-[9px] text-emerald-500 uppercase font-black">Scheduling Override</p>
                                <div class="grid grid-cols-2 gap-2">
                                    <input type="date" @bind="item.StartDate" class="bg-black border border-slate-800 rounded-lg p-2 text-[10px] text-white" />
                                    <input type="date" @bind="item.EndDate" class="bg-black border border-slate-800 rounded-lg p-2 text-[10px] text-white" />
                                </div>
                                <div class="pt-2">
                                    <div class="flex justify-between items-center mb-2">
                                        <span class="text-[9px] text-slate-500 uppercase font-bold">Daily Slots</span>
                                        <button @onclick="() => AddTimeframe(item)" class="text-[8px] text-emerald-500 font-black">＋ Add Slot</button>
                                    </div>
                                    @foreach(var tf in item.Timeframes) {
                                        <div class="flex gap-2 mb-1">
                                            <input @bind="tf.Name" placeholder="Lunch" class="flex-1 bg-black border border-slate-800 rounded p-1.5 text-[10px]" />
                                            <input @bind="tf.TimeRange" placeholder="11a-2p" class="flex-1 bg-black border border-slate-800 rounded p-1.5 text-[10px]" />
                                            <button @onclick="() => item.Timeframes.Remove(tf)" class="text-slate-600 hover:text-red-500">✕</button>
                                        </div>
                                    }
                                </div>
                            </div>

                            @* Pricing / Sizes *@
                            <div class="space-y-4">
                                <div class="flex justify-between items-center">
                                    <p class="text-[9px] text-emerald-500 uppercase font-black">Sizes & Pricing</p>
                                    <button @onclick="() => AddSize(item)" class="bg-emerald-500/10 text-emerald-500 px-3 py-1 rounded text-[8px] font-black uppercase border border-emerald-500/20">Add Size</button>
                                </div>
                                
                                @foreach(var size in item.Sizes) {
                                    <div class="bg-black/40 p-4 rounded-2xl border border-slate-800 space-y-3">
                                        <div class="flex gap-2">
                                            <input @bind="size.Name" placeholder="Size (e.g. Small)" class="flex-1 bg-[#111] border border-slate-800 rounded-lg p-2 text-xs font-bold text-white" />
                                            <div class="relative w-24">
                                                <span class="absolute left-3 top-2 text-slate-500 text-xs">$</span>
                                                <input type="number" @bind="size.BasePrice" class="w-full bg-[#111] border border-slate-800 rounded-lg p-2 pl-6 text-xs font-mono text-emerald-400" />
                                            </div>
                                            <button @onclick="() => item.Sizes.Remove(size)" class="text-slate-700">✕</button>
                                        </div>

                                        @* Options under this size *@
                                        <div class="pl-4 border-l border-slate-800 space-y-2">
                                            @foreach(var opt in size.Options) {
                                                <div class="flex gap-2 items-center">
                                                    <input @bind="opt.Name" placeholder="Option (Add Chicken)" class="flex-1 bg-transparent border-b border-slate-800 p-1 text-[10px]" />
                                                    <div class="flex items-center gap-1">
                                                        <span class="text-[8px] text-slate-600">+$</span>
                                                        <input type="number" @bind="opt.AddOnPrice" class="w-12 bg-transparent border-b border-slate-800 text-[10px] font-mono text-blue-400" />
                                                    </div>
                                                    <button @onclick="() => size.Options.Remove(opt)" class="text-[10px] text-slate-700">✕</button>
                                                </div>
                                            }
                                            <button @onclick="() => AddOption(size)" class="text-[8px] text-blue-500 font-black uppercase tracking-widest mt-1">＋ Add Option</button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int OwnerId { get; set; }
    [Parameter] public int? MenuId { get; set; }

    private PPP_Menu menu = new();
    private List<PPP_Recipe> availableRecipes = new();
    private List<ToastItem> toasts = new();

    protected override async Task OnInitializedAsync()
    {
        availableRecipes = await Db.PPP_Recipes.AsNoTracking().Where(r => r.OwnerId == OwnerId).OrderBy(r => r.Name).ToListAsync();

        if (MenuId.HasValue) {
            var existing = await Db.Set<PPP_Menu>()
                .Include(m => m.Items).ThenInclude(i => i.Recipe)
                .Include(m => m.Items).ThenInclude(i => i.Timeframes)
                .Include(m => m.Items).ThenInclude(i => i.Sizes).ThenInclude(s => s.Options)
                .FirstOrDefaultAsync(m => m.Id == MenuId.Value);
            if (existing != null) menu = existing;
        } else {
            menu.OwnerId = OwnerId;
        }
    }

    private void AddRecipeToMenu(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int rid) && rid > 0) {
            var recipe = availableRecipes.FirstOrDefault(r => r.Id == rid);
            if (recipe != null && !menu.Items.Any(i => i.RecipeId == rid)) {
                menu.Items.Add(new PPP_MenuItem { RecipeId = rid, Recipe = recipe, StartDate = menu.StartDate, EndDate = menu.EndDate });
            }
        }
    }

    private void AddTimeframe(PPP_MenuItem item) => item.Timeframes.Add(new PPP_MenuItemTimeframe { Name = "Dinner", TimeRange = "5:00 PM - 9:00 PM" });
    private void AddSize(PPP_MenuItem item) => item.Sizes.Add(new PPP_MenuItemSize { Name = "Standard", BasePrice = 10.00 });
    private void AddOption(PPP_MenuItemSize size) => size.Options.Add(new PPP_MenuItemOption { Name = "Extra Protein", AddOnPrice = 3.00 });

    private async Task SaveMenu()
    {
        if (string.IsNullOrWhiteSpace(menu.Name)) { await ShowToast("Name required", true); return; }
        try {
            await using var db = await DbFactory.CreateDbContextAsync();
            foreach(var item in menu.Items) item.Recipe = null; // Prevent recipe re-save

            if (menu.Id == 0) db.Set<PPP_Menu>().Add(menu);
            else db.Entry(menu).State = EntityState.Modified;

            // Tracking logic for children
            foreach(var item in menu.Items) {
                if (item.Id == 0) db.Add(item); else db.Entry(item).State = EntityState.Modified;
                foreach(var sz in item.Sizes) {
                    if (sz.Id == 0) db.Add(sz); else db.Entry(sz).State = EntityState.Modified;
                    foreach(var opt in sz.Options) {
                        if (opt.Id == 0) db.Add(opt); else db.Entry(opt).State = EntityState.Modified;
                    }
                }
                foreach(var tf in item.Timeframes) {
                    if (tf.Id == 0) db.Add(tf); else db.Entry(tf).State = EntityState.Modified;
                }
            }

            await db.SaveChangesAsync();
            _ = ShowToast("Menu Saved Successfully");
            await Task.Delay(1000);
            Nav.NavigateTo($"/ppp-owner-admin");
        } catch (Exception ex) {
            await ShowToast($"Save Error: {ex.Message}", true);
        }
    }

    private async Task ShowToast(string msg, bool isError = false) {
        var toast = new ToastItem { Message = msg, IsError = isError };
        toasts.Add(toast); StateHasChanged();
        await Task.Delay(4000); toasts.Remove(toast); StateHasChanged();
    }
    private class ToastItem { public string Message { get; set; } = ""; public bool IsError { get; set; } }
}