@page "/ppp-menu-editor/{OwnerId:int}/{MenuId:int?}"
@using Dashboard
@using Dashboard.Components
@using Dashboard.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Forms
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#050505] text-slate-200 p-4 md:p-8 font-sans antialiased pb-40">
    <PPPAdminNav CurrentPage="Menu Architect" />

    @* Notification Stack *@
    <div class="fixed top-24 right-6 z-[100] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950 border-red-500 text-red-200" : "bg-emerald-950 border-emerald-500 text-emerald-200") backdrop-blur-md">
                <div class="flex items-center gap-3">
                    <span class="text-lg">@(toast.IsError ? "✕" : "✓")</span>
                    <span class="text-xs font-bold uppercase tracking-widest">@toast.Message</span>
                </div>
            </div>
        }
    </div>

    <div class="max-w-7xl mx-auto mb-10 flex justify-between items-start">
        <div>
            <h1 class="text-4xl font-black tracking-tighter text-white uppercase italic">Menu Architect</h1>
            <p class="text-slate-500 text-sm uppercase tracking-[0.2em] mt-1">Design scheduling and pricing tiers</p>
        </div>
        <div class="flex gap-4">
            @if (menu.Id != 0) {
                <button @onclick="DuplicateWholeMenu" class="bg-blue-600/10 hover:bg-blue-600 text-blue-500 hover:text-white px-6 py-4 rounded-2xl font-black text-xs uppercase tracking-[0.2em] border border-blue-500/20 transition-all active:scale-95">
                    Duplicate Entire Menu
                </button>
            }
        </div>
    </div>

    <div class="max-w-7xl mx-auto grid grid-cols-12 gap-8">
        @* Sidebar: Identity & Publishing *@
        <div class="col-span-12 lg:col-span-4 space-y-6">
            <div class="bg-[#111] border border-slate-800 rounded-3xl p-8 shadow-xl">
                <h2 class="text-xs font-black uppercase tracking-[0.2em] text-emerald-500 mb-6">Menu Identity</h2>
                <div class="space-y-6">
                    <div>
                        <label class="text-[10px] text-slate-500 uppercase font-bold mb-2 block">Menu Name</label>
                        <input @bind="menu.Name" placeholder="e.g. Week of April 13th" class="w-full bg-black border border-slate-800 rounded-2xl p-4 text-sm focus:border-emerald-500 outline-none" />
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="text-[10px] text-slate-500 uppercase font-bold mb-2 block">Global Start</label>
                            <input type="date" value="@menu.StartDate.ToString("yyyy-MM-dd")" @onchange="OnMenuStartChanged" class="w-full bg-black border border-slate-800 rounded-2xl p-4 text-sm text-white" />
                        </div>
                        <div>
                            <label class="text-[10px] text-slate-500 uppercase font-bold mb-2 block">Global End</label>
                            <input type="date" @bind="menu.EndDate" class="w-full bg-black border border-slate-800 rounded-2xl p-4 text-sm text-white" />
                        </div>
                    </div>

                    <div class="pt-6 border-t border-white/5">
                        <label class="flex items-center gap-4 cursor-pointer group">
                            <div class="relative">
                                <input type="checkbox" @bind="menu.IsPublished" class="sr-only peer" />
                                <div class="w-12 h-6 bg-slate-800 rounded-full peer peer-checked:bg-emerald-600 transition-colors"></div>
                                <div class="absolute left-1 top-1 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-6"></div>
                            </div>
                            <div>
                                <span class="text-[10px] font-black uppercase tracking-widest block @(menu.IsPublished ? "text-emerald-500" : "text-slate-500")">
                                    @(menu.IsPublished ? "Published / Live" : "Draft Mode")
                                </span>
                                <p class="text-[8px] text-slate-600 uppercase">Controls visibility on customer app</p>
                            </div>
                        </label>
                    </div>
                </div>
            </div>
        </div>

        @* Main Content *@
        <div class="col-span-12 lg:col-span-8 space-y-6">
            <div class="flex items-center justify-between px-4">
                <h2 class="text-xs font-black uppercase tracking-[0.2em] text-slate-400">Scheduled Recipes (@menu.Items.Count)</h2>
                <select @onchange="AddRecipeToMenu" class="bg-emerald-600 hover:bg-emerald-500 text-white px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest outline-none cursor-pointer transition-all shadow-lg">
                    <option value="0">＋ Add Recipe to Menu</option>
                    @foreach (var r in availableRecipes) { <option value="@r.Id">@r.Name</option> }
                </select>
            </div>

            <div class="space-y-4">
                @foreach (var item in menu.Items)
                {
                    <div class="bg-[#111] border border-slate-800 rounded-[2rem] p-6 flex flex-col md:flex-row items-center gap-8 group hover:border-emerald-500/50 transition-all shadow-lg relative">
                        <div class="w-full md:w-48 aspect-square rounded-2xl bg-black border border-slate-800 flex items-center justify-center overflow-hidden">
                            @if (item.Recipe?.ImageId != null) {
                                <img src="/db-images-ppp/@item.Recipe.ImageId" class="w-full h-full object-contain" />
                            } else {
                                <span class="text-4xl opacity-20">🍲</span>
                            }
                        </div>
                        
                        <div class="flex-1">
                            <p class="text-sm text-emerald-500 font-black uppercase tracking-widest mb-1">@item.StartDate.ToString("dddd, MMMM d, yyyy")</p>
                            <h3 class="text-2xl font-black text-white uppercase italic tracking-tight">@(item.Recipe?.Name ?? "PICK A RECIPE")</h3>
                            
                            <div class="flex flex-wrap gap-4 mt-4">
                                <div class="bg-black/40 px-3 py-1.5 rounded-lg border border-slate-800">
                                    <span class="text-[8px] text-slate-500 uppercase font-black block">Sizes</span>
                                    <span class="text-xs text-white font-bold">@item.Sizes.Count Types</span>
                                </div>
                                <div class="bg-black/40 px-3 py-1.5 rounded-lg border border-slate-800">
                                    <span class="text-[8px] text-slate-500 uppercase font-black block">Slots</span>
                                    <span class="text-xs text-white font-bold">@item.Timeframes.Count Daily</span>
                                </div>
                            </div>
                        </div>

                        <div class="flex gap-2 shrink-0">
                            <button @onclick="() => DuplicateItem(item)" class="p-3 bg-white/5 hover:bg-blue-600 rounded-xl transition-all" title="Duplicate Settings">👯</button>
                            <button @onclick="() => OpenConfig(item)" class="p-3 bg-white/5 hover:bg-emerald-600 rounded-xl transition-all" title="Configure Details">⚙️</button>
                            <button @onclick="() => menu.Items.Remove(item)" class="p-3 bg-white/5 hover:bg-red-600 rounded-xl transition-all">✕</button>
                        </div>
                    </div>
                }
            </div>

            @if(menu.Items.Any())
            {
                <div class="pt-12 pb-20 flex justify-center">
                    <button @onclick="SaveMenu" class="w-full max-w-xl bg-emerald-600 hover:bg-emerald-500 text-white py-6 rounded-[2rem] font-black text-xs uppercase tracking-[0.5em] transition-all shadow-[0_20px_50px_rgba(0,0,0,0.5)] active:scale-95 border border-emerald-400/20">
                        Save Menu
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@* Modal: Item Configuration Details *@
@if (activeItem != null)
{
    <div class="fixed inset-0 bg-black/95 backdrop-blur-md z-[200] flex items-center justify-center p-4">
        <div class="bg-[#0a0a0a] w-full max-w-5xl rounded-[3rem] border border-slate-800 shadow-[0_0_100px_rgba(0,0,0,0.9)] overflow-hidden animate-in zoom-in duration-300">
            <div class="p-8 bg-white/5 border-b border-slate-800 flex justify-between items-center">
                <div>
                    <select @onchange="ChangeRecipeForItem" class="bg-black border border-slate-800 rounded-xl p-3 text-lg font-black text-emerald-500 uppercase italic outline-none">
                        <option value="0">-- SELECT RECIPE --</option>
                        @foreach (var r in availableRecipes) { 
                            <option value="@r.Id" selected="@(activeItem.RecipeId == r.Id)">@r.Name</option> 
                        }
                    </select>
                </div>
                <button @onclick="() => activeItem = null" class="text-slate-500 hover:text-white text-4xl font-light">&times;</button>
            </div>
            
            <div class="p-10 grid grid-cols-1 md:grid-cols-2 gap-12 max-h-[60vh] overflow-y-auto">
                @* LEFT: Scheduling *@
                <div class="space-y-8">
                    <div>
                        <p class="text-xs text-emerald-500 font-black uppercase tracking-[0.2em] mb-4">Availability Window</p>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="text-[9px] text-slate-500 uppercase font-black block mb-2">Start Date</label>
                                <input type="date" value="@activeItem.StartDate.ToString("yyyy-MM-dd")" @onchange="(e) => OnItemStartChanged(e, activeItem)" class="w-full bg-black border border-slate-800 rounded-2xl p-4 text-sm text-white" />
                            </div>
                            <div>
                                <label class="text-[9px] text-slate-500 uppercase font-black block mb-2">End Date</label>
                                <input type="date" @bind="activeItem.EndDate" class="w-full bg-black border border-slate-800 rounded-2xl p-4 text-sm text-white" />
                            </div>
                        </div>
                    </div>

                    <div>
                        <div class="flex justify-between items-center mb-4">
                            <p class="text-xs text-emerald-500 font-black uppercase tracking-[0.2em]">Time Slots</p>
                            <button @onclick="() => AddTimeframe(activeItem)" class="text-[9px] bg-emerald-600 text-white px-4 py-1.5 rounded-full font-black uppercase tracking-widest">＋ Add Slot</button>
                        </div>
                        <div class="grid grid-cols-2 gap-2">
                            @foreach(var tf in activeItem.Timeframes) {
                                <div class="flex items-center bg-[#111] p-1.5 rounded-xl border border-slate-800">
                                    <input @bind="tf.Name" placeholder="e.g. Dinner" class="flex-1 bg-transparent px-3 text-[10px] font-black uppercase outline-none" />
                                    <button @onclick="() => activeItem.Timeframes.Remove(tf)" class="text-red-900 hover:text-red-500 px-3 font-bold">✕</button>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                @* RIGHT: Pricing & Add-ons *@
                <div class="space-y-8">
                    <div class="flex justify-between items-center mb-4">
                        <div class="flex items-center gap-4">
                            <p class="text-xs text-blue-500 font-black uppercase tracking-[0.2em]">Sizes & Add-ons</p>
                            <button @onclick="ClearAllOptions" class="text-[8px] bg-red-900/20 text-red-500 px-3 py-1 rounded-full border border-red-900/20 font-black uppercase hover:bg-red-600 hover:text-white transition-colors" title="Remove all options from every size">Clear All Options</button>
                        </div>
                        <button @onclick="() => AddSize(activeItem)" class="text-[9px] bg-blue-600 text-white px-4 py-1.5 rounded-full font-black uppercase tracking-widest">＋ Add Size</button>
                    </div>

                    <div class="space-y-4">
                        @foreach(var size in activeItem.Sizes) {
                            <div class="bg-[#111] p-6 rounded-3xl border border-slate-800">
                                <div class="flex gap-3 mb-4">
                                    <input @bind="size.Name" placeholder="Size Name" class="flex-1 bg-black border border-slate-800 rounded-xl p-3 text-xs font-black uppercase text-white" />
                                    <div class="relative w-28">
                                        <span class="absolute left-3 top-3.5 text-slate-500 text-xs">$</span>
                                        <input type="number" @bind="size.BasePrice" class="w-full bg-black border border-slate-800 rounded-xl p-3 pl-7 text-xs font-mono text-emerald-400" />
                                    </div>
                                    <button @onclick="() => activeItem.Sizes.Remove(size)" class="text-slate-700 hover:text-red-500">✕</button>
                                </div>

                                <div class="pl-4 border-l-2 border-white/5 space-y-2">
                                    @foreach(var opt in size.Options) {
                                        <div class="flex gap-2 items-center">
                                            <input @bind="opt.Name" placeholder="Option" class="flex-1 bg-transparent border-b border-slate-800 p-1 text-[10px] text-slate-300" />
                                            <div class="flex items-center gap-1">
                                                <span class="text-[8px] text-slate-600">+$</span>
                                                <input type="number" @bind="opt.AddOnPrice" class="w-14 bg-transparent border-b border-slate-800 text-[10px] font-mono text-blue-400" />
                                            </div>
                                            <button @onclick="() => CopyOptionToAll(activeItem, opt)" class="text-[14px] p-1" title="Copy to all other sizes">📋</button>
                                            <button @onclick="() => size.Options.Remove(opt)" class="text-slate-800">✕</button>
                                        </div>
                                    }
                                    <button @onclick="() => AddOption(size)" class="text-[9px] text-blue-500 font-black uppercase tracking-widest mt-2 hover:text-blue-400">＋ New Option</button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            
            <div class="p-8 bg-black border-t border-slate-800 flex justify-end">
                <button @onclick="() => activeItem = null" class="bg-emerald-600 text-white px-12 py-4 rounded-2xl font-black text-xs uppercase tracking-widest transition-all">Confirm Configuration</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int OwnerId { get; set; }
    [Parameter] public int? MenuId { get; set; }

    private PPP_Menu menu = new();
    private List<PPP_Recipe> availableRecipes = new();
    private List<ToastItem> toasts = new();
    private PPP_MenuItem? activeItem;

    protected override async Task OnInitializedAsync() {
        availableRecipes = await Db.PPP_Recipes.AsNoTracking().Where(r => r.OwnerId == OwnerId).OrderBy(r => r.Name).ToListAsync();
        if (MenuId.HasValue) {
            menu = await Db.Set<PPP_Menu>()
                .AsNoTracking()
                .Include(m => m.Items).ThenInclude(i => i.Recipe)
                .Include(m => m.Items).ThenInclude(i => i.Timeframes)
                .Include(m => m.Items).ThenInclude(i => i.Sizes).ThenInclude(s => s.Options)
                .FirstOrDefaultAsync(m => m.Id == MenuId.Value) ?? new() { OwnerId = OwnerId };
        } else {
            menu.OwnerId = OwnerId; menu.StartDate = DateTime.Today; menu.EndDate = DateTime.Today;
        }
    }

    private void OnMenuStartChanged(ChangeEventArgs e) { if (DateTime.TryParse(e.Value?.ToString(), out var d)) { menu.StartDate = d; menu.EndDate = d; } }
    private void OnItemStartChanged(ChangeEventArgs e, PPP_MenuItem item) { if (DateTime.TryParse(e.Value?.ToString(), out var d)) { item.StartDate = d; item.EndDate = d; } }

    private void AddRecipeToMenu(ChangeEventArgs e) {
        if (int.TryParse(e.Value?.ToString(), out int rid) && rid > 0) {
            var recipe = availableRecipes.FirstOrDefault(r => r.Id == rid);
            if (recipe != null) {
                var newItem = new PPP_MenuItem { RecipeId = rid, Recipe = recipe, StartDate = menu.StartDate, EndDate = menu.EndDate };
                menu.Items.Add(newItem); activeItem = newItem;
            }
        }
    }

    private void ChangeRecipeForItem(ChangeEventArgs e) {
        if (activeItem != null && int.TryParse(e.Value?.ToString(), out int rid)) {
            if (rid == 0) { activeItem.RecipeId = 0; activeItem.Recipe = null; }
            else {
                var recipe = availableRecipes.FirstOrDefault(r => r.Id == rid);
                if (recipe != null) { activeItem.RecipeId = rid; activeItem.Recipe = recipe; }
            }
        }
    }

    private void DuplicateItem(PPP_MenuItem original) {
        var clone = new PPP_MenuItem {
            RecipeId = 0, Recipe = null, 
            StartDate = original.StartDate, EndDate = original.EndDate,
            Timeframes = original.Timeframes.Select(t => new PPP_MenuItemTimeframe { Name = t.Name }).ToList(),
            Sizes = original.Sizes.Select(s => new PPP_MenuItemSize { Name = s.Name, BasePrice = s.BasePrice,
                Options = s.Options.Select(o => new PPP_MenuItemOption { Name = o.Name, AddOnPrice = o.AddOnPrice }).ToList()
            }).ToList()
        };
        menu.Items.Add(clone); activeItem = clone;
    }

    private void DuplicateWholeMenu() {
        menu.Id = 0; menu.Name += " (COPY)";
        foreach(var item in menu.Items) {
            item.Id = 0; item.MenuId = 0;
            foreach(var tf in item.Timeframes) tf.Id = 0;
            foreach(var sz in item.Sizes) {
                sz.Id = 0; foreach(var opt in sz.Options) opt.Id = 0;
            }
        }
        _ = ShowToast("Local Copy Created. Click Save to publish.");
    }

    private void CopyOptionToAll(PPP_MenuItem item, PPP_MenuItemOption template) {
        foreach(var size in item.Sizes) {
            if (!size.Options.Any(o => o.Name.Equals(template.Name, StringComparison.OrdinalIgnoreCase))) {
                size.Options.Add(new PPP_MenuItemOption { Name = template.Name, AddOnPrice = template.AddOnPrice });
            }
        }
        _ = ShowToast("Option synced across all sizes.");
    }

    private void ClearAllOptions() {
        if (activeItem == null) return;
        foreach(var size in activeItem.Sizes) size.Options.Clear();
        _ = ShowToast("All options cleared.");
    }

    private void OpenConfig(PPP_MenuItem item) => activeItem = item;
    private void AddTimeframe(PPP_MenuItem item) => item.Timeframes.Add(new PPP_MenuItemTimeframe { Name = "Lunch" });
    private void AddSize(PPP_MenuItem item) {
        var newSize = new PPP_MenuItemSize { Name = "Standard", BasePrice = 10.00 };
        var existing = item.Sizes.SelectMany(s => s.Options).GroupBy(o => o.Name).Select(g => g.First());
        foreach(var opt in existing) newSize.Options.Add(new PPP_MenuItemOption { Name = opt.Name, AddOnPrice = opt.AddOnPrice });
        item.Sizes.Add(newSize);
    }
    private void AddOption(PPP_MenuItemSize size) => size.Options.Add(new PPP_MenuItemOption { Name = "New Option", AddOnPrice = 2.00 });

    private async Task SaveMenu() {
        if (string.IsNullOrWhiteSpace(menu.Name)) { await ShowToast("Name required", true); return; }
        if (menu.Items.Any(i => i.RecipeId == 0)) { await ShowToast("All items must have a recipe selected", true); return; }
        
        try {
            await using var db = await DbFactory.CreateDbContextAsync();
            db.ChangeTracker.Clear();

            PPP_Menu? dbMenu = null;
            if (menu.Id != 0) {
                dbMenu = await db.Set<PPP_Menu>()
                    .Include(m => m.Items).ThenInclude(i => i.Timeframes)
                    .Include(m => m.Items).ThenInclude(i => i.Sizes).ThenInclude(s => s.Options)
                    .FirstOrDefaultAsync(m => m.Id == menu.Id);
            }

            if (dbMenu != null) {
                db.RemoveRange(dbMenu.Items);
                await db.SaveChangesAsync(); 
                db.Entry(dbMenu).CurrentValues.SetValues(menu);
            } else {
                dbMenu = new PPP_Menu { OwnerId = OwnerId };
                db.Entry(dbMenu).CurrentValues.SetValues(menu);
                db.Add(dbMenu);
            }

            foreach(var uiItem in menu.Items) {
                uiItem.Id = 0;
                uiItem.MenuId = 0; 
                uiItem.Recipe = null; 
                foreach(var tf in uiItem.Timeframes) tf.Id = 0;
                foreach(var sz in uiItem.Sizes) {
                    sz.Id = 0;
                    foreach(var opt in sz.Options) opt.Id = 0;
                }
                dbMenu.Items.Add(uiItem);
            }

            await db.SaveChangesAsync();
            Nav.NavigateTo($"/ppp-menu-manager/{OwnerId}", forceLoad: true);
        } catch (Exception ex) {
            await ShowToast($"Save Error: {ex.InnerException?.Message ?? ex.Message}", true);
        }
    }

    private async Task ShowToast(string msg, bool isError = false) {
        var toast = new ToastItem { Message = msg, IsError = isError };
        toasts.Add(toast); StateHasChanged();
        await Task.Delay(4000); toasts.Remove(toast); StateHasChanged();
    }
    private class ToastItem { public string Message { get; set; } = ""; public bool IsError { get; set; } }
}