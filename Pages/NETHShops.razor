@page "/admin/neth-shops"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using System.Text.Json
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

@* Fail-safe FontAwesome Loader *@
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<style>
    .neth-shop-card {
        background: #25262b;
        border-radius: 1rem;
        border: 1px solid #374151;
        overflow: hidden;
        position: relative;
        transition: all 0.3s ease;
        min-height: 120px;
        display: flex;
    }

    .neth-shop-card:hover {
        border-color: #4b5563;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.5);
    }

    /* Logo Container: Full Height, Auto Width */
    .shop-logo-frame {
        height: 120px;
        background: #1a1b1e;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 8px;
        border-right: 1px solid #374151;
    }

    .shop-logo-frame img {
        height: 100%;
        width: auto;
        max-width: 200px;
        object-fit: contain;
        border-radius: 4px;
    }

    /* Hover Action Container */
    .shop-actions {
        position: absolute;
        top: 1rem;
        right: 1rem;
        display: flex;
        gap: 0.5rem;
        opacity: 0;
        transition: opacity 0.2s ease;
        z-index: 10;
    }
    .neth-shop-card:hover .shop-actions { opacity: 1; }

    .action-btn {
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 0.75rem;
        transition: all 0.2s;
        color: white !important;
        backdrop-filter: blur(4px);
    }

    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #374151; border-radius: 10px; }
</style>

@if (isAuthorized)
{
    <div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex font-sans">
        <NETHAdminSidebar />

        <div class="flex-1 p-8">
            <div class="max-w-5xl mx-auto">
                <div class="flex justify-between items-end mb-10">
                    <div>
                        <h2 class="text-3xl font-black text-white uppercase tracking-tighter italic">Shop Registry</h2>
                        <p class="text-[10px] text-gray-500 font-mono uppercase tracking-[0.2em]">Live Modules: @allShops.Count</p>
                    </div>
                    <div class="flex gap-3">
                        <button @onclick="RepairDatabase" class="bg-orange-600/10 hover:bg-orange-600 text-orange-500 hover:text-white text-[9px] font-black uppercase px-4 py-3 rounded-lg border border-orange-500/20 transition">Schema_Sync</button>
                        <button @onclick="OpenCreateModal" class="bg-blue-600 hover:bg-blue-500 text-white text-[10px] font-black uppercase px-6 py-3 rounded-lg shadow-xl transition tracking-widest">＋ New Location</button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="mb-6 p-4 rounded-lg font-mono text-[10px] uppercase flex justify-between items-center @(statusMessage.Contains("ERR") ? "bg-red-900/20 text-red-400 border border-red-500/30" : "bg-blue-900/20 text-blue-400 border border-blue-500/30")">
                        <span>@statusMessage</span>
                        <button @onclick='() => statusMessage = ""' class="opacity-50 hover:opacity-100 text-xl">&times;</button>
                    </div>
                }

                @if (isLoading)
                {
                    <div class="text-center py-20 animate-pulse font-black text-gray-600 uppercase tracking-widest">Initialising_Registry...</div>
                }
                else
                {
                    <div class="grid gap-6">
                        @foreach (var shop in allShops)
                        {
                            <div class="neth-shop-card group">
                                @* LOGO SECTION: Brand Color Outline applied here *@
                                <div class="shop-logo-frame">
                                    @if (shop.LogoId.HasValue)
                                    {
                                        <img src="/neth-images/@shop.LogoId" 
                                             style="border: 2px solid @shop.BrandColor; box-shadow: 0 0 15px @(shop.BrandColor)44;" 
                                             alt="Logo" />
                                    }
                                    else
                                    {
                                        <div class="w-20 h-20 rounded flex items-center justify-center text-3xl" 
                                             style="background: @(shop.BrandColor)22; color: @shop.BrandColor; border: 2px solid @shop.BrandColor;">
                                            <i class="fa-solid fa-shop"></i>
                                        </div>
                                    }
                                </div>

                                @* INFO SECTION *@
                                <div class="p-6 flex-1 flex flex-col justify-center">
                                    <h3 class="text-xl font-black text-white uppercase tracking-tight">@shop.BusinessName</h3>
                                    <div class="flex gap-4 mt-2 font-mono text-[9px] uppercase tracking-widest">
                                        <span style="color: @shop.BrandColor">@shop.UrlKey</span>
                                        <span class="text-gray-600">Ref_ID: #@shop.Id</span>
                                    </div>
                                </div>

                                @* HOVER ACTIONS *@
                                <div class="shop-actions">
                                    <button @onclick="() => OpenEditModal(shop)" class="action-btn bg-blue-600/20 hover:bg-blue-600 border border-blue-500/30">
                                        <i class="fa-solid fa-gear text-xs"></i>
                                    </button>
                                    <button @onclick="() => DeleteShop(shop.Id, shop.LogoId)" class="action-btn bg-red-600/20 hover:bg-red-600 border border-red-500/30">
                                        <i class="fa-solid fa-trash-can text-xs"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@if (showModal && editingShop != null)
{
    <div class="fixed inset-0 bg-black/95 backdrop-blur-md z-50 flex items-center justify-center p-4">
        <div class="bg-[#25262b] w-full max-w-lg rounded-2xl border border-gray-700 shadow-2xl overflow-hidden animate-in zoom-in-95 duration-200">
            <div class="p-5 border-b border-gray-800 flex justify-between items-center bg-black/20">
                <h3 class="text-white font-black uppercase text-xs tracking-[0.3em]">
                    <i class="fa-solid fa-sliders mr-2 text-blue-500"></i>
                    @(editingShop.Id == 0 ? "Establish New Shop" : "Modify Configuration")
                </h3>
                <button @onclick="CloseModal" class="text-gray-500 hover:text-white text-2xl">&times;</button>
            </div>
            
            <div class="p-8 space-y-6">
                <div class="space-y-4">
                    <div>
                        <label class="text-[9px] font-black uppercase text-gray-500 mb-1.5 block ml-1">Business Name</label>
                        <input @bind="editingShop.BusinessName" class="w-full bg-black/40 border border-gray-700 rounded-xl p-3 text-white outline-none focus:border-blue-500 transition-colors" placeholder="e.g. Downtown Barber Co." />
                    </div>
                    
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="text-[9px] font-black uppercase text-gray-500 mb-1.5 block ml-1">URL Extension</label>
                            <input @bind="editingShop.UrlKey" class="w-full bg-black/40 border border-gray-700 rounded-xl p-3 text-white outline-none focus:border-blue-500 font-mono" placeholder="downtown" />
                        </div>
                        <div>
                            <label class="text-[9px] font-black uppercase text-gray-500 mb-1.5 block ml-1">Brand Palette</label>
                            <div class="flex gap-2">
                                <input type="color" @bind="editingShop.BrandColor" class="h-11 w-14 bg-transparent border-none cursor-pointer" />
                                <input @bind="editingShop.BrandColor" class="w-full bg-black/40 border border-gray-700 rounded-xl p-3 text-xs font-mono text-white outline-none uppercase" />
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="text-[9px] font-black uppercase text-gray-500 mb-2 block ml-1">Logo Asset</label>
                        <div class="flex items-center gap-4 p-5 bg-black/40 border border-dashed border-gray-700 rounded-2xl group hover:border-blue-500/50 transition-colors">
                            <div class="w-16 h-16 bg-gray-900 rounded-lg flex items-center justify-center overflow-hidden border border-gray-800">
                                @if (logoBuffer != null) { <img src="data:@logoContentType;base64,@Convert.ToBase64String(logoBuffer)" class="w-full h-full object-contain" /> }
                                else if (editingShop.LogoId.HasValue) { <img src="/neth-images/@editingShop.LogoId" class="w-full h-full object-contain" /> }
                                else { <i class="fa-solid fa-cloud-arrow-up text-gray-700 text-xl"></i> }
                            </div>
                            <div class="flex-1">
                                <InputFile OnChange="HandleFileSelected" class="text-[10px] text-gray-500 cursor-pointer file:bg-blue-600/10 file:border-0 file:text-blue-500 file:rounded-md file:px-3 file:py-1 file:mr-3 hover:file:bg-blue-600 hover:file:text-white" />
                                <p class="text-[8px] text-gray-700 uppercase mt-2 font-bold tracking-tighter">Recommended: Transparent PNG (2MB Max)</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="p-5 bg-black/20 border-t border-gray-800 flex justify-end gap-3">
                <button @onclick="CloseModal" class="text-[10px] text-gray-600 uppercase px-6 py-2 font-black hover:text-white transition">Cancel</button>
                <button @onclick="SaveShop" class="bg-blue-600 hover:bg-blue-500 text-white text-[10px] uppercase px-10 py-3 rounded-xl font-black shadow-2xl transition tracking-[0.1em]">
                    @(isSaving ? "Uploading..." : "Commit_Registry")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool isAuthorized = false, isLoading = true, isSaving = false, showModal = false;
    private List<NETH_Shop> allShops = new();
    private NETH_Shop? editingShop;
    private string statusMessage = "";

    private byte[]? logoBuffer;
    private string logoContentType = "";
    private string logoFileName = "";

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "neth_session");
            if (string.IsNullOrEmpty(json)) Nav.NavigateTo("/nethaircut");
            else { isAuthorized = true; await LoadAllShops(); isLoading = false; StateHasChanged(); }
        }
    }

    private async Task LoadAllShops() { 
        try { allShops = await Db.NETH_Shops.AsNoTracking().ToListAsync(); StateHasChanged(); } catch { } 
    }

    private async Task RepairDatabase() {
        try {
            await Db.Database.ExecuteSqlRawAsync(@"
                CREATE TABLE IF NOT EXISTS ""NETH_StoredImages"" (
                    ""Id"" SERIAL PRIMARY KEY,
                    ""Data"" BYTEA NOT NULL,
                    ""ContentType"" TEXT NOT NULL,
                    ""FileName"" TEXT NOT NULL,
                    ""Category"" TEXT NOT NULL DEFAULT 'General',
                    ""AltText"" TEXT,
                    ""UploadedAt"" TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP
                );");
            statusMessage = "DB_SYNC: StoredImages Table Verified.";
        } catch (Exception ex) { statusMessage = "ERR: " + ex.Message; }
    }

    private void OpenCreateModal() { 
        editingShop = new NETH_Shop { BrandColor = "#D2B48C", PhoneId = 1, StripeAccountId = "" }; 
        logoBuffer = null; showModal = true; 
    }
    
    private void OpenEditModal(NETH_Shop shop) { 
        editingShop = new NETH_Shop { 
            Id = shop.Id, 
            BusinessName = shop.BusinessName, 
            UrlKey = shop.UrlKey, 
            BrandColor = shop.BrandColor, 
            PhoneId = shop.PhoneId, 
            StripeAccountId = shop.StripeAccountId,
            LogoId = shop.LogoId
        }; 
        logoBuffer = null; showModal = true; 
    }

    private void CloseModal() { showModal = false; editingShop = null; logoBuffer = null; }

    private async Task HandleFileSelected(InputFileChangeEventArgs e) {
        try {
            var file = e.File;
            if (file == null) return;
            
            using var stream = file.OpenReadStream(2 * 1024 * 1024);
            logoBuffer = new byte[file.Size];
            await stream.ReadAsync(logoBuffer);
            logoContentType = file.ContentType;
            logoFileName = file.Name;
        } catch (Exception ex) { statusMessage = "ERR: File too large or invalid."; }
    }

    private async Task SaveShop() {
        if (editingShop == null || isSaving) return;
        isSaving = true;
        try {
            int? finalLogoId = editingShop.LogoId;

            if (logoBuffer != null) {
                if (editingShop.LogoId.HasValue) {
                    await Db.Database.ExecuteSqlRawAsync(@"DELETE FROM ""NETH_StoredImages"" WHERE ""Id"" = {0}", editingShop.LogoId.Value);
                }

                var newImg = new NETH_StoredImage {
                    Data = logoBuffer,
                    ContentType = logoContentType,
                    FileName = logoFileName,
                    Category = "ShopLogo",
                    UploadedAt = DateTime.UtcNow
                };
                Db.NETH_StoredImages.Add(newImg);
                await Db.SaveChangesAsync();
                finalLogoId = newImg.Id;
            }

            if (editingShop.Id == 0) {
                await Db.Database.ExecuteSqlRawAsync(
                    @"INSERT INTO ""NETH_Shops"" (""BusinessName"", ""UrlKey"", ""BrandColor"", ""StripeAccountId"", ""PhoneId"", ""LogoId"") 
                      VALUES ({0}, {1}, {2}, {3}, {4}, {5})", 
                    editingShop.BusinessName, editingShop.UrlKey, editingShop.BrandColor, editingShop.StripeAccountId, editingShop.PhoneId, finalLogoId
                );
            } else {
                await Db.Database.ExecuteSqlRawAsync(
                    @"UPDATE ""NETH_Shops"" SET ""BusinessName"" = {0}, ""UrlKey"" = {1}, ""BrandColor"" = {2}, ""StripeAccountId"" = {3}, ""LogoId"" = {4} 
                      WHERE ""Id"" = {5}", 
                    editingShop.BusinessName, editingShop.UrlKey, editingShop.BrandColor, editingShop.StripeAccountId, finalLogoId, editingShop.Id
                );
            }
            
            await LoadAllShops(); 
            CloseModal();
            statusMessage = "SUCCESS: Registry updated.";
        } catch (Exception ex) { statusMessage = "ERR: " + ex.Message; }
        finally { isSaving = false; }
    }

    private async Task DeleteShop(int id, int? logoId) { 
        if (await JS.InvokeAsync<bool>("confirm", "Delete shop? This cannot be undone.")) {
            if (logoId.HasValue) {
                await Db.Database.ExecuteSqlRawAsync(@"DELETE FROM ""NETH_StoredImages"" WHERE ""Id"" = {0}", logoId.Value);
            }
            await Db.Database.ExecuteSqlRawAsync(@"DELETE FROM ""NETH_Shops"" WHERE ""Id"" = {0}", id); 
            await LoadAllShops(); 
        } 
    }

    private bool IsDark(string hex) { 
        if (string.IsNullOrEmpty(hex) || !hex.StartsWith("#")) return true; 
        try { 
            var r = int.Parse(hex.Substring(1, 2), System.Globalization.NumberStyles.HexNumber); 
            var g = int.Parse(hex.Substring(3, 2), System.Globalization.NumberStyles.HexNumber); 
            var b = int.Parse(hex.Substring(5, 2), System.Globalization.NumberStyles.HexNumber); 
            return ((r * 299 + g * 587 + b * 114) / 1000) < 128; 
        } catch { return true; } 
    }
}