@page "/ppp-recipe-editor/{RecipeId:int?}"
@using Dashboard
@using Dashboard.Components
@using Dashboard.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Forms
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#0a0a0a] text-white p-6 font-black relative overflow-hidden">
    <PPPAdminNav CurrentPage="Recipe Architect" />

    @* Notification Stack *@
    <div class="fixed top-24 right-6 z-[100] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-2xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950 border-red-500 text-red-200" : "bg-emerald-950 border-emerald-500 text-emerald-200")">
                <div class="flex items-center gap-3">
                    <span>@(toast.IsError ? "❌" : "✅")</span>
                    <span class="text-xs uppercase tracking-widest">@toast.Message</span>
                </div>
            </div>
        }
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-6">
            @* Recipe Config *@
            <div class="bg-[#111] p-6 rounded-3xl border border-gray-800 shadow-xl">
                <div class="grid grid-cols-12 gap-6">
                    <div class="col-span-12 md:col-span-4">
                        <div class="aspect-square bg-black rounded-2xl border border-gray-800 flex items-center justify-center overflow-hidden relative group">
                            @if (recipe.ImageId.HasValue) {
                                <img src="/db-images-ppp/@recipe.ImageId" class="w-full h-full object-cover" />
                            } else {
                                <div class="text-center opacity-20"><span class="text-3xl block">📸</span></div>
                            }
                            <label class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition flex items-center justify-center cursor-pointer text-[9px] uppercase">
                                Upload Photo
                                <InputFile OnChange="HandleImageUpload" class="hidden" />
                            </label>
                        </div>
                    </div>
                    <div class="col-span-12 md:col-span-8 space-y-4">
                        <label class="text-[10px] text-gray-500 uppercase block tracking-widest">Recipe Name</label>
                        <input @bind="recipe.Name" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-orange-500 outline-none" />
                        <div class="grid grid-cols-3 gap-4">
                            <div>
                                <label class="text-[10px] text-orange-500 uppercase block tracking-widest">Servings</label>
                                <input type="number" @bind="recipe.Servings" @bind:event="oninput" class="w-full bg-black border border-orange-900/50 rounded-xl p-3 text-sm focus:border-orange-500 outline-none text-center font-mono" />
                            </div>
                            <div class="col-span-2">
                                <label class="text-[10px] text-gray-500 uppercase block tracking-widest">Serving Size</label>
                                <input @bind="recipe.ServingSize" placeholder="e.g. 12oz Bowl" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-orange-500 outline-none" />
                            </div>
                        </div>
                        <label class="text-[10px] text-gray-500 uppercase block tracking-widest">Recipe Owner</label>
                        <select @bind="recipe.OwnerId" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-orange-500 outline-none">
                            <option value="0" disabled>-- Select Owner --</option>
                            @foreach(var o in owners) { <option value="@o.Id">@o.BusinessName</option> }
                        </select>
                    </div>
                </div>
            </div>

            @foreach (var group in recipe.IngredientGroups.OrderBy(g => g.DisplayOrder))
            {
                <div class="bg-[#111] p-6 rounded-3xl border border-gray-800 shadow-lg">
                    <div class="flex justify-between items-center mb-6">
                        <input @bind="group.GroupName" class="bg-transparent border-b border-gray-800 text-orange-400 font-black focus:border-orange-500 outline-none" />
                        <button @onclick="() => recipe.IngredientGroups.Remove(group)" class="text-[9px] text-red-500 uppercase">Remove</button>
                    </div>
                    <div class="space-y-4">
                        @foreach (IngredientUIModel mapping in group.Ingredients.OfType<IngredientUIModel>())
                        {
                            <div class="bg-black/40 p-4 rounded-xl border @(mapping.IngredientId == 0 ? "border-blue-500/50" : "border-gray-800") relative">
                                <div class="grid grid-cols-12 gap-3 items-end">
                                    <div class="col-span-5 relative">
                                        <label class="text-[9px] text-gray-600 mb-1 block">Ingredient Search</label>
                                        <input @bind="mapping.IngredientName" 
                                            @oninput="(e) => SearchIng(e, mapping)" 
                                            @onblur="() => HandleBlur(mapping)"
                                            class="w-full bg-black border border-gray-800 rounded p-2 text-xs outline-none focus:border-blue-500" 
                                            placeholder="Type to search..." />
                                        @if (activeMapping == mapping && searchResults.Any()) {
                                            <div class="absolute z-50 w-full mt-1 bg-gray-900 border border-gray-700 rounded shadow-2xl max-h-40 overflow-y-auto">
                                                @foreach (var r in searchResults) {
                                                    <div @onclick="() => SelectIng(r, mapping)" class="p-2 text-[10px] hover:bg-orange-600 cursor-pointer">@r.Name (@r.Unit)</div>
                                                }
                                            </div>
                                        }
                                    </div>
                                    <div class="col-span-2">
                                        <label class="text-[8px] text-gray-600 uppercase mb-1">Qty</label>
                                        <input type="number" step="0.01" value="@mapping.Quantity" @oninput="(e) => UpdateQty(e, mapping)" class="w-full bg-black border border-gray-800 rounded p-2 text-xs text-center font-mono" />
                                    </div>
                                    <div class="col-span-2">
                                        <label class="text-[8px] text-gray-600 uppercase mb-1">Unit</label>
                                        <input value="@mapping.Unit" @onchange="(e) => UpdateUnit(e, mapping)" class="w-full bg-black border border-gray-800 rounded p-2 text-xs text-center" />
                                    </div>
                                    <div class="col-span-3 text-right">
                                        <button @onclick="() => group.Ingredients.Remove(mapping)" class="text-gray-700 hover:text-red-500 transition">✕</button>
                                    </div>
                                </div>
                                <div class="mt-3 pt-3 border-t border-white/5 grid grid-cols-5 gap-2">
                                    <div class="flex flex-col"><span class="text-[8px] text-gray-600 uppercase">Cals</span><input type="number" step="0.1" @bind="mapping.ScaledCals" @bind:event="oninput" readonly="@(mapping.IngredientId != 0)" class="@(mapping.IngredientId == 0 ? "bg-white/5 text-blue-400" : "bg-transparent text-orange-400") border-b border-transparent focus:border-blue-500 outline-none text-[11px] font-mono p-1 rounded" /></div>
                                    <div class="flex flex-col"><span class="text-[8px] text-gray-600 uppercase">Prot</span><input type="number" step="0.1" @bind="mapping.ScaledProt" @bind:event="oninput" readonly="@(mapping.IngredientId != 0)" class="@(mapping.IngredientId == 0 ? "bg-white/5 text-blue-400" : "bg-transparent text-blue-400") border-b border-transparent focus:border-blue-500 outline-none text-[11px] font-mono p-1 rounded" /></div>
                                    <div class="flex flex-col"><span class="text-[8px] text-gray-600 uppercase">Fat</span><input type="number" step="0.1" @bind="mapping.ScaledFat" @bind:event="oninput" readonly="@(mapping.IngredientId != 0)" class="@(mapping.IngredientId == 0 ? "bg-white/5 text-blue-400" : "bg-transparent text-yellow-500") border-b border-transparent focus:border-blue-500 outline-none text-[11px] font-mono p-1 rounded" /></div>
                                    <div class="flex flex-col"><span class="text-[8px] text-gray-600 uppercase">Carb</span><input type="number" step="0.1" @bind="mapping.ScaledCarb" @bind:event="oninput" readonly="@(mapping.IngredientId != 0)" class="@(mapping.IngredientId == 0 ? "bg-white/5 text-blue-400" : "bg-transparent text-red-400") border-b border-transparent focus:border-blue-500 outline-none text-[11px] font-mono p-1 rounded" /></div>
                                    <div class="flex flex-col"><span class="text-[8px] text-gray-600 uppercase">Fiber</span><input type="number" step="0.1" @bind="mapping.ScaledFiber" @bind:event="oninput" readonly="@(mapping.IngredientId != 0)" class="@(mapping.IngredientId == 0 ? "bg-white/5 text-blue-400" : "bg-transparent text-emerald-400") border-b border-transparent focus:border-blue-500 outline-none text-[11px] font-mono p-1 rounded" /></div>
                                </div>
                                @if (mapping.IngredientId == 0 && !string.IsNullOrEmpty(mapping.IngredientName)) {
                                    <div class="absolute top-1 right-12 bg-blue-600 text-white text-[6px] px-1 rounded uppercase font-black">Manual Entry Mode</div>
                                }
                            </div>
                        }
                        <button @onclick="() => AddIngredient(group)" class="w-full py-2 border border-dashed border-gray-800 rounded-xl text-[10px] text-gray-600 hover:border-gray-600 transition">＋ Add Ingredient</button>
                    </div>
                </div>
            }
            <button @onclick="AddGroup" class="w-full py-4 bg-white/5 border border-gray-800 rounded-3xl text-[11px] text-gray-500 uppercase hover:bg-white/10 transition">＋ Add Group</button>
        </div>

        <div class="lg:col-span-1">
            <div class="bg-emerald-950/10 border border-emerald-500/20 p-8 rounded-3xl sticky top-24 shadow-2xl">
                <h3 class="text-[11px] tracking-[0.2em] text-emerald-500 uppercase border-b border-emerald-500/20 pb-4 mb-6">Per Serving @(string.IsNullOrEmpty(recipe.ServingSize) ? "" : $"({recipe.ServingSize})")</h3>
                <div class="space-y-6">
                    @{ double safe = Math.Max(1, recipe.Servings); }
                    <div><div class="flex justify-between items-end mb-1"><span class="text-[10px] text-gray-500 uppercase">Cals</span><span class="text-2xl font-mono">@((TotalCals/safe).ToString("N0"))</span></div></div>
                    <div><div class="flex justify-between items-end mb-1"><span class="text-[10px] text-gray-500 uppercase">Protein</span><span class="text-lg font-mono text-blue-400">@((TotalProt/safe).ToString("N1"))g</span></div></div>
                    <div><div class="flex justify-between items-end mb-1"><span class="text-[10px] text-gray-500 uppercase">Total Fat</span><span class="text-lg font-mono text-yellow-500">@((TotalFat/safe).ToString("N1"))g</span></div></div>
                    <div><div class="flex justify-between items-end mb-1"><span class="text-[10px] text-gray-500 uppercase">Net Carbs</span><span class="text-lg font-mono text-emerald-400">@((TotalNet/safe).ToString("N1"))g</span></div></div>
                </div>
                <button @onclick="SaveRecipe" class="w-full mt-10 bg-emerald-600 hover:bg-emerald-500 py-4 rounded-2xl text-[11px] font-black tracking-widest uppercase shadow-xl transition">Commit Recipe</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int? RecipeId { get; set; }
    [SupplyParameterFromQuery] public int? ownerId { get; set; }

    private PPP_Recipe recipe = new() { Servings = 1, Name = "", ServingSize = "" };
    private List<PPP_Owner> owners = new();
    private List<PPP_Ingredient> masterIngs = new();
    private List<PPP_Ingredient> searchResults = new();
    private IngredientUIModel? activeMapping;
    private List<ToastItem> toasts = new();

    protected override async Task OnInitializedAsync() {
        owners = await Db.PPP_Owners.AsNoTracking().OrderBy(o => o.BusinessName).ToListAsync();
        masterIngs = await Db.PPP_Ingredients.AsNoTracking().ToListAsync();
        if (RecipeId.HasValue) await LoadRecipe(RecipeId.Value);
        else { AddGroup(); if (ownerId.HasValue) recipe.OwnerId = ownerId.Value; }
    }

    private void UpdateUnit(ChangeEventArgs e, IngredientUIModel m) 
    {
        string newUnit = e.Value?.ToString() ?? "";
        string oldUnit = m.Unit;

        if (m.BaseIngredient != null && !string.Equals(oldUnit, newUnit, StringComparison.OrdinalIgnoreCase)) 
        {
            // Try to convert the quantity (e.g., 1 lb -> 16 oz)
            if (PPPUnitConverter.TryConvert(m.Quantity, oldUnit, newUnit, out double convertedQty)) 
            {
                m.Quantity = Math.Round(convertedQty, 2);
                m.Unit = newUnit;
                // Scale() will now multiply (Base Calories per 1 lb) * (16) 
                // Wait - if the Base is 1lb, and the qty is 16, that's 16lbs!
                // We need to normalize the Base macros to the NEW unit.
                
                m.Scale();
                _ = ShowToast($"Converted {oldUnit} to {newUnit}. Amount updated to {m.Quantity}.");
            } 
            else 
            {
                m.IngredientId = 0; 
                m.Unit = newUnit;
                _ = ShowToast($"Incompatible units. Manual mode enabled.", true);
            }
        } 
        else { m.Unit = newUnit; }
    }

private async Task SaveRecipe() {
    if (recipe.OwnerId == 0) { await ShowToast("Select an Owner", true); return; }
    
    try {
        // PHASE 1: STANDALONE INGREDIENT COMMITS
        foreach(var group in recipe.IngredientGroups) {
            foreach(var m in group.Ingredients.OfType<IngredientUIModel>()) {
                if (m.IngredientId == 0 && !string.IsNullOrWhiteSpace(m.IngredientName)) {
                    double qty = Math.Max(0.001, m.Quantity);
                    var newIng = new PPP_Ingredient {
                        Name = m.IngredientName,
                        Unit = m.Unit,
                        Calories = m.ScaledCals / qty,
                        Protein = m.ScaledProt / qty,
                        Fat = m.ScaledFat / qty,
                        Carbs = m.ScaledCarb / qty,
                        Fiber = m.ScaledFiber / qty,
                        OwnerId = recipe.OwnerId,
                        CreatedAt = DateTime.UtcNow
                    };
                    
                    Db.PPP_Ingredients.Add(newIng);
                    await Db.SaveChangesAsync(); 
                    
                    m.IngredientId = newIng.Id;
                    m.BaseIngredient = null;
                    Db.Entry(newIng).State = EntityState.Detached;
                }
            }
        }

        // PHASE 2: SAVE THE RECIPE ROOT ONLY
        // We ensure the recipe exists before we try to link groups/mappings
        if (recipe.Id == 0) {
            Db.PPP_Recipes.Add(recipe);
        } else {
            // Only update the recipe itself, not the whole graph yet
            var entry = Db.Entry(recipe);
            entry.State = EntityState.Modified;
        }
        await Db.SaveChangesAsync();

        // PHASE 3: MANUALLY COMMIT GROUPS AND MAPPINGS
        // By saving groups and then mappings one by one, we prevent the "Sync Error"
        foreach (var group in recipe.IngredientGroups) {
            group.RecipeId = recipe.Id;
            if (group.Id == 0) Db.PPP_RecipeIngredientGroups.Add(group);
            else Db.Entry(group).State = EntityState.Modified;
            
            await Db.SaveChangesAsync();

            foreach (var mapping in group.Ingredients) {
                mapping.IngredientGroupId = group.Id;
                
                // Scrub object references
                if (mapping is IngredientUIModel ui) ui.BaseIngredient = null;

                if (mapping.Id == 0) Db.PPP_RecipeIngredientMappings.Add(mapping);
                else Db.Entry(mapping).State = EntityState.Modified;
            }
            await Db.SaveChangesAsync();
        }

        _ = ShowToast("Recipe Saved Successfully");
        await Task.Delay(800);
        Nav.NavigateTo($"/ppp-recipe-manager/{recipe.OwnerId}");
        
    } catch (Exception ex) { 
        var msg = ex.InnerException?.Message ?? ex.Message;
        Console.WriteLine($"[MANUAL SAVE FAIL] {msg}");
        // If it fails here, we reset the context for the next click
        Db.ChangeTracker.Clear();
        await ShowToast("Save Failed: " + msg, true); 
    }
}

    private async Task HandleImageUpload(InputFileChangeEventArgs e) {
        try {
            var file = e.File;
            using var ms = new System.IO.MemoryStream();
            await file.OpenReadStream(5120 * 1024).CopyToAsync(ms);
            var img = new PPP_StoredImage { Data = ms.ToArray(), ContentType = file.ContentType, FileName = file.Name, UploadedAt = DateTime.UtcNow };
            Db.PPP_StoredImages.Add(img); await Db.SaveChangesAsync();
            recipe.ImageId = img.Id; await ShowToast("Image Uploaded");
        } catch (Exception ex) { await ShowToast(ex.Message, true); }
    }

    private async Task LoadRecipe(int id) {
        var existing = await Db.PPP_Recipes.Include(r => r.IngredientGroups).ThenInclude(ig => ig.Ingredients).FirstOrDefaultAsync(r => r.Id == id);
        if (existing != null) {
            recipe = existing;
            foreach(var group in recipe.IngredientGroups) {
                var uiItems = new List<PPP_RecipeIngredientMapping>();
                foreach(var mapping in group.Ingredients) {
                    var ui = new IngredientUIModel { Id = mapping.Id, IngredientGroupId = mapping.IngredientGroupId, IngredientId = mapping.IngredientId, Quantity = mapping.Quantity, Unit = mapping.Unit, Notes = mapping.Notes, DisplayOrder = mapping.DisplayOrder, BaseIngredient = masterIngs.FirstOrDefault(i => i.Id == mapping.IngredientId) };
                    ui.IngredientName = ui.BaseIngredient?.Name ?? "Manual Entry"; ui.Scale(); uiItems.Add(ui);
                }
                group.Ingredients = uiItems;
            }
        }
    }

    private void AddGroup() => recipe.IngredientGroups.Add(new PPP_RecipeIngredientGroup { GroupName = "New Component", DisplayOrder = recipe.IngredientGroups.Count });
    private void AddIngredient(PPP_RecipeIngredientGroup g) => g.Ingredients.Add(new IngredientUIModel { DisplayOrder = g.Ingredients.Count, Unit = "oz" });
    
    private void SearchIng(ChangeEventArgs e, IngredientUIModel m) 
    {
        activeMapping = m;
        var q = e.Value?.ToString()?.Trim() ?? "";
        m.IngredientName = q; // Keep the model in sync while typing

        if (q.Length < 2) 
        { 
            searchResults.Clear(); 
            return; 
        }

        // Just show suggestions, don't trigger Manual Mode yet
        searchResults = masterIngs
            .Where(i => i.Name.ToLower().Contains(q.ToLower()))
            .Take(5)
            .ToList();
    }

    private async Task HandleBlur(IngredientUIModel m)
    {
        // Give the UI a tiny moment to process a click on a search result instead of a blur
        await Task.Delay(200); 

        var q = m.IngredientName?.Trim() ?? "";
        if (string.IsNullOrEmpty(q)) return;

        // Check for an exact match in the library
        var match = masterIngs.FirstOrDefault(i => i.Name.Equals(q, StringComparison.OrdinalIgnoreCase));

        if (match != null)
        {
            // Typo fixed or found exact match! Re-lock to library
            if (m.IngredientId != match.Id)
            {
                m.IngredientId = match.Id;
                m.BaseIngredient = match;
                m.Unit = match.Unit ?? "";
                m.Scale();
                _ = ShowToast($"Matched to library: {match.Name}");
            }
        }
        else
        {
            // No match found - This is a Custom Ingredient
            if (m.IngredientId != 0)
            {
                m.IngredientId = 0;
                m.BaseIngredient = null;
                _ = ShowToast("Custom New Ingredient - please enter macro values.", false);
            }
        }
        
        searchResults.Clear();
        activeMapping = null;
    }

    private void SelectIng(PPP_Ingredient master, IngredientUIModel mapping) { mapping.IngredientId = master.Id; mapping.IngredientName = master.Name; mapping.Unit = master.Unit ?? ""; mapping.BaseIngredient = master; mapping.Quantity = 1; mapping.Scale(); searchResults.Clear(); activeMapping = null; }
    private void UpdateQty(ChangeEventArgs e, IngredientUIModel m) { if (double.TryParse(e.Value?.ToString(), out var v)) { m.Quantity = v; m.Scale(); } }
    private double TotalCals => recipe.IngredientGroups.SelectMany(g => g.Ingredients).OfType<IngredientUIModel>().Sum(i => i.ScaledCals);
    private double TotalProt => recipe.IngredientGroups.SelectMany(g => g.Ingredients).OfType<IngredientUIModel>().Sum(i => i.ScaledProt);
    private double TotalFat => recipe.IngredientGroups.SelectMany(g => g.Ingredients).OfType<IngredientUIModel>().Sum(i => i.ScaledFat);
    private double TotalNet => recipe.IngredientGroups.SelectMany(g => g.Ingredients).OfType<IngredientUIModel>().Sum(i => i.ScaledCarb - i.ScaledFiber);
    private async Task ShowToast(string msg, bool isError = false) { var toast = new ToastItem { Message = msg, IsError = isError }; toasts.Add(toast); StateHasChanged(); await Task.Delay(4000); toasts.Remove(toast); StateHasChanged(); }

    public class IngredientUIModel : PPP_RecipeIngredientMapping {
        public string IngredientName { get; set; } = "";
        public PPP_Ingredient? BaseIngredient { get; set; }
        public double ScaledCals { get; set; }
        public double ScaledProt { get; set; }
        public double ScaledFat { get; set; }
        public double ScaledCarb { get; set; }
        public double ScaledFiber { get; set; }

        public void Scale() 
        { 
            if (BaseIngredient == null || IngredientId == 0) return; 

            double calcQty = Quantity;

            // Normalize back to base unit
            if (!string.Equals(Unit, BaseIngredient.Unit, StringComparison.OrdinalIgnoreCase))
            {
                if (PPPUnitConverter.TryConvert(Quantity, Unit, BaseIngredient.Unit ?? "", out double normalized))
                {
                    // We use a high-precision round here to handle the 0.9999999 drift
                    calcQty = Math.Round(normalized, 6);
                }
            }

            // Multiply and round to 2 decimal places for storage/display
            // Using MidpointRounding.AwayFromZero ensures 1151.999 becomes 1152.00
            ScaledCals = Math.Round(BaseIngredient.Calories * calcQty, 2, MidpointRounding.AwayFromZero); 
            ScaledProt = Math.Round(BaseIngredient.Protein * calcQty, 2, MidpointRounding.AwayFromZero); 
            ScaledFat = Math.Round(BaseIngredient.Fat * calcQty, 2, MidpointRounding.AwayFromZero); 
            ScaledCarb = Math.Round(BaseIngredient.Carbs * calcQty, 2, MidpointRounding.AwayFromZero); 
            ScaledFiber = Math.Round(BaseIngredient.Fiber * calcQty, 2, MidpointRounding.AwayFromZero); 
        }
    }

    private class ToastItem { public string Message { get; set; } = ""; public bool IsError { get; set; } }
}