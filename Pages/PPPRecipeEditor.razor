@page "/ppp-recipe-editor/{RecipeId:int?}"
@using Dashboard
@using Dashboard.Components
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Forms
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#0a0a0a] text-white p-6 font-black relative overflow-hidden">
    <PPPAdminNav CurrentPage="Recipe Architect" />

    @* Notification Stack *@
    <div class="fixed top-24 right-6 z-[100] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-2xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950 border-red-500 text-red-200" : "bg-emerald-950 border-emerald-500 text-emerald-200")">
                <div class="flex items-center gap-3">
                    <span>@(toast.IsError ? "❌" : "✅")</span>
                    <span class="text-xs uppercase tracking-widest">@toast.Message</span>
                </div>
            </div>
        }
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-6">
            
            @* Recipe Config *@
            <div class="bg-[#111] p-6 rounded-3xl border border-gray-800 shadow-xl">
                <div class="grid grid-cols-12 gap-6">
                    @* Image Asset *@
                    <div class="col-span-12 md:col-span-4">
                        <div class="aspect-square bg-black rounded-2xl border border-gray-800 flex items-center justify-center overflow-hidden relative group">
                            @if (recipe.ImageId.HasValue) {
                                <img src="/db-images-ppp/@recipe.ImageId" class="w-full h-full object-cover" />
                            } else {
                                <div class="text-center opacity-20"><span class="text-3xl block">📸</span></div>
                            }
                            <label class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition flex items-center justify-center cursor-pointer text-[9px] uppercase tracking-widest">
                                Upload Photo
                                <InputFile OnChange="HandleImageUpload" class="hidden" />
                            </label>
                        </div>
                    </div>

                    @* Core Details *@
                    <div class="col-span-12 md:col-span-8 space-y-4">
                        <div>
                            <label class="text-[10px] text-gray-500 uppercase block tracking-widest mb-2">Recipe Name</label>
                            <input @bind="recipe.Name" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-orange-500 outline-none" placeholder="Enter recipe name..." />
                        </div>
                        <div class="grid grid-cols-3 gap-4">
                            <div>
                                <label class="text-[10px] text-orange-500 uppercase block tracking-widest mb-2">Servings</label>
                                <input type="number" @bind="recipe.Servings" @bind:event="oninput" class="w-full bg-black border border-orange-900/50 rounded-xl p-3 text-sm focus:border-orange-500 outline-none text-center font-mono" />
                            </div>
                            <div class="col-span-2">
                                <label class="text-[10px] text-gray-500 uppercase block tracking-widest mb-2">Serving Size Description</label>
                                <input @bind="recipe.ServingSize" placeholder="e.g. 12oz Bowl or 2 Tacos" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-orange-500 outline-none" />
                            </div>
                        </div>
                        <div>
                            <label class="text-[10px] text-gray-500 uppercase block tracking-widest mb-2">Business Owner</label>
                            <select @bind="recipe.OwnerId" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-orange-500 outline-none">
                                <option value="0" disabled>-- Select Business --</option>
                                @foreach(var o in owners) { <option value="@o.Id">@o.BusinessName</option> }
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            @foreach (var group in recipe.IngredientGroups.OrderBy(g => g.DisplayOrder))
            {
                <div class="bg-[#111] p-6 rounded-3xl border border-gray-800 shadow-lg">
                    <div class="flex justify-between items-center mb-6">
                        <input @bind="group.GroupName" class="bg-transparent border-b border-gray-800 text-orange-400 tracking-tight font-black focus:border-orange-500 outline-none" />
                        <button @onclick="() => recipe.IngredientGroups.Remove(group)" class="text-[9px] text-red-500 uppercase hover:text-red-400 transition">Remove Group</button>
                    </div>

                    <div class="space-y-4">
                        @foreach (IngredientUIModel mapping in group.Ingredients.OfType<IngredientUIModel>())
                        {
                            <div class="bg-black/40 p-4 rounded-xl border @(mapping.IngredientId == 0 ? "border-blue-500/50" : "border-gray-800") relative group">
                                <div class="grid grid-cols-12 gap-3 items-end">
                                    <div class="col-span-5 relative">
                                        <label class="text-[9px] text-gray-600 mb-1 block">Ingredient Search</label>
                                        <input @bind="mapping.IngredientName" @oninput="(e) => SearchIng(e, mapping)" class="w-full bg-black border border-gray-800 rounded p-2 text-xs outline-none focus:border-blue-500" placeholder="Type to search..." />
                                        @if (activeMapping == mapping && searchResults.Any())
                                        {
                                            <div class="absolute z-50 w-full mt-1 bg-gray-900 border border-gray-700 rounded shadow-2xl max-h-40 overflow-y-auto">
                                                @foreach (var r in searchResults) {
                                                    <div @onclick="() => SelectIng(r, mapping)" class="p-2 text-[10px] hover:bg-orange-600 cursor-pointer border-b border-gray-800 last:border-0">@r.Name (@r.Unit)</div>
                                                }
                                            </div>
                                        }
                                    </div>
                                    <div class="col-span-2">
                                        <label class="text-[8px] text-gray-600 uppercase mb-1">Qty</label>
                                        <input type="number" step="0.01" value="@mapping.Quantity" @oninput="(e) => UpdateQty(e, mapping)" class="w-full bg-black border border-gray-800 rounded p-2 text-xs text-center font-mono" />
                                    </div>
                                    <div class="col-span-2">
                                        <label class="text-[8px] text-gray-600 uppercase mb-1">Unit</label>
                                        <input value="@mapping.Unit" @onchange="(e) => UpdateUnit(e, mapping)" class="w-full bg-black border border-gray-800 rounded p-2 text-xs text-center" />
                                    </div>
                                    <div class="col-span-3 text-right">
                                        <button @onclick="() => group.Ingredients.Remove(mapping)" class="text-gray-700 hover:text-red-500 transition">✕</button>
                                    </div>
                                </div>

                                @* Manual Macro Inputs - Enabled only when IngredientId is 0 *@
                                <div class="mt-3 pt-3 border-t border-white/5 grid grid-cols-5 gap-4">
                                    <div class="flex flex-col">
                                        <span class="text-[8px] text-gray-600 uppercase">Cals</span>
                                        <input type="number" step="0.1" @bind="mapping.ScaledCals" @bind:event="oninput" readonly="@(mapping.IngredientId != 0)" 
                                               class="@(mapping.IngredientId == 0 ? "bg-white/5 text-blue-400" : "bg-transparent text-orange-400") border-b border-transparent focus:border-blue-500 outline-none text-[11px] font-mono p-1 rounded" />
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-[8px] text-gray-600 uppercase">Prot</span>
                                        <input type="number" step="0.1" @bind="mapping.ScaledProt" @bind:event="oninput" readonly="@(mapping.IngredientId != 0)" 
                                               class="@(mapping.IngredientId == 0 ? "bg-white/5 text-blue-400" : "bg-transparent text-blue-400") border-b border-transparent focus:border-blue-500 outline-none text-[11px] font-mono p-1 rounded" />
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-[8px] text-gray-600 uppercase">Fat</span>
                                        <input type="number" step="0.1" @bind="mapping.ScaledFat" @bind:event="oninput" readonly="@(mapping.IngredientId != 0)" 
                                               class="@(mapping.IngredientId == 0 ? "bg-white/5 text-blue-400" : "bg-transparent text-yellow-500") border-b border-transparent focus:border-blue-500 outline-none text-[11px] font-mono p-1 rounded" />
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-[8px] text-gray-600 uppercase">Carb</span>
                                        <input type="number" step="0.1" @bind="mapping.ScaledCarb" @bind:event="oninput" readonly="@(mapping.IngredientId != 0)" 
                                               class="@(mapping.IngredientId == 0 ? "bg-white/5 text-blue-400" : "bg-transparent text-red-400") border-b border-transparent focus:border-blue-500 outline-none text-[11px] font-mono p-1 rounded" />
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-[8px] text-gray-600 uppercase">Fiber</span>
                                        <input type="number" step="0.1" @bind="mapping.ScaledFiber" @bind:event="oninput" readonly="@(mapping.IngredientId != 0)" 
                                               class="@(mapping.IngredientId == 0 ? "bg-white/5 text-blue-400" : "bg-transparent text-emerald-400") border-b border-transparent focus:border-blue-500 outline-none text-[11px] font-mono p-1 rounded" />
                                    </div>
                                </div>
                                @if (mapping.IngredientId == 0 && !string.IsNullOrEmpty(mapping.IngredientName)) {
                                    <div class="absolute top-1 right-12 bg-blue-600 text-white text-[6px] px-1 rounded uppercase font-black">Manual Entry Mode</div>
                                }
                            </div>
                        }
                        <button @onclick="() => AddIngredient(group)" class="w-full py-2 border border-dashed border-gray-800 rounded-xl text-[10px] text-gray-600 hover:border-gray-600 transition">＋ Add Ingredient Row</button>
                    </div>
                </div>
            }
            <button @onclick="AddGroup" class="w-full py-4 bg-white/5 border border-gray-800 rounded-3xl text-[11px] text-gray-500 uppercase tracking-widest hover:bg-white/10 transition">＋ Create Ingredient Group</button>
        </div>

        @* Macros Sidebar *@
        <div class="lg:col-span-1">
            <div class="bg-emerald-950/10 border border-emerald-500/20 p-8 rounded-3xl sticky top-24 shadow-2xl">
                <div class="flex justify-between items-center mb-8 border-b border-emerald-500/20 pb-4">
                    <h3 class="text-[11px] tracking-[0.2em] text-emerald-500 uppercase">Per Serving Macros</h3>
                    <span class="text-[10px] bg-emerald-500/20 text-emerald-400 px-2 py-0.5 rounded-full font-black">@recipe.Servings Servings</span>
                </div>

                <div class="space-y-6">
                    @{
                        double safeDivisor = Math.Max(1, recipe.Servings);
                    }
                    <div>
                        <div class="flex justify-between items-end mb-1">
                            <span class="text-[10px] text-gray-500 uppercase">Calories</span>
                            <span class="text-2xl font-mono">@((TotalCals / safeDivisor).ToString("N0"))</span>
                        </div>
                        <div class="text-[8px] text-gray-700 uppercase text-right">Batch Total: @TotalCals.ToString("N0")</div>
                    </div>

                    <div>
                        <div class="flex justify-between items-end mb-1">
                            <span class="text-[10px] text-gray-500 uppercase">Protein</span>
                            <span class="text-lg font-mono text-blue-400">@((TotalProt / safeDivisor).ToString("N1"))g</span>
                        </div>
                        <div class="text-[8px] text-gray-700 uppercase text-right">Batch Total: @TotalProt.ToString("N1")g</div>
                    </div>

                    <div>
                        <div class="flex justify-between items-end mb-1">
                            <span class="text-[10px] text-gray-500 uppercase">Total Fat</span>
                            <span class="text-lg font-mono text-yellow-500">@((TotalFat / safeDivisor).ToString("N1"))g</span>
                        </div>
                        <div class="text-[8px] text-gray-700 uppercase text-right">Batch Total: @TotalFat.ToString("N1")g</div>
                    </div>

                    <div>
                        <div class="flex justify-between items-end mb-1">
                            <span class="text-[10px] text-gray-500 uppercase">Net Carbs</span>
                            <span class="text-lg font-mono text-emerald-400">@((TotalNet / safeDivisor).ToString("N1"))g</span>
                        </div>
                        <div class="text-[8px] text-gray-700 uppercase text-right">Batch Total: @TotalNet.ToString("N1")g</div>
                    </div>
                </div>

                <button @onclick="SaveRecipe" class="w-full mt-10 bg-emerald-600 hover:bg-emerald-500 py-4 rounded-2xl text-[11px] font-black tracking-widest uppercase shadow-xl transition">Commit Recipe</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int? RecipeId { get; set; }
    [SupplyParameterFromQuery] public int? ownerId { get; set; }

    private PPP_Recipe recipe = new() { Servings = 1, Name = "", ServingSize = "" };
    private List<PPP_Owner> owners = new();
    private List<PPP_Ingredient> masterIngs = new();
    private List<PPP_Ingredient> searchResults = new();
    private IngredientUIModel? activeMapping;
    private List<ToastItem> toasts = new();

    protected override async Task OnInitializedAsync() {
        owners = await Db.PPP_Owners.AsNoTracking().OrderBy(o => o.BusinessName).ToListAsync();
        masterIngs = await Db.PPP_Ingredients.AsNoTracking().ToListAsync();

        if (RecipeId.HasValue) {
            await LoadRecipe(RecipeId.Value);
        } else {
            AddGroup();
            if (ownerId.HasValue) recipe.OwnerId = ownerId.Value;
        }
    }

    private void UpdateUnit(ChangeEventArgs e, IngredientUIModel m) 
    {
        string newUnit = e.Value?.ToString() ?? "";
        string oldUnit = m.Unit; // Capture the current state before we mess with it

        // If we have a master ingredient and the unit actually changed family-wise
        if (m.BaseIngredient != null && !string.Equals(oldUnit, newUnit, StringComparison.OrdinalIgnoreCase)) 
        {
            // Try the conversion using the OLD unit as the source and NEW as target
            if (PPPUnitConverter.TryConvert(m.Quantity, oldUnit, newUnit, out double convertedQty)) 
            {
                m.Quantity = Math.Round(convertedQty, 2);
                m.Unit = newUnit; // Officially update the unit now that math passed
                m.Scale();
                _ = ShowToast($"Scaled {m.IngredientName} from {oldUnit} to {newUnit}");
            } 
            else 
            {
                // Conversion failed (e.g., Weight to Volume)
                // DON'T change the quantity, but switch to Manual Mode
                m.IngredientId = 0; 
                m.Unit = newUnit;
                
                var suggested = string.Join(", ", PPPUnitConverter.GetCompatibleUnits(oldUnit));
                _ = ShowToast($"Incompatible! Cannot scale {oldUnit} to {newUnit}. Manual mode enabled. Compatible with {oldUnit}: {suggested}", true);
            }
        } 
        else 
        {
            // Simple update for manual entries
            m.Unit = newUnit;
        }
    }

    private async Task SaveRecipe() {
        if (recipe.OwnerId == 0) { await ShowToast("Select a Business Owner", true); return; }
        try {
            foreach(var group in recipe.IngredientGroups) {
                foreach(var m in group.Ingredients.OfType<IngredientUIModel>()) {
                    if (m.IngredientId == 0 && !string.IsNullOrWhiteSpace(m.IngredientName)) {
                        var newIng = new PPP_Ingredient {
                            Name = m.IngredientName,
                            Unit = m.Unit,
                            Calories = m.ScaledCals / Math.Max(0.01, m.Quantity),
                            Protein = m.ScaledProt / Math.Max(0.01, m.Quantity),
                            Fat = m.ScaledFat / Math.Max(0.01, m.Quantity),
                            Carbs = m.ScaledCarb / Math.Max(0.01, m.Quantity),
                            Fiber = m.ScaledFiber / Math.Max(0.01, m.Quantity),
                            OwnerId = recipe.OwnerId,
                            CreatedAt = DateTime.UtcNow
                        };
                        Db.PPP_Ingredients.Add(newIng);
                        await Db.SaveChangesAsync();
                        m.IngredientId = newIng.Id;
                    }
                }
            }
            if (recipe.Id == 0) Db.PPP_Recipes.Add(recipe);
            else Db.Update(recipe);
            await Db.SaveChangesAsync();
            Nav.NavigateTo($"/ppp-recipe-manager/{recipe.OwnerId}");
        } catch (Exception ex) { await ShowToast("Error: " + ex.Message, true); }
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e) {
        try {
            var file = e.File;
            using var ms = new System.IO.MemoryStream();
            await file.OpenReadStream(5120 * 1024).CopyToAsync(ms);
            var img = new PPP_StoredImage { Data = ms.ToArray(), ContentType = file.ContentType, FileName = file.Name, UploadedAt = DateTime.UtcNow };
            Db.PPP_StoredImages.Add(img); await Db.SaveChangesAsync();
            recipe.ImageId = img.Id; await ShowToast("Meal Image Uploaded");
        } catch (Exception ex) { await ShowToast(ex.Message, true); }
    }

    private async Task LoadRecipe(int id) {
        var existing = await Db.PPP_Recipes.Include(r => r.IngredientGroups).ThenInclude(ig => ig.Ingredients).FirstOrDefaultAsync(r => r.Id == id);
        if (existing != null) {
            recipe = existing;
            foreach(var group in recipe.IngredientGroups) {
                var uiItems = new List<PPP_RecipeIngredientMapping>();
                foreach(var mapping in group.Ingredients) {
                    var ui = new IngredientUIModel {
                        Id = mapping.Id,
                        IngredientGroupId = mapping.IngredientGroupId,
                        IngredientId = mapping.IngredientId,
                        Quantity = mapping.Quantity,
                        Unit = mapping.Unit,
                        Notes = mapping.Notes,
                        DisplayOrder = mapping.DisplayOrder,
                        BaseIngredient = masterIngs.FirstOrDefault(i => i.Id == mapping.IngredientId)
                    };
                    ui.IngredientName = ui.BaseIngredient?.Name ?? "Manual Entry";
                    ui.Scale();
                    uiItems.Add(ui);
                }
                group.Ingredients = uiItems;
            }
        }
    }

    private void AddGroup() => recipe.IngredientGroups.Add(new PPP_RecipeIngredientGroup { GroupName = "Main Components", DisplayOrder = recipe.IngredientGroups.Count });
    private void AddIngredient(PPP_RecipeIngredientGroup g) => g.Ingredients.Add(new IngredientUIModel { DisplayOrder = g.Ingredients.Count, Unit = "oz" });
    private void SearchIng(ChangeEventArgs e, IngredientUIModel m) { activeMapping = m; var q = e.Value?.ToString()?.ToLower() ?? ""; if (q.Length < 2) { searchResults.Clear(); return; } searchResults = masterIngs.Where(i => i.Name.ToLower().Contains(q)).Take(5).ToList(); }
    private void SelectIng(PPP_Ingredient master, IngredientUIModel mapping) { mapping.IngredientId = master.Id; mapping.IngredientName = master.Name; mapping.Unit = master.Unit ?? ""; mapping.BaseIngredient = master; mapping.Quantity = 1; mapping.Scale(); searchResults.Clear(); activeMapping = null; }
    private void UpdateQty(ChangeEventArgs e, IngredientUIModel m) { if (double.TryParse(e.Value?.ToString(), out var v)) { m.Quantity = v; m.Scale(); } }
    private double TotalCals => recipe.IngredientGroups.SelectMany(g => g.Ingredients).OfType<IngredientUIModel>().Sum(i => i.ScaledCals);
    private double TotalProt => recipe.IngredientGroups.SelectMany(g => g.Ingredients).OfType<IngredientUIModel>().Sum(i => i.ScaledProt);
    private double TotalFat => recipe.IngredientGroups.SelectMany(g => g.Ingredients).OfType<IngredientUIModel>().Sum(i => i.ScaledFat);
    private double TotalNet => recipe.IngredientGroups.SelectMany(g => g.Ingredients).OfType<IngredientUIModel>().Sum(i => i.ScaledCarb - i.ScaledFiber);

    private async Task ShowToast(string msg, bool isError = false) { 
        var toast = new ToastItem { Message = msg, IsError = isError }; 
        toasts.Add(toast); StateHasChanged(); 
        await Task.Delay(4000); 
        toasts.Remove(toast); StateHasChanged(); 
    }

    public class IngredientUIModel : PPP_RecipeIngredientMapping {
        public string IngredientName { get; set; } = "";
        public PPP_Ingredient? BaseIngredient { get; set; }
        public double ScaledCals { get; set; }
        public double ScaledProt { get; set; }
        public double ScaledFat { get; set; }
        public double ScaledCarb { get; set; }
        public double ScaledFiber { get; set; }
        public void Scale() { if (BaseIngredient == null || IngredientId == 0) return; ScaledCals = Math.Round(BaseIngredient.Calories * Quantity, 2); ScaledProt = Math.Round(BaseIngredient.Protein * Quantity, 2); ScaledFat = Math.Round(BaseIngredient.Fat * Quantity, 2); ScaledCarb = Math.Round(BaseIngredient.Carbs * Quantity, 2); ScaledFiber = Math.Round(BaseIngredient.Fiber * Quantity, 2); }
    }
    private class ToastItem { public string Message { get; set; } = ""; public bool IsError { get; set; } }

    // EMBEDDED CONVERTER TO ELIMINATE EXTERNAL FILE ERRORS
    private static class InternalConverter {
        private enum Family { Weight, Volume, Count }
        private static readonly Dictionary<string, (Family F, double B)> U = new(StringComparer.OrdinalIgnoreCase) {
            { "g", (Family.Weight, 1.0) }, { "gram", (Family.Weight, 1.0) }, { "grams", (Family.Weight, 1.0) }, 
            { "oz", (Family.Weight, 28.35) }, { "ounce", (Family.Weight, 28.35) },
            { "lb", (Family.Weight, 453.6) }, { "lbs", (Family.Weight, 453.6) },
            { "ml", (Family.Volume, 1.0) }, { "tsp", (Family.Volume, 4.93) }, { "tbsp", (Family.Volume, 14.79) }, 
            { "cup", (Family.Volume, 236.6) }, { "cups", (Family.Volume, 236.6) },
            { "each", (Family.Count, 1.0) }, { "piece", (Family.Count, 1.0) }
        };
        public static bool TryConvert(double q, string f, string t, out double n) {
            n = q; if (string.IsNullOrWhiteSpace(f) || string.IsNullOrWhiteSpace(t)) return false;
            if (!U.ContainsKey(f) || !U.ContainsKey(t)) return false;
            if (U[f].F != U[t].F) return false;
            n = (q * U[f].B) / U[t].B; return true;
        }
        public static List<string> GetCompatibleUnits(string unit) {
            if (string.IsNullOrWhiteSpace(unit) || !U.ContainsKey(unit)) return new List<string>();
            var fam = U[unit].F; return U.Where(x => x.Value.F == fam).Select(x => x.Key).ToList();
        }
    }
}