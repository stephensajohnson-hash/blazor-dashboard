@page "/ppp-recipe-editor/{RecipeId:int?}"
@using Dashboard
@using Dashboard.Components
@using Dashboard.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Forms
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#050505] text-slate-200 p-4 md:p-8 font-sans antialiased">
    <PPPAdminNav CurrentPage="Recipe Architect" />

    @* Notification Stack *@
    <div class="fixed top-24 right-6 z-[100] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950/90 border-red-500/50 text-red-200" : "bg-emerald-950/90 border-emerald-500/50 text-emerald-200") backdrop-blur-md">
                <div class="flex items-center gap-3">
                    <span class="text-lg">@(toast.IsError ? "✕" : "✓")</span>
                    <span class="text-xs font-bold uppercase tracking-widest">@toast.Message</span>
                </div>
            </div>
        }
    </div>

    @* Header Section *@
    <div class="max-w-7xl mx-auto mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-4xl font-black tracking-tighter text-white">@(RecipeId.HasValue ? "Edit Recipe" : "New Creation")</h1>
            <p class="text-slate-500 text-sm uppercase tracking-[0.2em] mt-1">@recipe.Name</p>
        </div>
    </div>

    @* Global Macros Bar *@
    <div class="max-w-7xl mx-auto mb-8">
        <div class="bg-emerald-600/5 border border-emerald-500/20 p-6 rounded-3xl backdrop-blur-sm grid grid-cols-2 md:grid-cols-7 gap-6 items-center shadow-lg text-center">
            @{ double safe = Math.Max(1, recipe.Servings); }
            <div class="col-span-2 md:col-span-1 border-r border-emerald-500/10 text-left">
                <p class="text-[9px] text-slate-500 uppercase font-black tracking-widest mb-1">Per Serving</p>
                <p class="text-[10px] text-emerald-500 font-bold">@(string.IsNullOrEmpty(recipe.ServingSize) ? "Yield" : recipe.ServingSize)</p>
            </div>
            <div>
                <span class="text-[9px] text-slate-500 uppercase font-bold tracking-widest block mb-1">Calories</span>
                <span class="text-2xl font-black text-white">@((TotalCals/safe).ToString("N0"))</span>
            </div>
            <div>
                <span class="text-[9px] text-slate-500 uppercase font-bold tracking-widest block mb-1">Protein</span>
                <span class="text-2xl font-black text-blue-400">@((TotalProt/safe).ToString("N1"))g</span>
            </div>
            <div>
                <span class="text-[9px] text-slate-500 uppercase font-bold tracking-widest block mb-1">Fat</span>
                <span class="text-2xl font-black text-yellow-500">@((TotalFat/safe).ToString("N1"))g</span>
            </div>
            <div>
                <span class="text-[9px] text-slate-500 uppercase font-bold tracking-widest block mb-1">Carbs</span>
                <span class="text-2xl font-black text-red-500">@((TotalCarb/safe).ToString("N1"))g</span>
            </div>
            <div>
                <span class="text-[9px] text-slate-500 uppercase font-bold tracking-widest block mb-1">Fiber</span>
                <span class="text-2xl font-black text-emerald-600">@((TotalFiber/safe).ToString("N1"))g</span>
            </div>
            <div class="bg-emerald-500/10 py-2 rounded-xl border border-emerald-500/20">
                <span class="text-[9px] text-emerald-500 uppercase font-bold tracking-widest block mb-1">Net Carbs</span>
                <span class="text-2xl font-black text-emerald-400">@((TotalNet/safe).ToString("N1"))g</span>
            </div>
        </div>
    </div>

    @* Tab Navigation *@
    <div class="max-w-7xl mx-auto mb-8">
        <div class="flex gap-1 bg-[#111] p-1.5 rounded-2xl w-fit border border-slate-800/50">
            <button @onclick='() => currentTab = "Details"' class="px-8 py-3 rounded-xl text-[11px] font-black uppercase tracking-widest transition-all @(currentTab == "Details" ? "bg-emerald-600 text-white shadow-lg" : "text-slate-500 hover:text-slate-300")">Details</button>
            <button @onclick='() => currentTab = "Ingredients"' class="px-8 py-3 rounded-xl text-[11px] font-black uppercase tracking-widest transition-all @(currentTab == "Ingredients" ? "bg-emerald-600 text-white shadow-lg" : "text-slate-500 hover:text-slate-300")">Ingredients</button>
            <button @onclick='() => currentTab = "Instructions"' class="px-8 py-3 rounded-xl text-[11px] font-black uppercase tracking-widest transition-all @(currentTab == "Instructions" ? "bg-emerald-600 text-white shadow-lg" : "text-slate-500 hover:text-slate-300")">Instructions</button>
        </div>
    </div>

    <div class="max-w-7xl mx-auto">
        @if (currentTab == "Details")
        {
            <div class="space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500">
                <div class="bg-[#111] border border-slate-800 rounded-3xl p-8 shadow-xl">
                    <div class="grid grid-cols-12 gap-8">
                        <div class="col-span-12 md:col-span-4">
                            <div class="aspect-square bg-black rounded-3xl border border-slate-800 flex items-center justify-center overflow-hidden relative group">
                                @if (recipe.ImageId.HasValue) {
                                    <img src="/db-images-ppp/@recipe.ImageId" class="w-full h-full object-cover" />
                                } else {
                                    <div class="text-center opacity-10"><span class="text-6xl block">🖼️</span></div>
                                }
                                <label class="absolute inset-0 bg-emerald-600/80 opacity-0 group-hover:opacity-100 transition-all flex items-center justify-center cursor-pointer font-bold text-xs uppercase text-white text-center">
                                    Update Visual
                                    <InputFile OnChange="HandleImageUpload" class="hidden" />
                                </label>
                            </div>
                        </div>
                        <div class="col-span-12 md:col-span-8 space-y-6">
                            <div>
                                <label class="text-[10px] text-slate-500 uppercase font-bold tracking-widest mb-2 block">Recipe Title</label>
                                <input @bind="recipe.Name" class="w-full bg-black border border-slate-800 rounded-2xl p-4 text-sm focus:border-emerald-500 outline-none transition-colors" />
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="text-[10px] text-slate-500 uppercase font-bold tracking-widest mb-2 block">Servings</label>
                                    <input type="number" @bind="recipe.Servings" @bind:event="oninput" class="w-full bg-black border border-slate-800 rounded-2xl p-4 text-sm focus:border-emerald-500 outline-none transition-colors font-mono" />
                                </div>
                                <div>
                                    <label class="text-[10px] text-slate-500 uppercase font-bold tracking-widest mb-2 block">Serving Size Type</label>
                                    <input @bind="recipe.ServingSize" placeholder="e.g. 12oz Bowl" class="w-full bg-black border border-slate-800 rounded-2xl p-4 text-sm focus:border-emerald-500 outline-none transition-colors" />
                                </div>
                            </div>
                            <div>
                                <label class="text-[10px] text-slate-500 uppercase font-bold tracking-widest mb-2 block">Owner Assignment</label>
                                <select @bind="recipe.OwnerId" class="w-full bg-black border border-slate-800 rounded-2xl p-4 text-sm focus:border-emerald-500 outline-none appearance-none transition-colors">
                                    <option value="0">Select Owner...</option>
                                    @foreach(var o in owners) { <option value="@o.Id">@o.BusinessName</option> }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
                <button @onclick="SaveRecipe" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white py-5 rounded-2xl font-black text-xs uppercase tracking-[0.3em] transition-all active:scale-[0.98]">Save Recipe</button>
            </div>
        }

        @if (currentTab == "Ingredients")
        {
            <div class="space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500">
                <div class="space-y-6">
                    @foreach (var group in recipe.IngredientGroups.OrderBy(g => g.DisplayOrder))
                    {
                        <div class="bg-[#111] border border-slate-800 rounded-3xl overflow-hidden shadow-lg">
                            <div class="bg-white/5 px-6 py-4 border-b border-slate-800 flex justify-between items-center">
                                <input @bind="group.GroupName" class="bg-transparent border-none text-white font-black text-lg focus:ring-0 outline-none" />
                                <button @onclick="() => recipe.IngredientGroups.Remove(group)" class="text-[10px] text-red-500 uppercase font-black tracking-widest hover:text-red-400 transition-colors">Remove Group</button>
                            </div>
                            <div class="p-6 space-y-4">
                                @{ var sortedIngs = group.Ingredients.OfType<IngredientUIModel>().OrderBy(i => i.DisplayOrder).ToList(); }
                                @foreach (var mapping in sortedIngs)
                                {
                                    <div class="group/item bg-black/40 p-4 rounded-2xl border @(mapping.IngredientId == 0 ? "border-emerald-500/30" : "border-slate-800") relative">
                                        <div class="grid grid-cols-12 gap-4 items-center">
                                            <div class="col-span-1 flex flex-col items-center gap-1 opacity-20 group-hover/item:opacity-100 transition-opacity">
                                                <button @onclick="() => MoveIngredient(group, mapping, -1)" class="text-xs hover:text-emerald-500">▲</button>
                                                <button @onclick="() => MoveIngredient(group, mapping, 1)" class="text-xs hover:text-emerald-500">▼</button>
                                            </div>

                                            <div class="col-span-11 md:col-span-5 relative">
                                                <label class="text-[9px] text-slate-500 uppercase font-bold mb-1 block">Ingredient</label>
                                                <input @bind="mapping.IngredientName" @oninput="(e) => SearchIng(e, mapping)" @onblur="() => HandleBlur(mapping)"
                                                       class="w-full bg-[#111] border border-slate-800 rounded-xl p-3 text-xs outline-none focus:border-emerald-500 transition-colors" />
                                                @if (activeMapping == mapping && searchResults.Any()) {
                                                    <div class="absolute z-[110] w-full mt-2 bg-[#1a1a1a] border border-slate-700 rounded-xl shadow-2xl max-h-60 overflow-y-auto">
                                                        @foreach (var r in searchResults) {
                                                            <div @onclick="() => SelectIng(r, mapping)" class="p-4 text-xs hover:bg-emerald-600 transition-colors cursor-pointer text-white font-bold border-b border-white/5 last:border-none">@r.Name (@r.Unit)</div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                            <div class="col-span-4 md:col-span-2">
                                                <label class="text-[9px] text-slate-500 uppercase font-bold mb-1 block">Qty</label>
                                                <input type="number" step="0.01" value="@mapping.Quantity" @oninput="(e) => UpdateQty(e, mapping)" class="w-full bg-[#111] border border-slate-800 rounded-xl p-3 text-xs text-center font-mono focus:border-emerald-500" />
                                            </div>
                                            <div class="col-span-4 md:col-span-3">
                                                <label class="text-[9px] text-slate-500 uppercase font-bold mb-1 block">Unit</label>
                                                <input @bind="mapping.Unit" @onchange="(e) => UpdateUnit(e, mapping)" class="w-full bg-[#111] border border-slate-800 rounded-xl p-3 text-xs focus:border-emerald-500" />
                                            </div>
                                            <div class="col-span-4 md:col-span-1 text-right">
                                                <button @onclick="() => group.Ingredients.Remove(mapping)" class="text-slate-600 hover:text-red-500 p-2 text-lg transition-colors">✕</button>
                                            </div>
                                        </div>
                                        
                                        <div class="mt-4 pt-4 border-t border-white/5 flex flex-wrap gap-2 text-center">
                                            <div class="flex-1 bg-black/40 p-2 rounded-lg border border-white/5">
                                                <span class="text-[7px] text-slate-500 uppercase block mb-1">Cals</span>
                                                <input type="number" step="0.1" @bind="mapping.ScaledCals" @bind:event="oninput" readonly="@(mapping.IngredientId != 0)" class="w-full bg-transparent text-white font-mono text-[10px] text-center outline-none" />
                                            </div>
                                            <div class="flex-1 bg-black/40 p-2 rounded-lg border border-white/5">
                                                <span class="text-[7px] text-slate-500 uppercase block mb-1">Prot</span>
                                                <input type="number" step="0.1" @bind="mapping.ScaledProt" @bind:event="oninput" readonly="@(mapping.IngredientId != 0)" class="w-full bg-transparent text-blue-400 font-mono text-[10px] text-center outline-none" />
                                            </div>
                                            <div class="flex-1 bg-black/40 p-2 rounded-lg border border-white/5">
                                                <span class="text-[7px] text-slate-500 uppercase block mb-1">Fat</span>
                                                <input type="number" step="0.1" @bind="mapping.ScaledFat" @bind:event="oninput" readonly="@(mapping.IngredientId != 0)" class="w-full bg-transparent text-yellow-500 font-mono text-[10px] text-center outline-none" />
                                            </div>
                                            <div class="flex-1 bg-black/40 p-2 rounded-lg border border-white/5">
                                                <span class="text-[7px] text-slate-500 uppercase block mb-1">Carb</span>
                                                <input type="number" step="0.1" @bind="mapping.ScaledCarb" @bind:event="oninput" readonly="@(mapping.IngredientId != 0)" class="w-full bg-transparent text-red-400 font-mono text-[10px] text-center outline-none" />
                                            </div>
                                            <div class="flex-1 bg-black/40 p-2 rounded-lg border border-white/5">
                                                <span class="text-[7px] text-slate-500 uppercase block mb-1">Fiber</span>
                                                <input type="number" step="0.1" @bind="mapping.ScaledFiber" @bind:event="oninput" readonly="@(mapping.IngredientId != 0)" class="w-full bg-transparent text-emerald-600 font-mono text-[10px] text-center outline-none" />
                                            </div>
                                            <div class="flex-1 bg-emerald-400/5 p-2 rounded-lg border border-emerald-500/20">
                                                <span class="text-[7px] text-emerald-500 uppercase block mb-1">Net C</span>
                                                <span class="w-full text-emerald-400 font-mono text-[10px] text-center block">@((mapping.ScaledCarb - mapping.ScaledFiber).ToString("N1"))</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                                <button @onclick="() => AddIngredient(group)" class="w-full py-4 border-2 border-dashed border-slate-800 rounded-2xl text-[10px] text-slate-500 uppercase font-black tracking-widest hover:border-emerald-500 hover:text-emerald-500 transition-all">
                                    ＋ Add Ingredient
                                </button>
                            </div>
                        </div>
                    }
                    <button @onclick="AddGroup" class="w-full py-6 bg-white/5 border-2 border-dashed border-slate-800 rounded-3xl text-[11px] text-slate-500 font-black uppercase tracking-widest hover:bg-emerald-600/5 hover:border-emerald-600/30 hover:text-emerald-500 transition-all">
                        ＋ New Ingredient Group
                    </button>
                </div>
                <button @onclick="SaveRecipe" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white py-5 rounded-2xl font-black text-xs uppercase tracking-[0.3em] transition-all shadow-xl active:scale-[0.98]">Save Recipe</button>
            </div>
        }

        @if (currentTab == "Instructions")
        {
            <div class="space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500">
                <div class="space-y-6">
                    @foreach (var insGroup in instructionGroups.OrderBy(g => g.DisplayOrder))
                    {
                        <div class="bg-[#111] border border-slate-800 rounded-3xl overflow-hidden shadow-lg">
                            <div class="bg-white/5 px-6 py-4 border-b border-slate-800 flex justify-between items-center">
                                <input @bind="insGroup.GroupName" class="bg-transparent border-none text-white font-black text-lg focus:ring-0 outline-none" />
                                <button @onclick="() => instructionGroups.Remove(insGroup)" class="text-[10px] text-red-500 uppercase font-black tracking-widest hover:text-red-400 transition-colors">Delete Group</button>
                            </div>
                            <div class="p-6 space-y-4">
                                @{ var sortedSteps = insGroup.Instructions.OrderBy(s => s.DisplayOrder).ToList(); }
                                @foreach (var step in sortedSteps)
                                {
                                    <div class="flex gap-4 items-start group/step">
                                        <div class="flex flex-col items-center shrink-0 mt-1 opacity-20 group-hover/step:opacity-100 transition-opacity">
                                            <button @onclick="() => MoveInstruction(insGroup, step, -1)" class="text-[10px] hover:text-emerald-500 transition-colors">▲</button>
                                            <div class="w-7 h-7 rounded-full bg-emerald-600/20 border border-emerald-500/30 flex items-center justify-center text-[10px] font-black text-emerald-500">
                                                @(step.DisplayOrder + 1)
                                            </div>
                                            <button @onclick="() => MoveInstruction(insGroup, step, 1)" class="text-[10px] hover:text-emerald-500 transition-colors">▼</button>
                                        </div>
                                        <textarea @bind="step.StepDescription" rows="2" 
                                                  class="w-full bg-black border border-slate-800 rounded-xl p-4 text-sm focus:border-emerald-500 outline-none transition-colors leading-relaxed" 
                                                  placeholder="Describe step..."></textarea>
                                        <button @onclick="() => insGroup.Instructions.Remove(step)" class="text-slate-700 hover:text-red-500 p-2 mt-1 transition-colors">✕</button>
                                    </div>
                                }
                                <button @onclick="() => AddStep(insGroup)" class="w-full py-3 border border-dashed border-slate-800 rounded-xl text-[10px] text-slate-500 uppercase font-black tracking-widest hover:border-emerald-500/50 hover:text-emerald-500 transition-all">
                                    ＋ Add Step
                                </button>
                            </div>
                        </div>
                    }
                    <button @onclick="AddInstructionGroup" class="w-full py-6 bg-white/5 border-2 border-dashed border-slate-800 rounded-3xl text-[11px] text-slate-500 font-black uppercase tracking-widest hover:bg-emerald-600/5 hover:border-emerald-600/30 hover:text-emerald-500 transition-all">
                        ＋ New Instruction Group
                    </button>
                </div>
                <button @onclick="SaveRecipe" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white py-5 rounded-2xl font-black text-xs uppercase tracking-[0.3em] transition-all shadow-xl active:scale-[0.98]">Save Recipe</button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public int? RecipeId { get; set; }
    [SupplyParameterFromQuery] public int? ownerId { get; set; }

    private string currentTab = "Details";
    private PPP_Recipe recipe = new() { Servings = 1, Name = "", ServingSize = "" };
    private List<PPP_Owner> owners = new();
    private List<PPP_Ingredient> masterIngs = new();
    private List<PPP_Ingredient> searchResults = new();
    private IngredientUIModel? activeMapping;
    private List<ToastItem> toasts = new();
    private List<PPP_RecipeInstructionGroup> instructionGroups = new();

    protected override async Task OnInitializedAsync() {
        recipe = new PPP_Recipe { Servings = 1, Name = "", ServingSize = "" };
        owners = await Db.PPP_Owners.AsNoTracking().OrderBy(o => o.BusinessName).ToListAsync();
        masterIngs = await Db.PPP_Ingredients.AsNoTracking().ToListAsync();
        
        if (RecipeId.HasValue) await LoadRecipe(RecipeId.Value);
        else { 
            AddGroup(); 
            if (ownerId.HasValue) recipe.OwnerId = ownerId.Value;
            AddInstructionGroup(); 
        }
    }

    private void AddInstructionGroup() => instructionGroups.Add(new PPP_RecipeInstructionGroup { GroupName = "Instructions", DisplayOrder = instructionGroups.Count });
    private void AddStep(PPP_RecipeInstructionGroup g) => g.Instructions.Add(new PPP_RecipeInstruction { DisplayOrder = g.Instructions.Count });

    private void MoveIngredient(PPP_RecipeIngredientGroup group, IngredientUIModel item, int direction) {
        var list = group.Ingredients.OfType<IngredientUIModel>().OrderBy(i => i.DisplayOrder).ToList();
        int idx = list.IndexOf(item);
        int newIdx = idx + direction;
        if (newIdx < 0 || newIdx >= list.Count) return;
        var swap = list[newIdx];
        int oldOrder = item.DisplayOrder;
        item.DisplayOrder = swap.DisplayOrder;
        swap.DisplayOrder = oldOrder;
    }

    private void MoveInstruction(PPP_RecipeInstructionGroup group, PPP_RecipeInstruction step, int direction) {
        var list = group.Instructions.OrderBy(i => i.DisplayOrder).ToList();
        int idx = list.IndexOf(step);
        int newIdx = idx + direction;
        if (newIdx < 0 || newIdx >= list.Count) return;
        var swap = list[newIdx];
        int oldOrder = step.DisplayOrder;
        step.DisplayOrder = swap.DisplayOrder;
        swap.DisplayOrder = oldOrder;
    }

    private async Task SaveRecipe() {
        if (recipe.OwnerId == 0) { await ShowToast("Select an Owner", true); return; }
        
        try {
            var orphans = new List<(IngredientUIModel UI, PPP_Ingredient Entity)>();
            foreach(var group in recipe.IngredientGroups) {
                foreach(var m in group.Ingredients.OfType<IngredientUIModel>()) {
                    if (m.IngredientId == 0 && !string.IsNullOrWhiteSpace(m.IngredientName)) {
                        double qty = Math.Max(0.001, m.Quantity);
                        var standalone = new PPP_Ingredient { 
                            Name = m.IngredientName, 
                            Unit = m.Unit ?? "", 
                            Calories = m.ScaledCals / qty, 
                            Protein = m.ScaledProt / qty, 
                            Fat = m.ScaledFat / qty, 
                            Carbs = m.ScaledCarb / qty, 
                            Fiber = m.ScaledFiber / qty, 
                            OwnerId = recipe.OwnerId, 
                            CreatedAt = DateTime.UtcNow 
                        };
                        orphans.Add((m, standalone));
                    }
                }
            }

            if (orphans.Any()) {
                Db.ChangeTracker.Clear();
                foreach(var item in orphans) {
                    Db.PPP_Ingredients.Add(item.Entity);
                    await Db.SaveChangesAsync(); 
                    item.UI.IngredientId = item.Entity.Id;
                    item.UI.BaseIngredient = null;
                    Db.Entry(item.Entity).State = EntityState.Detached;
                }
            }

            Db.ChangeTracker.Clear();
            if (recipe.Id == 0) Db.PPP_Recipes.Add(recipe);
            else Db.Entry(recipe).State = EntityState.Modified;
            await Db.SaveChangesAsync();

            foreach (var group in recipe.IngredientGroups) {
                group.RecipeId = recipe.Id;
                if (group.Id == 0) Db.Add(group);
                else Db.Entry(group).State = EntityState.Modified;
                await Db.SaveChangesAsync();

                foreach (var m in group.Ingredients.OfType<IngredientUIModel>()) {
                    m.IngredientGroupId = group.Id; m.BaseIngredient = null;
                    if (m.Id == 0) {
                        await Db.Database.ExecuteSqlRawAsync(
                            "INSERT INTO \"PPP_RecipeIngredientMappings\" (\"IngredientGroupId\", \"IngredientId\", \"Quantity\", \"Unit\", \"Notes\", \"DisplayOrder\") VALUES ({0}, {1}, {2}, {3}, {4}, {5})", 
                            group.Id, m.IngredientId, m.Quantity, m.Unit ?? "", m.Notes ?? "", m.DisplayOrder);
                    } else {
                        await Db.Database.ExecuteSqlRawAsync(
                            "UPDATE \"PPP_RecipeIngredientMappings\" SET \"IngredientGroupId\"={0}, \"IngredientId\"={1}, \"Quantity\"={2}, \"Unit\"={3}, \"Notes\"={4}, \"DisplayOrder\"={5} WHERE \"Id\"={6}", 
                            group.Id, m.IngredientId, m.Quantity, m.Unit ?? "", m.Notes ?? "", m.DisplayOrder, m.Id);
                    }
                }
            }

            foreach (var insGroup in instructionGroups) {
                insGroup.RecipeId = recipe.Id;
                if (insGroup.Id == 0) Db.Add(insGroup);
                else Db.Entry(insGroup).State = EntityState.Modified;
                await Db.SaveChangesAsync();

                foreach (var step in insGroup.Instructions) {
                    step.InstructionGroupId = insGroup.Id;
                    if (step.Id == 0) Db.Add(step);
                    else Db.Entry(step).State = EntityState.Modified;
                }
                await Db.SaveChangesAsync();
            }

            recipe.IngredientGroups.Clear();
            Db.ChangeTracker.Clear();
            _ = ShowToast("Saved.");
            await Task.Delay(800);
            Nav.NavigateTo($"/ppp-recipe-manager/{recipe.OwnerId}", forceLoad: true);
        } catch (Exception ex) {
            Console.WriteLine($"[SAVE ERROR] {ex.Message}");
            await ShowToast("Database sync error. Retry.", true);
        }
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e) {
        try {
            var file = e.File;
            using var ms = new System.IO.MemoryStream();
            await file.OpenReadStream(5120 * 1024).CopyToAsync(ms);
            var img = new PPP_StoredImage { Data = ms.ToArray(), ContentType = file.ContentType, FileName = file.Name, UploadedAt = DateTime.UtcNow };
            Db.PPP_StoredImages.Add(img); await Db.SaveChangesAsync();
            recipe.ImageId = img.Id; await ShowToast("Visual Ready");
        } catch (Exception ex) { await ShowToast(ex.Message, true); }
    }

    private async Task LoadRecipe(int id) {
        var existing = await Db.PPP_Recipes.Include(r => r.IngredientGroups).ThenInclude(ig => ig.Ingredients).FirstOrDefaultAsync(r => r.Id == id);
        if (existing != null) {
            recipe = existing;
            foreach(var group in recipe.IngredientGroups) {
                var uiItems = new List<PPP_RecipeIngredientMapping>();
                foreach(var mapping in group.Ingredients.OrderBy(m => m.DisplayOrder)) {
                    var ui = new IngredientUIModel { Id = mapping.Id, IngredientGroupId = mapping.IngredientGroupId, IngredientId = mapping.IngredientId, Quantity = mapping.Quantity, Unit = mapping.Unit, Notes = mapping.Notes, DisplayOrder = mapping.DisplayOrder, BaseIngredient = masterIngs.FirstOrDefault(i => i.Id == mapping.IngredientId) };
                    ui.IngredientName = ui.BaseIngredient?.Name ?? "Manual Entry"; ui.Scale(); uiItems.Add(ui);
                }
                group.Ingredients = uiItems;
            }
            instructionGroups = await Db.Set<PPP_RecipeInstructionGroup>().Include(g => g.Instructions).Where(g => g.RecipeId == id).OrderBy(g => g.DisplayOrder).ToListAsync();
        }
    }

    private void AddGroup() => recipe.IngredientGroups.Add(new PPP_RecipeIngredientGroup { GroupName = "New Section", DisplayOrder = recipe.IngredientGroups.Count });
    private void AddIngredient(PPP_RecipeIngredientGroup g) => g.Ingredients.Add(new IngredientUIModel { DisplayOrder = g.Ingredients.Count, Unit = "oz" });
    
    private void SearchIng(ChangeEventArgs e, IngredientUIModel m) {
        activeMapping = m;
        var q = e.Value?.ToString()?.Trim() ?? "";
        m.IngredientName = q;
        if (q.Length < 2) { searchResults.Clear(); return; }
        searchResults = masterIngs.Where(i => i.Name.ToLower().Contains(q.ToLower())).Take(5).ToList();
    }

    private async Task HandleBlur(IngredientUIModel m) {
        await Task.Delay(200); 
        var q = m.IngredientName?.Trim() ?? "";
        if (string.IsNullOrEmpty(q)) return;
        var match = masterIngs.FirstOrDefault(i => i.Name.Equals(q, StringComparison.OrdinalIgnoreCase));
        if (match != null) {
            if (m.IngredientId != match.Id) { m.IngredientId = match.Id; m.BaseIngredient = match; m.Unit = match.Unit ?? ""; m.Scale(); }
        } else if (m.IngredientId != 0) {
            m.IngredientId = 0; m.BaseIngredient = null;
        }
        searchResults.Clear(); activeMapping = null;
    }

    private void SelectIng(PPP_Ingredient master, IngredientUIModel mapping) { mapping.IngredientId = master.Id; mapping.IngredientName = master.Name; mapping.Unit = master.Unit ?? ""; mapping.BaseIngredient = master; mapping.Quantity = 1; mapping.Scale(); searchResults.Clear(); activeMapping = null; }
    private void UpdateQty(ChangeEventArgs e, IngredientUIModel m) { if (double.TryParse(e.Value?.ToString(), out var v)) { m.Quantity = v; m.Scale(); } }
    private void UpdateUnit(ChangeEventArgs e, IngredientUIModel m) { m.Unit = e.Value?.ToString() ?? ""; m.Scale(); }

    private double TotalCals => recipe.IngredientGroups.SelectMany(g => g.Ingredients).OfType<IngredientUIModel>().Sum(i => i.ScaledCals);
    private double TotalProt => recipe.IngredientGroups.SelectMany(g => g.Ingredients).OfType<IngredientUIModel>().Sum(i => i.ScaledProt);
    private double TotalFat => recipe.IngredientGroups.SelectMany(g => g.Ingredients).OfType<IngredientUIModel>().Sum(i => i.ScaledFat);
    private double TotalCarb => recipe.IngredientGroups.SelectMany(g => g.Ingredients).OfType<IngredientUIModel>().Sum(i => i.ScaledCarb);
    private double TotalFiber => recipe.IngredientGroups.SelectMany(g => g.Ingredients).OfType<IngredientUIModel>().Sum(i => i.ScaledFiber);
    private double TotalNet => TotalCarb - TotalFiber;

    private async Task ShowToast(string msg, bool isError = false) { var toast = new ToastItem { Message = msg, IsError = isError }; toasts.Add(toast); StateHasChanged(); await Task.Delay(4000); toasts.Remove(toast); StateHasChanged(); }

    public class IngredientUIModel : PPP_RecipeIngredientMapping {
        public string IngredientName { get; set; } = "";
        public PPP_Ingredient? BaseIngredient { get; set; }
        public double ScaledCals { get; set; }
        public double ScaledProt { get; set; }
        public double ScaledFat { get; set; }
        public double ScaledCarb { get; set; }
        public double ScaledFiber { get; set; }

        public void Scale() { 
            if (BaseIngredient == null || IngredientId == 0) return; 
            double calcQty = Quantity;
            if (!string.Equals(Unit, BaseIngredient.Unit, StringComparison.OrdinalIgnoreCase)) {
                if (PPPUnitConverter.TryConvert(Quantity, Unit ?? "", BaseIngredient.Unit ?? "", out double normalized)) calcQty = Math.Round(normalized, 6);
            }
            ScaledCals = Math.Round(BaseIngredient.Calories * calcQty, 2); 
            ScaledProt = Math.Round(BaseIngredient.Protein * calcQty, 2); 
            ScaledFat = Math.Round(BaseIngredient.Fat * calcQty, 2); 
            ScaledCarb = Math.Round(BaseIngredient.Carbs * calcQty, 2); 
            ScaledFiber = Math.Round(BaseIngredient.Fiber * calcQty, 2); 
        }
    }

    private class ToastItem { public string Message { get; set; } = ""; public bool IsError { get; set; } }
}