@page "/ppp-recipe-editor/{RecipeId:int?}"
@using Dashboard
@using Dashboard.Components
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#0a0a0a] text-white p-6 font-black relative overflow-hidden">
    
    <PPPAdminNav CurrentPage="Recipe Architect" />

    @* Notification Stack *@
    <div class="fixed top-24 right-6 z-[100] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-2xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950 border-red-500" : "bg-emerald-950 border-emerald-500")">
                <span class="text-xs uppercase tracking-widest">@toast.Message</span>
            </div>
        }
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-6">
            
            @* Recipe Config *@
            <div class="bg-[#111] p-6 rounded-3xl border border-gray-800 grid grid-cols-12 gap-4">
                <div class="col-span-8">
                    <label class="text-[10px] text-gray-500 uppercase mb-2 block">Recipe Name</label>
                    <input @bind="recipe.Name" placeholder="e.g. Lemon Herb Roasted Chicken" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-orange-500 outline-none" />
                </div>
                <div class="col-span-4">
                    <label class="text-[10px] text-orange-500 uppercase mb-2 block">Servings</label>
                    <input type="number" @bind="recipe.Servings" @bind:event="oninput" min="1" class="w-full bg-black border border-orange-900/50 rounded-xl p-3 text-sm focus:border-orange-500 outline-none font-mono text-center" />
                </div>
                <div class="col-span-12">
                    <label class="text-[10px] text-gray-500 uppercase mb-2 block">Business Owner</label>
                    <select @bind="recipe.OwnerId" class="w-full bg-black border border-gray-800 rounded-xl p-3 text-sm focus:border-orange-500 outline-none">
                        <option value="0" disabled>-- Select Business --</option>
                        @foreach(var o in owners) 
                        { 
                            <option value="@o.Id">@o.BusinessName</option> 
                        }
                    </select>
                </div>
            </div>

            @foreach (var group in recipe.IngredientGroups.OrderBy(g => g.DisplayOrder))
            {
                <div class="bg-[#111] p-6 rounded-3xl border border-gray-800">
                    <div class="flex justify-between items-center mb-6">
                        <input @bind="group.GroupName" class="bg-transparent border-b border-gray-800 text-orange-400 tracking-tight font-black focus:border-orange-500 outline-none" />
                        <button @onclick="() => recipe.IngredientGroups.Remove(group)" class="text-[9px] text-red-500 uppercase">Remove Group</button>
                    </div>

                    <div class="space-y-4">
                        @foreach (IngredientUIModel mapping in group.Ingredients.OfType<IngredientUIModel>())
                        {
                            <div class="bg-black/40 p-4 rounded-xl border border-gray-800 relative group">
                                <div class="grid grid-cols-12 gap-3 items-end">
                                    <div class="col-span-5 relative">
                                        <label class="text-[9px] text-gray-600 mb-1 block">Ingredient search</label>
                                        <input @bind="mapping.IngredientName" @oninput="(e) => SearchIng(e, mapping)" class="w-full bg-black border border-gray-800 rounded p-2 text-xs outline-none focus:border-blue-500" placeholder="Type to search library..." />
                                        @if (activeMapping == mapping && searchResults.Any())
                                        {
                                            <div class="absolute z-50 w-full mt-1 bg-gray-900 border border-gray-700 rounded shadow-2xl max-h-40 overflow-y-auto">
                                                @foreach (var r in searchResults) {
                                                    <div @onclick="() => SelectIng(r, mapping)" class="p-2 text-[10px] hover:bg-orange-600 cursor-pointer border-b border-gray-800 last:border-0">@r.Name (@r.Unit)</div>
                                                }
                                            </div>
                                        }
                                    </div>
                                    <div class="col-span-2">
                                        <label class="text-[9px] text-gray-600 mb-1 block">Qty</label>
                                        <input type="number" step="0.01" value="@mapping.Quantity" @oninput="(e) => UpdateQty(e, mapping)" class="w-full bg-black border border-gray-800 rounded p-2 text-xs text-center font-mono" />
                                    </div>
                                    <div class="col-span-2">
                                        <label class="text-[9px] text-gray-600 mb-1 block">Unit</label>
                                        <input value="@mapping.Unit" @oninput="(e) => UpdateUnit(e, mapping)" class="w-full bg-black border border-gray-800 rounded p-2 text-xs text-center" />
                                    </div>
                                    <div class="col-span-3 text-right">
                                        <button @onclick="() => group.Ingredients.Remove(mapping)" class="text-gray-700 hover:text-red-500 transition">✕</button>
                                    </div>
                                </div>

                                @* Macro Inputs (Editable if IngredientId == 0) *@
                                <div class="mt-3 pt-3 border-t border-white/5 grid grid-cols-5 gap-4">
                                    <div class="flex flex-col">
                                        <span class="text-[8px] text-gray-600 uppercase">Cals</span>
                                        <input type="number" step="0.1" @bind="mapping.ScaledCals" readonly="@(mapping.IngredientId != 0)" class="bg-transparent border-b border-transparent focus:border-blue-500 outline-none text-[11px] font-mono text-orange-400" />
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-[8px] text-gray-600 uppercase">Prot</span>
                                        <input type="number" step="0.1" @bind="mapping.ScaledProt" readonly="@(mapping.IngredientId != 0)" class="bg-transparent border-b border-transparent focus:border-blue-500 outline-none text-[11px] font-mono text-blue-400" />
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-[8px] text-gray-600 uppercase">Fat</span>
                                        <input type="number" step="0.1" @bind="mapping.ScaledFat" readonly="@(mapping.IngredientId != 0)" class="bg-transparent border-b border-transparent focus:border-blue-500 outline-none text-[11px] font-mono text-yellow-500" />
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-[8px] text-gray-600 uppercase">Carb</span>
                                        <input type="number" step="0.1" @bind="mapping.ScaledCarb" readonly="@(mapping.IngredientId != 0)" class="bg-transparent border-b border-transparent focus:border-blue-500 outline-none text-[11px] font-mono text-red-400" />
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-[8px] text-gray-600 uppercase">Fiber</span>
                                        <input type="number" step="0.1" @bind="mapping.ScaledFiber" readonly="@(mapping.IngredientId != 0)" class="bg-transparent border-b border-transparent focus:border-blue-500 outline-none text-[11px] font-mono text-emerald-400" />
                                    </div>
                                </div>
                            </div>
                        }
                        <button @onclick="() => AddIngredient(group)" class="w-full py-2 border border-dashed border-gray-800 rounded-xl text-[10px] text-gray-600 hover:border-gray-600 transition">＋ Add ingredient row</button>
                    </div>
                </div>
            }
            <button @onclick="AddGroup" class="w-full py-4 bg-white/5 border border-gray-800 rounded-3xl text-[11px] text-gray-500 tracking-widest hover:bg-white/10 transition">＋ Create ingredient group</button>
        </div>

        @* Macros Sidebar *@
        <div class="lg:col-span-1">
            <div class="bg-emerald-950/10 border border-emerald-500/20 p-8 rounded-3xl sticky top-24 shadow-2xl">
                <div class="flex justify-between items-center mb-8 border-b border-emerald-500/20 pb-4">
                    <h3 class="text-[11px] tracking-[0.2em] text-emerald-500 uppercase">Recipe batch total</h3>
                    <span class="text-[10px] bg-emerald-500/20 text-emerald-400 px-2 py-0.5 rounded-full font-black">@recipe.Servings Servings</span>
                </div>

                <div class="space-y-6">
                    <div>
                        <div class="flex justify-between items-end mb-1">
                            <span class="text-[10px] text-gray-500">Total Calories</span>
                            <span class="text-2xl font-mono">@TotalCals.ToString("N0")</span>
                        </div>
                        <div class="text-[9px] text-emerald-500/60 text-right font-black uppercase">@((TotalCals / Math.Max(1, recipe.Servings)).ToString("N0")) Per Serving</div>
                    </div>

                    <div>
                        <div class="flex justify-between items-end mb-1">
                            <span class="text-[10px] text-gray-500">Protein</span>
                            <span class="text-lg font-mono text-blue-400">@TotalProt.ToString("N1")g</span>
                        </div>
                        <div class="text-[9px] text-blue-500/60 text-right font-black uppercase">@((TotalProt / Math.Max(1, recipe.Servings)).ToString("N1"))g Per Serving</div>
                    </div>

                    <div>
                        <div class="flex justify-between items-end mb-1">
                            <span class="text-[10px] text-gray-500">Total Fat</span>
                            <span class="text-lg font-mono text-yellow-500">@TotalFat.ToString("N1")g</span>
                        </div>
                        <div class="text-[9px] text-yellow-500/60 text-right font-black uppercase">@((TotalFat / Math.Max(1, recipe.Servings)).ToString("N1"))g Per Serving</div>
                    </div>

                    <div>
                        <div class="flex justify-between items-end mb-1">
                            <span class="text-[10px] text-gray-500">Net Carbs</span>
                            <span class="text-lg font-mono text-emerald-400">@TotalNet.ToString("N1")g</span>
                        </div>
                        <div class="text-[9px] text-emerald-500/60 text-right font-black uppercase">@((TotalNet / Math.Max(1, recipe.Servings)).ToString("N1"))g Per Serving</div>
                    </div>
                </div>

                <button @onclick="SaveRecipe" class="w-full mt-10 bg-emerald-600 hover:bg-emerald-500 py-4 rounded-2xl text-[11px] tracking-widest font-black transition shadow-xl uppercase">Commit Recipe</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int? RecipeId { get; set; }
    private PPP_Recipe recipe = new() { Servings = 1 };
    private List<PPP_Owner> owners = new();
    private List<PPP_Ingredient> masterIngs = new();
    private List<PPP_Ingredient> searchResults = new();
    private IngredientUIModel? activeMapping;
    private List<ToastItem> toasts = new();

    protected override async Task OnInitializedAsync() {
        owners = await Db.PPP_Owners.AsNoTracking().OrderBy(o => o.BusinessName).ToListAsync();
        masterIngs = await Db.PPP_Ingredients.AsNoTracking().ToListAsync();
        if(!RecipeId.HasValue) AddGroup();
    }

    private void AddGroup() => recipe.IngredientGroups.Add(new PPP_RecipeIngredientGroup { GroupName = "New Component", DisplayOrder = recipe.IngredientGroups.Count });
    private void AddIngredient(PPP_RecipeIngredientGroup g) => g.Ingredients.Add(new IngredientUIModel { DisplayOrder = g.Ingredients.Count, Unit = "oz" });

    private void SearchIng(ChangeEventArgs e, IngredientUIModel m) {
        activeMapping = m;
        var q = e.Value?.ToString()?.ToLower() ?? "";
        if (q.Length < 2) { searchResults.Clear(); return; }
        searchResults = masterIngs.Where(i => i.Name.ToLower().Contains(q)).Take(5).ToList();
    }

    private void SelectIng(PPP_Ingredient master, IngredientUIModel mapping) {
        mapping.IngredientId = master.Id;
        mapping.IngredientName = master.Name;
        mapping.Unit = master.Unit ?? "";
        mapping.BaseIngredient = master;
        mapping.Quantity = 1;
        mapping.Scale();
        searchResults.Clear();
        activeMapping = null;
    }

    private void UpdateQty(ChangeEventArgs e, IngredientUIModel mapping) {
        if (double.TryParse(e.Value?.ToString(), out var v)) { mapping.Quantity = v; mapping.Scale(); }
    }

    private void UpdateUnit(ChangeEventArgs e, IngredientUIModel m) {
        m.Unit = e.Value?.ToString() ?? "";
        if (m.BaseIngredient != null && m.Unit != m.BaseIngredient.Unit) m.IngredientId = 0; 
        else if (m.BaseIngredient != null && m.Unit == m.BaseIngredient.Unit) { m.IngredientId = m.BaseIngredient.Id; m.Scale(); }
    }

    private double TotalCals => recipe.IngredientGroups.SelectMany(g => g.Ingredients).OfType<IngredientUIModel>().Sum(i => i.ScaledCals);
    private double TotalProt => recipe.IngredientGroups.SelectMany(g => g.Ingredients).OfType<IngredientUIModel>().Sum(i => i.ScaledProt);
    private double TotalFat => recipe.IngredientGroups.SelectMany(g => g.Ingredients).OfType<IngredientUIModel>().Sum(i => i.ScaledFat);
    private double TotalNet => recipe.IngredientGroups.SelectMany(g => g.Ingredients).OfType<IngredientUIModel>().Sum(i => i.ScaledCarb - i.ScaledFiber);

    private async Task SaveRecipe() {
        if (recipe.OwnerId == 0) { await ShowToast("Select a Business Owner", true); return; }
        try {
            if (recipe.Id == 0) Db.PPP_Recipes.Add(recipe);
            else Db.Update(recipe);
            await Db.SaveChangesAsync();
            Nav.NavigateTo("/ppp-dashboard");
        } catch (Exception ex) { await ShowToast("Error: " + ex.Message, true); }
    }

    private async Task ShowToast(string msg, bool isError = false) {
        var toast = new ToastItem { Message = msg, IsError = isError };
        toasts.Add(toast); StateHasChanged();
        await Task.Delay(4000);
        toasts.Remove(toast); StateHasChanged();
    }

    public class IngredientUIModel : PPP_RecipeIngredientMapping {
        public string IngredientName { get; set; } = "";
        public PPP_Ingredient? BaseIngredient { get; set; }
        public double ScaledCals { get; set; }
        public double ScaledProt { get; set; }
        public double ScaledFat { get; set; }
        public double ScaledCarb { get; set; }
        public double ScaledFiber { get; set; }
        public void Scale() {
            if (BaseIngredient == null || IngredientId == 0) return;
            ScaledCals = Math.Round(BaseIngredient.Calories * Quantity, 2);
            ScaledProt = Math.Round(BaseIngredient.Protein * Quantity, 2);
            ScaledFat = Math.Round(BaseIngredient.Fat * Quantity, 2);
            ScaledCarb = Math.Round(BaseIngredient.Carbs * Quantity, 2);
            ScaledFiber = Math.Round(BaseIngredient.Fiber * Quantity, 2);
        }
    }
    private class ToastItem { public string Message { get; set; } = ""; public bool IsError { get; set; } }
}