@page "/ppp-dashboard"
@using Dashboard
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#0a0a0a] text-white p-6 font-black relative overflow-hidden">
    
    @* TOAST NOTIFICATION STACK *@
    <div class="fixed top-24 right-6 z-[100] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-2xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950/90 border-red-500 text-red-200" : "bg-emerald-950/90 border-emerald-500 text-emerald-200")">
                <div class="flex items-center gap-3">
                    <span>@(toast.IsError ? "❌" : "✅")</span>
                    <span class="text-xs uppercase tracking-widest">@toast.Message</span>
                </div>
            </div>
        }
    </div>

    @* STANDALONE HEADER *@
    <div class="flex justify-between items-center mb-10 bg-[#111] p-4 rounded-2xl border border-gray-800 shadow-xl">
        <div class="flex items-center gap-4">
            <span class="text-3xl">👨‍🍳</span>
            <div>
                <h1 class="text-xl uppercase tracking-tighter">PickPrepPlate</h1>
                <p class="text-[9px] text-emerald-500 uppercase tracking-widest">System Administration</p>
            </div>
        </div>
        <div class="flex gap-4 flex-wrap justify-end">
            <a href="/ppp-ingredient-admin" class="bg-orange-600 hover:bg-orange-500 text-white px-4 py-2 rounded-xl text-[10px] uppercase tracking-widest transition shadow-lg flex items-center justify-center">
                Ingredients
            </a>
            <a href="/ppp-owner-admin" class="bg-emerald-600 hover:bg-emerald-500 text-white px-4 py-2 rounded-xl text-[10px] uppercase tracking-widest transition shadow-lg flex items-center justify-center">
                Owners
            </a>
            <a href="/ppp-user-admin" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-xl text-[10px] uppercase tracking-widest transition shadow-lg flex items-center justify-center">
                Users
            </a>
            <button @onclick="InitializePPP" disabled="@isProcessing" class="relative bg-purple-600 hover:bg-purple-500 text-white px-6 py-2 rounded-xl text-[10px] uppercase tracking-widest transition disabled:opacity-50 min-w-[140px]">
                @if (isProcessing)
                {
                    <div class="absolute inset-0 flex items-center justify-center">
                        <div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
                    </div>
                    <span class="opacity-0">Processing</span>
                }
                else
                {
                    <span>Setup DB & Seed</span>
                }
            </button>
            <a href="/" class="bg-gray-800 hover:bg-gray-700 text-white px-4 py-2 rounded-xl text-[10px] uppercase tracking-widest transition border border-gray-700 flex items-center justify-center">
                Exit
            </a>
        </div>
    </div>

    @* DASHBOARD KPI CARDS *@
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <div class="bg-[#111] border border-emerald-900/50 p-6 rounded-3xl shadow-xl hover:scale-[1.02] transition">
            <div class="text-[10px] text-emerald-500 uppercase tracking-widest mb-2">Total Owners</div>
            <div class="text-3xl tracking-tighter">@ownerCount</div>
            <div class="text-xs text-gray-500 mt-2">Active Multi-Tenants</div>
        </div>

        <div class="bg-[#111] border border-blue-900/50 p-6 rounded-3xl shadow-xl hover:scale-[1.02] transition">
            <div class="text-[10px] text-blue-500 uppercase tracking-widest mb-2">Total Users</div>
            <div class="text-3xl tracking-tighter">@pppUsers.Count</div>
            <div class="text-xs text-gray-500 mt-2">Customers & Staff</div>
        </div>

        <div class="bg-[#111] border border-orange-900/50 p-6 rounded-3xl shadow-xl hover:scale-[1.02] transition">
            <div class="text-[10px] text-orange-500 uppercase tracking-widest mb-2">Ingredient Master</div>
            <div class="text-3xl tracking-tighter font-mono">@ingredientCount</div>
            <div class="text-xs text-gray-500 mt-2">Global Library Items</div>
        </div>
    </div>

    @* USER LIST VERIFICATION *@
    <div class="bg-[#111] border border-gray-800 rounded-3xl p-8 mb-10 shadow-2xl">
        <div class="flex justify-between items-end mb-6">
            <div>
                <h3 class="text-xl uppercase tracking-tighter">Active System Users</h3>
                <p class="text-[10px] text-gray-500 uppercase tracking-widest mt-1">Registry Synchronization Check</p>
            </div>
        </div>

        @if (isLoadingData)
        {
            <div class="py-10 flex flex-col items-center justify-center gap-4">
                <div class="w-8 h-8 border-2 border-purple-500 border-t-transparent rounded-full animate-spin"></div>
                <div class="text-[10px] uppercase tracking-[0.3em] text-gray-600">Syncing_Records...</div>
            </div>
        }
        else if (!pppUsers.Any())
        {
            <div class="py-10 text-center border-2 border-dashed border-gray-800 rounded-2xl">
                <div class="text-4xl mb-3">🕵️‍♂️</div>
                <div class="text-xs text-gray-500 uppercase tracking-widest">No records found. Initialize database to begin.</div>
            </div>
        }
        else
        {
            <div class="overflow-x-auto rounded-2xl border border-gray-800 bg-black/20">
                <table class="w-full text-left">
                    <thead>
                        <tr class="text-[10px] font-black uppercase text-gray-500 bg-gray-900/50">
                            <th class="p-4 border-r border-gray-800/50">ID</th>
                            <th class="p-4">Identity</th>
                            <th class="p-4">Contact</th>
                            <th class="p-4">Role</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm divide-y divide-gray-800/50">
                        @foreach (var user in pppUsers)
                        {
                            <tr class="hover:bg-white/5 transition">
                                <td class="p-4 font-mono text-gray-600 border-r border-gray-800/50">#@user.Id</td>
                                <td class="p-4 uppercase tracking-tight font-black text-white">@user.FirstName @user.LastName</td>
                                <td class="p-4 font-mono text-xs text-gray-400">@user.Email</td>
                                <td class="p-4">
                                    <span class="px-2 py-0.5 rounded text-[9px] font-black uppercase @(user.Role == "Admin" ? "bg-red-900/30 text-red-400 border border-red-800" : "bg-blue-900/30 text-blue-400 border border-blue-800")">
                                        @user.Role
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private bool isProcessing = false;
    private bool isLoadingData = true;
    private int ownerCount = 0;
    private int ingredientCount = 0;
    private List<ToastItem> toasts = new();
    private List<PPP_User> pppUsers = new();

    private class ToastItem 
    {
        public string Message { get; set; } = "";
        public bool IsError { get; set; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadSystemStats();
        }
    }

    private async Task LoadSystemStats()
    {
        isLoadingData = true;
        StateHasChanged();

        try 
        {
            pppUsers = await Db.PPP_Users.AsNoTracking().OrderBy(u => u.LastName).ToListAsync();
            ownerCount = await Db.PPP_Owners.CountAsync();
            ingredientCount = await Db.PPP_Ingredients.CountAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"PPP Load Error: {ex.Message}");
        }

        isLoadingData = false;
        StateHasChanged();
    }

    private async Task ShowToast(string msg, bool isError = false)
    {
        var toast = new ToastItem { Message = msg, IsError = isError };
        toasts.Add(toast);
        StateHasChanged();
        await Task.Delay(4000);
        toasts.Remove(toast);
        StateHasChanged();
    }

    private async Task InitializePPP()
    {
        if (isProcessing) return;
        isProcessing = true;
        StateHasChanged();

        try 
        {
            // 1. Core Shared Tables
            await Db.Database.ExecuteSqlRawAsync(@"
                CREATE TABLE IF NOT EXISTS ""PPP_StoredImages"" (
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
                    ""Data"" bytea NOT NULL,
                    ""ContentType"" text NOT NULL,
                    ""FileName"" text NOT NULL,
                    ""UploadedAt"" timestamp with time zone NOT NULL
                );
                CREATE TABLE IF NOT EXISTS ""PPP_Addresses"" (
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
                    ""Street"" text NOT NULL,
                    ""City"" text NOT NULL,
                    ""State"" text NOT NULL,
                    ""ZipCode"" text NOT NULL,
                    ""Apartment"" text NULL,
                    ""DeliveryInstructions"" text NULL
                );");

            // 2. Main Entities
            await Db.Database.ExecuteSqlRawAsync(@"
                CREATE TABLE IF NOT EXISTS ""PPP_Owners"" (
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
                    ""BusinessName"" text NOT NULL,
                    ""OwnerName"" text NOT NULL,
                    ""Email"" text NOT NULL,
                    ""Phone"" text NOT NULL,
                    ""Bio"" text NOT NULL,
                    ""CreatedAt"" timestamp with time zone NOT NULL,
                    ""LogoId"" integer REFERENCES ""PPP_StoredImages""(""Id"") ON DELETE SET NULL,
                    ""AddressId"" integer REFERENCES ""PPP_Addresses""(""Id"") ON DELETE SET NULL
                );
                CREATE TABLE IF NOT EXISTS ""PPP_Users"" (
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
                    ""FirstName"" text NOT NULL,
                    ""LastName"" text NOT NULL,
                    ""Email"" text NOT NULL,
                    ""Phone"" text NOT NULL,
                    ""Role"" text NOT NULL,
                    ""CreatedAt"" timestamp with time zone NOT NULL,
                    ""RewardPoints"" integer NOT NULL DEFAULT 0,
                    ""PreferredPlan"" text NULL,
                    ""AvatarId"" integer REFERENCES ""PPP_StoredImages""(""Id"") ON DELETE SET NULL,
                    ""AddressId"" integer REFERENCES ""PPP_Addresses""(""Id"") ON DELETE SET NULL
                );");

            // 3. Ingredient Master
            await Db.Database.ExecuteSqlRawAsync(@"
                CREATE TABLE IF NOT EXISTS ""PPP_Ingredients"" (
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
                    ""Name"" text NOT NULL,
                    ""Unit"" text NULL,
                    ""Calories"" double precision NOT NULL,
                    ""Protein"" double precision NOT NULL,
                    ""Fat"" double precision NOT NULL,
                    ""Carbs"" double precision NOT NULL,
                    ""Fiber"" double precision NOT NULL,
                    ""OwnerId"" integer REFERENCES ""PPP_Owners""(""Id"") ON DELETE SET NULL,
                    ""CreatedAt"" timestamp with time zone NOT NULL
                );");

            // 4. Recipe Engine
            await Db.Database.ExecuteSqlRawAsync(@"
                CREATE TABLE IF NOT EXISTS ""PPP_Recipes"" (
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
                    ""Name"" text NOT NULL,
                    ""Description"" text NOT NULL,
                    ""OwnerId"" integer REFERENCES ""PPP_Owners""(""Id"") ON DELETE SET NULL
                );
                CREATE TABLE IF NOT EXISTS ""PPP_RecipeIngredientGroups"" (
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
                    ""RecipeId"" integer REFERENCES ""PPP_Recipes""(""Id"") ON DELETE CASCADE,
                    ""GroupName"" text NOT NULL,
                    ""DisplayOrder"" integer NOT NULL
                );
                CREATE TABLE IF NOT EXISTS ""PPP_RecipeIngredientMappings"" (
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
                    ""IngredientGroupId"" integer REFERENCES ""PPP_RecipeIngredientGroups""(""Id"") ON DELETE CASCADE,
                    ""IngredientId"" integer REFERENCES ""PPP_Ingredients""(""Id"") ON DELETE CASCADE,
                    ""Quantity"" double precision NOT NULL,
                    ""Unit"" text NOT NULL,
                    ""Notes"" text NOT NULL,
                    ""DisplayOrder"" integer NOT NULL
                );
                CREATE TABLE IF NOT EXISTS ""PPP_RecipeInstructionGroups"" (
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
                    ""RecipeId"" integer REFERENCES ""PPP_Recipes""(""Id"") ON DELETE CASCADE,
                    ""GroupName"" text NOT NULL,
                    ""DisplayOrder"" integer NOT NULL
                );
                CREATE TABLE IF NOT EXISTS ""PPP_RecipeInstructions"" (
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
                    ""InstructionGroupId"" integer REFERENCES ""PPP_RecipeInstructionGroups""(""Id"") ON DELETE CASCADE,
                    ""StepDescription"" text NOT NULL,
                    ""DisplayOrder"" integer NOT NULL
                );");

            // 5. Seed if empty
            if (!await Db.PPP_Users.AnyAsync())
            {
                var seed = new PPP_User { 
                    FirstName = "Stephens", 
                    LastName = "Allen Johnson", 
                    Email = "stephens@example.com", 
                    Phone="903-555-1212", 
                    Role = "Admin", 
                    CreatedAt = DateTime.UtcNow 
                };
                Db.PPP_Users.Add(seed);
                await Db.SaveChangesAsync();
                await ShowToast("Database initialized and seeded.");
            }
            else 
            {
                await ShowToast("Database verified.");
            }

            await LoadSystemStats();
        }
        catch (Exception ex)
        {
            await ShowToast("Init Error: " + ex.Message, true);
            Console.WriteLine($"PPP Init Error: {ex}");
        }
        finally 
        {
            isProcessing = false;
            StateHasChanged();
        }
    }
}