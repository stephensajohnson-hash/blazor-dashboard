@page "/ppp-dashboard"
@using Dashboard
@using Dashboard.Components
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#0a0a0a] text-white p-6 font-black relative overflow-hidden">
    
    @* SHARED ADMIN NAVIGATION *@
    <PPPAdminNav CurrentPage="System Overview" />

    @* TOAST NOTIFICATION STACK *@
    <div class="fixed top-24 right-6 z-[100] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-2xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950 border-red-500 text-red-200" : "bg-emerald-950 border-emerald-500 text-emerald-200")">
                <div class="flex items-center gap-3">
                    <span>@(toast.IsError ? "❌" : "✅")</span>
                    <span class="text-xs uppercase tracking-widest">@toast.Message</span>
                </div>
            </div>
        }
    </div>

    @* DASHBOARD KPI CARDS *@
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-10">
        <div class="bg-[#111] border border-emerald-900/50 p-6 rounded-3xl shadow-xl hover:scale-[1.02] transition">
            <div class="text-[10px] text-emerald-500 uppercase tracking-widest mb-2">Total Owners</div>
            <div class="text-3xl tracking-tighter">@ownerCount</div>
            <div class="text-xs text-gray-500 mt-2">Active Multi-Tenants</div>
        </div>

        <div class="bg-[#111] border border-blue-900/50 p-6 rounded-3xl shadow-xl hover:scale-[1.02] transition">
            <div class="text-[10px] text-blue-500 uppercase tracking-widest mb-2">Total Users</div>
            <div class="text-3xl tracking-tighter">@pppUsers.Count</div>
            <div class="text-xs text-gray-500 mt-2">Customers & Staff</div>
        </div>

        <div class="bg-[#111] border border-orange-900/50 p-6 rounded-3xl shadow-xl hover:scale-[1.02] transition">
            <div class="text-[10px] text-orange-500 uppercase tracking-widest mb-2">Ingredient Master</div>
            <div class="text-3xl tracking-tighter font-mono">@ingredientCount</div>
            <div class="text-xs text-gray-500 mt-2">Global Library Items</div>
        </div>

        <div class="bg-[#111] border border-purple-900/50 p-6 rounded-3xl shadow-xl hover:scale-[1.02] transition cursor-pointer" @onclick='() => Nav.NavigateTo("/ppp-recipe-manager")'>
            <div class="text-[10px] text-purple-500 uppercase tracking-widest mb-2">Recipe Engine</div>
            <div class="text-3xl tracking-tighter">Manage</div>
            <div class="text-xs text-gray-500 mt-2">Build & Scale Recipes</div>
        </div>
    </div>

    @* DATABASE MAINTENANCE SECTION *@
    <div class="mb-10 p-6 bg-[#111] border border-gray-800 rounded-3xl shadow-xl flex justify-between items-center">
        <div>
            <h3 class="text-lg uppercase tracking-tighter">Database Maintenance</h3>
            <p class="text-[9px] text-gray-500 uppercase tracking-widest">Execute schema validation and seed global ingredients</p>
        </div>
        <button @onclick="InitializePPP" disabled="@isProcessing" class="relative bg-purple-600 hover:bg-purple-500 text-white px-8 py-3 rounded-xl text-[10px] uppercase tracking-widest transition disabled:opacity-50 min-w-[160px]">
            @if (isProcessing)
            {
                <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
                </div>
                <span class="opacity-0">Processing</span>
            }
            else
            {
                <span>Fix DB & Seed</span>
            }
        </button>
    </div>

    @* USER LIST VERIFICATION *@
    <div class="bg-[#111] border border-gray-800 rounded-3xl p-8 mb-10 shadow-2xl">
        <h3 class="text-xl uppercase tracking-tighter mb-6">Active System Users</h3>
        @if (isLoadingData)
        {
            <div class="py-10 flex flex-col items-center justify-center gap-4">
                <div class="w-8 h-8 border-2 border-purple-500 border-t-transparent rounded-full animate-spin"></div>
            </div>
        }
        else
        {
            <div class="overflow-x-auto rounded-2xl border border-gray-800 bg-black/20">
                <table class="w-full text-left">
                    <thead>
                        <tr class="text-[10px] font-black uppercase text-gray-500 bg-gray-900/50">
                            <th class="p-4 border-r border-gray-800/50">ID</th>
                            <th class="p-4">Identity</th>
                            <th class="p-4">Contact</th>
                            <th class="p-4 text-right">Role</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm divide-y divide-gray-800/50">
                        @foreach (var user in pppUsers)
                        {
                            <tr class="hover:bg-white/5 transition">
                                <td class="p-4 font-mono text-gray-600 border-r border-gray-800/50">#@user.Id</td>
                                <td class="p-4 uppercase tracking-tight font-black text-white">@user.FirstName @user.LastName</td>
                                <td class="p-4 font-mono text-xs text-gray-400">@user.Email</td>
                                <td class="p-4 text-right">
                                    <span class="px-2 py-0.5 rounded text-[9px] font-black uppercase @(user.Role == "Admin" ? "bg-red-900/30 text-red-400 border border-red-800" : "bg-blue-900/30 text-blue-400 border border-blue-800")">
                                        @user.Role
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private bool isProcessing = false;
    private bool isLoadingData = true;
    private int ownerCount = 0;
    private int ingredientCount = 0;
    private List<ToastItem> toasts = new();
    private List<PPP_User> pppUsers = new();

    private class ToastItem { public string Message { get; set; } = ""; public bool IsError { get; set; } }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await LoadSystemStats();
    }

    private async Task LoadSystemStats()
    {
        isLoadingData = true;
        try 
        {
            pppUsers = await Db.PPP_Users.AsNoTracking().OrderBy(u => u.LastName).ToListAsync();
            ownerCount = await Db.PPP_Owners.CountAsync();
            ingredientCount = await Db.PPP_Ingredients.CountAsync();
        }
        catch (Exception) { }
        isLoadingData = false;
        StateHasChanged();
    }

    private async Task ShowToast(string msg, bool isError = false)
    {
        var toast = new ToastItem { Message = msg, IsError = isError };
        toasts.Add(toast); StateHasChanged();
        await Task.Delay(4000);
        toasts.Remove(toast); StateHasChanged();
    }

    private async Task InitializePPP()
    {
        if (isProcessing) return;
        isProcessing = true;
        StateHasChanged();

        try 
        {
            // 1. Core Shared Tables
            await Db.Database.ExecuteSqlRawAsync(@"
                CREATE TABLE IF NOT EXISTS ""PPP_StoredImages"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""Data"" bytea NOT NULL, ""ContentType"" text NOT NULL, ""FileName"" text NOT NULL, ""UploadedAt"" timestamp with time zone NOT NULL );
                CREATE TABLE IF NOT EXISTS ""PPP_Addresses"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""Street"" text NOT NULL, ""City"" text NOT NULL, ""State"" text NOT NULL, ""ZipCode"" text NOT NULL, ""Apartment"" text NULL, ""DeliveryInstructions"" text NULL );
                CREATE TABLE IF NOT EXISTS ""PPP_Owners"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""BusinessName"" text NOT NULL, ""OwnerName"" text NOT NULL, ""Email"" text NOT NULL, ""Phone"" text NOT NULL, ""Bio"" text NOT NULL, ""CreatedAt"" timestamp with time zone NOT NULL, ""LogoId"" integer REFERENCES ""PPP_StoredImages""(""Id"") ON DELETE SET NULL, ""AddressId"" integer REFERENCES ""PPP_Addresses""(""Id"") ON DELETE SET NULL );
                CREATE TABLE IF NOT EXISTS ""PPP_Users"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""FirstName"" text NOT NULL, ""LastName"" text NOT NULL, ""Email"" text NOT NULL, ""Phone"" text NOT NULL, ""Role"" text NOT NULL, ""CreatedAt"" timestamp with time zone NOT NULL, ""RewardPoints"" integer NOT NULL DEFAULT 0, ""PreferredPlan"" text NULL, ""AvatarId"" integer REFERENCES ""PPP_StoredImages""(""Id"") ON DELETE SET NULL, ""AddressId"" integer REFERENCES ""PPP_Addresses""(""Id"") ON DELETE SET NULL );
                CREATE TABLE IF NOT EXISTS ""PPP_Ingredients"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""Name"" text NOT NULL, ""Unit"" text NULL, ""Calories"" double precision NOT NULL, ""Protein"" double precision NOT NULL, ""Fat"" double precision NOT NULL, ""Carbs"" double precision NOT NULL, ""Fiber"" double precision NOT NULL, ""OwnerId"" integer REFERENCES ""PPP_Owners""(""Id"") ON DELETE SET NULL, ""CreatedAt"" timestamp with time zone NOT NULL );
            ");

            // 2. Recipe Engine & Schema Patches
            await Db.Database.ExecuteSqlRawAsync(@"
                CREATE TABLE IF NOT EXISTS ""PPP_Recipes"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""Name"" text NOT NULL, ""Description"" text NOT NULL, ""OwnerId"" integer NOT NULL REFERENCES ""PPP_Owners""(""Id"") ON DELETE CASCADE );
                
                DO $$ BEGIN 
                    IF NOT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_name='PPP_Recipes' AND column_name='Servings') THEN
                        ALTER TABLE ""PPP_Recipes"" ADD COLUMN ""Servings"" integer NOT NULL DEFAULT 1;
                    END IF;

                    IF NOT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_name='PPP_Recipes' AND column_name='ServingSize') THEN
                        ALTER TABLE ""PPP_Recipes"" ADD COLUMN ""ServingSize"" text NOT NULL DEFAULT '';
                    END IF;

                    IF NOT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_name='PPP_Recipes' AND column_name='ImageId') THEN
                        ALTER TABLE ""PPP_Recipes"" ADD COLUMN ""ImageId"" integer REFERENCES ""PPP_StoredImages""(""Id"") ON DELETE SET NULL;
                    END IF;
                END $$;

                CREATE TABLE IF NOT EXISTS ""PPP_RecipeIngredientGroups"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""RecipeId"" integer NOT NULL REFERENCES ""PPP_Recipes""(""Id"") ON DELETE CASCADE, ""GroupName"" text NOT NULL, ""DisplayOrder"" integer NOT NULL );
                CREATE TABLE IF NOT EXISTS ""PPP_RecipeIngredientMappings"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""IngredientGroupId"" integer NOT NULL REFERENCES ""PPP_RecipeIngredientGroups""(""Id"") ON DELETE CASCADE, ""IngredientId"" integer REFERENCES ""PPP_Ingredients""(""Id"") ON DELETE CASCADE, ""Quantity"" double precision NOT NULL, ""Unit"" text NOT NULL, ""Notes"" text NOT NULL, ""DisplayOrder"" integer NOT NULL );
                CREATE TABLE IF NOT EXISTS ""PPP_RecipeInstructionGroups"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""RecipeId"" integer NOT NULL REFERENCES ""PPP_Recipes""(""Id"") ON DELETE CASCADE, ""GroupName"" text NOT NULL, ""DisplayOrder"" integer NOT NULL );
                CREATE TABLE IF NOT EXISTS ""PPP_RecipeInstructions"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""InstructionGroupId"" integer NOT NULL REFERENCES ""PPP_RecipeInstructionGroups""(""Id"") ON DELETE CASCADE, ""StepDescription"" text NOT NULL, ""DisplayOrder"" integer NOT NULL );
                CREATE TABLE IF NOT EXISTS ""PPP_Orders"" (
                    ""Id"" SERIAL PRIMARY KEY,
                    ""OwnerId"" integer NOT NULL,
                    ""CustomerIdentifier"" text NOT NULL,
                    ""CreatedAt"" timestamp with time zone NOT NULL,
                    ""IsCheckedOut"" boolean NOT NULL DEFAULT false,
                    ""CheckedOutAt"" timestamp with time zone
                );

                CREATE TABLE IF NOT EXISTS ""PPP_OrderItems"" (
                    ""Id"" SERIAL PRIMARY KEY,
                    ""OrderId"" integer REFERENCES ""PPP_Orders""(""Id"") ON DELETE CASCADE,
                    ""MenuItemId"" integer NOT NULL,
                    ""RecipeName"" text NOT NULL,
                    ""SizeName"" text NOT NULL,
                    ""BasePrice"" float8 NOT NULL,
                    ""ScheduledDate"" timestamp with time zone NOT NULL
                );

                CREATE TABLE IF NOT EXISTS ""PPP_OrderItemOptions"" (
                    ""Id"" SERIAL PRIMARY KEY,
                    ""OrderItemId"" integer REFERENCES ""PPP_OrderItems""(""Id"") ON DELETE CASCADE,
                    ""OptionName"" text NOT NULL,
                    ""AddOnPrice"" float8 NOT NULL
                );
            ");

            // 3. Menu Engine (NEW)
            // Inside InitializePPP() under section 3. Menu Engine
            await Db.Database.ExecuteSqlRawAsync(@"
                CREATE TABLE IF NOT EXISTS ""PPP_Menus"" ( 
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, 
                    ""OwnerId"" integer NOT NULL REFERENCES ""PPP_Owners""(""Id"") ON DELETE CASCADE, 
                    ""Name"" text NOT NULL, 
                    ""StartDate"" timestamp with time zone NOT NULL, 
                    ""EndDate"" timestamp with time zone NOT NULL 
                );

                CREATE TABLE IF NOT EXISTS ""PPP_MenuItems"" ( 
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, 
                    ""MenuId"" integer NOT NULL REFERENCES ""PPP_Menus""(""Id"") ON DELETE CASCADE, 
                    ""RecipeId"" integer NOT NULL REFERENCES ""PPP_Recipes""(""Id"") ON DELETE CASCADE, 
                    ""StartDate"" timestamp with time zone NOT NULL, 
                    ""EndDate"" timestamp with time zone NOT NULL 
                );

                CREATE TABLE IF NOT EXISTS ""PPP_MenuItemTimeframes"" ( 
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, 
                    ""MenuItemId"" integer NOT NULL REFERENCES ""PPP_MenuItems""(""Id"") ON DELETE CASCADE, 
                    ""Name"" text NOT NULL, 
                    ""TimeRange"" text NOT NULL 
                );

                CREATE TABLE IF NOT EXISTS ""PPP_MenuItemSizes"" (
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
                    ""MenuItemId"" integer NOT NULL REFERENCES ""PPP_MenuItems""(""Id"") ON DELETE CASCADE,
                    ""Name"" text NOT NULL,
                    ""BasePrice"" double precision NOT NULL
                );

                CREATE TABLE IF NOT EXISTS ""PPP_MenuItemOptions"" (
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
                    ""MenuItemSizeId"" integer NOT NULL REFERENCES ""PPP_MenuItemSizes""(""Id"") ON DELETE CASCADE,
                    ""Name"" text NOT NULL,
                    ""AddOnPrice"" double precision NOT NULL
                );
            ");

            await Db.Database.ExecuteSqlRawAsync(@"
                DO $$ 
                BEGIN 
                    IF NOT EXISTS (SELECT 1 FROM information_schema.columns 
                                WHERE table_name='PPP_Menus' AND column_name='IsPublished') THEN
                        ALTER TABLE ""PPP_Menus"" ADD COLUMN ""IsPublished"" boolean NOT NULL DEFAULT false;
                    END IF;
                END $$;
            ");

            await SeedIngredients();

            if (!await Db.PPP_Users.AnyAsync())
            {
                var seed = new PPP_User { FirstName = "Stephens", LastName = "Allen Johnson", Email = "stephens@example.com", Phone="903-555-1212", Role = "Admin", CreatedAt = DateTime.UtcNow };
                Db.PPP_Users.Add(seed);
                await Db.SaveChangesAsync();
            }

            await LoadSystemStats();
            await ShowToast("System Synced Successfully");
        }
        catch (Exception ex)
        {
            await ShowToast("Sync Error: " + ex.Message, true);
        }
        finally 
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task SeedIngredients()
    {
        var library = new List<PPP_Ingredient>
        {
            new() { Name = "Salt", Unit = "tsp", Calories = 0, Protein = 0, Fat = 0, Carbs = 0, Fiber = 0 }
        };

        foreach (var item in library)
        {
            if (!await Db.PPP_Ingredients.AnyAsync(i => i.Name == item.Name))
            {
                item.CreatedAt = DateTime.UtcNow;
                Db.PPP_Ingredients.Add(item);
            }
        }
        await Db.SaveChangesAsync();
    }
}