@page "/ppp-dashboard"
@using Dashboard
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#0a0a0a] text-white p-6 font-black relative overflow-hidden">
    
    @* TOAST NOTIFICATION STACK *@
    <div class="fixed top-24 right-6 z-[100] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-2xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950/90 border-red-500 text-red-200" : "bg-emerald-950/90 border-emerald-500 text-emerald-200")">
                <div class="flex items-center gap-3">
                    <span>@(toast.IsError ? "❌" : "✅")</span>
                    <span class="text-xs uppercase tracking-widest">@toast.Message</span>
                </div>
            </div>
        }
    </div>

    @* STANDALONE HEADER *@
    <div class="flex justify-between items-center mb-10 bg-[#111] p-4 rounded-2xl border border-gray-800 shadow-xl">
        <div class="flex items-center gap-4">
            <span class="text-3xl">👨‍🍳</span>
            <div>
                <h1 class="text-xl uppercase tracking-tighter">PickPrepPlate</h1>
                <p class="text-[9px] text-emerald-500 uppercase tracking-widest">Customer Portal</p>
            </div>
        </div>
        <div class="flex gap-4">
            <a href="/ppp-user-admin" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-xl text-[10px] uppercase tracking-widest transition shadow-lg flex items-center justify-center">
                Manage Users
            </a>
            <button @onclick="InitializePPP" disabled="@isProcessing" class="relative bg-purple-600 hover:bg-purple-500 text-white px-6 py-2 rounded-xl text-[10px] uppercase tracking-widest transition disabled:opacity-50 min-w-[140px]">
                @if (isProcessing)
                {
                    <div class="absolute inset-0 flex items-center justify-center">
                        <div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
                    </div>
                    <span class="opacity-0">Processing</span>
                }
                else
                {
                    <span>Setup DB & Seed</span>
                }
            </button>
            <a href="/" class="bg-gray-800 hover:bg-gray-700 text-white px-4 py-2 rounded-xl text-[10px] uppercase tracking-widest transition border border-gray-700 flex items-center justify-center">
                Back to Dashboard
            </a>
        </div>
    </div>

    @* DASHBOARD KPI CARDS *@
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <div class="bg-[#111] border border-emerald-900/50 p-6 rounded-3xl shadow-xl hover:scale-[1.02] transition">
            <div class="text-[10px] text-emerald-500 uppercase tracking-widest mb-2">Next Pickup</div>
            <div class="text-3xl tracking-tighter">Sunday, April 12th</div>
            <div class="text-xs text-gray-500 mt-2">4 Meals Scheduled</div>
        </div>

        <div class="bg-[#111] border border-blue-900/50 p-6 rounded-3xl shadow-xl hover:scale-[1.02] transition">
            <div class="text-[10px] text-blue-500 uppercase tracking-widest mb-2">Active Plan</div>
            <div class="text-3xl tracking-tighter">Clean Eating 10</div>
            <div class="text-xs text-gray-500 mt-2">$125.00 / Week</div>
        </div>

        <div class="bg-[#111] border border-purple-900/50 p-6 rounded-3xl shadow-xl hover:scale-[1.02] transition">
            <div class="text-[10px] text-purple-500 uppercase tracking-widest mb-2">Rewards Points</div>
            <div class="text-3xl tracking-tighter font-mono">1,250</div>
            <div class="text-xs text-gray-500 mt-2">Next free meal at 1,500</div>
        </div>
    </div>

    @* PROOF OF LIFE: USER LIST *@
    <div class="bg-[#111] border border-gray-800 rounded-3xl p-8 mb-10 shadow-2xl">
        <div class="flex justify-between items-end mb-6">
            <div>
                <h3 class="text-xl uppercase tracking-tighter">PPP_User Table Records</h3>
                <p class="text-[10px] text-gray-500 uppercase tracking-widest mt-1">Live data verification</p>
            </div>
            <div class="text-[10px] font-mono text-purple-400 bg-purple-400/10 px-3 py-1 rounded-full border border-purple-500/20">
                TOTAL: @pppUsers.Count
            </div>
        </div>

        @if (isLoadingData)
        {
            <div class="py-10 flex flex-col items-center justify-center gap-4">
                <div class="w-8 h-8 border-2 border-purple-500 border-t-transparent rounded-full animate-spin"></div>
                <div class="text-[10px] uppercase tracking-[0.3em] text-gray-600">Querying_Postgres...</div>
            </div>
        }
        else if (!pppUsers.Any())
        {
            <div class="py-10 text-center border-2 border-dashed border-gray-800 rounded-2xl">
                <div class="text-4xl mb-3">🕵️‍♂️</div>
                <div class="text-xs text-gray-500 uppercase tracking-widest">Table empty. Click "Setup DB" above.</div>
            </div>
        }
        else
        {
            <div class="overflow-x-auto rounded-2xl border border-gray-800 bg-black/20">
                <table class="w-full text-left">
                    <thead>
                        <tr class="text-[10px] font-black uppercase text-gray-500 bg-gray-900/50">
                            <th class="p-4 border-r border-gray-800/50">ID</th>
                            <th class="p-4">Name</th>
                            <th class="p-4">Email</th>
                            <th class="p-4">Role</th>
                            <th class="p-4 text-right">Points</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm divide-y divide-gray-800/50">
                        @foreach (var user in pppUsers)
                        {
                            <tr class="hover:bg-white/5 transition">
                                <td class="p-4 font-mono text-gray-600 border-r border-gray-800/50">#@user.Id</td>
                                <td class="p-4 uppercase tracking-tight font-black text-white">@user.FirstName @user.LastName</td>
                                <td class="p-4 font-mono text-xs text-gray-400">@user.Email</td>
                                <td class="p-4">
                                    <span class="px-2 py-0.5 rounded text-[9px] font-black uppercase @(user.Role == "Owner" ? "bg-purple-900/30 text-purple-400 border border-purple-800" : "bg-blue-900/30 text-blue-400 border border-blue-800")">
                                        @user.Role
                                    </span>
                                </td>
                                <td class="p-4 text-right font-mono text-emerald-500">@user.RewardPoints.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private bool isProcessing = false;
    private bool isLoadingData = true;
    private List<ToastItem> toasts = new();
    private List<PPP_User> pppUsers = new();

    private class ToastItem 
    {
        public string Message { get; set; } = "";
        public bool IsError { get; set; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadUserData();
        }
    }

    private async Task LoadUserData()
    {
        isLoadingData = true;
        StateHasChanged();

        try 
        {
            // Simple check to see if the table exists to prevent crash on new installs
            pppUsers = await Db.PPP_Users.OrderBy(u => u.Id).ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"PPP Load Error (likely table missing): {ex.Message}");
            pppUsers = new();
        }

        isLoadingData = false;
        StateHasChanged();
    }

    private async Task ShowToast(string msg, bool isError = false)
    {
        var toast = new ToastItem { Message = msg, IsError = isError };
        toasts.Add(toast);
        StateHasChanged();
        await Task.Delay(4000);
        toasts.Remove(toast);
        StateHasChanged();
    }

 private async Task InitializePPP()
    {
        if (isProcessing) return;
        isProcessing = true;
        StateHasChanged();

        try 
        {
            // 1. Create the Images table if it doesn't exist
            var sqlImages = @"
                CREATE TABLE IF NOT EXISTS ""PPP_StoredImages"" (
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY,
                    ""Data"" bytea NOT NULL,
                    ""ContentType"" text NOT NULL,
                    ""FileName"" text NOT NULL,
                    ""UploadedAt"" timestamp with time zone NOT NULL,
                    CONSTRAINT ""PK_PPP_StoredImages"" PRIMARY KEY (""Id"")
                );";
            await Db.Database.ExecuteSqlRawAsync(sqlImages);

            // 2. Create the Users table if it doesn't exist
            var sqlUsers = @"
                CREATE TABLE IF NOT EXISTS ""PPP_Users"" (
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY,
                    ""FirstName"" text NOT NULL,
                    ""LastName"" text NOT NULL,
                    ""Email"" text NOT NULL,
                    ""Phone"" text NOT NULL,
                    ""Role"" text NOT NULL,
                    ""CreatedAt"" timestamp with time zone NOT NULL,
                    ""RewardPoints"" integer NOT NULL,
                    ""PreferredPlan"" text NULL,
                    CONSTRAINT ""PK_PPP_Users"" PRIMARY KEY (""Id"")
                );";
            await Db.Database.ExecuteSqlRawAsync(sqlUsers);

            // 3. PATCH: Add AvatarId column if it's missing from an existing table
            var sqlPatch = @"
                DO $$ 
                BEGIN 
                    IF NOT EXISTS (SELECT 1 FROM information_schema.columns 
                                   WHERE table_name='PPP_Users' AND column_name='AvatarId') THEN
                        ALTER TABLE ""PPP_Users"" ADD COLUMN ""AvatarId"" integer NULL;
                        ALTER TABLE ""PPP_Users"" 
                        ADD CONSTRAINT ""FK_PPP_Users_PPP_StoredImages_AvatarId"" 
                        FOREIGN KEY (""AvatarId"") REFERENCES ""PPP_StoredImages""(""Id"") ON DELETE SET NULL;
                    END IF;
                END $$;";
            await Db.Database.ExecuteSqlRawAsync(sqlPatch);

            // 4. Check current count and seed if empty
            var currentCount = 0;
            try { currentCount = await Db.PPP_Users.CountAsync(); } catch { }

            if (currentCount == 0)
            {
                var seedData = new List<PPP_User> {
                    new PPP_User { FirstName = "Stephens", LastName = "Allen Johnson", Email = "stephens@example.com", Phone="555-0101", Role = "Admin", RewardPoints = 5000, CreatedAt = DateTime.UtcNow },
                    new PPP_User { FirstName = "Cayce", LastName = "Johnson", Email = "cayce@example.com", Phone="555-0102", Role = "Customer", RewardPoints = 1250, PreferredPlan = "Clean Eating 10", CreatedAt = DateTime.UtcNow }
                };

                Db.PPP_Users.AddRange(seedData);
                await Db.SaveChangesAsync();
                await ShowToast("Database patched and seeded!");
            }
            else 
            {
                await ShowToast("Database structure verified.");
            }

            await LoadUserData();
        }
        catch (Exception ex)
        {
            await ShowToast("Init Error: " + ex.Message, true);
            Console.WriteLine($"PPP Init Error: {ex}");
        }
        finally 
        {
            isProcessing = false;
            StateHasChanged();
        }
    }
}