@page "/ppp-dashboard"
@using Dashboard
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#0a0a0a] text-white p-6 font-black">
    @* Manual Header (No shared menu) *@
    <div class="flex justify-between items-center mb-10 bg-[#111] p-4 rounded-2xl border border-gray-800 shadow-xl">
        <div class="flex items-center gap-4">
            <span class="text-3xl">👨‍🍳</span>
            <h1 class="text-xl uppercase tracking-tighter">PickPrepPlate</h1>
        </div>
        <div class="flex gap-4">
             <button @onclick="InitializePPP" class="bg-purple-600 hover:bg-purple-500 text-white px-4 py-2 rounded-xl text-[10px] uppercase tracking-widest transition">
                Setup DB & Seed
            </button>
            <a href="/" class="bg-gray-800 hover:bg-gray-700 text-white px-4 py-2 rounded-xl text-[10px] uppercase tracking-widest transition border border-gray-700">
                Back to Dashboard
            </a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="mb-6 p-4 bg-blue-900/30 border border-blue-500 text-blue-400 rounded-xl text-xs uppercase tracking-widest">
            @statusMessage
        </div>
    }

    @* Dashboard Hero Cards *@
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <div class="bg-[#111] border border-emerald-900/50 p-6 rounded-3xl shadow-xl hover:scale-[1.02] transition">
            <div class="text-[10px] text-emerald-500 uppercase tracking-widest mb-2">Next Pickup</div>
            <div class="text-3xl tracking-tighter">Sunday, April 12th</div>
            <div class="text-xs text-gray-500 mt-2">4 Meals Scheduled</div>
        </div>

        <div class="bg-[#111] border border-blue-900/50 p-6 rounded-3xl shadow-xl hover:scale-[1.02] transition">
            <div class="text-[10px] text-blue-500 uppercase tracking-widest mb-2">Active Plan</div>
            <div class="text-3xl tracking-tighter">Clean Eating 10</div>
            <div class="text-xs text-gray-500 mt-2">$125.00 / Week</div>
        </div>

        <div class="bg-[#111] border border-purple-900/50 p-6 rounded-3xl shadow-xl hover:scale-[1.02] transition">
            <div class="text-[10px] text-purple-500 uppercase tracking-widest mb-2">Rewards Points</div>
            <div class="text-3xl tracking-tighter font-mono">1,250</div>
            <div class="text-xs text-gray-500 mt-2">Next free meal at 1,500</div>
        </div>
    </div>

    @* Placeholder content remains same as previous step... *@
</div>

@code {
    private string statusMessage = "";

    private async Task InitializePPP()
    {
        try 
        {
            // 1. Create table via Raw SQL if not exists
            var sql = @"
                CREATE TABLE IF NOT EXISTS ""PPP_Users"" (
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY,
                    ""FirstName"" text NOT NULL,
                    ""LastName"" text NOT NULL,
                    ""Email"" text NOT NULL,
                    ""Phone"" text NOT NULL,
                    ""Role"" text NOT NULL,
                    ""CreatedAt"" timestamp with time zone NOT NULL,
                    ""RewardPoints"" integer NOT NULL,
                    ""PreferredPlan"" text NULL,
                    CONSTRAINT ""PK_PPP_Users"" PRIMARY KEY (""Id"")
                );";
            
            await Db.Database.ExecuteSqlRawAsync(sql);

            // 2. Seed Fake Data if empty
            if (!await Db.PPP_Users.AnyAsync())
            {
                Db.PPP_Users.AddRange(new List<PPP_User> {
                    new PPP_User { FirstName = "Stephens", LastName = "Johnson", Email = "stephens@example.com", Role = "Owner", RewardPoints = 5000 },
                    new PPP_User { FirstName = "Cayce", LastName = "Johnson", Email = "cayce@example.com", Role = "Customer", RewardPoints = 1250, PreferredPlan = "Clean Eating 10" },
                    new PPP_User { FirstName = "Demo", LastName = "User", Email = "demo@example.com", Role = "Customer", RewardPoints = 100 }
                });
                await Db.SaveChangesAsync();
                statusMessage = "Database initialized and seeded with fake users!";
            }
            else 
            {
                statusMessage = "Database already exists and has data.";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
        }
    }
}