@page "/ppp-dashboard"
@using Dashboard
@using Dashboard.Components
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#0a0a0a] text-white p-6 font-black relative overflow-hidden">
    
    <PPPAdminNav CurrentPage="System Overview" />

    <div class="fixed top-24 right-6 z-[100] flex flex-col gap-3">
        @foreach (var toast in toasts)
        {
            <div class="p-4 rounded-2xl border shadow-2xl animate-in slide-in-from-right duration-300 @(toast.IsError ? "bg-red-950 border-red-500 text-red-200" : "bg-emerald-950 border-emerald-500 text-emerald-200")">
                <div class="flex items-center gap-3">
                    <span>@(toast.IsError ? "❌" : "✅")</span>
                    <span class="text-xs uppercase tracking-widest">@toast.Message</span>
                </div>
            </div>
        }
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-10">
        <div class="bg-[#111] border border-emerald-900/50 p-6 rounded-3xl shadow-xl">
            <div class="text-[10px] text-emerald-500 uppercase tracking-widest mb-2">Total Owners</div>
            <div class="text-3xl tracking-tighter">@ownerCount</div>
        </div>
        <div class="bg-[#111] border border-blue-900/50 p-6 rounded-3xl shadow-xl">
            <div class="text-[10px] text-blue-500 uppercase tracking-widest mb-2">Total Users</div>
            <div class="text-3xl tracking-tighter">@pppUsers.Count</div>
        </div>
        <div class="bg-[#111] border border-orange-900/50 p-6 rounded-3xl shadow-xl">
            <div class="text-[10px] text-orange-500 uppercase tracking-widest mb-2">Ingredients</div>
            <div class="text-3xl tracking-tighter font-mono">@ingredientCount</div>
        </div>
        <div class="bg-[#111] border border-purple-900/50 p-6 rounded-3xl shadow-xl hover:scale-[1.02] transition cursor-pointer" @onclick='() => Nav.NavigateTo("/ppp-recipe-editor")'>
            <div class="text-[10px] text-purple-500 uppercase tracking-widest mb-2">Recipe Engine</div>
            <div class="text-3xl tracking-tighter">Build</div>
        </div>
    </div>

    <div class="mb-10 p-6 bg-[#111] border border-gray-800 rounded-3xl flex justify-between items-center shadow-xl">
        <div>
            <h3 class="text-lg uppercase tracking-tighter">Database Maintenance</h3>
            <p class="text-[9px] text-gray-500 uppercase tracking-widest">Force column updates (Servings) and seed global library</p>
        </div>
        <button @onclick="InitializePPP" disabled="@isProcessing" class="relative bg-purple-600 hover:bg-purple-500 text-white px-8 py-3 rounded-xl text-[10px] uppercase tracking-widest transition disabled:opacity-50 min-w-[160px]">
            @if (isProcessing) {
                <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
                </div>
                <span class="opacity-0">Processing</span>
            } else {
                <span>Fix DB & Seed</span>
            }
        </button>
    </div>

    <div class="bg-[#111] border border-gray-800 rounded-3xl p-8 shadow-2xl">
        <h3 class="text-xl uppercase tracking-tighter mb-6">Active System Users</h3>
        @if (isLoadingData) {
            <div class="py-10 flex justify-center"><div class="w-8 h-8 border-2 border-blue-500 border-t-transparent rounded-full animate-spin"></div></div>
        } else {
            <div class="overflow-x-auto rounded-2xl border border-gray-800 bg-black/20">
                <table class="w-full text-left">
                    <thead>
                        <tr class="text-[10px] font-black uppercase text-gray-500 bg-gray-900/50">
                            <th class="p-4">Identity</th>
                            <th class="p-4">Role</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm divide-y divide-gray-800/50">
                        @foreach (var user in pppUsers) {
                            <tr class="hover:bg-white/5 transition">
                                <td class="p-4 uppercase font-black text-white">@user.FirstName @user.LastName</td>
                                <td class="p-4">
                                    <span class="px-2 py-0.5 rounded text-[9px] font-black uppercase @(user.Role == "Admin" ? "bg-red-900/30 text-red-400 border border-red-800" : "bg-blue-900/30 text-blue-400 border border-blue-800")">
                                        @user.Role
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private bool isProcessing = false;
    private bool isLoadingData = true;
    private int ownerCount = 0;
    private int ingredientCount = 0;
    private List<ToastItem> toasts = new();
    private List<PPP_User> pppUsers = new();

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) await LoadSystemStats();
    }

    private async Task LoadSystemStats() {
        isLoadingData = true;
        try {
            pppUsers = await Db.PPP_Users.AsNoTracking().OrderBy(u => u.LastName).ToListAsync();
            ownerCount = await Db.PPP_Owners.CountAsync();
            ingredientCount = await Db.PPP_Ingredients.CountAsync();
        } catch { }
        isLoadingData = false;
        StateHasChanged();
    }

    private async Task ShowToast(string msg, bool isError = false) {
        var toast = new ToastItem { Message = msg, IsError = isError };
        toasts.Add(toast); StateHasChanged();
        await Task.Delay(4000);
        toasts.Remove(toast); StateHasChanged();
    }

    private async Task InitializePPP() {
        if (isProcessing) return;
        isProcessing = true;
        try {
            // 1. Core Tables
            await Db.Database.ExecuteSqlRawAsync(@"
                CREATE TABLE IF NOT EXISTS ""PPP_StoredImages"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""Data"" bytea NOT NULL, ""ContentType"" text NOT NULL, ""FileName"" text NOT NULL, ""UploadedAt"" timestamp with time zone NOT NULL );
                CREATE TABLE IF NOT EXISTS ""PPP_Addresses"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""Street"" text NOT NULL, ""City"" text NOT NULL, ""State"" text NOT NULL, ""ZipCode"" text NOT NULL, ""Apartment"" text NULL, ""DeliveryInstructions"" text NULL );
                CREATE TABLE IF NOT EXISTS ""PPP_Owners"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""BusinessName"" text NOT NULL, ""OwnerName"" text NOT NULL, ""Email"" text NOT NULL, ""Phone"" text NOT NULL, ""Bio"" text NOT NULL, ""CreatedAt"" timestamp with time zone NOT NULL, ""LogoId"" integer REFERENCES ""PPP_StoredImages""(""Id"") ON DELETE SET NULL, ""AddressId"" integer REFERENCES ""PPP_Addresses""(""Id"") ON DELETE SET NULL );
                CREATE TABLE IF NOT EXISTS ""PPP_Users"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""FirstName"" text NOT NULL, ""LastName"" text NOT NULL, ""Email"" text NOT NULL, ""Phone"" text NOT NULL, ""Role"" text NOT NULL, ""CreatedAt"" timestamp with time zone NOT NULL, ""RewardPoints"" integer NOT NULL DEFAULT 0, ""PreferredPlan"" text NULL, ""AvatarId"" integer REFERENCES ""PPP_StoredImages""(""Id"") ON DELETE SET NULL, ""AddressId"" integer REFERENCES ""PPP_Addresses""(""Id"") ON DELETE SET NULL );
                CREATE TABLE IF NOT EXISTS ""PPP_Ingredients"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""Name"" text NOT NULL, ""Unit"" text NULL, ""Calories"" double precision NOT NULL, ""Protein"" double precision NOT NULL, ""Fat"" double precision NOT NULL, ""Carbs"" double precision NOT NULL, ""Fiber"" double precision NOT NULL, ""OwnerId"" integer REFERENCES ""PPP_Owners""(""Id"") ON DELETE SET NULL, ""CreatedAt"" timestamp with time zone NOT NULL );
            ");

            // 2. Recipe Engine with Column Patches
            await Db.Database.ExecuteSqlRawAsync(@"
                CREATE TABLE IF NOT EXISTS ""PPP_Recipes"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""Name"" text NOT NULL, ""Description"" text NOT NULL, ""OwnerId"" integer NOT NULL REFERENCES ""PPP_Owners""(""Id"") ON DELETE CASCADE );
                
                -- FORCE ADD SERVINGS COLUMN IF MISSING
                DO $$ 
                BEGIN 
                    IF NOT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_name='PPP_Recipes' AND column_name='Servings') THEN
                        ALTER TABLE ""PPP_Recipes"" ADD COLUMN ""Servings"" integer NOT NULL DEFAULT 1;
                    END IF;
                END $$;

                CREATE TABLE IF NOT EXISTS ""PPP_RecipeIngredientGroups"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""RecipeId"" integer REFERENCES ""PPP_Recipes""(""Id"") ON DELETE CASCADE, ""GroupName"" text NOT NULL, ""DisplayOrder"" integer NOT NULL );
                CREATE TABLE IF NOT EXISTS ""PPP_RecipeIngredientMappings"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""IngredientGroupId"" integer REFERENCES ""PPP_RecipeIngredientGroups""(""Id"") ON DELETE CASCADE, ""IngredientId"" integer REFERENCES ""PPP_Ingredients""(""Id"") ON DELETE CASCADE, ""Quantity"" double precision NOT NULL, ""Unit"" text NOT NULL, ""Notes"" text NOT NULL, ""DisplayOrder"" integer NOT NULL );
                CREATE TABLE IF NOT EXISTS ""PPP_RecipeInstructionGroups"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""RecipeId"" integer REFERENCES ""PPP_Recipes""(""Id"") ON DELETE CASCADE, ""GroupName"" text NOT NULL, ""DisplayOrder"" integer NOT NULL );
                CREATE TABLE IF NOT EXISTS ""PPP_RecipeInstructions"" ( ""Id"" integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, ""InstructionGroupId"" integer REFERENCES ""PPP_RecipeInstructionGroups""(""Id"") ON DELETE CASCADE, ""StepDescription"" text NOT NULL, ""DisplayOrder"" integer NOT NULL );
            ");

            await SeedIngredients();
            await LoadSystemStats();
            await ShowToast("Database Synced & Columns Verified");
        } catch (Exception ex) {
            await ShowToast("Fix Error: " + ex.Message, true);
        } finally {
            isProcessing = false;
        }
    }

    private async Task SeedIngredients() {
        var library = new List<PPP_Ingredient> {
            new() { Name = "Chicken Breast", Unit = "lbs", Calories = 544, Protein = 104, Fat = 12, Carbs = 0, Fiber = 0 },
            new() { Name = "Ground Beef (80/20)", Unit = "lbs", Calories = 1152, Protein = 78, Fat = 91, Carbs = 0, Fiber = 0 },
            new() { Name = "Jasmine Rice (Dry)", Unit = "cup", Calories = 640, Protein = 13, Fat = 1, Carbs = 142, Fiber = 0 },
            new() { Name = "Olive Oil", Unit = "tbsp", Calories = 119, Protein = 0, Fat = 14, Carbs = 0, Fiber = 0 }
        };
        foreach (var item in library) {
            if (!await Db.PPP_Ingredients.AnyAsync(i => i.Name == item.Name)) {
                item.CreatedAt = DateTime.UtcNow;
                Db.PPP_Ingredients.Add(item);
            }
        }
        await Db.SaveChangesAsync();
    }

    private class ToastItem { public string Message { get; set; } = ""; public bool IsError { get; set; } }
}