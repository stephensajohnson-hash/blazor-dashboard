@page "/ppp-dashboard"
@using Dashboard
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject NavigationManager Nav

<div class="min-h-screen bg-[#0a0a0a] text-white p-6 font-black">
    @* Manual Header (No shared menu) *@
    <div class="flex justify-between items-center mb-10 bg-[#111] p-4 rounded-2xl border border-gray-800 shadow-xl">
        <div class="flex items-center gap-4">
            <span class="text-3xl">👨‍🍳</span>
            <h1 class="text-xl uppercase tracking-tighter">PickPrepPlate</h1>
        </div>
        <div class="flex gap-4">
             <button @onclick="InitializePPP" class="bg-purple-600 hover:bg-purple-500 text-white px-4 py-2 rounded-xl text-[10px] uppercase tracking-widest transition">
                Setup DB & Seed
            </button>
            <a href="/" class="bg-gray-800 hover:bg-gray-700 text-white px-4 py-2 rounded-xl text-[10px] uppercase tracking-widest transition border border-gray-700">
                Back to Dashboard
            </a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="mb-6 p-4 bg-blue-900/30 border border-blue-500 text-blue-400 rounded-xl text-xs uppercase tracking-widest">
            @statusMessage
        </div>
    }

    @* Dashboard Hero Cards *@
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <div class="bg-[#111] border border-emerald-900/50 p-6 rounded-3xl shadow-xl hover:scale-[1.02] transition">
            <div class="text-[10px] text-emerald-500 uppercase tracking-widest mb-2">Next Pickup</div>
            <div class="text-3xl tracking-tighter">Sunday, April 12th</div>
            <div class="text-xs text-gray-500 mt-2">4 Meals Scheduled</div>
        </div>

        <div class="bg-[#111] border border-blue-900/50 p-6 rounded-3xl shadow-xl hover:scale-[1.02] transition">
            <div class="text-[10px] text-blue-500 uppercase tracking-widest mb-2">Active Plan</div>
            <div class="text-3xl tracking-tighter">Clean Eating 10</div>
            <div class="text-xs text-gray-500 mt-2">$125.00 / Week</div>
        </div>

        <div class="bg-[#111] border border-purple-900/50 p-6 rounded-3xl shadow-xl hover:scale-[1.02] transition">
            <div class="text-[10px] text-purple-500 uppercase tracking-widest mb-2">Rewards Points</div>
            <div class="text-3xl tracking-tighter font-mono">1,250</div>
            <div class="text-xs text-gray-500 mt-2">Next free meal at 1,500</div>
        </div>
    </div>

    @* Menu Preview *@
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div class="bg-[#111] border border-gray-800 rounded-3xl p-8">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xl uppercase tracking-tighter">Weekly Menu Preview</h3>
                <button class="bg-emerald-600 text-white px-4 py-1.5 rounded-xl text-[10px] uppercase tracking-widest">Select Meals</button>
            </div>
            
            <div class="space-y-4">
                <div class="flex items-center gap-4 bg-black/40 p-4 rounded-2xl border border-gray-800/50">
                    <div class="w-16 h-16 bg-gray-800 rounded-xl flex items-center justify-center text-2xl">🥩</div>
                    <div>
                        <div class="text-sm">Grass-Fed Steak & Asparagus</div>
                        <div class="text-[10px] text-gray-500 uppercase mt-1">Low Carb • 540 Cal</div>
                    </div>
                </div>
                <div class="flex items-center gap-4 bg-black/40 p-4 rounded-2xl border border-gray-800/50">
                    <div class="w-16 h-16 bg-gray-800 rounded-xl flex items-center justify-center text-2xl">🐟</div>
                    <div>
                        <div class="text-sm">Lemon Butter Salmon</div>
                        <div class="text-[10px] text-gray-500 uppercase mt-1">High Protein • 480 Cal</div>
                    </div>
                </div>
            </div>
        </div>

        @* Recent Orders *@
        <div class="bg-[#111] border border-gray-800 rounded-3xl p-8">
             <h3 class="text-xl uppercase tracking-tighter mb-6">Order History</h3>
             <div class="overflow-hidden rounded-2xl border border-gray-800">
                 <table class="w-full text-left text-sm">
                     <thead class="bg-gray-900/50 text-[10px] uppercase text-gray-500 tracking-widest">
                         <tr>
                             <th class="p-4 font-black">Date</th>
                             <th class="p-4 font-black">Status</th>
                             <th class="p-4 font-black text-right">Total</th>
                         </tr>
                     </thead>
                     <tbody class="divide-y divide-gray-800/50">
                         <tr>
                             <td class="p-4 text-xs">April 5, 2026</td>
                             <td class="p-4"><span class="text-[10px] bg-emerald-900/30 text-emerald-500 px-2 py-0.5 rounded-full uppercase">Delivered</span></td>
                             <td class="p-4 text-right font-mono">$125.00</td>
                         </tr>
                         <tr>
                             <td class="p-4 text-xs">March 29, 2026</td>
                             <td class="p-4"><span class="text-[10px] bg-emerald-900/30 text-emerald-500 px-2 py-0.5 rounded-full uppercase">Delivered</span></td>
                             <td class="p-4 text-right font-mono">$125.00</td>
                         </tr>
                     </tbody>
                 </table>
             </div>
        </div>
    </div>
</div>

@code {
    private string statusMessage = "";

    private async Task InitializePPP()
    {
        statusMessage = "Starting initialization...";
        StateHasChanged();
        Console.WriteLine("PPP Init: Button Clicked");

        try 
        {
            var sql = @"
                CREATE TABLE IF NOT EXISTS ""PPP_Users"" (
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY,
                    ""FirstName"" text NOT NULL,
                    ""LastName"" text NOT NULL,
                    ""Email"" text NOT NULL,
                    ""Phone"" text NOT NULL,
                    ""Role"" text NOT NULL,
                    ""CreatedAt"" timestamp with time zone NOT NULL,
                    ""RewardPoints"" integer NOT NULL,
                    ""PreferredPlan"" text NULL,
                    CONSTRAINT ""PK_PPP_Users"" PRIMARY KEY (""Id"")
                );";
            
            Console.WriteLine("PPP Init: Executing DDL...");
            await Db.Database.ExecuteSqlRawAsync(sql);

            var userCount = await Db.PPP_Users.CountAsync();
            Console.WriteLine($"PPP Init: Current user count is {userCount}");

            if (userCount == 0)
            {
                Db.PPP_Users.AddRange(new List<PPP_User> {
                    new PPP_User { FirstName = "Stephens", LastName = "Allen Johnson", Email = "stephens@example.com", Phone="555-0101", Role = "Owner", RewardPoints = 5000, CreatedAt = DateTime.UtcNow },
                    new PPP_User { FirstName = "Cayce", LastName = "Johnson", Email = "cayce@example.com", Phone="555-0102", Role = "Customer", RewardPoints = 1250, PreferredPlan = "Clean Eating 10", CreatedAt = DateTime.UtcNow },
                    new PPP_User { FirstName = "Demo", LastName = "User", Email = "demo@example.com", Phone="555-0103", Role = "Customer", RewardPoints = 100, CreatedAt = DateTime.UtcNow }
                });
                await Db.SaveChangesAsync();
                statusMessage = "Success: Database created and seeded!";
            }
            else 
            {
                statusMessage = $"Database already exists with {userCount} users.";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
            Console.WriteLine($"PPP Init Error: {ex.ToString()}");
        }
        
        StateHasChanged();
    }
}