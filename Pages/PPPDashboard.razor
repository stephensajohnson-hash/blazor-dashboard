@code {
    private string statusMessage = "";

    private async Task InitializePPP()
    {
        statusMessage = "Starting initialization...";
        StateHasChanged();
        Console.WriteLine("PPP Init: Button Clicked");

        try 
        {
            // 1. Create table via Raw SQL using verified Postgres syntax
            // Using double quotes for table and column names to match EF Core's default behavior
            var sql = @"
                CREATE TABLE IF NOT EXISTS ""PPP_Users"" (
                    ""Id"" integer GENERATED BY DEFAULT AS IDENTITY,
                    ""FirstName"" text NOT NULL,
                    ""LastName"" text NOT NULL,
                    ""Email"" text NOT NULL,
                    ""Phone"" text NOT NULL,
                    ""Role"" text NOT NULL,
                    ""CreatedAt"" timestamp with time zone NOT NULL,
                    ""RewardPoints"" integer NOT NULL,
                    ""PreferredPlan"" text NULL,
                    CONSTRAINT ""PK_PPP_Users"" PRIMARY KEY (""Id"")
                );";
            
            Console.WriteLine("PPP Init: Executing DDL...");
            await Db.Database.ExecuteSqlRawAsync(sql);
            Console.WriteLine("PPP Init: DDL complete.");

            // 2. Seed Fake Data if empty
            // Use a fresh query to check existence
            var userCount = await Db.PPP_Users.CountAsync();
            Console.WriteLine($"PPP Init: Current user count is {userCount}");

            if (userCount == 0)
            {
                Console.WriteLine("PPP Init: Seeding data...");
                Db.PPP_Users.AddRange(new List<PPP_User> {
                    new PPP_User { FirstName = "Stephens", LastName = "Allen Johnson", Email = "stephens@example.com", Phone="555-0101", Role = "Owner", RewardPoints = 5000, CreatedAt = DateTime.UtcNow },
                    new PPP_User { FirstName = "Cayce", LastName = "Johnson", Email = "cayce@example.com", Phone="555-0102", Role = "Customer", RewardPoints = 1250, PreferredPlan = "Clean Eating 10", CreatedAt = DateTime.UtcNow },
                    new PPP_User { FirstName = "Demo", LastName = "User", Email = "demo@example.com", Phone="555-0103", Role = "Customer", RewardPoints = 100, CreatedAt = DateTime.UtcNow }
                });
                await Db.SaveChangesAsync();
                statusMessage = "Success: Database created and seeded!";
                Console.WriteLine("PPP Init: Seeding complete.");
            }
            else 
            {
                statusMessage = $"Database already exists with {userCount} users.";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
            Console.WriteLine($"PPP Init Error: {ex.ToString()}");
        }
        
        StateHasChanged();
    }
}