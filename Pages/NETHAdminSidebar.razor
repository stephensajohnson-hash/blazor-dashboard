@using Microsoft.AspNetCore.Components.Web
@inject NavigationManager Nav

<div class="w-64 bg-[#15161a] border-r border-gray-800 flex flex-col">
    <div class="p-6 border-b border-gray-800">
        <h1 class="text-xl font-black text-white uppercase tracking-tighter">NETH_Admin</h1>
        <p class="text-[9px] text-gray-500 font-mono uppercase tracking-widest mt-1">v2.0_Terminal</p>
    </div>
    
    <nav class="flex-1 p-4 space-y-1">
        <NavLink href="/admin/neth-dashboard" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white transition group">
            <i class="fas fa-th-large text-sm group-hover:text-blue-400"></i>
            <span class="text-[11px] font-black uppercase tracking-wider">Dashboard</span>
        </NavLink>

        <NavLink href="/admin/neth-appointments" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white transition group">
            <i class="fas fa-calendar-check text-sm group-hover:text-green-400"></i>
            <span class="text-[11px] font-black uppercase tracking-wider">Appointments</span>
        </NavLink>

        <div class="pt-4 pb-2 px-4 text-[9px] font-black text-gray-600 uppercase tracking-[0.2em]">Registry</div>

        <NavLink href="/admin/neth-stylists" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white transition group">
            <i class="fas fa-user-tie text-sm group-hover:text-[#D2B48C]"></i>
            <span class="text-[11px] font-black uppercase tracking-wider">Stylists</span>
        </NavLink>

        <NavLink href="/admin/neth-schedules" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white transition group">
            <i class="fas fa-clock text-sm group-hover:text-orange-400"></i>
            <span class="text-[11px] font-black uppercase tracking-wider">Schedules</span>
        </NavLink>

        <NavLink href="/admin/neth-clients" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white transition group">
            <i class="fas fa-users text-sm group-hover:text-purple-400"></i>
            <span class="text-[11px] font-black uppercase tracking-wider">Clients</span>
        </NavLink>

        <NavLink href="/admin/neth-shops" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white transition group">
            <i class="fas fa-store text-sm group-hover:text-red-400"></i>
            <span class="text-[11px] font-black uppercase tracking-wider">Shops</span>
        </NavLink>
    </nav>

    <div class="p-4 border-t border-gray-800">
        <button @onclick="Logout" class="w-full flex items-center gap-3 px-4 py-3 rounded-lg text-gray-500 hover:text-red-400 transition">
            <i class="fas fa-sign-out-alt text-sm"></i>
            <span class="text-[11px] font-black uppercase">Terminate_Session</span>
        </button>
    </div>
</div>

@code {
    private void Logout() {
        // Logic to clear local storage and redirect
        Nav.NavigateTo("/nethaircut");
    }
}