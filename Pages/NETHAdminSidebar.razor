@using Microsoft.JSInterop
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="w-64 bg-[#25262b] border-r border-gray-700 p-6 flex flex-col gap-2 shrink-0">
    <h1 class="text-[#D2B48C] font-black uppercase tracking-tighter mb-8 text-xl">NETH Admin</h1>
    
    <nav class="flex flex-col gap-2">
        <NavLink href="/admin/neth-users" class="px-4 py-3 rounded font-black text-[10px] uppercase tracking-widest transition flex items-center gap-3 text-gray-500 hover:text-white hover:bg-white/5" ActiveClass="bg-[#D2B48C] text-[#1a1b1e] shadow-lg shadow-[#D2B48C]/10 !text-[#1a1b1e]">
            <i class="fas fa-users w-5"></i> Users
        </NavLink>
        <NavLink href="/admin/neth-shops" class="px-4 py-3 rounded font-black text-[10px] uppercase tracking-widest transition flex items-center gap-3 text-gray-500 hover:text-white hover:bg-white/5" ActiveClass="bg-[#D2B48C] text-[#1a1b1e] shadow-lg shadow-[#D2B48C]/10 !text-[#1a1b1e]">
            <i class="fas fa-shop w-5"></i> Shops
        </NavLink>
        <NavLink href="/admin/neth-stylists" class="px-4 py-3 rounded font-black text-[10px] uppercase tracking-widest transition flex items-center gap-3 text-gray-500 hover:text-white hover:bg-white/5" ActiveClass="bg-[#D2B48C] text-[#1a1b1e] shadow-lg shadow-[#D2B48C]/10 !text-[#1a1b1e]">
            <i class="fas fa-user-tie w-5"></i> Stylists
        </NavLink>
    </nav>
    
    <div class="mt-auto pt-4 border-t border-gray-700 flex flex-col gap-2">
        <NavLink href="/nethaircut" Match="NavLinkMatch.All" class="px-4 py-3 rounded font-black text-[10px] uppercase tracking-widest transition flex items-center gap-3 text-gray-500 hover:text-white hover:bg-white/5" ActiveClass="bg-[#D2B48C] text-[#1a1b1e] shadow-lg shadow-[#D2B48C]/10 !text-[#1a1b1e]">
            <i class="fas fa-terminal w-5"></i> Terminal
        </NavLink>
        <button @onclick="HandleLogout" class="px-4 py-2 rounded font-black text-[10px] uppercase tracking-widest transition text-left mt-2 text-red-500/50 hover:text-red-500 flex items-center gap-3">
            <i class="fas fa-power-off w-5"></i> Logout
        </button>
    </div>
</div>

@code {
    private async Task HandleLogout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "neth_session");
        Nav.NavigateTo("/nethaircut", true);
    }
}