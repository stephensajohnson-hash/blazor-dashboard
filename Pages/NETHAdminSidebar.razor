@using Microsoft.JSInterop
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="w-64 bg-[#25262b] border-r border-gray-700 p-6 flex flex-col gap-2">
    <h1 class="text-[#D2B48C] font-black uppercase tracking-tighter mb-8 text-xl">NETH Admin</h1>
    
    <button @onclick='() => Nav.NavigateTo("/admin/neth-users")' class="@GetClass("/admin/neth-users")">Users</button>
    <button @onclick='() => Nav.NavigateTo("/admin/neth-shops")' class="@GetClass("/admin/neth-shops")">Shops</button>
    <button @onclick='() => Nav.NavigateTo("/admin/neth-stylists")' class="@GetClass("/admin/neth-stylists")">Stylists</button>
    <button class="text-gray-600 cursor-not-allowed px-4 py-2 rounded font-black text-xs uppercase tracking-widest text-left">Services (Soon)</button>
    
    <div class="mt-auto pt-4 border-t border-gray-700 flex flex-col gap-4">
        <button @onclick='() => Nav.NavigateTo("/nethaircut")' class="text-gray-500 hover:text-white px-4 py-2 rounded font-black text-xs uppercase tracking-widest transition text-left">Back to Terminal</button>
        <button @onclick="Logout" class="text-red-500/50 hover:text-red-500 px-4 py-2 rounded font-black text-xs uppercase tracking-widest transition text-left">Logout</button>
    </div>
</div>

@code {
    private string GetClass(string path)
    {
        var isActive = Nav.Uri.Contains(path);
        var baseClass = "px-4 py-2 rounded font-black text-xs uppercase tracking-widest transition text-left ";
        return isActive 
            ? baseClass + "bg-[#D2B48C] text-[#1a1b1e]" 
            : baseClass + "text-gray-500 hover:text-white";
    }

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "neth_session");
        Nav.NavigateTo("/nethaircut", true);
    }
}