@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using Dashboard.Services
@inject NavigationManager Nav
@inject NETHStateService State
@inject IJSRuntime JS

<div class="w-64 bg-[#15161a] border-r border-gray-800 flex flex-col min-h-screen sticky top-0">
    <div class="p-6 border-b border-gray-800">
        <h1 class="text-xl font-black text-white uppercase tracking-tighter">
            @(State.IsImpersonating ? "NETH_Stylist" : "NETH_Admin")
        </h1>
        <p class="text-[9px] text-gray-500 font-mono uppercase tracking-widest mt-1">
            @(State.IsImpersonating ? "Scoped_Session" : "v2.0_Terminal")
        </p>
    </div>
    
    <nav class="flex-1 p-4 space-y-1 overflow-y-auto custom-scrollbar">
        <a href="/nethaircut" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white transition group">
            <i class="fas fa-th-large text-sm group-hover:text-blue-400"></i>
            <span class="text-[11px] font-black uppercase tracking-wider">Dashboard</span>
        </a>

        <a href="/admin/neth-appointments" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white transition group">
            <i class="fas fa-calendar-check text-sm group-hover:text-green-400"></i>
            <span class="text-[11px] font-black uppercase tracking-wider">Appointments</span>
        </a>

        @if (!State.IsImpersonating)
        {
            <div class="pt-4 pb-2 px-4 text-[9px] font-black text-gray-600 uppercase tracking-[0.2em]">Registry</div>

            <a href="/admin/neth-stylists" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white transition group">
                <i class="fas fa-user-tie text-sm group-hover:text-[#D2B48C]"></i>
                <span class="text-[11px] font-black uppercase tracking-wider">Stylists</span>
            </a>

            <a href="/admin/neth-schedules" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white transition group">
                <i class="fas fa-clock text-sm group-hover:text-orange-400"></i>
                <span class="text-[11px] font-black uppercase tracking-wider">Schedules</span>
            </a>
        }

        <div class="pt-4 pb-2 px-4 text-[9px] font-black text-gray-600 uppercase tracking-[0.2em]">Workflows</div>

        <a href="/admin/neth-clients" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white transition group">
            <i class="fas fa-users text-sm group-hover:text-purple-400"></i>
            <span class="text-[11px] font-black uppercase tracking-wider">Clients</span>
        </a>

        <a href="/admin/neth-client-notes" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white transition group">
            <i class="fas fa-clipboard-list text-sm group-hover:text-teal-400"></i>
            <span class="text-[11px] font-black uppercase tracking-wider">Client Notes</span>
        </a>

        @if (!State.IsImpersonating)
        {
            <div class="pt-4 pb-2 px-4 text-[9px] font-black text-gray-600 uppercase tracking-[0.2em]">System</div>

            <a href="/admin/neth-users" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white transition group">
                <i class="fas fa-user-shield text-sm group-hover:text-blue-300"></i>
                <span class="text-[11px] font-black uppercase tracking-wider">Users</span>
            </a>

            <a href="/admin/neth-shops" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white transition group">
                <i class="fas fa-store text-sm group-hover:text-red-400"></i>
                <span class="text-[11px] font-black uppercase tracking-wider">Shops</span>
            </a>
        }
    </nav>

    <div class="p-4 border-t border-gray-800 space-y-2">
        @if (State.IsImpersonating)
        {
            <button @onclick="ExitImpersonation" class="w-full flex items-center gap-3 px-4 py-3 rounded-lg bg-orange-600/10 text-orange-500 hover:bg-orange-600 hover:text-white transition group">
                <i class="fas fa-user-secret text-sm"></i>
                <span class="text-[11px] font-black uppercase">Exit Session</span>
            </button>
        }
        
        <button @onclick="Logout" class="w-full flex items-center gap-3 px-4 py-3 rounded-lg text-gray-500 hover:text-red-400 transition">
            <i class="fas fa-sign-out-alt text-sm"></i>
            <span class="text-[11px] font-black uppercase">Logout</span>
        </button>
    </div>
</div>

@code {
    private async Task Logout() 
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "neth_session");
        State.Clear();
        Nav.NavigateTo("/nethaircut", forceLoad: true);
    }

    private void ExitImpersonation()
    {
        State.Clear();
        Nav.NavigateTo("/nethaircut");
    }
}