@using Microsoft.JSInterop
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="w-64 bg-[#25262b] border-r border-gray-700 p-6 flex flex-col gap-2 shrink-0">
    <h1 class="text-[#D2B48C] font-black uppercase tracking-tighter mb-8 text-xl">NETH Admin</h1>
    
    <nav class="flex flex-col gap-2">
        <button @onclick='() => Navigate("/admin/neth-users")' class="@GetClass("/admin/neth-users")">
            <i class="fas fa-users w-5"></i> Users
        </button>
        <button @onclick='() => Navigate("/admin/neth-shops")' class="@GetClass("/admin/neth-shops")">
            <i class="fas fa-shop w-5"></i> Shops
        </button>
        <button @onclick='() => Navigate("/admin/neth-stylists")' class="@GetClass("/admin/neth-stylists")">
            <i class="fas fa-user-tie w-5"></i> Stylists
        </button>
    </nav>
    
    <div class="mt-auto pt-4 border-t border-gray-700 flex flex-col gap-2">
        <button @onclick='() => Navigate("/nethaircut")' class="@GetClass("/nethaircut")">
            <i class="fas fa-terminal w-5"></i> Terminal
        </button>
        <button @onclick="Logout" class="text-red-500/50 hover:text-red-500 px-4 py-2 rounded font-black text-xs uppercase tracking-widest transition text-left mt-2">
            <i class="fas fa-power-off w-5"></i> Logout
        </button>
    </div>
</div>

@code {
    private void Navigate(string path)
    {
        Nav.NavigateTo(path);
    }

    private string GetClass(string path)
    {
        // Simple string containment check for current URI
        var isActive = Nav.Uri.EndsWith(path) || Nav.Uri.Contains(path + "?");
        var baseClass = "px-4 py-3 rounded font-black text-[10px] uppercase tracking-widest transition text-left flex items-center gap-3 ";
        
        return isActive 
            ? baseClass + "bg-[#D2B48C] text-[#1a1b1e] shadow-lg shadow-[#D2B48C]/10" 
            : baseClass + "text-gray-500 hover:text-white hover:bg-white/5";
    }

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "neth_session");
        Nav.NavigateTo("/nethaircut", true);
    }
}