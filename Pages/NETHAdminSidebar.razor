@using Microsoft.JSInterop
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="w-64 bg-[#25262b] border-r border-gray-700 p-6 flex flex-col gap-2 shrink-0">
    <h1 class="text-[#D2B48C] font-black uppercase tracking-tighter mb-8 text-xl">NETH Admin</h1>
    
    <nav class="flex flex-col gap-2">
        @* NEW TOP HOME BUTTON *@
        <a href="/nethaircut" class="@GetActiveClass("/nethaircut")">
            <i class="fas fa-home w-5"></i> Admin Home
        </a>

        <div class="my-2 border-t border-gray-800"></div>

        <a href="/admin/neth-users" class="@GetActiveClass("/admin/neth-users")">
            <i class="fas fa-users w-5"></i> Users
        </a>
        <a href="/admin/neth-shops" class="@GetActiveClass("/admin/neth-shops")">
            <i class="fas fa-shop w-5"></i> Shops
        </a>
        <a href="/admin/neth-stylists" class="@GetActiveClass("/admin/neth-stylists")">
            <i class="fas fa-user-tie w-5"></i> Stylists
        </a>
    </nav>
    
    <div class="mt-auto pt-4 border-t border-gray-700 flex flex-col gap-2">
        <button @onclick="HandleLogout" class="px-4 py-3 rounded font-black text-[10px] uppercase tracking-widest transition text-left text-red-500/50 hover:text-red-500 hover:bg-red-500/5 flex items-center gap-3">
            <i class="fas fa-power-off w-5"></i> Logout
        </button>
    </div>
</div>

@code {
    private string GetActiveClass(string path)
    {
        // Simple URI check to highlight the correct link
        bool isActive = Nav.Uri.EndsWith(path) || Nav.Uri.Contains(path + "?");
        
        string baseClass = "px-4 py-3 rounded font-black text-[10px] uppercase tracking-widest transition flex items-center gap-3 ";
        
        return isActive 
            ? baseClass + "bg-[#D2B48C] text-[#1a1b1e] shadow-lg shadow-[#D2B48C]/10" 
            : baseClass + "text-gray-500 hover:text-white hover:bg-white/5";
    }

    private async Task HandleLogout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "neth_session");
        // Force load to clear any circuit state
        Nav.NavigateTo("/nethaircut", forceLoad: true);
    }
}