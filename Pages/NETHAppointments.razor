@page "/admin/neth-appointments"
@page "/admin/neth-appointments/{PreSelectedStylistId:int}"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using Dashboard.Components
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<style>
    .neth-grid-container { height: 1200px; position: relative; background: #1a1b1e; }
    .neth-hour-row { height: 100px; border-bottom: 1px solid rgba(255,255,255,0.05); position: relative; }
    
    .neth-shift-zone { position: absolute; left: 0; right: 0; background: rgba(34, 197, 94, 0.08); border-left: 2px solid #22c55e; z-index: 1; pointer-events: none; }
    
    /* Click slots are Layer 10 */
    .neth-click-slot { position: absolute; left: 0; right: 0; z-index: 10; cursor: pointer; }
    .neth-ghost-preview { position: absolute; top: 0; left: 0; right: 0; border: 2px dashed #60a5fa; background: rgba(96, 165, 250, 0.2); pointer-events: none; opacity: 0; transition: opacity 0.1s; z-index: 15; display: flex; align-items: center; justify-content: center; }
    .neth-click-slot:hover .neth-ghost-preview { opacity: 1; }
    
    /* Existing appointments are Layer 100 to stay on top of slots */
    .neth-appointment-block { position: absolute; left: 4px; right: 4px; background: #2563eb; border: 1px solid #60a5fa; border-radius: 4px; z-index: 100; padding: 6px; overflow: hidden; cursor: pointer; transition: transform 0.1s; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); }
    .neth-appointment-block:hover { transform: scale(1.01); filter: brightness(1.2); }
    
    .neth-ghost-invalid { border-color: #ef4444 !important; background: rgba(239, 68, 68, 0.4) !important; }
    
    @@keyframes neth-shake {
        0%, 100% { transform: translateX(0); }
        20%, 60% { transform: translateX(-10px); }
        40%, 80% { transform: translateX(10px); }
    }
    .shake-it { animation: neth-shake 0.3s ease-in-out !important; border: 2px solid #ef4444 !important; background-color: rgba(239, 68, 68, 0.5) !important; }

    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #374151; border-radius: 10px; }
</style>

<div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex font-sans">
    <NETHAdminSidebar />

    <div class="flex-1 p-8">
        <div class="max-w-7xl mx-auto">
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h2 class="text-2xl font-black text-white uppercase tracking-tight">Appointment Desk</h2>
                    <p class="text-xs text-[#D2B48C] font-mono uppercase tracking-widest">@startOfWeek.ToString("MMMM yyyy")</p>
                </div>
                <div class="flex gap-4 items-center">
                    <select @onchange="OnStylistChanged" value="@selectedStylistId" class="bg-[#25262b] border border-gray-700 rounded px-4 py-2 text-white text-[10px] font-black uppercase outline-none focus:border-blue-500">
                        <option value="0">-- Select Barber --</option>
                        @foreach(var s in allStylists) { <option value="@s.Id">@s.Name</option> }
                    </select>
                    <div class="flex items-center bg-[#25262b] rounded border border-gray-700 p-1">
                        <button @onclick="() => ChangeWeek(-1)" class="px-3 py-1 hover:text-white transition">&lt;</button>
                        <span class="px-4 text-[9px] font-black uppercase tracking-tighter text-gray-500 border-x border-gray-800">WEEK</span>
                        <button @onclick="() => ChangeWeek(1)" class="px-3 py-1 hover:text-white transition">&gt;</button>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="mb-6 p-4 rounded font-mono text-[10px] uppercase flex justify-between items-center @(statusMessage.Contains("ERR") ? "bg-red-900/20 text-red-400 border border-red-500/30" : "bg-blue-900/20 text-blue-400 border border-blue-500/30")">
                    <span>@statusMessage</span>
                    <button @onclick='() => statusMessage = ""' class="opacity-50 hover:opacity-100">&times;</button>
                </div>
            }

            @if (selectedStylistId > 0)
            {
                <div class="grid grid-cols-1 xl:grid-cols-4 gap-8">
                    <div class="xl:col-span-1 space-y-4">
                        <div class="bg-[#25262b] p-5 rounded-xl border border-gray-700 shadow-2xl">
                            <h3 class="text-[10px] font-black uppercase text-[#D2B48C] mb-4 tracking-widest">1. Select Services</h3>
                            <div class="space-y-1.5 mb-4 max-h-[350px] overflow-y-auto pr-1 custom-scrollbar">
                                @foreach (var svc in filteredServices)
                                {
                                    <div @onclick="() => ToggleService(svc)" class="flex justify-between items-center p-3 rounded border @(selectedServices.Any(x => x.Id == svc.Id) ? "bg-blue-600/20 border-blue-500 text-white" : "bg-black/20 border-gray-800 text-gray-400") cursor-pointer transition">
                                        <span class="text-[10px] font-black uppercase">@svc.Name</span>
                                        <span class="text-[9px] font-mono">@svc.DurationMinutes m</span>
                                    </div>
                                }
                            </div>
                            <div class="pt-3 border-t border-gray-800 flex justify-between items-center text-[10px] font-black uppercase">
                                <span class="text-gray-500">Duration</span>
                                <span class="text-blue-400 font-mono">@totalDuration MIN</span>
                            </div>
                        </div>

                        @if (isTimeSelected)
                        {
                            <div class="bg-blue-600 p-5 rounded-xl shadow-2xl @(isShaking ? "shake-it" : "")">
                                <h3 class="text-[10px] font-black uppercase text-white/70 mb-3 tracking-widest">2. Booking Details</h3>
                                <div class="mb-4">
                                    <p class="text-white font-black uppercase text-lg leading-none">@bookingStart.ToString("h:mm tt")</p>
                                    <p class="text-white/60 text-[9px] font-mono uppercase mt-1">@bookingStart.ToString("dddd, MMM dd")</p>
                                </div>
                                <select @bind="selectedClientId" class="w-full bg-black/20 border border-white/20 rounded p-3 text-xs text-white outline-none mb-3">
                                    <option value="0">-- Select Client --</option>
                                    @foreach(var c in allClients) { <option value="@c.Id">@c.FirstName @c.LastName</option> }
                                </select>
                                <button @onclick="CreateAppointment" class="w-full bg-white text-blue-600 font-black uppercase text-[10px] py-3.5 rounded hover:bg-gray-100 transition shadow-lg">Confirm Booking</button>
                                <button @onclick='() => { isTimeSelected = false; statusMessage = ""; }' class="w-full mt-2 text-white/50 text-[9px] font-black uppercase hover:text-white">Clear</button>
                            </div>
                        }
                    </div>

                    <div class="xl:col-span-3 bg-[#25262b] rounded-xl border border-gray-700 shadow-2xl overflow-hidden flex flex-col">
                        <div class="grid grid-cols-8 bg-black/40 border-b border-gray-700">
                            <div class="p-4 border-r border-gray-800"></div>
                            @for (int i = 0; i < 7; i++)
                            {
                                var day = startOfWeek.AddDays(i);
                                <div class="p-3 text-center border-r border-gray-800 @(day.Date == DateTime.Today ? "bg-blue-500/10" : "")">
                                    <p class="text-[9px] font-black text-gray-500 uppercase">@day.ToString("ddd")</p>
                                    <p class="text-sm font-black text-white">@day.Day</p>
                                </div>
                            }
                        </div>

                        <div class="relative overflow-y-auto custom-scrollbar bg-[#1a1b1e] h-[700px]">
                            <div class="grid grid-cols-8 relative neth-grid-container">
                                <div class="col-span-1 border-r border-gray-800 bg-[#25262b]/50">
                                    @for (int h = 8; h < 20; h++)
                                    {
                                        <div class="neth-hour-row pr-3 pt-2 text-[10px] font-mono text-gray-600 text-right uppercase">
                                            @((h > 12 ? h - 12 : h)):00 @(h >= 12 ? "PM" : "AM")
                                        </div>
                                    }
                                </div>

                                @for (int i = 0; i < 7; i++)
                                {
                                    var dayDate = startOfWeek.AddDays(i);
                                    var dayShifts = stylistSchedules.Where(x => x.DayOfWeek == (int)dayDate.DayOfWeek).ToList();
                                    var dayApps = existingAppointments.Where(x => x.StartTime.Date == dayDate.Date).ToList();

                                    <div class="col-span-1 border-r border-gray-800 relative">
                                        @foreach (var shift in dayShifts)
                                        {
                                            <div class="neth-shift-zone" style="top: @(GetPx(shift.StartTime))px; height: @(GetH(shift.StartTime, shift.EndTime))px;"></div>
                                            
                                            @for (DateTime t = shift.StartTime; t < shift.EndTime; t = t.AddMinutes(15))
                                            {
                                                var slotStart = t;
                                                var slotEnd = t.AddMinutes(totalDuration);
                                                
                                                // REFINED COLLISION: Checks if ANY part of the 30/45/60m block hits an app
                                                bool hasConflict = dayApps.Any(a => slotStart < a.EndTime && slotEnd > a.StartTime);
                                                bool isTooLate = slotEnd > shift.EndTime;

                                                <div @onclick='() => HandleSlotClick(dayDate, slotStart, hasConflict || isTooLate)' 
                                                     class="neth-click-slot" 
                                                     style="top: @(GetPx(slotStart))px; height: 25px;">
                                                    <div class='neth-ghost-preview @(hasConflict || isTooLate ? "neth-ghost-invalid" : "")' 
                                                         style="height: @(totalDuration * 1.666)px;">
                                                        @if(hasConflict || isTooLate) { <i class="fas fa-ban text-red-500 text-xs"></i> }
                                                        else { <span class="text-[8px] font-black text-white uppercase">@totalDuration m</span> }
                                                    </div>
                                                </div>
                                            }
                                        }

                                        @foreach (var app in dayApps)
                                        {
                                            var client = allClients.FirstOrDefault(x => x.Id == app.ClientId);
                                            <div @onclick="() => DeleteApp(app)" @onclick:stopPropagation="true" class="neth-appointment-block" 
                                                 style="top: @(GetPx(app.StartTime))px; height: @(GetH(app.StartTime, app.EndTime))px;">
                                                <p class="text-[9px] font-black text-white uppercase truncate">@(client?.FirstName ?? "Booked")</p>
                                                <p class="text-[7px] font-mono text-white/50 uppercase">@app.StartTime.ToString("h:mm")</p>
                                            </div>
                                        }

                                        @if(isTimeSelected && bookingStart.Date == dayDate.Date)
                                        {
                                            <div class="absolute inset-x-1 border-2 border-white bg-blue-500/50 shadow-xl z-20 pointer-events-none @(isShaking ? "shake-it" : "")"
                                                 style="top: @(GetPx(bookingStart))px; height: @(totalDuration * 1.666)px;">
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int PreSelectedStylistId { get; set; }
    private bool isAuthorized, isTimeSelected, isShaking;
    private int selectedStylistId, selectedClientId, viewWeekOffset;
    private string statusMessage = "";
    private DateTime bookingStart;

    private List<NETH_Stylist> allStylists = new();
    private List<NETH_Client> allClients = new();
    private List<NETH_Service> filteredServices = new();
    private List<NETH_Service> selectedServices = new();
    private List<NETH_Schedule> stylistSchedules = new();
    private List<NETH_Appointment> existingAppointments = new();

    private DateTime startOfWeek => DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek).AddDays(viewWeekOffset * 7);
    private int totalDuration => selectedServices.Any() ? selectedServices.Sum(x => x.DurationMinutes) : 30;

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "neth_session");
            if (!string.IsNullOrEmpty(json)) { 
                isAuthorized = true; 
                allStylists = await Db.NETH_Stylists.AsNoTracking().ToListAsync(); 
                allClients = await Db.NETH_Clients.AsNoTracking().ToListAsync(); 
                if (PreSelectedStylistId > 0) { selectedStylistId = PreSelectedStylistId; await LoadStylistData(); }
                StateHasChanged(); 
            } else Nav.NavigateTo("/nethaircut");
        }
    }

    private void ChangeWeek(int delta) { viewWeekOffset += delta; isTimeSelected = false; StateHasChanged(); }
    private async Task OnStylistChanged(ChangeEventArgs e) { 
        selectedStylistId = int.Parse(e.Value?.ToString() ?? "0"); 
        isTimeSelected = false; 
        await LoadStylistData(); 
    }

    private async Task LoadStylistData() {
        if (selectedStylistId == 0) return;
        filteredServices = await Db.NETH_Services.Where(x => x.StylistId == selectedStylistId).ToListAsync();
        stylistSchedules = await Db.NETH_Schedules.Where(x => x.StylistId == selectedStylistId).ToListAsync();
        existingAppointments = await Db.NETH_Appointments.Where(x => x.StylistId == selectedStylistId).ToListAsync();
        StateHasChanged();
    }

    private void ToggleService(NETH_Service svc) {
        if (selectedServices.Any(x => x.Id == svc.Id)) selectedServices.RemoveAll(x => x.Id == svc.Id);
        else selectedServices.Add(svc);
        StateHasChanged();
    }

    private async Task HandleSlotClick(DateTime date, DateTime time, bool invalid) {
        if (invalid) {
            statusMessage = "ERR: COLLISION_DETECTED";
            isShaking = true; StateHasChanged();
            await Task.Delay(300);
            isShaking = false; StateHasChanged();
            return;
        }
        bookingStart = date.Date.Add(time.TimeOfDay);
        isTimeSelected = true;
        statusMessage = "";
    }

    private async Task DeleteApp(NETH_Appointment app) {
        if (await JS.InvokeAsync<bool>("confirm", "Delete this record?")) {
            await Db.Database.ExecuteSqlRawAsync("DELETE FROM \"NETH_Appointments\" WHERE \"Id\" = {0}", app.Id);
            await Db.Database.ExecuteSqlRawAsync("DELETE FROM \"NETH_AppointmentServices\" WHERE \"AppointmentId\" = {0}", app.Id);
            await LoadStylistData();
        }
    }

    private double GetPx(DateTime t) => ((t.Hour - 8) + (t.Minute / 60.0)) * 100;
    private double GetH(DateTime s, DateTime e) => (e - s).TotalMinutes * 1.666;

    private async Task CreateAppointment() {
        if (selectedClientId == 0 || !selectedServices.Any()) { statusMessage = "ERR: CLIENT_REQUIRED"; return; }
        try {
            var end = bookingStart.AddMinutes(totalDuration);
            var stylist = allStylists.First(x => x.Id == selectedStylistId);
            
            // Final server-side check
            if (existingAppointments.Any(a => bookingStart < a.EndTime && end > a.StartTime)) {
                statusMessage = "ERR: SLOT_OCCUPIED";
                return;
            }

            await Db.Database.ExecuteSqlRawAsync("INSERT INTO \"NETH_Appointments\" (\"ShopId\", \"StylistId\", \"ClientId\", \"StartTime\", \"EndTime\", \"Status\", \"TotalPrice\", \"IsPaid\", \"Notes\") VALUES ({0}, {1}, {2}, {3}, {4}, 'Booked', {5}, false, '')", stylist.ShopId, selectedStylistId, selectedClientId, bookingStart, end, selectedServices.Sum(s => s.Price));
            
            var idResult = await Db.Database.SqlQueryRaw<int>("SELECT MAX(\"Id\") as \"Value\" FROM \"NETH_Appointments\"").ToListAsync();
            var newId = idResult.FirstOrDefault();

            foreach(var svc in selectedServices) {
                await Db.Database.ExecuteSqlRawAsync("INSERT INTO \"NETH_AppointmentServices\" (\"AppointmentId\", \"ServiceId\", \"PriceAtBooking\", \"DurationAtBooking\") VALUES ({0}, {1}, {2}, {3})", newId, svc.Id, svc.Price, svc.DurationMinutes);
            }
            isTimeSelected = false; selectedServices.Clear(); await LoadStylistData();
            statusMessage = "APPOINTMENT_SAVED";
        } catch (Exception ex) { statusMessage = "ERR: " + ex.Message; }
    }
}