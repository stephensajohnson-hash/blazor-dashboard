@page "/admin/neth-appointments"
@page "/admin/neth-appointments/{PreSelectedStylistId:int}"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using Dashboard.Components
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex font-sans">
    <NETHAdminSidebar />

    <div class="flex-1 p-8">
        <div class="max-w-7xl mx-auto">
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h2 class="text-2xl font-black text-white uppercase tracking-tight">Appointment Desk</h2>
                    <p class="text-xs text-[#D2B48C] font-mono uppercase tracking-widest">@startOfWeek.ToString("MMMM yyyy")</p>
                </div>
                <div class="flex gap-2 items-center">
                    <select @onchange="OnStylistChanged" value="@selectedStylistId" class="bg-[#25262b] border border-gray-700 rounded px-4 py-2 text-white text-[10px] font-black uppercase outline-none focus:border-blue-500 mr-4">
                        <option value="0">-- Select Barber --</option>
                        @foreach(var s in allStylists) { <option value="@s.Id">@s.Name</option> }
                    </select>
                    
                    <button @onclick="() => ChangeWeek(-1)" class="bg-[#25262b] px-4 py-2 rounded border border-gray-700 hover:text-white font-black text-xs transition">&lt;</button>
                    <span class="text-[10px] font-black uppercase px-2 text-gray-500 tracking-widest">Week</span>
                    <button @onclick="() => ChangeWeek(1)" class="bg-[#25262b] px-4 py-2 rounded border border-gray-700 hover:text-white font-black text-xs transition">&gt;</button>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="mb-6 p-4 @(statusMessage.StartsWith("ERR") ? "bg-red-900/20 border-red-500/30 text-red-400" : "bg-blue-900/20 border-blue-500/30 text-blue-400") border rounded font-mono text-[10px] uppercase flex justify-between items-center">
                    <span>@statusMessage</span>
                    <button @onclick='() => statusMessage = ""' class="text-white/50">&times;</button>
                </div>
            }

            @if (selectedStylistId > 0)
            {
                <div class="grid grid-cols-1 xl:grid-cols-4 gap-8">
                    
                    <div class="xl:col-span-1 space-y-6">
                        <div class="bg-[#25262b] p-6 rounded-xl border border-gray-700 shadow-xl">
                            <label class="text-[10px] font-black uppercase text-[#D2B48C] mb-4 block tracking-widest">Services</label>
                            <div class="space-y-2 mb-4 max-h-[400px] overflow-y-auto pr-2 custom-scrollbar">
                                @foreach (var svc in filteredServices)
                                {
                                    <div @onclick="() => ToggleService(svc)" class="flex justify-between items-center p-3 rounded border @(selectedServices.Any(x => x.Id == svc.Id) ? "bg-blue-600/20 border-blue-500 text-white" : "bg-black/20 border-gray-800 text-gray-400") cursor-pointer transition">
                                        <div class="text-[10px] font-black uppercase">@svc.Name</div>
                                        <div class="text-[9px] font-mono opacity-60">@svc.DurationMinutes m</div>
                                    </div>
                                }
                            </div>
                            <div class="pt-4 border-t border-gray-800 flex justify-between items-center">
                                <span class="text-[10px] font-black text-gray-500 uppercase">Block Size:</span>
                                <span class="text-blue-400 font-mono font-black text-sm">@totalDuration MINS</span>
                            </div>
                        </div>

                        @if (isTimeSelected)
                        {
                            <div class="bg-blue-600 p-6 rounded-xl shadow-2xl animate-in zoom-in-95 duration-200">
                                <label class="text-[10px] font-black uppercase text-white/70 mb-2 block tracking-widest">New Appointment</label>
                                <div class="text-white font-black uppercase leading-tight">
                                    <div class="text-sm">@bookingStart.ToString("dddd, MMM dd")</div>
                                    <div class="text-xl">@bookingStart.ToString("h:mm tt")</div>
                                </div>
                                
                                <select @bind="selectedClientId" class="w-full mt-4 bg-black/20 border border-white/20 rounded p-3 text-xs text-white outline-none">
                                    <option value="0">-- Select Client --</option>
                                    @foreach(var c in allClients) { <option value="@c.Id">@c.FirstName @c.LastName</option> }
                                </select>

                                <button @onclick="CreateAppointment" class="w-full mt-4 bg-white text-blue-600 font-black uppercase text-[10px] py-4 rounded-lg shadow-xl hover:bg-gray-100 transition">Save Appointment</button>
                                <button @onclick="() => isTimeSelected = false" class="w-full mt-2 text-white/50 text-[9px] uppercase font-black hover:text-white">Clear Selection</button>
                            </div>
                        }
                    </div>

                    <div class="xl:col-span-3 bg-[#25262b] rounded-xl border border-gray-700 shadow-xl overflow-hidden flex flex-col">
                        <div class="grid grid-cols-8 border-b border-gray-700 bg-black/20">
                            <div class="p-4 border-r border-gray-700"></div>
                            @for (int i = 0; i < 7; i++)
                            {
                                var day = startOfWeek.AddDays(i);
                                <div class="p-3 text-center border-r border-gray-700 @(day.Date == DateTime.Today ? "bg-blue-600/10" : "")">
                                    <div class="text-[9px] font-black text-gray-600 uppercase">@day.ToString("ddd")</div>
                                    <div class="text-sm font-black text-white">@day.Day</div>
                                </div>
                            }
                        </div>

                        <div class="relative h-[700px] overflow-y-auto custom-scrollbar bg-[#1a1b1e]">
                            <div class="grid grid-cols-8 relative" style="height: 1200px;">
                                <div class="col-span-1 border-r border-gray-800 bg-[#25262b] z-20">
                                    @for (int h = 8; h < 20; h++)
                                    {
                                        <div class="h-[100px] border-b border-gray-800/30 pr-3 pt-1 text-[10px] font-mono text-gray-600 text-right uppercase relative">
                                            @((h > 12 ? h - 12 : h)):00 @(h >= 12 ? "PM" : "AM")
                                            <div class="absolute top-[50px] right-2 text-[8px] opacity-30">:30</div>
                                        </div>
                                    }
                                </div>

                                @for (int i = 0; i < 7; i++)
                                {
                                    var dayDate = startOfWeek.AddDays(i);
                                    var dayShifts = stylistSchedules.Where(x => x.DayOfWeek == (int)dayDate.DayOfWeek).ToList();
                                    var dayApps = existingAppointments.Where(x => x.StartTime.Date == dayDate.Date).ToList();

                                    <div class="col-span-1 border-r border-gray-800 relative">
                                        @for(int h=0; h<12; h++) { 
                                            <div class="absolute w-full border-b border-gray-800/20" style="top: @(h * 100)px; height: 50px;"></div> 
                                            <div class="absolute w-full border-b border-gray-800/10" style="top: @(h * 100 + 50)px; height: 50px; border-style: dashed;"></div>
                                        }

                                        @foreach (var shift in dayShifts)
                                        {
                                            for(DateTime t = shift.StartTime; t < shift.EndTime; t = t.AddMinutes(15))
                                            {
                                                var slotStart = t; 
                                                var slotEnd = t.AddMinutes(totalDuration);
                                                
                                                bool overlaps = dayApps.Any(a => 
                                                    (slotStart >= a.StartTime && slotStart < a.EndTime) || 
                                                    (slotEnd > a.StartTime && slotEnd <= a.EndTime) ||
                                                    (slotStart <= a.StartTime && slotEnd >= a.EndTime)
                                                );

                                                <div @onclick='() => { if(!overlaps) SetBookingTime(dayDate, slotStart); else statusMessage = "ERR: OVERLAP DETECTED"; }' 
                                                     class="absolute left-0 right-0 z-40 border-t border-transparent transition-all group" 
                                                     style="top: @(GetPixelOffset(slotStart))px; height: 25px;">
                                                    
                                                    <div class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity z-50 flex items-center justify-center border-2 border-dashed
                                                                @(overlaps ? "bg-red-500/20 border-red-500 cursor-not-allowed" : "bg-blue-500/10 border-blue-500 cursor-pointer")"
                                                         style="height: @(totalDuration * 1.666)px; width: 100%; top: 0;">
                                                        @if(overlaps) { <i class="fas fa-ban text-red-500 text-xs"></i> }
                                                        else { <span class="text-[8px] font-black text-blue-400 uppercase">@totalDuration MIN</span> }
                                                    </div>
                                                </div>
                                            }
                                        }

                                        @foreach (var app in dayApps)
                                        {
                                            var client = allClients.FirstOrDefault(x => x.Id == app.ClientId);
                                            var top = GetPixelOffset(app.StartTime);
                                            var height = GetPixelHeight(app.StartTime, app.EndTime);
                                            <div @onclick="() => HandleExistingClick(app)" 
                                                 class="absolute left-1 right-1 bg-blue-600 border border-blue-400 rounded shadow-lg z-10 p-1 overflow-hidden cursor-help hover:brightness-125 transition" 
                                                 style="top: @(top)px; height: @(height)px;">
                                                <div class="text-[9px] font-black text-white uppercase truncate">@(client?.FirstName ?? "N/A")</div>
                                                <div class="text-[7px] font-mono text-white/70">@app.StartTime.ToString("h:mm")</div>
                                            </div>
                                        }

                                        @if(isTimeSelected && bookingStart.Date == dayDate.Date)
                                        {
                                            <div class="absolute left-1 right-1 bg-blue-400 border-2 border-blue-200 z-30 pointer-events-none flex items-center justify-center overflow-hidden shadow-2xl"
                                                 style="top: @(GetPixelOffset(bookingStart))px; height: @(totalDuration * 1.666)px;">
                                                <span class="text-[8px] font-black text-white uppercase px-1 rounded">@totalDuration Min Block</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int PreSelectedStylistId { get; set; }
    private bool isAuthorized = false, isTimeSelected = false;
    private int selectedStylistId = 0, selectedClientId = 0, viewWeekOffset = 0;
    private string statusMessage = "";
    private DateTime bookingStart;
    
    private List<NETH_Stylist> allStylists = new();
    private List<NETH_Client> allClients = new();
    private List<NETH_Service> filteredServices = new();
    private List<NETH_Service> selectedServices = new();
    private List<NETH_Schedule> stylistSchedules = new();
    private List<NETH_Appointment> existingAppointments = new();

    private DateTime startOfWeek => DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek).AddDays(viewWeekOffset * 7);
    private int totalDuration => selectedServices.Any() ? selectedServices.Sum(x => x.DurationMinutes) : 30;

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "neth_session");
            if (string.IsNullOrEmpty(json)) Nav.NavigateTo("/nethaircut");
            else { 
                isAuthorized = true; 
                allStylists = await Db.NETH_Stylists.AsNoTracking().ToListAsync(); 
                allClients = await Db.NETH_Clients.AsNoTracking().ToListAsync(); 
                if (PreSelectedStylistId > 0) { selectedStylistId = PreSelectedStylistId; await LoadStylistData(); }
                StateHasChanged(); 
            }
        }
    }

    private void ChangeWeek(int delta) { viewWeekOffset += delta; isTimeSelected = false; }
    private async Task OnStylistChanged(ChangeEventArgs e) { selectedStylistId = int.Parse(e.Value?.ToString() ?? "0"); await LoadStylistData(); }

    private async Task LoadStylistData() {
        if (selectedStylistId == 0) return;
        filteredServices = await Db.NETH_Services.Where(x => x.StylistId == selectedStylistId).ToListAsync();
        stylistSchedules = await Db.NETH_Schedules.Where(x => x.StylistId == selectedStylistId).ToListAsync();
        existingAppointments = await Db.NETH_Appointments.Where(x => x.StylistId == selectedStylistId).ToListAsync();
        StateHasChanged();
    }

    private void ToggleService(NETH_Service svc) {
        if (selectedServices.Any(x => x.Id == svc.Id)) selectedServices.RemoveAll(x => x.Id == svc.Id);
        else selectedServices.Add(svc);
        StateHasChanged();
    }

    private void SetBookingTime(DateTime date, DateTime baseTime) {
        bookingStart = date.Date.Add(baseTime.TimeOfDay);
        isTimeSelected = true;
    }

    private async Task HandleExistingClick(NETH_Appointment app) {
        if (await JS.InvokeAsync<bool>("confirm", "Delete appointment?")) {
            await Db.Database.ExecuteSqlRawAsync("DELETE FROM \"NETH_Appointments\" WHERE \"Id\" = {0}", app.Id);
            await Db.Database.ExecuteSqlRawAsync("DELETE FROM \"NETH_AppointmentServices\" WHERE \"AppointmentId\" = {0}", app.Id);
            await LoadStylistData();
        }
    }

    private double GetPixelOffset(DateTime time) => ((time.Hour - 8) + (time.Minute / 60.0)) * 100;
    private double GetPixelHeight(DateTime start, DateTime end) => (end - start).TotalMinutes * 1.666;

    private async Task CreateAppointment() {
        if (selectedClientId == 0 || selectedStylistId == 0 || !selectedServices.Any()) { statusMessage = "ERR: MISSING_FIELDS"; return; }
        try {
            var end = bookingStart.AddMinutes(totalDuration);
            var stylist = allStylists.First(x => x.Id == selectedStylistId);
            bool overlap = existingAppointments.Any(a => a.StylistId == selectedStylistId && bookingStart < a.EndTime && end > a.StartTime);
            if (overlap) { statusMessage = "ERR: SLOT_NO_LONGER_AVAILABLE"; return; }

            await Db.Database.ExecuteSqlRawAsync("INSERT INTO \"NETH_Appointments\" (\"ShopId\", \"StylistId\", \"ClientId\", \"StartTime\", \"EndTime\", \"Status\", \"TotalPrice\", \"IsPaid\", \"Notes\") VALUES ({0}, {1}, {2}, {3}, {4}, 'Booked', {5}, false, '')", stylist.ShopId, selectedStylistId, selectedClientId, bookingStart, end, selectedServices.Sum(s => s.Price));
            var idResult = await Db.Database.SqlQueryRaw<int>("SELECT MAX(\"Id\") as \"Value\" FROM \"NETH_Appointments\"").ToListAsync();
            var newId = idResult.FirstOrDefault();

            foreach(var svc in selectedServices) {
                await Db.Database.ExecuteSqlRawAsync("INSERT INTO \"NETH_AppointmentServices\" (\"AppointmentId\", \"ServiceId\", \"PriceAtBooking\", \"DurationAtBooking\") VALUES ({0}, {1}, {2}, {3})", newId, svc.Id, svc.Price, svc.DurationMinutes);
            }
            isTimeSelected = false;
            selectedServices.Clear();
            await LoadStylistData();
            statusMessage = "APPOINTMENT_SAVED";
        } catch (Exception ex) { statusMessage = "ERR: " + ex.Message; }
    }
}