@page "/admin/neth-appointments"
@page "/admin/neth-appointments/{PreSelectedStylistId:int}"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using Dashboard.Components
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<style>
    .neth-grid-container { height: 1200px; position: relative; background: #1a1b1e; }
    .neth-hour-row { height: 100px; border-bottom: 1px solid rgba(255,255,255,0.08); position: relative; }
    
    /* 30-Minute Tick Mark */
    .neth-hour-row::after {
        content: "";
        position: absolute;
        top: 50px;
        left: 0;
        right: 0;
        border-bottom: 1px dashed rgba(255,255,255,0.03);
    }

    .neth-shift-zone { position: absolute; left: 0; right: 0; background: rgba(34, 197, 94, 0.05); border-left: 2px solid #22c55e; z-index: 1; pointer-events: none; }
    .neth-click-slot { position: absolute; left: 0; right: 0; z-index: 10; cursor: pointer; }
    
    /* Ghost preview now only shows a dashed box, no text */
    .neth-ghost-preview { 
        position: absolute; top: 0; left: 0; right: 0; 
        border: 1px dashed rgba(96, 165, 250, 0.4); 
        background: rgba(96, 165, 250, 0.1); 
        pointer-events: none; opacity: 0; z-index: 15; 
    }
    .neth-click-slot:hover .neth-ghost-preview { opacity: 1; }

    .neth-appointment-group { 
        position: absolute; 
        left: 4px; 
        right: 4px; 
        z-index: 100; 
        border: 1px solid rgba(255,255,255,0.3); 
        border-radius: 4px; 
        cursor: pointer; 
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
        transition: transform 0.1s, border-color 0.2s;
        display: flex;
        flex-direction: column;
    }
    .neth-appointment-group:hover { border-color: white; z-index: 200; }
    
    .neth-service-segment { 
        width: 100%; 
        border-bottom: 1px solid rgba(0,0,0,0.1); 
        display: flex; 
        flex-direction: column; 
        justify-content: center; 
        padding: 0 6px;
        min-height: 15px;
        text-shadow: 0 1px 2px rgba(0,0,0,0.8);
        position: relative;
    }

    /* Client Avatar / Initials Logic */
    .mini-client-avatar {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        border: 1px solid white;
        background: #25262b;
        margin-right: 6px;
        flex-shrink: 0;
        object-fit: cover;
        transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 7px; /* Base size for initials */
        font-weight: 900;
        color: white;
    }

    /* Pop-Out Zoom Fix: Scale the container AND the font */
    .neth-appointment-group:hover .mini-client-avatar {
        position: absolute;
        width: 80px;
        height: 80px;
        top: -30px;
        left: -10px;
        z-index: 500;
        box-shadow: 0 10px 25px rgba(0,0,0,0.9);
        border: 2px solid #D2B48C;
        font-size: 24px; /* Scaled initials */
    }

    .stylist-head-avatar {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        border: 2px solid #374151;
        object-fit: cover;
        background: #25262b;
    }

    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #374151; border-radius: 10px; }
</style>

<div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex flex-col font-sans">
    <div class="flex flex-1">
        <NETHAdminSidebar />

        <div class="flex-1 p-8">
            <div class="max-w-7xl mx-auto">
                <div class="flex justify-between items-center mb-8">
                    <div class="flex items-center gap-4">
                        @if (currentStylist?.AvatarId > 0)
                        {
                            <img src="/neth-images/@currentStylist.AvatarId" class="stylist-head-avatar shadow-2xl" />
                        }
                        <div>
                            <h2 class="text-2xl font-black text-white uppercase tracking-tight">
                                @(currentStylist?.Name ?? "Appointment Desk")
                            </h2>
                            <p class="text-xs text-[#D2B48C] font-mono uppercase tracking-widest">@startOfWeek.ToString("MMMM yyyy")</p>
                        </div>
                    </div>
                    
                    <div class="flex gap-4 items-center">
                        <select @onchange="OnStylistChanged" value="@selectedStylistId" class="bg-[#25262b] border border-gray-700 rounded px-4 py-2 text-white text-[10px] font-black uppercase outline-none focus:border-blue-500">
                            <option value="0">-- Select Stylist --</option>
                            @foreach(var s in allStylists) { <option value="@s.Id">@s.Name</option> }
                        </select>
                        <button @onclick="() => ChangeWeek(-1)" class="bg-[#25262b] px-4 py-2 rounded border border-gray-700 hover:text-white transition">&lt;</button>
                        <button @onclick="() => ChangeWeek(1)" class="bg-[#25262b] px-4 py-2 rounded border border-gray-700 hover:text-white transition">&gt;</button>
                    </div>
                </div>

                @if (selectedStylistId > 0)
                {
                    <div class="grid grid-cols-1 xl:grid-cols-4 gap-8">
                        <div class="xl:col-span-1 space-y-4">
                            <div class="bg-[#25262b] p-5 rounded-xl border border-gray-700 shadow-2xl transition-colors">
                                <h3 class="text-[10px] font-black uppercase text-[#D2B48C] mb-4 tracking-widest">1. Services (@totalDuration min)</h3>
                                @foreach (var svc in filteredServices)
                                {
                                    <div @onclick="() => ToggleService(svc)" class="flex justify-between items-center p-3 mb-1 rounded border @(selectedServices.Any(x => x.Id == svc.Id) ? "bg-blue-600/20 border-blue-500 text-white" : "bg-black/20 border-gray-800 text-gray-400") cursor-pointer transition">
                                        <div class="flex items-center gap-2">
                                            <div class="w-3 h-3 rounded-full border border-white/20 shadow-sm" style="background: @svc.Color"></div>
                                            <span class="text-[10px] font-black uppercase">@svc.Name</span>
                                        </div>
                                    </div>
                                }
                            </div>

                            @if (isTimeSelected)
                            {
                                <div class="bg-blue-600 p-5 rounded-xl shadow-2xl animate-in slide-in-from-bottom-2">
                                    <p class="text-white font-black uppercase text-lg leading-none">@bookingStart.ToString("h:mm tt")</p>
                                    <select @bind="selectedClientId" class="w-full bg-black/20 border border-white/20 rounded p-3 text-xs text-white mt-4 outline-none">
                                        <option value="0">-- Select Client --</option>
                                        @foreach(var c in allClients) { <option value="@c.Id">@c.FirstName @c.LastName</option> }
                                    </select>
                                    <button @onclick="CreateAppointment" class="w-full bg-white text-blue-600 font-black py-4 rounded mt-4 shadow-lg uppercase text-[10px] tracking-widest hover:bg-gray-100 transition">Confirm Booking</button>
                                </div>
                            }
                        </div>

                        <div class="xl:col-span-3 bg-[#25262b] rounded-xl border border-gray-700 overflow-hidden flex flex-col shadow-2xl">
                            <div class="grid grid-cols-8 bg-black/40 border-b border-gray-700 font-black uppercase text-[9px] text-gray-500">
                                <div class="p-4 border-r border-gray-800">TIME</div>
                                @for (int i = 0; i < 7; i++) {
                                    <div class="p-3 text-center border-r border-gray-800">
                                        <p>@startOfWeek.AddDays(i).ToString("ddd")</p>
                                        <p class="text-white text-sm">@startOfWeek.AddDays(i).Day</p>
                                    </div>
                                }
                            </div>

                            <div class="relative overflow-y-auto bg-[#1a1b1e] h-[650px] custom-scrollbar">
                                <div class="grid grid-cols-8 relative neth-grid-container">
                                    <div class="col-span-1 border-r border-gray-800 bg-[#25262b]/50">
                                        @for (int h = 8; h < 20; h++) { 
                                            <div class="neth-hour-row pr-3 pt-2 text-[10px] font-mono text-gray-600 text-right uppercase">
                                                @((h > 12 ? h - 12 : h)):00
                                            </div> 
                                        }
                                    </div>

                                    @for (int i = 0; i < 7; i++)
                                    {
                                        var dayDate = startOfWeek.AddDays(i);
                                        var dayShifts = stylistSchedules.Where(x => x.DayOfWeek == (int)dayDate.DayOfWeek).ToList();
                                        var dayApps = existingAppointments.Where(x => x.StartTime.Date == dayDate.Date).ToList();

                                        <div class="col-span-1 border-r border-gray-800 relative">
                                            @foreach (var shift in dayShifts)
                                            {
                                                <div class="neth-shift-zone" style="top: @(GetPx(shift.StartTime))px; height: @(GetH(shift.StartTime, shift.EndTime))px;"></div>
                                                @for (DateTime t = shift.StartTime; t < shift.EndTime; t = t.AddMinutes(15))
                                                {
                                                    var start = t; var end = t.AddMinutes(totalDuration);
                                                    bool collision = dayApps.Any(a => start.TimeOfDay < a.EndTime.TimeOfDay && end.TimeOfDay > a.StartTime.TimeOfDay);
                                                    bool overShift = end.TimeOfDay > shift.EndTime.TimeOfDay;

                                                    <div @onclick="() => HandleSlotClick(dayDate, start, collision || overShift)" class="neth-click-slot" style="top: @(GetPx(start))px; height: 25px;">
                                                        @if (!(collision || overShift)) {
                                                            <div class="neth-ghost-preview" style="height: @(totalDuration * 1.666)px;"></div>
                                                        }
                                                    </div>
                                                }
                                            }

                                            @foreach (var app in dayApps)
                                            {
                                                var client = allClients.FirstOrDefault(x => x.Id == app.ClientId);
                                                var appServices = allAppointmentServices.Where(x => x.AppointmentId == app.Id).ToList();
                                                
                                                <div @onclick="() => DeleteApp(app)" @onclick:stopPropagation="true" class="neth-appointment-group group" 
                                                     style="top: @(GetPx(app.StartTime))px; height: @(GetH(app.StartTime, app.EndTime))px;">
                                                    
                                                    <div class="absolute top-1 right-1 hidden group-hover:flex gap-1 z-50">
                                                        <button @onclick="() => GoToNotes(app.ClientId)" @onclick:stopPropagation="true"
                                                                class="bg-black/80 hover:bg-green-500 text-white w-7 h-7 flex items-center justify-center rounded-md border border-white/30 transition-all shadow-xl">
                                                            <i class="fa-solid fa-note-sticky text-xs"></i>
                                                        </button>
                                                    </div>

                                                    @if (appServices.Any())
                                                    {
                                                        @for (int j = 0; j < appServices.Count; j++)
                                                        {
                                                            var aps = appServices[j];
                                                            var svc = allServices.FirstOrDefault(s => s.Id == aps.ServiceId);
                                                            <div class="neth-service-segment" style="height: @(aps.DurationAtBooking * 1.666)px; background: @(svc?.Color ?? "#3b82f6")">
                                                                <div class="flex items-center overflow-visible">
                                                                    @if (j == 0) {
                                                                        @if (client?.AvatarId > 0) {
                                                                            <img src="/neth-images/@client.AvatarId" class="mini-client-avatar shadow-sm" />
                                                                        } else {
                                                                            <div class="mini-client-avatar shadow-sm">
                                                                                @client?.FirstName?[0]@client?.LastName?[0]
                                                                            </div>
                                                                        }
                                                                        <p class="text-[8px] font-bold text-white/90 truncate">@(client?.FirstName)</p>
                                                                    }
                                                                    else {
                                                                        <p class="text-[8px] font-black text-white uppercase truncate leading-none">@(svc?.Name ?? "Service")</p>
                                                                    }
                                                                </div>
                                                            </div>
                                                        }
                                                    }
                                                </div>
                                            }

                                            @if(isTimeSelected && bookingStart.Date == dayDate.Date)
                                            {
                                                <div class="absolute inset-x-1 border-2 border-white bg-blue-500/40 z-20 pointer-events-none rounded-md" style="top: @(GetPx(bookingStart))px; height: @(totalDuration * 1.666)px;"></div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int PreSelectedStylistId { get; set; }
    private bool isTimeSelected, isShaking;
    private int selectedStylistId, selectedClientId, viewWeekOffset;
    private string statusMessage = "";
    private DateTime bookingStart;
    private NETH_Stylist? currentStylist;

    private List<NETH_Stylist> allStylists = new();
    private List<NETH_Client> allClients = new();
    private List<NETH_Service> allServices = new();
    private List<NETH_Service> filteredServices = new();
    private List<NETH_Service> selectedServices = new();
    private List<NETH_Schedule> stylistSchedules = new();
    private List<NETH_Appointment> existingAppointments = new();
    private List<NETH_AppointmentService> allAppointmentServices = new();

    private DateTime startOfWeek => DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek).AddDays(viewWeekOffset * 7);
    private int totalDuration => selectedServices.Any() ? selectedServices.Sum(x => x.DurationMinutes) : 30;

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) {
            allStylists = await Db.NETH_Stylists.AsNoTracking().ToListAsync(); 
            allClients = await Db.NETH_Clients.AsNoTracking().ToListAsync(); 
            allServices = await Db.NETH_Services.AsNoTracking().ToListAsync();
            if (PreSelectedStylistId > 0) { selectedStylistId = PreSelectedStylistId; await LoadStylistData(); }
            StateHasChanged(); 
        }
    }

    private async Task OnStylistChanged(ChangeEventArgs e) { 
        selectedStylistId = int.Parse(e.Value?.ToString() ?? "0"); 
        await LoadStylistData(); 
    }

    private async Task LoadStylistData() {
        if (selectedStylistId == 0) return;
        currentStylist = await Db.NETH_Stylists.FirstOrDefaultAsync(x => x.Id == selectedStylistId);
        filteredServices = await Db.NETH_Services.Where(x => x.StylistId == selectedStylistId).ToListAsync();
        stylistSchedules = await Db.NETH_Schedules.Where(x => x.StylistId == selectedStylistId).ToListAsync();
        existingAppointments = await Db.NETH_Appointments.Where(x => x.StylistId == selectedStylistId).ToListAsync();
        var appIds = existingAppointments.Select(x => x.Id).ToArray();
        if (appIds.Any()) allAppointmentServices = await Db.Database.SqlQueryRaw<NETH_AppointmentService>("SELECT * FROM \"NETH_AppointmentServices\" WHERE \"AppointmentId\" = ANY({0})", appIds).ToListAsync();
        StateHasChanged();
    }

    private void ToggleService(NETH_Service svc) {
        if (selectedServices.Any(x => x.Id == svc.Id)) selectedServices.RemoveAll(x => x.Id == svc.Id);
        else selectedServices.Add(svc);
        StateHasChanged();
    }

    private async Task HandleSlotClick(DateTime date, DateTime time, bool isInvalid) {
        if (isInvalid) {
            statusMessage = "ERR: INTERSECTION";
            isShaking = true; StateHasChanged();
            await Task.Delay(400);
            isShaking = false; StateHasChanged();
            return;
        }
        bookingStart = date.Date.Add(time.TimeOfDay);
        isTimeSelected = true;
        statusMessage = "";
    }

    private async Task DeleteApp(NETH_Appointment app) {
        if (await JS.InvokeAsync<bool>("confirm", "Delete booking?")) {
            await Db.Database.ExecuteSqlRawAsync("DELETE FROM \"NETH_Appointments\" WHERE \"Id\" = {0}", app.Id);
            await Db.Database.ExecuteSqlRawAsync("DELETE FROM \"NETH_AppointmentServices\" WHERE \"AppointmentId\" = {0}", app.Id);
            await LoadStylistData();
        }
    }

    private double GetPx(DateTime t) => ((t.Hour - 8) + (t.Minute / 60.0)) * 100;
    private double GetH(DateTime s, DateTime e) => (e - s).TotalMinutes * 1.666;
    private void ChangeWeek(int delta) { viewWeekOffset += delta; isTimeSelected = false; StateHasChanged(); }

    private void GoToNotes(int clientId) {
        Nav.NavigateTo($"/admin/neth-client-notes?StylistId={selectedStylistId}&ClientId={clientId}");
    }

    private async Task CreateAppointment() {
        if (selectedClientId == 0 || !selectedServices.Any() || currentStylist == null) return;
        try {
            var end = bookingStart.AddMinutes(totalDuration);
            await Db.Database.ExecuteSqlRawAsync("INSERT INTO \"NETH_Appointments\" (\"ShopId\", \"StylistId\", \"ClientId\", \"StartTime\", \"EndTime\", \"Status\", \"TotalPrice\", \"IsPaid\", \"Notes\") VALUES ({0}, {1}, {2}, {3}, {4}, 'Booked', {5}, false, '')", currentStylist.ShopId, selectedStylistId, selectedClientId, bookingStart, end, selectedServices.Sum(s => s.Price));
            var newId = (await Db.Database.SqlQueryRaw<int>("SELECT MAX(\"Id\") as \"Value\" FROM \"NETH_Appointments\"").ToListAsync()).First();
            foreach(var svc in selectedServices) await Db.Database.ExecuteSqlRawAsync("INSERT INTO \"NETH_AppointmentServices\" (\"AppointmentId\", \"ServiceId\", \"PriceAtBooking\", \"DurationAtBooking\") VALUES ({0}, {1}, {2}, {3})", newId, svc.Id, svc.Price, svc.DurationMinutes);
            isTimeSelected = false; selectedServices.Clear(); await LoadStylistData();
            statusMessage = "SUCCESS";
        } catch (Exception ex) { statusMessage = "ERR: " + ex.Message; }
    }
}