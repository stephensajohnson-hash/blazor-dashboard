@page "/admin/neth-appointments"
@page "/admin/neth-appointments/{PreSelectedStylistId:int}"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using Dashboard.Components
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<style>
    .neth-grid-container { height: 1200px; position: relative; background: #1a1b1e; }
    .neth-hour-row { height: 100px; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .neth-shift-zone { position: absolute; left: 0; right: 0; background: rgba(34, 197, 94, 0.08); border-left: 2px solid #22c55e; z-index: 1; pointer-events: none; }
    .neth-click-slot { position: absolute; left: 0; right: 0; z-index: 10; cursor: pointer; }
    .neth-ghost-preview { position: absolute; top: 0; left: 0; right: 0; border: 2px dashed #60a5fa; background: rgba(96, 165, 250, 0.2); pointer-events: none; opacity: 0; z-index: 15; display: flex; align-items: center; justify-content: center; }
    .neth-click-slot:hover .neth-ghost-preview { opacity: 1; }
    .neth-appointment-block { position: absolute; left: 4px; right: 4px; background: #2563eb; border: 1px solid #60a5fa; border-radius: 4px; z-index: 100; padding: 6px; overflow: hidden; cursor: pointer; }
    
    @@keyframes neth-shake {
        0%, 100% { transform: translateX(0); }
        20%, 60% { transform: translateX(-10px); }
        40%, 80% { transform: translateX(10px); }
    }
    .shake-it { animation: neth-shake 0.3s ease-in-out !important; border: 2px solid #ef4444 !important; }
    .debug-panel { background: #000; border-top: 4px solid #444; color: #0f0; font-family: monospace; font-size: 11px; padding: 20px; z-index: 999; width: 100%; }
</style>

<div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex flex-col">
    <div class="flex flex-1">
        <NETHAdminSidebar />

        <div class="flex-1 p-8">
            <div class="max-w-7xl mx-auto">
                <div class="flex justify-between items-center mb-8">
                    <div>
                        <h2 class="text-2xl font-black text-white uppercase tracking-tight">Appointment Desk</h2>
                        <p class="text-xs text-[#D2B48C] font-mono">@startOfWeek.ToString("MMMM yyyy")</p>
                    </div>
                    <div class="flex gap-4">
                        <select @onchange="OnStylistChanged" value="@selectedStylistId" class="bg-[#25262b] border border-gray-700 rounded px-4 py-2 text-white text-[10px] font-black uppercase">
                            <option value="0">-- Select Barber --</option>
                            @foreach(var s in allStylists) { <option value="@s.Id">@s.Name</option> }
                        </select>
                        <button @onclick="() => ChangeWeek(-1)" class="bg-[#25262b] px-4 py-2 rounded border border-gray-700 hover:text-white">&lt;</button>
                        <button @onclick="() => ChangeWeek(1)" class="bg-[#25262b] px-4 py-2 rounded border border-gray-700 hover:text-white">&gt;</button>
                    </div>
                </div>

                @if (selectedStylistId > 0)
                {
                    <div class="grid grid-cols-1 xl:grid-cols-4 gap-8">
                        <div class="xl:col-span-1 space-y-4">
                            <div class="bg-[#25262b] p-5 rounded-xl border border-gray-700 @(isShaking ? "shake-it" : "")">
                                <h3 class="text-[10px] font-black text-[#D2B48C] mb-4 uppercase">Services (@totalDuration min)</h3>
                                @foreach (var svc in filteredServices)
                                {
                                    <div @onclick="() => ToggleService(svc)" class="p-3 mb-1 rounded border @(selectedServices.Any(x => x.Id == svc.Id) ? "bg-blue-600/20 border-blue-500 text-white" : "bg-black/20 border-gray-800 text-gray-400") cursor-pointer">
                                        <span class="text-[10px] font-black">@svc.Name (@svc.DurationMinutes m)</span>
                                    </div>
                                }
                            </div>

                            @if (isTimeSelected)
                            {
                                <div class="bg-blue-600 p-5 rounded-xl shadow-2xl">
                                    <p class="text-white font-black uppercase text-lg">@bookingStart.ToString("h:mm tt")</p>
                                    <select @bind="selectedClientId" class="w-full bg-black/20 border border-white/20 rounded p-3 text-xs text-white mt-3">
                                        <option value="0">-- Client --</option>
                                        @foreach(var c in allClients) { <option value="@c.Id">@c.FirstName @c.LastName</option> }
                                    </select>
                                    <button @onclick="CreateAppointment" class="w-full bg-white text-blue-600 font-black py-3 rounded mt-3 shadow-lg">SAVE APPOINTMENT</button>
                                </div>
                            }
                        </div>

                        <div class="xl:col-span-3 bg-[#25262b] rounded-xl border border-gray-700 overflow-hidden flex flex-col">
                            <div class="grid grid-cols-8 bg-black/40 border-b border-gray-700">
                                <div class="p-4 border-r border-gray-800"></div>
                                @for (int i = 0; i < 7; i++) {
                                    <div class="p-3 text-center border-r border-gray-800">
                                        <p class="text-[9px] font-black text-gray-500 uppercase">@startOfWeek.AddDays(i).ToString("ddd")</p>
                                        <p class="text-sm font-black text-white">@startOfWeek.AddDays(i).Day</p>
                                    </div>
                                }
                            </div>

                            <div class="relative overflow-y-auto bg-[#1a1b1e] h-[600px]">
                                <div class="grid grid-cols-8 relative neth-grid-container">
                                    <div class="col-span-1 border-r border-gray-800 bg-[#25262b]/50">
                                        @for (int h = 8; h < 20; h++) { <div class="neth-hour-row pr-3 pt-2 text-[10px] font-mono text-gray-600 text-right uppercase">@((h > 12 ? h - 12 : h)):00</div> }
                                    </div>

                                    @for (int i = 0; i < 7; i++)
                                    {
                                        var dayDate = startOfWeek.AddDays(i);
                                        var dayShifts = stylistSchedules.Where(x => x.DayOfWeek == (int)dayDate.DayOfWeek).ToList();
                                        var dayApps = existingAppointments.Where(x => x.StartTime.Date == dayDate.Date).ToList();

                                        <div class="col-span-1 border-r border-gray-800 relative">
                                            @foreach (var shift in dayShifts)
                                            {
                                                <div class="neth-shift-zone" style="top: @(GetPx(shift.StartTime))px; height: @(GetH(shift.StartTime, shift.EndTime))px;"></div>
                                                @for (DateTime t = shift.StartTime; t < shift.EndTime; t = t.AddMinutes(15))
                                                {
                                                    var start = t; var end = t.AddMinutes(totalDuration);
                                                    bool collision = dayApps.Any(a => start < a.EndTime && end > a.StartTime);
                                                    bool overShift = end > shift.EndTime;

                                                    <div @onclick="() => HandleSlotClick(dayDate, start, collision || overShift)" class="neth-click-slot" style="top: @(GetPx(start))px; height: 25px;">
                                                        @if (!(collision || overShift)) {
                                                            <div class="neth-ghost-preview" style="height: @(totalDuration * 1.666)px;">
                                                                <span class="text-[8px] font-black text-white uppercase">@totalDuration m</span>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            }

                                            @foreach (var app in dayApps)
                                            {
                                                <div @onclick="() => DeleteApp(app)" @onclick:stopPropagation="true" class="neth-appointment-block" style="top: @(GetPx(app.StartTime))px; height: @(GetH(app.StartTime, app.EndTime))px;">
                                                    <p class="text-[9px] font-black text-white truncate">@(allClients.FirstOrDefault(c => c.Id == app.ClientId)?.FirstName ?? "User")</p>
                                                </div>
                                            }

                                            @if(isTimeSelected && bookingStart.Date == dayDate.Date)
                                            {
                                                <div class="absolute inset-x-1 border-2 border-white bg-blue-500/50 z-20 pointer-events-none" style="top: @(GetPx(bookingStart))px; height: @(totalDuration * 1.666)px;"></div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* FORCED DEBUG CONSOLE *@
    <div class="debug-panel">
        <div class="flex justify-between border-b border-green-900 mb-2 pb-1">
            <span class="font-bold text-white">SYSTEM TERMINAL [CONNECTED]</span>
            <button @onclick="ClearStylistAppointments" class="text-red-500 text-[10px] uppercase font-bold hover:underline">Reset Stylist Data</button>
        </div>
        <div>Active Stylist ID: @selectedStylistId</div>
        <div>Appointments Loaded: @existingAppointments.Count</div>
        @foreach(var a in existingAppointments.OrderBy(x => x.StartTime)) {
            <div class="opacity-80">> APP ID:@a.Id | @a.StartTime.ToString("ddd HH:mm") - @a.EndTime.ToString("HH:mm") (Client: @a.ClientId)</div>
        }
        @if(!string.IsNullOrEmpty(statusMessage)) { <div class="text-white bg-red-900 px-2 mt-1">LOG: @statusMessage</div> }
    </div>
</div>

@code {
    [Parameter] public int PreSelectedStylistId { get; set; }
    private bool isTimeSelected, isShaking;
    private int selectedStylistId, selectedClientId, viewWeekOffset;
    private string statusMessage = "";
    private DateTime bookingStart;

    private List<NETH_Stylist> allStylists = new();
    private List<NETH_Client> allClients = new();
    private List<NETH_Service> filteredServices = new();
    private List<NETH_Service> selectedServices = new();
    private List<NETH_Schedule> stylistSchedules = new();
    private List<NETH_Appointment> existingAppointments = new();

    private DateTime startOfWeek => DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek).AddDays(viewWeekOffset * 7);
    private int totalDuration => selectedServices.Any() ? selectedServices.Sum(x => x.DurationMinutes) : 30;

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) {
            allStylists = await Db.NETH_Stylists.AsNoTracking().ToListAsync(); 
            allClients = await Db.NETH_Clients.AsNoTracking().ToListAsync(); 
            if (PreSelectedStylistId > 0) { selectedStylistId = PreSelectedStylistId; await LoadStylistData(); }
            StateHasChanged(); 
        }
    }

    private void ChangeWeek(int delta) { viewWeekOffset += delta; isTimeSelected = false; StateHasChanged(); }
    private async Task OnStylistChanged(ChangeEventArgs e) { 
        selectedStylistId = int.Parse(e.Value?.ToString() ?? "0"); 
        await LoadStylistData(); 
    }

    private async Task LoadStylistData() {
        if (selectedStylistId == 0) return;
        filteredServices = await Db.NETH_Services.Where(x => x.StylistId == selectedStylistId).ToListAsync();
        stylistSchedules = await Db.NETH_Schedules.Where(x => x.StylistId == selectedStylistId).ToListAsync();
        existingAppointments = await Db.NETH_Appointments.Where(x => x.StylistId == selectedStylistId).ToListAsync();
        StateHasChanged();
    }

    private void ToggleService(NETH_Service svc) {
        if (selectedServices.Any(x => x.Id == svc.Id)) selectedServices.RemoveAll(x => x.Id == svc.Id);
        else selectedServices.Add(svc);
        StateHasChanged();
    }

    private async Task HandleSlotClick(DateTime date, DateTime time, bool isInvalid) {
        if (isInvalid) {
            statusMessage = "COLLISION AT " + time.ToString("HH:mm");
            isShaking = true; StateHasChanged();
            await Task.Delay(400);
            isShaking = false; StateHasChanged();
            return;
        }
        bookingStart = date.Date.Add(time.TimeOfDay);
        isTimeSelected = true;
        statusMessage = "";
    }

    private async Task DeleteApp(NETH_Appointment app) {
        if (await JS.InvokeAsync<bool>("confirm", "Delete this appointment?")) {
            await Db.Database.ExecuteSqlRawAsync("DELETE FROM \"NETH_Appointments\" WHERE \"Id\" = {0}", app.Id);
            await Db.Database.ExecuteSqlRawAsync("DELETE FROM \"NETH_AppointmentServices\" WHERE \"AppointmentId\" = {0}", app.Id);
            await LoadStylistData();
        }
    }

    private async Task ClearStylistAppointments() {
        if (await JS.InvokeAsync<bool>("confirm", "DANGER: Wipe all data for this stylist?")) {
            await Db.Database.ExecuteSqlRawAsync("DELETE FROM \"NETH_Appointments\" WHERE \"StylistId\" = {0}", selectedStylistId);
            await LoadStylistData();
        }
    }

    private double GetPx(DateTime t) => ((t.Hour - 8) + (t.Minute / 60.0)) * 100;
    private double GetH(DateTime s, DateTime e) => (e - s).TotalMinutes * 1.666;

    private async Task CreateAppointment() {
        if (selectedClientId == 0 || !selectedServices.Any()) { statusMessage = "MISSING DATA"; return; }
        try {
            var end = bookingStart.AddMinutes(totalDuration);
            var stylist = allStylists.FirstOrDefault(x => x.Id == selectedStylistId);
            if (stylist == null) return;
            
            await Db.Database.ExecuteSqlRawAsync("INSERT INTO \"NETH_Appointments\" (\"ShopId\", \"StylistId\", \"ClientId\", \"StartTime\", \"EndTime\", \"Status\", \"TotalPrice\", \"IsPaid\", \"Notes\") VALUES ({0}, {1}, {2}, {3}, {4}, 'Booked', {5}, false, '')", stylist.ShopId, selectedStylistId, selectedClientId, bookingStart, end, selectedServices.Sum(s => s.Price));
            var newId = (await Db.Database.SqlQueryRaw<int>("SELECT MAX(\"Id\") as \"Value\" FROM \"NETH_Appointments\"").ToListAsync()).First();
            foreach(var svc in selectedServices) await Db.Database.ExecuteSqlRawAsync("INSERT INTO \"NETH_AppointmentServices\" (\"AppointmentId\", \"ServiceId\", \"PriceAtBooking\", \"DurationAtBooking\") VALUES ({0}, {1}, {2}, {3})", newId, svc.Id, svc.Price, svc.DurationMinutes);
            isTimeSelected = false; selectedServices.Clear(); await LoadStylistData();
            statusMessage = "APPOINTMENT SAVED";
        } catch (Exception ex) { statusMessage = "ERR: " + ex.Message; }
    }
}