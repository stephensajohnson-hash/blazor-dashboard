@page "/admin/neth-appointments"
@page "/admin/neth-appointments/{PreSelectedStylistId:int}"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using Dashboard.Components
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex font-sans">
    <NETHAdminSidebar />

    <div class="flex-1 p-8">
        <div class="max-w-7xl mx-auto">
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h2 class="text-2xl font-black text-white uppercase tracking-tight">Appointment Desk</h2>
                    <p class="text-xs text-gray-500 font-mono">Visual Time-Grid Management</p>
                </div>
                <div class="flex gap-4">
                    <select @onchange="OnStylistChanged" value="@selectedStylistId" class="bg-[#25262b] border border-gray-700 rounded px-4 py-2 text-white text-[10px] font-black uppercase outline-none focus:border-blue-500">
                        <option value="0">-- Select Barber --</option>
                        @foreach(var s in allStylists) { <option value="@s.Id">@s.Name</option> }
                    </select>
                    <button @onclick="() => viewWeekOffset--" class="bg-[#25262b] p-2 rounded border border-gray-700 hover:text-white"><i class="fas fa-chevron-left"></i></button>
                    <button @onclick="() => viewWeekOffset++" class="bg-[#25262b] p-2 rounded border border-gray-700 hover:text-white"><i class="fas fa-chevron-right"></i></button>
                </div>
            </div>

            @if (selectedStylistId > 0)
            {
                <div class="grid grid-cols-1 xl:grid-cols-4 gap-8">
                    
                    @* LEFT PANEL: SERVICES & SELECTION *@
                    <div class="xl:col-span-1 space-y-6">
                        <div class="bg-[#25262b] p-6 rounded-xl border border-gray-700 shadow-xl">
                            <label class="text-[10px] font-black uppercase text-[#D2B48C] mb-4 block tracking-widest">Selected Services</label>
                            <div class="space-y-2 mb-4">
                                @foreach (var svc in filteredServices)
                                {
                                    <div @onclick="() => ToggleService(svc)" class="flex justify-between items-center p-3 rounded border @(selectedServices.Any(x => x.Id == svc.Id) ? "bg-blue-600/20 border-blue-500 text-white" : "bg-black/20 border-gray-800 text-gray-400") cursor-pointer transition">
                                        <div class="text-[10px] font-black uppercase">@svc.Name</div>
                                        <div class="text-[10px] font-mono">@svc.Price.ToString("C0")</div>
                                    </div>
                                }
                            </div>
                            <div class="pt-4 border-t border-gray-800 flex justify-between items-center">
                                <span class="text-[10px] font-black text-gray-500 uppercase">Total Time:</span>
                                <span class="text-blue-400 font-mono text-sm">@totalDuration MINS</span>
                            </div>
                        </div>

                        @if (isTimeSelected)
                        {
                            <div class="bg-blue-600 p-6 rounded-xl shadow-2xl animate-in zoom-in-95 duration-200">
                                <label class="text-[10px] font-black uppercase text-white/70 mb-2 block tracking-widest">Confirm Slot</label>
                                <div class="text-white font-black uppercase leading-tight">
                                    <div class="text-lg">@bookingStart.ToString("dddd, MMM dd")</div>
                                    <div class="text-2xl">@bookingStart.ToString("h:mm tt")</div>
                                </div>
                                <input @bind="customerName" placeholder="Client Name..." class="w-full mt-4 bg-black/20 border border-white/20 rounded p-3 text-xs text-white placeholder-white/40 outline-none" />
                                <button @onclick="CreateAppointment" class="w-full mt-4 bg-white text-blue-600 font-black uppercase text-[10px] py-4 rounded-lg shadow-xl hover:bg-gray-100 transition">Finalize Booking</button>
                            </div>
                        }
                    </div>

                    @* RIGHT PANEL: THE WEEKLY GRID *@
                    <div class="xl:col-span-3 bg-[#25262b] rounded-xl border border-gray-700 shadow-xl overflow-hidden">
                        <div class="grid grid-cols-8 border-b border-gray-700 bg-black/20">
                            <div class="p-4 border-r border-gray-700"></div> @* Time Column Header *@
                            @for (int i = 0; i < 7; i++)
                            {
                                var day = startOfWeek.AddDays(i);
                                <div class="p-4 text-center border-r border-gray-700 @(day.Date == DateTime.Today ? "bg-blue-600/10" : "")">
                                    <div class="text-[10px] font-black text-gray-500 uppercase">@day.ToString("ddd")</div>
                                    <div class="text-sm font-black text-white">@day.Day</div>
                                </div>
                            }
                        </div>

                        <div class="relative h-[600px] overflow-y-auto custom-scrollbar">
                            <div class="grid grid-cols-8">
                                @* TIME SCALE *@
                                <div class="col-span-1 border-r border-gray-800">
                                    @for (int h = 8; h <= 20; h++)
                                    {
                                        <div class="h-20 border-b border-gray-800/30 p-2 text-[9px] font-mono text-gray-600 text-right">
                                            @(h > 12 ? h - 12 : h):00 @(h >= 12 ? "PM" : "AM")
                                        </div>
                                    }
                                </div>

                                @* DAY COLUMNS *@
                                @for (int i = 0; i < 7; i++)
                                {
                                    var dayDate = startOfWeek.AddDays(i);
                                    var dayShifts = stylistSchedules.Where(x => x.DayOfWeek == (int)dayDate.DayOfWeek).ToList();
                                    var dayApps = existingAppointments.Where(x => x.StartTime.Date == dayDate.Date).ToList();

                                    <div class="col-span-1 border-r border-gray-800 relative bg-black/5">
                                        @* RENDER WORK WINDOWS *@
                                        @foreach (var shift in dayShifts)
                                        {
                                            var top = GetOffset(shift.StartTime);
                                            var height = GetHeight(shift.StartTime, shift.EndTime);
                                            <div @onclick="() => SetBookingTime(dayDate, shift.StartTime)" 
                                                 class="absolute left-0 right-0 bg-green-500/10 border-x border-green-500/20 cursor-pointer hover:bg-green-500/20 transition-all z-0" 
                                                 style="top: @(top)px; height: @(height)px;">
                                            </div>
                                        }

                                        @* RENDER EXISTING APPOINTMENTS *@
                                        @foreach (var app in dayApps)
                                        {
                                            var top = GetOffset(app.StartTime);
                                            var height = GetHeight(app.StartTime, app.EndTime);
                                            <div class="absolute left-1 right-1 bg-red-500/40 border border-red-500/50 rounded p-1 overflow-hidden z-10 shadow-lg" 
                                                 style="top: @(top)px; height: @(height)px;">
                                                <div class="text-[8px] font-black text-white uppercase leading-tight truncate">OCCUPIED</div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int PreSelectedStylistId { get; set; }
    private bool isAuthorized = false, isTimeSelected = false;
    private int selectedStylistId = 0, viewWeekOffset = 0;
    private string customerName = "";
    private DateTime bookingStart;
    
    private List<NETH_Stylist> allStylists = new();
    private List<NETH_Service> filteredServices = new();
    private List<NETH_Service> selectedServices = new();
    private List<NETH_Schedule> stylistSchedules = new();
    private List<NETH_Appointment> existingAppointments = new();

    private DateTime startOfWeek => DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek + (viewWeekOffset * 7));
    private int totalDuration => selectedServices.Sum(x => x.DurationMinutes);

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "neth_session");
            if (string.IsNullOrEmpty(json)) Nav.NavigateTo("/nethaircut");
            else { 
                isAuthorized = true; 
                allStylists = await Db.NETH_Stylists.AsNoTracking().ToListAsync();
                if (PreSelectedStylistId > 0) { selectedStylistId = PreSelectedStylistId; await LoadStylistData(); }
                StateHasChanged(); 
            }
        }
    }

    private async Task OnStylistChanged(ChangeEventArgs e) {
        selectedStylistId = int.Parse(e.Value?.ToString() ?? "0");
        await LoadStylistData();
    }

    private async Task LoadStylistData() {
        if (selectedStylistId == 0) return;
        filteredServices = await Db.NETH_Services.Where(x => x.StylistId == selectedStylistId).ToListAsync();
        stylistSchedules = await Db.NETH_Schedules.Where(x => x.StylistId == selectedStylistId).ToListAsync();
        existingAppointments = await Db.NETH_Appointments.Where(x => x.StylistId == selectedStylistId).ToListAsync();
    }

    private void ToggleService(NETH_Service svc) {
        if (selectedServices.Any(x => x.Id == svc.Id)) selectedServices.RemoveAll(x => x.Id == svc.Id);
        else selectedServices.Add(svc);
    }

    private void SetBookingTime(DateTime date, DateTime time) {
        bookingStart = date.Date.Add(time.TimeOfDay);
        isTimeSelected = true;
    }

    // Grid Helpers: 1 hour = 80 pixels
    private double GetOffset(DateTime time) => (time.Hour - 8 + (time.Minute / 60.0)) * 80;
    private double GetHeight(DateTime start, DateTime end) => (end - start).TotalHours * 80;

    private async Task CreateAppointment() {
        // ... previous save logic using bookingStart and totalDuration ...
        await JS.InvokeVoidAsync("alert", "Appointment Saved!");
        await LoadStylistData();
        isTimeSelected = false;
    }
}