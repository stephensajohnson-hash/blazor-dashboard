@page "/admin/neth-clients"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Dashboard
@using Dashboard.Components
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

@if (isAuthorized)
{
    <div class="min-h-screen bg-[#1a1b1e] text-gray-300 flex font-sans">
        
        <NETHAdminSidebar />

        <div class="flex-1 p-8">
            <div class="max-w-6xl mx-auto">
                <div class="flex justify-between items-end mb-8">
                    <div>
                        <h2 class="text-2xl font-black text-white uppercase tracking-tight">Client Database</h2>
                        <p class="text-xs text-gray-500 font-mono">Registry: @allClients.Count total customers</p>
                    </div>
                    <button @onclick="OpenCreateModal" class="bg-blue-600 hover:bg-blue-500 text-white text-[10px] font-black uppercase px-6 py-3 rounded shadow-xl transition">＋ Register New Client</button>
                </div>

                @if (isLoading)
                {
                    <div class="text-center py-20 animate-pulse font-black text-gray-600 uppercase tracking-widest">Accessing_Client_Registry...</div>
                }
                else
                {
                    <div class="bg-[#25262b] rounded-xl border border-gray-700 overflow-hidden shadow-2xl">
                        <table class="w-full text-left">
                            <thead>
                                <tr class="text-[10px] font-black uppercase text-gray-500 bg-black/20">
                                    <th class="p-4">Name</th>
                                    <th class="p-4">Contact Information</th>
                                    <th class="p-4">Linked User</th>
                                    <th class="p-4 text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm">
                                @foreach (var c in allClients)
                                {
                                    var phone = allPhones.FirstOrDefault(p => p.Id == c.PhoneId)?.Number ?? "NO_PHONE";
                                    var userName = allUsers.FirstOrDefault(u => u.Id == c.UserId)?.Username ?? "GUEST";

                                    <tr class="border-b border-gray-800 hover:bg-white/5 transition">
                                        <td class="p-4 font-black text-white uppercase">@c.FirstName @c.LastName</td>
                                        <td class="p-4">
                                            <div class="text-xs text-gray-400">@c.Email</div>
                                            <div class="text-[10px] font-mono text-[#D2B48C]">@phone</div>
                                        </td>
                                        <td class="p-4">
                                            <span class="px-2 py-0.5 rounded text-[9px] font-black uppercase @(c.UserId != null ? "bg-green-900/20 text-green-400 border border-green-500/20" : "bg-gray-800 text-gray-500")">
                                                @userName
                                            </span>
                                        </td>
                                        <td class="p-4 text-right">
                                            <button @onclick="() => OpenEditModal(c)" class="text-blue-400 hover:underline text-xs font-black uppercase mr-4">Edit</button>
                                            <button @onclick="() => DeleteClient(c.Id)" class="text-red-500/50 hover:text-red-500 transition text-xs font-black uppercase">Delete</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}

@* CLIENT MODAL *@
@if (showModal && editingClient != null)
{
    <div class="fixed inset-0 bg-black/90 backdrop-blur-sm z-50 flex items-center justify-center p-4 text-gray-300">
        <div class="bg-[#25262b] w-full max-w-lg rounded-xl border border-gray-700 shadow-2xl overflow-hidden font-black">
            <div class="p-4 bg-gray-800/50 border-b border-gray-700 flex justify-between items-center uppercase text-[11px] tracking-widest text-[#D2B48C]">
                <span>@(editingClient.Id == 0 ? "Register New Client" : "Edit Client Profile")</span>
                <button @onclick="CloseModal" class="text-gray-500 hover:text-white text-xl">&times;</button>
            </div>
            
            <div class="p-6 space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="text-[9px] uppercase text-gray-500 mb-1 block">First Name</label>
                        <input @bind="editingClient.FirstName" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-2 text-white outline-none focus:border-blue-500" />
                    </div>
                    <div>
                        <label class="text-[9px] uppercase text-gray-500 mb-1 block">Last Name</label>
                        <input @bind="editingClient.LastName" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-2 text-white outline-none focus:border-blue-500" />
                    </div>
                </div>

                <div>
                    <label class="text-[9px] uppercase text-gray-500 mb-1 block">Email Address</label>
                    <input @bind="editingClient.Email" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-2 text-white outline-none focus:border-blue-500" />
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="text-[9px] uppercase text-gray-500 mb-1 block">Phone Number</label>
                        <input @bind="uiPhoneNumber" placeholder="9035551212" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-2 text-white outline-none focus:border-[#D2B48C] font-mono" />
                    </div>
                    <div>
                        <label class="text-[9px] uppercase text-gray-500 mb-1 block">Link Account</label>
                        <select @bind="editingClient.UserId" class="w-full bg-[#1a1b1e] border border-gray-700 rounded p-2 text-white outline-none">
                            <option value="">-- Guest --</option>
                            @foreach(var u in allUsers.Where(x => x.Role == "Client")) {
                                <option value="@u.Id">@u.Username</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="p-4 bg-black/20 border-t border-gray-700 flex justify-end gap-3">
                <button @onclick="CloseModal" class="text-[10px] text-gray-500 uppercase px-4 py-2 font-black">Cancel</button>
                <button @onclick="SaveClient" class="bg-green-600 hover:bg-green-500 text-white text-[10px] uppercase px-8 py-2 rounded font-black shadow-xl">Commit_Registry</button>
            </div>
        </div>
    </div>
}

@code {
    private bool isAuthorized = false;
    private bool isLoading = true;
    private bool showModal = false;
    private string uiPhoneNumber = "";
    
    private List<NETH_Client> allClients = new();
    private List<NETH_Phone> allPhones = new();
    private List<NETHUsers.NETH_User> allUsers = new();
    private NETH_Client? editingClient;

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "neth_session");
            if (string.IsNullOrEmpty(json)) Nav.NavigateTo("/nethaircut");
            else { isAuthorized = true; await LoadAllData(); isLoading = false; StateHasChanged(); }
        }
    }

    private async Task LoadAllData() {
        try {
            allClients = await Db.NETH_Clients.AsNoTracking().ToListAsync();
            allPhones = await Db.NETH_Phones.AsNoTracking().ToListAsync();
            allUsers = await Db.Database.SqlQueryRaw<NETHUsers.NETH_User>(@"SELECT * FROM ""NETH_Users""").ToListAsync();
        } catch { }
    }

    private void OpenCreateModal() { 
        editingClient = new NETH_Client { FirstName = "", LastName = "", Email = "", PhoneId = 0 }; 
        uiPhoneNumber = "";
        showModal = true; 
    }

    private void OpenEditModal(NETH_Client c) { 
        editingClient = new NETH_Client { Id = c.Id, FirstName = c.FirstName, LastName = c.LastName, Email = c.Email, PhoneId = c.PhoneId, UserId = c.UserId };
        uiPhoneNumber = allPhones.FirstOrDefault(p => p.Id == c.PhoneId)?.Number ?? "";
        showModal = true; 
    }

    private void CloseModal() { showModal = false; editingClient = null; }

    private async Task SaveClient() {
        if (editingClient == null) return;

        try {
            // 1. Handle Phone Logic
            var existingPhone = allPhones.FirstOrDefault(p => p.Number == uiPhoneNumber);
            int finalPhoneId = 0;

            if (existingPhone != null) {
                finalPhoneId = existingPhone.Id;
            } else {
                await Db.Database.ExecuteSqlRawAsync(@"INSERT INTO ""NETH_Phones"" (""Number"", ""Type"") VALUES ({0}, 'Mobile')", uiPhoneNumber);
                var newP = await Db.NETH_Phones.OrderByDescending(x => x.Id).FirstOrDefaultAsync();
                finalPhoneId = newP?.Id ?? 1;
            }

            // 2. Save Client
            if (editingClient.Id == 0) {
                await Db.Database.ExecuteSqlRawAsync(
                    @"INSERT INTO ""NETH_Clients"" (""FirstName"", ""LastName"", ""Email"", ""PhoneId"", ""UserId"") VALUES ({0}, {1}, {2}, {3}, {4})",
                    editingClient.FirstName, editingClient.LastName, editingClient.Email, finalPhoneId, editingClient.UserId
                );
            } else {
                await Db.Database.ExecuteSqlRawAsync(
                    @"UPDATE ""NETH_Clients"" SET ""FirstName"" = {0}, ""LastName"" = {1}, ""Email"" = {2}, ""PhoneId"" = {3}, ""UserId"" = {4} WHERE ""Id"" = {5}",
                    editingClient.FirstName, editingClient.LastName, editingClient.Email, finalPhoneId, editingClient.UserId, editingClient.Id
                );
            }
            await LoadAllData(); CloseModal();
        } catch { }
    }

    private async Task DeleteClient(int id) {
        if (await JS.InvokeAsync<bool>("confirm", "Permanently remove client?")) {
            await Db.Database.ExecuteSqlRawAsync(@"DELETE FROM ""NETH_Clients"" WHERE ""Id"" = {0}", id);
            await LoadAllData();
        }
    }
}